---
interface ServiceTeaser {
  icon: 'server' | 'cloud' | 'shield' | 'lock' | 'globe';
  name: string;
  price: string;
  period: string;
  description: string;
  href: string;
  ctaLabel: string;
}
interface Props {
  items: ServiceTeaser[];
}
const { items } = Astro.props;

const icons: Record<string, string> = {
  server: '<rect x="3" y="4" width="18" height="6" rx="1.5"/><rect x="3" y="14" width="18" height="6" rx="1.5"/><circle cx="7" cy="7" r=".6" fill="currentColor"/><circle cx="7" cy="17" r=".6" fill="currentColor"/>',
  cloud: '<path d="M7 18h11a4 4 0 0 0 .5-7.97A6 6 0 0 0 6.2 12.1 3.5 3.5 0 0 0 7 18Z"/>',
  shield: '<path d="M12 3l7 3v6c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6l7-3Z"/>',
  lock: '<rect x="4" y="10" width="16" height="10" rx="2"/><path d="M8 10V7a4 4 0 0 1 8 0v3"/>',
  globe: '<circle cx="12" cy="12" r="9"/><path d="M3.5 9h17M3.5 15h17M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18"/>',
};
---
<div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-5">
  {items.map((s) => (
    <a href={s.href} class="card group flex flex-col !cursor-pointer">
      <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-accent-soft text-accent">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={icons[s.icon]}></svg>
      </div>
      <h3 class="mt-4 text-base font-semibold text-ink">{s.name}</h3>
      <p class="mt-1 text-xs leading-relaxed text-slate-500">{s.description}</p>
      <div class="mt-4 flex items-baseline gap-1">
        <span class="font-display text-2xl font-semibold text-ink">{s.price}</span>
        <span class="text-xs text-slate-400">{s.period}</span>
      </div>
      <span class="mt-4 inline-flex items-center gap-1.5 text-[13px] font-semibold text-accent">
        {s.ctaLabel}
        <svg width="13" height="13" viewBox="0 0 16 16" fill="none" class="transition-transform group-hover:translate-x-0.5"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </span>
    </a>
  ))}
</div>
