---
interface Props {
  icon: 'shield' | 'bolt' | 'server' | 'globe' | 'chart' | 'lock' | 'support' | 'cloud';
  title: string;
  description: string;
}
const { icon, title, description } = Astro.props;

const icons: Record<string, string> = {
  shield: '<path d="M12 3l7 3v6c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6l7-3Z"/><path d="m9.5 12 1.8 1.8L15 10"/>',
  bolt: '<path d="M13 2 4 14h6l-1 8 9-12h-6l1-8Z"/>',
  server: '<rect x="3" y="4" width="18" height="6" rx="1.5"/><rect x="3" y="14" width="18" height="6" rx="1.5"/><circle cx="7" cy="7" r=".6" fill="currentColor"/><circle cx="7" cy="17" r=".6" fill="currentColor"/>',
  globe: '<circle cx="12" cy="12" r="9"/><path d="M3.5 9h17M3.5 15h17M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18"/>',
  chart: '<path d="M4 20V10M12 20V4M20 20v-7"/>',
  lock: '<rect x="4" y="10" width="16" height="10" rx="2"/><path d="M8 10V7a4 4 0 0 1 8 0v3"/>',
  support: '<circle cx="12" cy="12" r="9"/><path d="M12 8v4l3 2"/>',
  cloud: '<path d="M7 18h11a4 4 0 0 0 .5-7.97A6 6 0 0 0 6.2 12.1 3.5 3.5 0 0 0 7 18Z"/>',
};
---
<div class="card">
  <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-accent-soft text-accent">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={icons[icon]}></svg>
  </div>
  <h3 class="mt-4 text-lg font-semibold text-ink">{title}</h3>
  <p class="mt-2 text-sm leading-relaxed text-slate-500">{description}</p>
</div>
