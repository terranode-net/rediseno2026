---
interface TItem {
  n: string;
  s: string;
  av: string;
  q: string;
}
interface Props {
  items: TItem[];
}
const { items } = Astro.props;
const total = items.length;
---
<div id="tc-root" data-total={total}>
  <!-- Desktop: 3-card view -->
  <div id="tc-desktop" class="hidden gap-3.5 md:grid md:grid-cols-3">
    {items.map((te, i) => (
      <figure class="tc-card-desktop m-0 rounded-[14px] border p-[22px] transition-all duration-500" data-index={i}>
        <div class="mb-3 flex gap-[3px]">
          {Array.from({ length: 5 }).map(() => (
            <svg viewBox="0 0 20 20" fill="#F59E0B" class="h-3 w-3"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          ))}
        </div>
        <blockquote class="mb-4 font-body text-[13px] leading-[1.7] text-slate-400">&ldquo;{te.q}&rdquo;</blockquote>
        <figcaption class="flex items-center gap-2.5">
          <div class="flex h-[34px] w-[34px] shrink-0 items-center justify-center rounded-full bg-[#1A3050] font-display text-xs font-bold text-[#3B82F6]">{te.av}</div>
          <div>
            <div class="font-display text-[13px] font-semibold text-white">{te.n}</div>
            <div class="font-body text-[11px] text-slate-500">{te.s}</div>
          </div>
        </figcaption>
      </figure>
    ))}
  </div>

  <!-- Mobile: 1-card view -->
  <div id="tc-mobile" class="md:hidden">
    <div id="tc-mobile-slot"></div>
    <div class="mt-[18px] flex justify-center gap-[7px]" id="tc-dots">
      {items.map((_, i) => (
        <button type="button" class="tc-dot h-[7px] rounded-full border-none p-0 transition-all duration-300" data-index={i} aria-label={`Slide ${i + 1}`}></button>
      ))}
    </div>
  </div>
</div>

<script define:vars={{ items }}>
  const root = document.getElementById('tc-root');
  const desktopWrap = document.getElementById('tc-desktop');
  const mobileWrap = document.getElementById('tc-mobile');
  const mobileSlot = document.getElementById('tc-mobile-slot');
  const dots = Array.from(document.querySelectorAll('.tc-dot'));
  const desktopCards = Array.from(document.querySelectorAll('.tc-card-desktop'));
  const total = items.length;
  let idx = 0;
  let isMobile = window.innerWidth < 768;
  let timer;

  const starsHtml = `<div style="display:flex;gap:3px;margin-bottom:12px">${Array.from({ length: 5 }).map(() => `<svg viewBox="0 0 20 20" fill="#F59E0B" style="width:12px;height:12px"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>`).join('')}</div>`;

  function renderMobile() {
    const te = items[idx];
    mobileSlot.innerHTML = `
      <figure style="background:rgba(59,130,246,.07);border:1px solid rgba(59,130,246,.28);border-radius:14px;padding:22px;margin:0">
        ${starsHtml}
        <blockquote style="font-family:'Metrophobic',sans-serif;font-size:13px;color:#6B8CAE;line-height:1.7;margin-bottom:16px">&ldquo;${te.q}&rdquo;</blockquote>
        <figcaption style="display:flex;align-items:center;gap:10px">
          <div style="width:34px;height:34px;border-radius:50%;background:#1A3050;display:flex;align-items:center;justify-content:center;font-family:'Instrument Sans',sans-serif;font-weight:700;font-size:12px;color:#3B82F6;flex-shrink:0">${te.av}</div>
          <div>
            <div style="font-family:'Instrument Sans',sans-serif;font-size:13px;font-weight:600;color:#fff">${te.n}</div>
            <div style="font-family:'Metrophobic',sans-serif;font-size:11px;color:#3A5A7A">${te.s}</div>
          </div>
        </figcaption>
      </figure>
    `;
    dots.forEach((d, i) => {
      d.style.width = i === idx ? '20px' : '7px';
      d.style.background = i === idx ? '#3B82F6' : 'rgba(255,255,255,.14)';
    });
  }

  function renderDesktop() {
    const positions = [-1, 0, 1].map((o) => (idx + o + total) % total);
    desktopCards.forEach((card) => {
      const i = Number(card.dataset.index);
      const pos = positions.indexOf(i);
      const isActive = pos === 1;
      card.style.order = String(pos === -1 ? 99 : pos);
      card.style.display = pos === -1 ? 'none' : 'block';
      card.style.background = isActive ? 'rgba(59,130,246,.07)' : 'rgba(255,255,255,.025)';
      card.style.borderColor = isActive ? 'rgba(59,130,246,.28)' : 'rgba(255,255,255,.06)';
      card.style.opacity = isActive ? '1' : '0.55';
      card.style.transform = isActive ? 'scale(1)' : 'scale(0.97)';
    });
  }

  function render() {
    if (isMobile) {
      desktopWrap.classList.add('hidden');
      mobileWrap.classList.remove('hidden');
      renderMobile();
    } else {
      mobileWrap.classList.add('hidden');
      desktopWrap.classList.remove('hidden');
      desktopWrap.classList.add('md:grid');
      renderDesktop();
    }
  }

  function next() {
    idx = (idx + 1) % total;
    render();
  }

  function restart() {
    clearInterval(timer);
    timer = setInterval(next, isMobile ? 3500 : 2200);
  }

  dots.forEach((dot) => {
    dot.addEventListener('click', () => {
      idx = Number(dot.dataset.index);
      render();
      restart();
    });
  });

  window.addEventListener('resize', () => {
    const nowMobile = window.innerWidth < 768;
    if (nowMobile !== isMobile) {
      isMobile = nowMobile;
      render();
      restart();
    }
  });

  render();
  restart();
</script>
