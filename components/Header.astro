---
import { SERVICES_NAV, COMING_SOON, pathFor, ORG, type Locale, type PageKey } from '@/lib/site';

interface Props {
  locale: Locale;
  currentKey: PageKey;
}
const { locale, currentKey } = Astro.props;
const other: Locale = locale === 'es' ? 'en' : 'es';
const switchHref = pathFor(other, currentKey);
const homeHref = pathFor(locale, 'home');

const t = {
  es: { services: 'Servicios', blog: 'Blog', about: 'Nosotros', contact: 'Contacto', client: 'Área de Cliente', infra: 'Infraestructura', dev: 'Desarrollo', soon: 'Pronto' },
  en: { services: 'Services', blog: 'Blog', about: 'About', contact: 'Contact', client: 'Client Area', infra: 'Infrastructure', dev: 'Development', soon: 'Soon' },
}[locale];

const infraItems = SERVICES_NAV.filter((i) => ['vps', 'hosting', 'dedicados', 'terramail', 'm365'].includes(i.key));
const devItems = SERVICES_NAV.filter((i) => ['devweb', 'devsistemas'].includes(i.key));

const SVC_ICONS: Record<string, string> = {
  hosting: '<rect x="2" y="2" width="20" height="6" rx="1.5"/><rect x="2" y="9" width="20" height="6" rx="1.5"/><rect x="2" y="16" width="20" height="6" rx="1.5"/><line x1="5.5" y1="5" x2="14" y2="5" stroke-linecap="round"/>',
  vps: '<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>',
  dedicados: '<rect x="7" y="7" width="10" height="10" rx="1"/><path d="M9 7V4M12 7V4M15 7V4M9 20v-3M12 20v-3M15 20v-3M21 9h-3M21 12h-3M21 15h-3M3 9h3M3 12h3M3 15h3" stroke-linecap="round"/>',
  terramail: '<rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 7 10-7"/>',
  m365: '<rect x="3" y="3" width="7.5" height="7.5" rx="1.5"/><rect x="13.5" y="3" width="7.5" height="7.5" rx="1.5"/><rect x="3" y="13.5" width="7.5" height="7.5" rx="1.5"/><rect x="13.5" y="13.5" width="7.5" height="7.5" rx="1.5"/>',
  devweb: '<polyline points="16 18 22 12 16 6" stroke-linecap="round"/><polyline points="8 6 2 12 8 18" stroke-linecap="round"/><line x1="14" y1="4" x2="10" y2="20" stroke-linecap="round"/>',
  devsistemas: '<rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4" stroke-linecap="round"/><path d="m9 10 2 2 4-4" stroke-linecap="round" stroke-linejoin="round"/>',
};
---
<header>
  <nav
    role="navigation"
    aria-label="Main navigation"
    id="main-nav"
    class="fixed inset-x-0 top-0 z-[100] border-b border-transparent bg-transparent transition-all duration-300"
  >
    <div class="mx-auto flex h-[66px] max-w-[1160px] items-center gap-1 px-6 lg:px-8">
      <a href={homeHref} aria-label="Terranode — Inicio" class="mr-7 flex shrink-0 items-center gap-2.5 no-underline">
        <img src="/logo-mark.png" alt="Terranode" class="h-8 w-auto" width="63" height="77" />
        <div>
          <div class="font-display text-[17px] font-bold leading-tight text-white">Terranode</div>
          <div class="font-body text-[8px] uppercase tracking-[2px] text-[#3B82F6]">Cloud Infrastructure</div>
        </div>
      </a>

      <div id="nav-links-wrap" class="hidden items-center gap-0.5 lg:flex">
        <div class="relative" id="services-dd">
          <button
            type="button"
            id="services-btn"
            aria-haspopup="true"
            aria-label={t.services}
            class="flex items-center gap-1 rounded-lg border-none bg-transparent px-3.5 py-1.5 font-body text-sm text-slate-400 transition-colors hover:text-white"
          >
            {t.services}<span class="text-[9px]">▾</span>
          </button>
          <div id="services-menu" class="invisible absolute left-0 top-[calc(100%+6px)] z-[300] min-w-[260px] rounded-xl border border-white/[0.08] bg-[#0C1525] p-2 opacity-0 shadow-2xl transition-opacity duration-150">
            <div class="px-3.5 pb-1 pt-2 font-body text-[10px] font-bold uppercase tracking-[2px] text-slate-600">{t.infra}</div>
            {infraItems.map((item) => (
              <a href={pathFor(locale, item.key)} class="flex items-center gap-2.5 rounded-lg px-3.5 py-2.5 font-body text-[13px] text-slate-400 no-underline transition-colors hover:bg-[#3B82F6]/[0.09] hover:text-white">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="h-[18px] w-[18px] shrink-0" set:html={SVC_ICONS[item.key]}></svg>
                {item.label[locale]}
              </a>
            ))}
            <div class="mt-1 px-3.5 pb-1 pt-2 font-body text-[10px] font-bold uppercase tracking-[2px] text-slate-600">{t.dev}</div>
            {devItems.map((item) => {
              const soon = COMING_SOON.includes(item.key);
              return (
                <a href={pathFor(locale, item.key)} class="flex items-center justify-between gap-2.5 rounded-lg px-3.5 py-2.5 font-body text-[13px] text-slate-400 no-underline transition-colors hover:bg-[#3B82F6]/[0.09] hover:text-white">
                  <span class="flex items-center gap-2.5">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="h-[18px] w-[18px] shrink-0" set:html={SVC_ICONS[item.key]}></svg>
                    {item.label[locale]}
                  </span>
                  {soon && <span class="rounded-full bg-white/[0.08] px-1.5 py-0.5 text-[9px] text-slate-500">{t.soon}</span>}
                </a>
              );
            })}
          </div>
        </div>

        <a href={pathFor(locale, 'blog')} class="rounded-lg px-3.5 py-1.5 font-body text-sm text-slate-400 no-underline transition-colors hover:text-white">{t.blog}</a>
        <a href={pathFor(locale, 'nosotros')} class="rounded-lg px-3.5 py-1.5 font-body text-sm text-slate-400 no-underline transition-colors hover:text-white">{t.about}</a>
        <a href={pathFor(locale, 'contacto')} class="rounded-lg px-3.5 py-1.5 font-body text-sm text-slate-400 no-underline transition-colors hover:text-white">{t.contact}</a>
      </div>

      <div class="ml-auto flex items-center gap-2.5">
        <a
          href={switchHref}
          id="lang-toggle"
          aria-label={locale === 'es' ? 'Switch to English' : 'Cambiar a Español'}
          class="hidden items-center gap-1.5 rounded-lg border border-[#3B82F6]/20 bg-[#3B82F6]/[0.08] px-3.5 py-[5px] font-display text-[13px] font-bold text-[#3B82F6] no-underline transition-colors hover:bg-[#3B82F6]/[0.16] sm:flex"
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-3.5 w-3.5">
            <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/>
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
          </svg>
          {locale === 'es' ? 'ES · EN' : 'EN · ES'}
        </a>
        <a
          href={ORG.clientPortal}
          target="_blank"
          rel="noopener"
          aria-label="Terranode client panel"
          class="hidden rounded-lg bg-[#3B82F6] px-[18px] py-2 font-display text-[13px] font-semibold text-white no-underline transition-colors hover:bg-[#2563EB] sm:inline-block"
        >
          {t.client}
        </a>
        <button id="menu-btn" aria-label="Menu" class="flex h-9 w-9 items-center justify-center rounded-lg border border-white/[0.12] text-slate-300 lg:hidden">
          <svg id="menu-icon-open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          <svg id="menu-icon-close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="hidden h-5 w-5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
    </div>

    <!-- Mobile fullscreen overlay -->
    <div id="mobile-nav" class="fixed inset-x-0 top-[66px] bottom-0 z-[99] hidden flex-col overflow-y-auto bg-[rgba(5,10,20,.97)] px-6 pb-10 pt-6 backdrop-blur-2xl lg:hidden">
      <div class="mb-1 font-body text-[11px] font-bold uppercase tracking-wider text-slate-600">{t.infra}</div>
      {infraItems.map((item) => (
        <a href={pathFor(locale, item.key)} class="border-b border-white/[0.06] py-[15px] font-body text-[17px] text-slate-300 no-underline">{item.label[locale]}</a>
      ))}
      <div class="mb-1 mt-4 font-body text-[11px] font-bold uppercase tracking-wider text-slate-600">{t.dev}</div>
      {devItems.map((item) => (
        <a href={pathFor(locale, item.key)} class="flex items-center justify-between border-b border-white/[0.06] py-[15px] font-body text-[17px] text-slate-300 no-underline">
          {item.label[locale]}
          {COMING_SOON.includes(item.key) && <span class="rounded-full bg-white/[0.08] px-2 py-0.5 text-[10px] text-slate-500">{t.soon}</span>}
        </a>
      ))}
      <a href={pathFor(locale, 'blog')} class="border-b border-white/[0.06] py-[15px] font-body text-[17px] text-slate-300 no-underline">{t.blog}</a>
      <a href={pathFor(locale, 'nosotros')} class="border-b border-white/[0.06] py-[15px] font-body text-[17px] text-slate-300 no-underline">{t.about}</a>
      <a href={pathFor(locale, 'contacto')} class="border-b border-white/[0.06] py-[15px] font-body text-[17px] text-slate-300 no-underline">{t.contact}</a>
      <div class="mt-6 flex gap-3">
        <a href={switchHref} class="flex-1 rounded-lg border border-[#3B82F6]/25 bg-[#3B82F6]/10 px-4 py-2.5 text-center font-display text-sm font-bold text-[#3B82F6] no-underline">
          {locale === 'es' ? 'ES · EN' : 'EN · ES'}
        </a>
        <a href={ORG.clientPortal} target="_blank" rel="noopener" class="flex-1 rounded-lg bg-[#3B82F6] px-4 py-2.5 text-center font-display text-sm font-semibold text-white no-underline">
          {t.client}
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  // Scroll-based nav background (transparent → blurred dark)
  const nav = document.getElementById('main-nav');
  function onScroll() {
    if (!nav) return;
    if (window.scrollY > 30) {
      nav.style.background = 'rgba(8,14,28,.95)';
      nav.style.backdropFilter = 'blur(20px)';
      nav.style.borderBottomColor = 'rgba(255,255,255,.06)';
    } else {
      nav.style.background = 'transparent';
      nav.style.backdropFilter = 'none';
      nav.style.borderBottomColor = 'transparent';
    }
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Services dropdown
  const ddRoot = document.getElementById('services-dd');
  const ddMenu = document.getElementById('services-menu');
  function openDD() {
    ddMenu?.classList.remove('invisible', 'opacity-0');
  }
  function closeDD() {
    ddMenu?.classList.add('invisible', 'opacity-0');
  }
  document.getElementById('services-btn')?.addEventListener('click', (e) => {
    e.stopPropagation();
    ddMenu?.classList.contains('invisible') ? openDD() : closeDD();
  });
  document.addEventListener('click', (e) => {
    if (ddRoot && !ddRoot.contains(e.target as Node)) closeDD();
  });
  ddRoot?.addEventListener('mouseenter', openDD);
  ddRoot?.addEventListener('mouseleave', closeDD);

  // Mobile menu
  const menuBtn = document.getElementById('menu-btn');
  const mobileNav = document.getElementById('mobile-nav');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');
  menuBtn?.addEventListener('click', () => {
    const isHidden = mobileNav?.classList.contains('hidden');
    mobileNav?.classList.toggle('hidden');
    mobileNav?.classList.toggle('flex');
    iconOpen?.classList.toggle('hidden', !isHidden);
    iconClose?.classList.toggle('hidden', isHidden);
    document.body.style.overflow = isHidden ? 'hidden' : '';
  });
</script>
