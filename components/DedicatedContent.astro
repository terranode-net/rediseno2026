---
interface Props { locale: 'es' | 'en'; plans?: any[] }
const { locale, plans } = Astro.props;
const es = locale === 'es';
const contactoHref = `/${locale}/${es ? 'contacto' : 'contact'}`;

const PLANS = (plans && plans.length) ? plans : [
  { id: 'e3', name: 'Intel Xeon E3-1230 V5', cpu: 'Intel Xeon E3-1230 V5 @ 3.4 GHz', cores: es ? '4 Núcleos / 8 Hilos' : '4 Cores / 8 Threads', ram: '32 GB DDR4', disk: '1 TB SSD', net: es ? '1 Gbps Ilimitado' : '1 Gbps Unmetered', ip: 'IPv4 + IPv6', price: '$47.99', period: '/mes', tagline: es ? 'Ideal para proyectos personales' : 'Ideal for personal projects', href: 'https://my.terranode.net/store/dedicated-servers', popular: false },
  { id: 'e5', name: 'Intel Xeon Dual E5-2680 V4', cpu: 'Intel Xeon Dual E5-2680 V4 @ 2.4 GHz', cores: es ? '28 Núcleos / 56 Hilos' : '28 Cores / 56 Threads', ram: '128 GB DDR4', disk: '1 TB SSD', net: es ? '1 Gbps Ilimitado' : '1 Gbps Unmetered', ip: 'IPv4 + IPv6', price: '$94.99', period: '/mes', tagline: es ? 'Para proyectos en crecimiento' : 'For growing projects', href: 'https://my.terranode.net/store/dedicated-servers', popular: true },
  { id: 'gold', name: 'Intel Xeon Dual Gold 6138', cpu: 'Intel Xeon Dual Gold 6138 @ 2.0 GHz', cores: es ? '40 Núcleos / 80 Hilos' : '40 Cores / 80 Threads', ram: '256 GB DDR4', disk: '2 TB U.2 NVMe', net: '10 Gbps (330 TB)', ip: 'IPv4 + IPv6', price: '$149.99', period: '/mes', tagline: es ? 'Para proyectos escalables y empresariales' : 'For scalable, enterprise projects', href: 'https://my.terranode.net/store/dedicated-servers', popular: false },
];

const OS_LIST = ['Ubuntu', 'Debian', 'CentOS', 'Rocky Linux', 'AlmaLinux', 'Arch Linux', 'Windows Server'];

const FEATS = es ? [
  { icon: 'cpu', t: 'Hardware exclusivo', d: 'CPU, RAM y almacenamiento 100% dedicados. Sin vecinos ruidosos ni recursos compartidos.' },
  { icon: 'nvme', t: 'NVMe / SSD Enterprise', d: 'Almacenamiento de nivel empresarial con alta IOPS para las cargas de trabajo más exigentes.' },
  { icon: 'net', t: 'Hasta 10 Gbps', d: 'Puerto de red dedicado hasta 10 Gbps con ancho de banda masivo incluido.' },
  { icon: 'ipmi', t: 'Acceso IPMI remoto', d: 'Gestión out-of-band completa: consola KVM, reinicio remoto y reinstalación del SO.' },
  { icon: 'raid', t: 'RAID automático', d: 'Configura RAID 1, 5 o 10 de forma automática desde el panel de control.' },
  { icon: 'ddos', t: 'DDoS 160 Gbps', d: 'Mitigación volumétrica automática en tiempo real incluida en todos los servidores.' },
  { icon: 'os', t: 'Flexibilidad de SO', d: 'Instala el SO que necesitas o sube tu propia imagen ISO personalizada.' },
  { icon: 'sup', t: 'Soporte 24/7', d: 'Ingenieros disponibles en todo momento para asistencia técnica avanzada.' },
] : [
  { icon: 'cpu', t: 'Exclusive hardware', d: '100% dedicated CPU, RAM and storage. No noisy neighbors, no shared resources.' },
  { icon: 'nvme', t: 'Enterprise NVMe / SSD', d: 'Enterprise-grade storage with high IOPS for the most demanding workloads.' },
  { icon: 'net', t: 'Up to 10 Gbps', d: 'Dedicated network port up to 10 Gbps with massive included bandwidth.' },
  { icon: 'ipmi', t: 'Remote IPMI access', d: 'Full out-of-band management: KVM console, remote reboot and OS reinstall.' },
  { icon: 'raid', t: 'Automatic RAID', d: 'Configure RAID 1, 5 or 10 automatically from the control panel.' },
  { icon: 'ddos', t: 'DDoS 160 Gbps', d: 'Automatic real-time volumetric mitigation included on every server.' },
  { icon: 'os', t: 'OS flexibility', d: 'Install the OS you need or upload your own custom ISO image.' },
  { icon: 'sup', t: '24/7 Support', d: 'Engineers available at all times for advanced technical assistance.' },
];

const FAQ = es ? [
  { q: '¿Cuánto tiempo tarda en aprovisionarse el servidor?', a: 'Los servidores dedicados típicamente se aprovisionan en 24-48 horas hábiles. Recibirás las credenciales de acceso por correo una vez listo.' },
  { q: '¿Puedo instalar cualquier sistema operativo?', a: 'Sí. Ofrecemos una amplia gama de sistemas operativos preinstalados. También puedes subir tu propia imagen ISO personalizada.' },
  { q: '¿Qué es el acceso IPMI?', a: 'IPMI (Intelligent Platform Management Interface) te permite gestionar el servidor de forma remota incluso si el SO no responde: consola KVM virtual, reinicio forzado, control de energía y más.' },
  { q: '¿Puedo configurar RAID desde el panel?', a: 'Sí. Nuestro panel permite configurar RAID 1, 5 y 10 de forma automática sin intervención manual.' },
  { q: '¿Los planes incluyen IPs adicionales?', a: 'Cada servidor incluye 1 IPv4 e IPv6. Puedes contratar IPs adicionales o bloques /29 contactando a nuestro equipo.' },
] : [
  { q: 'How long does it take to provision the server?', a: 'Dedicated servers typically provision in 24-48 business hours. You\u2019ll receive access credentials by email once ready.' },
  { q: 'Can I install any operating system?', a: 'Yes. We offer a wide range of pre-installed operating systems. You can also upload your own custom ISO image.' },
  { q: 'What is IPMI access?', a: 'IPMI (Intelligent Platform Management Interface) lets you manage the server remotely even if the OS is unresponsive: virtual KVM console, forced reboot, power control and more.' },
  { q: 'Can I configure RAID from the panel?', a: 'Yes. Our panel lets you configure RAID 1, 5 and 10 automatically with no manual intervention.' },
  { q: 'Do plans include additional IPs?', a: 'Every server includes 1 IPv4 and IPv6. You can order additional IPs or /29 blocks by contacting our team.' },
];

const ICONS: Record<string, string> = {
  cpu: '<rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><path d="M9 1v3M15 1v3M9 20v3M15 20v3M1 9h3M1 15h3M20 9h3M20 15h3"/>',
  nvme: '<rect x="2" y="6" width="20" height="12" rx="2"/><path d="M6 12h4M14 12h4" stroke-linecap="round"/><circle cx="12" cy="12" r="1" fill="currentColor"/>',
  net: '<path d="M5 12H19M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>',
  ipmi: '<rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/><circle cx="8" cy="10" r="1.5" fill="currentColor"/>',
  raid: '<path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>',
  ddos: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  os: '<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>',
  sup: '<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>',
};

const T = {
  eyebrow: es ? 'Servidores Dedicados' : 'Dedicated Servers',
  h1: es ? 'Hardware exclusivo para' : 'Exclusive hardware for',
  h1b: es ? 'máximo rendimiento' : 'maximum performance',
  sub: es ? 'Servidores dedicados con procesadores Intel Xeon, RAM DDR4 ECC y almacenamiento NVMe de nivel empresarial. Control total, sin vecinos, sin compromisos.' : 'Dedicated servers with Intel Xeon processors, ECC DDR4 RAM and enterprise-grade NVMe storage. Full control, no neighbors, no compromises.',
  cta1: es ? 'Ver todos los servidores' : 'View all servers',
  cta2: es ? 'Hablar con ventas' : 'Talk to sales',
  plansTag: es ? 'SERVIDORES' : 'SERVERS',
  plansH: es ? 'Elige tu servidor dedicado' : 'Choose your dedicated server',
  plansSub: es ? 'Hardware real, rendimiento real. Sin compartir recursos con nadie.' : 'Real hardware, real performance. No shared resources.',
  popular: es ? 'Popular' : 'Popular',
  buy: es ? 'Contratar' : 'Get started',
  quote: es ? 'Cotizar plan personalizado' : 'Quote custom plan',
  quoteD: es ? '¿Necesitas más núcleos, RAM o conectividad? Diseñamos configuraciones a medida.' : 'Need more cores, RAM or connectivity? We design custom configurations.',
  quoteBtn: es ? 'Solicitar cotización' : 'Request quote',
  featsH: es ? '¿Por qué elegir servidor dedicado?' : 'Why choose a dedicated server?',
  osH: es ? 'Sistemas Operativos Disponibles' : 'Available Operating Systems',
  osSub: es ? 'Flexibilidad total — o sube tu ISO' : 'Full flexibility — or upload your ISO',
  panelH: es ? 'Panel de control avanzado' : 'Advanced control panel',
  panelD: es ? 'Instala SO, configura RAID, gestiona reinicios, accede a la consola KVM remota y monitorea estadísticas en tiempo real desde un único panel.' : 'Install OS, configure RAID, manage reboots, access remote KVM console and monitor stats in real time from one panel.',
  faqH: es ? 'Preguntas frecuentes' : 'Frequently asked questions',
  specs: es ? ['CPU', 'Núcleos', 'RAM', 'Almacenamiento', 'Red', 'IPs'] : ['CPU', 'Cores', 'RAM', 'Storage', 'Network', 'IPs'],
  customIso: es ? '+ ISO propia' : '+ Custom ISO',
  panelFeats: es ? ['IPMI KVM', 'RAID 1/5/10', 'Consola remota', 'Estadísticas', 'OS Deploy', 'Reboot'] : ['IPMI KVM', 'RAID 1/5/10', 'Remote console', 'Statistics', 'OS Deploy', 'Reboot'],
};

const HERO_ROWS = es ? [
  { l: 'Procesador', v: 'Intel Xeon', c: '#60A5FA' },
  { l: 'Virtualización', v: 'Bare Metal', c: '#22C55E' },
  { l: 'Almacenamiento', v: 'NVMe Enterprise', c: '#A78BFA' },
  { l: 'Conectividad', v: '10 Gbps', c: '#60A5FA' },
  { l: 'Protección', v: 'DDoS 160 Gbps', c: '#EF4444' },
  { l: 'Gestión', v: 'IPMI + Panel', c: '#F59E0B' },
  { l: 'Disponibilidad', v: '99.99% SLA', c: '#22C55E' },
] : [
  { l: 'Processor', v: 'Intel Xeon', c: '#60A5FA' },
  { l: 'Virtualization', v: 'Bare Metal', c: '#22C55E' },
  { l: 'Storage', v: 'NVMe Enterprise', c: '#A78BFA' },
  { l: 'Connectivity', v: '10 Gbps', c: '#60A5FA' },
  { l: 'Protection', v: 'DDoS 160 Gbps', c: '#EF4444' },
  { l: 'Management', v: 'IPMI + Panel', c: '#F59E0B' },
  { l: 'Availability', v: '99.99% SLA', c: '#22C55E' },
];
---
<main style="padding-top:66px;background:#080E1C;min-height:100vh">
  <!-- HERO -->
  <section class="relative overflow-hidden border-b border-white/[0.04] px-6 py-16 md:py-[72px]">
    <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse 55% 65% at 50% 30%,rgba(37,99,235,.12),transparent 70%)"></div>
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(59,130,246,.035) 1px,transparent 1px),linear-gradient(90deg,rgba(59,130,246,.035) 1px,transparent 1px);background-size:50px 50px"></div>
    <div class="relative z-[2] mx-auto grid max-w-[1160px] grid-cols-1 items-center gap-10 md:grid-cols-[1.1fr_1fr] md:gap-[60px]">
      <div>
        <span class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#3B82F6]/20 bg-[#3B82F6]/[0.08] px-3.5 py-[5px] font-body text-[11px] font-bold uppercase tracking-[2.5px] text-[#3B82F6]">
          <svg viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="2" class="h-3 w-3"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/></svg>
          {T.eyebrow}
        </span>
        <h1 class="mb-1 font-display text-[clamp(2.2rem,4vw,3.6rem)] font-bold leading-[1.05] tracking-tight text-white">{T.h1}</h1>
        <h2 class="mb-[22px] font-display text-[clamp(2.2rem,4vw,3.6rem)] font-bold leading-[1.05] tracking-tight text-slate-600">{T.h1b}</h2>
        <p class="mb-8 max-w-[460px] font-body text-base leading-[1.7] text-slate-400">{T.sub}</p>
        <div class="flex flex-wrap gap-3">
          <a href="https://my.terranode.net/store/dedicated-servers" target="_blank" rel="noopener noreferrer" class="rounded-lg border-none bg-[#3B82F6] px-6 py-3 font-display text-[15px] font-semibold text-white no-underline shadow-[0_0_24px_rgba(59,130,246,.3)] transition-colors hover:bg-[#2563EB]">{T.cta1}</a>
          <a href={contactoHref} class="rounded-lg border border-white/[0.15] bg-transparent px-6 py-3 font-display text-[15px] font-semibold text-slate-300 no-underline transition-colors hover:text-white">{T.cta2}</a>
        </div>
      </div>
      <div class="relative overflow-hidden rounded-2xl border border-white/[0.08] bg-white/[0.03] p-7 font-body text-xs">
        <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(circle at 70% 30%,rgba(59,130,246,.06),transparent 60%)"></div>
        <div class="relative">
          {HERO_ROWS.map((row) => (
            <div class="flex items-center justify-between border-b border-white/[0.05] py-2.5">
              <span class="text-slate-600">{row.l}</span>
              <span class="font-display text-[13px] font-bold" style={`color:${row.c}`}>{row.v}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- PLANS -->
  <section class="bg-[#060B18] px-6 py-[72px]">
    <div class="mx-auto max-w-[1160px]">
      <header class="an mb-10">
        <p class="mb-3.5 font-body text-[11px] font-bold uppercase tracking-[2.5px] text-[#3B82F6]">{T.plansTag}</p>
        <h2 class="mb-1.5 font-display text-[clamp(1.8rem,3vw,2.5rem)] font-bold tracking-tight text-white">{T.plansH}</h2>
        <p class="font-body text-sm text-slate-500">{T.plansSub}</p>
      </header>
      <div class="mb-5 grid grid-cols-1 gap-3.5 md:grid-cols-3">
        {PLANS.map((p, i) => (
          <article class={`an d${i + 1} relative flex flex-col rounded-2xl p-6`} style={p.popular ? 'background:rgba(59,130,246,.07);border:1px solid rgba(59,130,246,.35)' : 'background:rgba(255,255,255,.025);border:1px solid rgba(255,255,255,.07)'}>
            {p.popular && <div class="absolute right-4 top-4 rounded-full bg-[#3B82F6] px-2.5 py-0.5 font-display text-[11px] font-bold text-white">{T.popular}</div>}
            <div class="mb-1 font-display text-[15px] font-bold text-white">{p.name}</div>
            <div class="mb-5 font-body text-xs text-slate-500">{p.tagline}</div>
            <div class="mb-[22px] flex flex-col gap-2">
              {[[T.specs[0], p.cpu], [T.specs[1], p.cores], [T.specs[2], p.ram], [T.specs[3], p.disk], [T.specs[4], p.net], [T.specs[5], p.ip]].map(([k, v]) => (
                <div class="flex justify-between gap-3 rounded-lg bg-white/[0.02] px-2.5 py-1.5">
                  <span class="shrink-0 font-body text-[11px] text-slate-600">{k}</span>
                  <span class="text-right font-body text-[11px] text-slate-300">{v}</span>
                </div>
              ))}
            </div>
            <div class="mb-4 font-display text-[34px] font-bold tracking-tight text-white">
              {p.price}<span class="text-[13px] font-normal text-slate-600">{p.period}</span>
            </div>
            <a href={p.href} target="_blank" rel="noopener noreferrer" class="mt-auto block rounded-lg py-2.5 text-center font-display text-sm font-semibold text-white no-underline" style={p.popular ? 'background:#3B82F6;border:1px solid transparent' : 'background:transparent;border:1px solid rgba(255,255,255,.14)'}>{T.buy}</a>
          </article>
        ))}
      </div>
      <div class="an flex flex-col items-start gap-6 rounded-2xl border border-[#3B82F6]/[0.18] bg-[#3B82F6]/[0.07] p-7 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <div class="mb-1 font-display text-[17px] font-bold text-white">{T.quote}</div>
          <p class="font-body text-[13px] text-slate-500">{T.quoteD}</p>
        </div>
        <a href={contactoHref} class="shrink-0 whitespace-nowrap rounded-lg bg-[#3B82F6] px-[22px] py-[11px] font-display text-sm font-semibold text-white no-underline">{T.quoteBtn}</a>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="border-t border-white/[0.04] bg-[#080E1C] px-6 py-[72px]">
    <div class="mx-auto max-w-[1160px]">
      <h2 class="an mb-10 text-center font-display text-[clamp(1.8rem,3vw,2.5rem)] font-bold tracking-tight text-white">{T.featsH}</h2>
      <div class="grid grid-cols-1 gap-3.5 sm:grid-cols-2 lg:grid-cols-4">
        {FEATS.map((f, i) => (
          <div class={`an d${(i % 4) + 1} rounded-2xl border border-white/[0.07] bg-white/[0.025] p-5`}>
            <div class="mb-3.5 flex h-11 w-11 items-center justify-center rounded-xl bg-[#3B82F6]/10">
              <svg viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="1.8" class="h-[22px] w-[22px]" set:html={ICONS[f.icon]}></svg>
            </div>
            <div class="mb-2 font-display text-sm font-semibold text-white">{f.t}</div>
            <p class="font-body text-xs leading-relaxed text-slate-500">{f.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- OS + Panel -->
  <section class="bg-[#080E1C] px-6 pb-[72px]">
    <div class="mx-auto grid max-w-[1160px] grid-cols-1 gap-3.5 md:grid-cols-2">
      <div class="an rounded-2xl border border-white/[0.07] bg-white/[0.025] p-7">
        <p class="mb-1.5 font-body text-[11px] font-bold uppercase tracking-[2.5px] text-[#3B82F6]">{T.osH}</p>
        <h3 class="mb-1.5 font-display text-lg font-bold text-white">{T.osSub}</h3>
        <div class="mt-4 flex flex-wrap gap-2">
          {OS_LIST.map((os) => (
            <span class="rounded-lg border border-white/[0.07] bg-white/[0.04] px-3.5 py-1.5 font-body text-xs text-slate-500">{os}</span>
          ))}
          <span class="rounded-lg border border-[#3B82F6]/20 bg-[#3B82F6]/[0.07] px-3.5 py-1.5 font-body text-xs text-[#3B82F6]">{T.customIso}</span>
        </div>
      </div>
      <div class="an d2 rounded-2xl border border-white/[0.07] bg-white/[0.025] p-7">
        <p class="mb-1.5 font-body text-[11px] font-bold uppercase tracking-[2.5px] text-[#3B82F6]">PANEL</p>
        <h3 class="mb-2.5 font-display text-lg font-bold text-white">{T.panelH}</h3>
        <p class="mb-4 font-body text-[13px] leading-[1.75] text-slate-500">{T.panelD}</p>
        <div class="flex flex-wrap gap-2">
          {T.panelFeats.map((f) => (
            <span class="rounded-md border border-white/[0.07] bg-white/[0.04] px-2.5 py-1 font-body text-[11px] text-slate-500">{f}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-white/[0.04] bg-[#060B18] px-6 pb-24">
    <div class="mx-auto max-w-[760px] pt-[72px]">
      <h2 class="an mb-10 text-center font-display text-[clamp(1.8rem,3vw,2.5rem)] font-bold tracking-tight text-white">{T.faqH}</h2>
      <div class="flex flex-col gap-2">
        {FAQ.map((item) => (
          <div class="ded-faq-item overflow-hidden rounded-xl border border-white/[0.07] bg-white/[0.025]">
            <button type="button" class="ded-faq-btn flex w-full items-center justify-between gap-4 border-none bg-transparent px-5 py-[18px] text-left">
              <span class="font-display text-sm font-semibold text-white">{item.q}</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="#4A6A88" stroke-width="2" class="ded-faq-chevron h-4 w-4 shrink-0 transition-transform"><path d="m6 9 6 6 6-6"/></svg>
            </button>
            <div class="ded-faq-answer hidden border-t border-white/[0.05] px-5 pb-[18px] pt-3 font-body text-[13px] leading-[1.7] text-slate-500">{item.a}</div>
          </div>
        ))}
      </div>
    </div>
  </section>
</main>

<script>
  document.querySelectorAll('.ded-faq-item').forEach((item) => {
    const btn = item.querySelector('.ded-faq-btn');
    const answer = item.querySelector('.ded-faq-answer');
    const chevron = item.querySelector('.ded-faq-chevron') as HTMLElement | null;
    btn?.addEventListener('click', () => {
      const isOpen = !answer?.classList.contains('hidden');
      answer?.classList.toggle('hidden', isOpen);
      if (chevron) chevron.style.transform = isOpen ? 'none' : 'rotate(180deg)';
    });
  });
</script>
