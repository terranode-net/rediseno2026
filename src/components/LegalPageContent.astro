---
import type { LegalSection, SummaryCard } from '@/lib/legalData';

interface Props {
  locale: 'es' | 'en';
  title: string;
  badge: string;
  icon: string;
  subtitle: string;
  updated: string;
  sections: LegalSection[];
  complianceBadge?: string;
  requestBtn?: string;
  requestUrl?: string;
  summary?: SummaryCard[];
  ctaTitle?: string;
  ctaSub?: string;
  ctaLabel?: string;
}
const { locale, title, badge, icon, subtitle, updated, sections, complianceBadge, requestBtn, requestUrl, summary, ctaTitle, ctaSub, ctaLabel } = Astro.props;
const es = locale === 'es';

// Parseo del contenido igual al original: viñetas "- ", negritas "**...**" al inicio,
// líneas de aviso que empiezan con "⚠", y párrafos normales.
type Line = { kind: 'bullet' | 'bold' | 'warn' | 'p' | 'br'; text: string };
function parse(content: string): Line[] {
  return content.split('\n').map((line): Line => {
    if (line.startsWith('- ')) return { kind: 'bullet', text: line.slice(2) };
    if (/^\*\*[^*]+\*\*/.test(line)) return { kind: 'bold', text: line.replace(/\*\*/g, '') };
    if (line.startsWith('⚠')) return { kind: 'warn', text: line };
    if (!line) return { kind: 'br', text: '' };
    return { kind: 'p', text: line };
  });
}
// Resalta los **fragmentos** dentro de viñetas y párrafos
function inlineBold(text: string): string {
  const escaped = text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  return escaped.replace(/\*\*([^*]+)\*\*/g, '<strong style="color:#fff;font-family:\'Instrument Sans\',sans-serif;font-size:13px">$1</strong>');
}
---
<main style="padding-top:66px;background:#080E1C;min-height:100vh">
  <style>
    .legal-grid { display:grid; grid-template-columns:220px 1fr; gap:48px; align-items:start; }
    .legal-toc { position:sticky; top:86px; }
    .legal-summary { display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:12px; }
    @media (max-width:820px) {
      .legal-grid { grid-template-columns:1fr; gap:24px; }
      .legal-toc { position:static; }
    }
  </style>

  <!-- HERO -->
  <section style="padding:64px 24px 52px;position:relative;overflow:hidden;border-bottom:1px solid rgba(255,255,255,.05)">
    <div style="position:absolute;inset:0;background:radial-gradient(ellipse 50% 60% at 50% 0%,rgba(37,99,235,.1),transparent 70%);pointer-events:none"></div>
    <div style="max-width:860px;margin:0 auto;position:relative;z-index:1">
      <div style="display:inline-flex;align-items:center;gap:8px;font-family:'Metrophobic',sans-serif;font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:#3B82F6;background:rgba(59,130,246,.08);border:1px solid rgba(59,130,246,.22);border-radius:100px;padding:5px 14px;margin-bottom:20px">
        {icon} {badge}
      </div>
      <h1 style="font-family:'Instrument Sans',sans-serif;font-weight:700;font-size:clamp(1.8rem,4vw,2.8rem);line-height:1.1;letter-spacing:-1px;color:#fff;margin:0 0 16px">{title}</h1>
      <p style="font-family:'Metrophobic',sans-serif;font-size:15px;color:#6B8CAE;margin:0 0 20px;line-height:1.7">{subtitle}</p>
      <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap">
        <span style="font-family:'Metrophobic',sans-serif;font-size:12px;color:#4A6A88">
          {es ? 'Última actualización: ' : 'Last updated: '}<strong style="color:#6B8CAE">{updated}</strong>
        </span>
        {complianceBadge && (
          <span style="font-family:'Metrophobic',sans-serif;font-size:11px;color:#22C55E;background:rgba(34,197,94,.08);border:1px solid rgba(34,197,94,.2);border-radius:100px;padding:3px 12px">✓ {complianceBadge}</span>
        )}
        {requestBtn && requestUrl && (
          <a href={requestUrl} target="_blank" rel="noopener noreferrer" style="font-family:'Instrument Sans',sans-serif;font-weight:600;font-size:13px;color:#3B82F6;background:rgba(59,130,246,.08);border:1px solid rgba(59,130,246,.2);border-radius:8px;padding:6px 16px;text-decoration:none">{requestBtn}</a>
        )}
      </div>
    </div>
  </section>

  <!-- SUMMARY CARDS (Reembolsos) -->
  {summary && (
    <div style="background:#060B18;border-bottom:1px solid rgba(255,255,255,.05);padding:32px 24px">
      <div style="max-width:860px;margin:0 auto">
        <p style="font-family:'Metrophobic',sans-serif;font-size:12px;color:#4A6A88;margin:0 0 16px;text-transform:uppercase;letter-spacing:1.5px;font-weight:700">
          {es ? 'Resumen rápido' : 'Quick summary'}
        </p>
        <div class="legal-summary">
          {summary.map((s) => (
            <div style={`background:rgba(255,255,255,.025);border:1px solid ${s.color}22;border-radius:12px;padding:16px 18px`}>
              <div style="font-size:22px;margin-bottom:8px">{s.icon}</div>
              <div style={`font-family:'Instrument Sans',sans-serif;font-size:13px;font-weight:700;color:${s.color};margin-bottom:4px`}>{s.title}</div>
              <p style="font-family:'Metrophobic',sans-serif;font-size:11px;color:#4A6A88;margin:0;line-height:1.5">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  )}

  <!-- CONTENT -->
  <div class="legal-grid" style="max-width:860px;margin:0 auto;padding:48px 24px 96px">
    <!-- TOC -->
    <nav class="legal-toc" style="background:rgba(255,255,255,.02);border:1px solid rgba(255,255,255,.06);border-radius:12px;padding:16px;display:flex;flex-direction:column;gap:2px">
      <div style="font-family:'Instrument Sans',sans-serif;font-size:11px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:#4A6A88;margin-bottom:8px">
        {es ? 'Contenido' : 'Contents'}
      </div>
      {sections.map((s) => (
        <a href={`#${s.id}`} class="legal-toc-link" data-target={s.id} style="font-family:'Metrophobic',sans-serif;font-size:11px;color:#4A6A88;text-decoration:none;padding:5px 8px;border-radius:6px;background:transparent;line-height:1.4;transition:all .15s">
          {s.title.split('.')[0] + '.'}<span style="margin-left:4px">{s.title.replace(/^\d+\.\s*/, '')}</span>
        </a>
      ))}
    </nav>

    <!-- Sections -->
    <div style="display:flex;flex-direction:column;gap:0">
      {sections.map((s, i) => (
        <div id={s.id} style={`padding:28px 0;${i < sections.length - 1 ? 'border-bottom:1px solid rgba(255,255,255,.05)' : ''}`}>
          <h2 style="font-family:'Instrument Sans',sans-serif;font-weight:700;font-size:1.1rem;color:#fff;margin:0 0 14px;letter-spacing:-0.3px;display:flex;align-items:center;gap:10px">
            <span style="width:3px;height:20px;background:#3B82F6;border-radius:2px;flex-shrink:0;display:inline-block"></span>
            {s.title}
          </h2>
          <div style="font-family:'Metrophobic',sans-serif;font-size:14px;color:#6B8CAE;line-height:1.85">
            {parse(s.content).map((line) => {
              if (line.kind === 'br') return <br />;
              if (line.kind === 'bullet') return (
                <div style="display:flex;gap:8px;margin-bottom:4px">
                  <span style="color:#3B82F6;flex-shrink:0">›</span>
                  <span set:html={inlineBold(line.text)}></span>
                </div>
              );
              if (line.kind === 'bold') return (
                <p style="margin:8px 0"><strong style="color:#fff;font-family:'Instrument Sans',sans-serif;font-size:13px">{line.text}</strong></p>
              );
              if (line.kind === 'warn') return (
                <div style="background:rgba(239,68,68,.07);border:1px solid rgba(239,68,68,.2);border-radius:10px;padding:14px 16px;margin:14px 0;font-family:'Metrophobic',sans-serif;font-size:13px;color:#FCA5A5;line-height:1.7">
                  {line.text}
                </div>
              );
              return <p style="margin:6px 0" set:html={inlineBold(line.text)}></p>;
            })}
          </div>
        </div>
      ))}

      {ctaTitle && (
        <div style="margin-top:32px;background:rgba(59,130,246,.06);border:1px solid rgba(59,130,246,.15);border-radius:14px;padding:24px 28px;text-align:center">
          <div style="font-family:'Instrument Sans',sans-serif;font-size:16px;font-weight:700;color:#fff;margin-bottom:8px">{ctaTitle}</div>
          <p style="font-family:'Metrophobic',sans-serif;font-size:13px;color:#6B8CAE;margin:0 0 16px">{ctaSub}</p>
          <a href="https://my.terranode.net" target="_blank" rel="noopener noreferrer" style="display:inline-block;background:#3B82F6;border-radius:8px;padding:11px 28px;color:#fff;font-family:'Instrument Sans',sans-serif;font-weight:700;font-size:14px;text-decoration:none">{ctaLabel}</a>
        </div>
      )}
    </div>
  </div>
</main>

<script>
  // Resalta en el índice la sección visible (equivale al estado "active" del original)
  const links = Array.from(document.querySelectorAll('.legal-toc-link'));
  const setActive = (id) => {
    links.forEach((a) => {
      const on = a.dataset.target === id;
      a.style.color = on ? '#3B82F6' : '#4A6A88';
      a.style.background = on ? 'rgba(59,130,246,.08)' : 'transparent';
    });
  };
  links.forEach((a) => a.addEventListener('click', () => setActive(a.dataset.target)));

  const targets = links.map((a) => document.getElementById(a.dataset.target)).filter(Boolean);
  if (targets.length) {
    const io = new IntersectionObserver(
      (entries) => {
        const visible = entries.filter((e) => e.isIntersecting).sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
        if (visible[0]) setActive(visible[0].target.id);
      },
      { rootMargin: '-80px 0px -70% 0px', threshold: 0 }
    );
    targets.forEach((t) => io.observe(t));
    setActive(targets[0].id);
  }
</script>
