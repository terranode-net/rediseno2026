---
interface Section {
  id: string;
  title: string;
  content: string;
}
interface Props {
  locale: 'es' | 'en';
  title: string;
  badge: string;
  icon: string;
  subtitle: string;
  updated: string;
  sections: Section[];
  complianceBadge?: string;
  summary?: { icon: string; color: string; title: string; desc: string }[];
  ctaTitle?: string;
  ctaSub?: string;
  ctaLabel?: string;
}
const { locale, title, badge, icon, subtitle, updated, sections, complianceBadge, summary, ctaTitle, ctaSub, ctaLabel } = Astro.props;
const es = locale === 'es';
---
<main style="padding-top:66px;background:#080E1C;min-height:100vh">
  <section class="border-b border-white/[0.05] px-6 py-16 md:py-[64px]">
    <div class="mx-auto max-w-[860px]">
      <div class="mb-5 inline-flex items-center gap-2 rounded-full border border-[#3B82F6]/[0.22] bg-[#3B82F6]/[0.08] px-3.5 py-[5px] font-body text-[11px] font-bold uppercase tracking-[2px] text-[#3B82F6]">
        <span>{icon}</span> {badge}
      </div>
      <h1 class="mb-4 font-display text-[clamp(1.8rem,4vw,2.8rem)] font-bold text-white">{title}</h1>
      <p class="mb-5 font-body text-[15px] leading-[1.7] text-slate-400">{subtitle}</p>
      <div class="flex flex-wrap items-center gap-5">
        <span class="font-body text-xs text-slate-600">
          {es ? 'Última actualización: ' : 'Last updated: '}
          <strong class="text-slate-400">{updated}</strong>
        </span>
        {complianceBadge && (
          <span class="rounded-full border border-[#22C55E]/20 bg-[#22C55E]/[0.08] px-3 py-[3px] font-body text-[11px] text-[#22C55E]">✓ {complianceBadge}</span>
        )}
      </div>
    </div>
  </section>

  {summary && (
    <div class="border-b border-white/[0.05] bg-[#060B18] px-6 py-8">
      <div class="mx-auto max-w-[860px]">
        <p class="mb-4 font-body text-xs font-bold uppercase tracking-[1.5px] text-slate-600">{es ? 'Resumen rápido' : 'Quick summary'}</p>
        <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {summary.map((s) => (
            <div class="rounded-xl border bg-white/[0.025] px-4.5 py-4" style={`border-color:${s.color}22`}>
              <div class="mb-2 text-[22px]">{s.icon}</div>
              <div class="mb-1 font-display text-[13px] font-bold" style={`color:${s.color}`}>{s.title}</div>
              <p class="m-0 font-body text-[11px] leading-snug text-slate-600">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  )}

  <div class="mx-auto grid max-w-[860px] grid-cols-1 gap-8 px-6 py-12 md:grid-cols-[200px_1fr] md:gap-12 md:py-24">
    <nav class="sticky top-[86px] hidden h-fit flex-col gap-0.5 rounded-xl border border-white/[0.06] bg-white/[0.02] p-4 md:flex">
      <div class="mb-2 font-display text-[11px] font-bold uppercase tracking-[1.5px] text-slate-600">{es ? 'Contenido' : 'Contents'}</div>
      {sections.map((s) => (
        <a href={`#${s.id}`} class="rounded-md px-2 py-1.5 font-body text-[11px] leading-tight text-slate-600 no-underline hover:text-slate-400">{s.title}</a>
      ))}
    </nav>
    <div class="flex flex-col">
      {sections.map((s, i) => (
        <div id={s.id} class={`py-7 ${i < sections.length - 1 ? 'border-b border-white/[0.05]' : ''}`}>
          <h2 class="mb-3.5 flex items-center gap-2.5 font-display text-[1.1rem] font-bold text-white">
            <span class="inline-block h-5 w-[3px] shrink-0 rounded-sm bg-[#3B82F6]"></span>
            {s.title}
          </h2>
          <div class="font-body text-sm leading-[1.85] text-slate-400">
            {s.content.split('\n').map((line) => {
              if (line.startsWith('- ')) {
                return (
                  <div class="mb-1.5 flex gap-2">
                    <span class="shrink-0 text-[#3B82F6]">›</span>
                    <span>{line.slice(2)}</span>
                  </div>
                );
              }
              if (line.startsWith('⚠')) {
                return (
                  <div class="my-3.5 rounded-[10px] border border-red-500/20 bg-red-500/[0.07] px-4 py-3.5 font-body text-[13px] leading-relaxed text-red-300">
                    {line}
                  </div>
                );
              }
              const isBold = line.endsWith(':');
              if (!line) return <br />;
              return (
                <p class="my-2">
                  {isBold ? <strong class="font-display text-[13px] text-white">{line}</strong> : line}
                </p>
              );
            })}
          </div>
        </div>
      ))}

      {ctaTitle && (
        <div class="mt-8 rounded-2xl border border-[#3B82F6]/[0.15] bg-[#3B82F6]/[0.06] px-7 py-6 text-center">
          <div class="mb-2 font-display text-base font-bold text-white">{ctaTitle}</div>
          <p class="mb-4 font-body text-[13px] text-slate-400">{ctaSub}</p>
          <a href="https://my.terranode.net" target="_blank" rel="noopener noreferrer" class="inline-block rounded-lg bg-[#3B82F6] px-7 py-2.5 font-display text-sm font-bold text-white no-underline">{ctaLabel}</a>
        </div>
      )}
    </div>
  </div>
</main>
