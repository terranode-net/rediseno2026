---
interface Props { locale: 'es' | 'en' }
const { locale } = Astro.props;
const es = locale === 'es';

const RESOLVERS = [
  { name: 'Google', flag: '🌐', loc: 'Global', ip: '8.8.8.8', doh: 'https://dns.google/resolve' },
  { name: 'Cloudflare', flag: '🌐', loc: 'Global', ip: '1.1.1.1', doh: 'https://cloudflare-dns.com/dns-query' },
  { name: 'OpenDNS', flag: '🇺🇸', loc: 'US', ip: '208.67.222.222', doh: 'https://doh.opendns.com/dns-query' },
  { name: 'Quad9', flag: '🌐', loc: 'Global', ip: '9.9.9.9', doh: 'https://dns.quad9.net/dns-query' },
  { name: 'AdGuard', flag: '🌐', loc: 'Global', ip: '94.140.14.14', doh: 'https://dns.adguard.com/dns-query' },
];

const RECORD_TYPES = ['A', 'AAAA', 'CNAME', 'MX', 'NS', 'TXT', 'SOA', 'CAA', 'SRV', 'PTR'];

const T = es ? {
  eyebrow: 'Herramienta gratuita', h1: 'Verificador de DNS', h1b: 'Propaga correctamente en todo el mundo',
  sub: 'Comprueba cómo se propagan tus registros DNS en múltiples servidores alrededor del mundo en tiempo real.',
  placeholder: 'ejemplo: terranode.net', check: 'Verificar', checking: 'Consultando...',
  noRecord: 'Sin registro', propagated: 'Propagado', notFound: 'No encontrado', error: 'Error', timeout: 'Timeout',
  resultsFor: 'Resultados para', allMatch: 'Todos coinciden ✓', mismatch: 'Hay diferencias ⚠',
  infoTitle: '¿Qué es la propagación DNS?',
  infoItems: ['Cuando cambias un registro DNS, no se actualiza en todo el mundo al instante', 'Puede tardar entre 15 minutos y 48 horas en propagarse completamente', 'Los TTL (Time To Live) del registro determinan la velocidad de propagación', 'Esta herramienta consulta múltiples resolvers para ver el estado actual'],
  typesTitle: 'Tipos de registros DNS',
  typeDescriptions: { A: 'Dirección IPv4 del dominio', AAAA: 'Dirección IPv6 del dominio', CNAME: 'Alias — apunta a otro dominio', MX: 'Servidores de correo', NS: 'Servidores de nombres autoritativos', TXT: 'Registros de texto (SPF, DKIM, etc.)', SOA: 'Información de autoridad de la zona', CAA: 'Autoridades de certificados SSL permitidas', SRV: 'Registros de servicio (VoIP, etc.)', PTR: 'Resolución inversa (IP → dominio)' },
} : {
  eyebrow: 'Free tool', h1: 'DNS Checker', h1b: 'Propagating correctly worldwide',
  sub: 'Check how your DNS records are propagating across multiple servers around the world in real time.',
  placeholder: 'example: terranode.net', check: 'Check', checking: 'Querying...',
  noRecord: 'No record', propagated: 'Propagated', notFound: 'Not found', error: 'Error', timeout: 'Timeout',
  resultsFor: 'Results for', allMatch: 'All match ✓', mismatch: 'Differences found ⚠',
  infoTitle: 'What is DNS propagation?',
  infoItems: ["When you change a DNS record, it doesn't update worldwide instantly", 'It can take between 15 minutes and 48 hours to fully propagate', "The record's TTL (Time To Live) determines propagation speed", 'This tool queries multiple resolvers to check the current state'],
  typesTitle: 'DNS record types',
  typeDescriptions: { A: 'Domain IPv4 address', AAAA: 'Domain IPv6 address', CNAME: 'Alias — points to another domain', MX: 'Mail servers', NS: 'Authoritative name servers', TXT: 'Text records (SPF, DKIM, etc.)', SOA: 'Zone authority information', CAA: 'Allowed SSL certificate authorities', SRV: 'Service records (VoIP, etc.)', PTR: 'Reverse lookup (IP → domain)' },
};
---
<main style="padding-top:66px;background:#080E1C;min-height:100vh">
  <section class="relative overflow-hidden border-b border-white/[0.04] px-6 py-16 md:py-[72px]">
    <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse 60% 60% at 50% 30%,rgba(37,99,235,.13),transparent 70%)"></div>
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(59,130,246,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(59,130,246,.03) 1px,transparent 1px);background-size:50px 50px"></div>
    <div class="relative z-[2] mx-auto max-w-[760px] text-center">
      <span class="mb-5 inline-block rounded-full border border-[#3B82F6]/[0.22] bg-[#3B82F6]/[0.08] px-4 py-[5px] font-body text-[11px] font-bold uppercase tracking-[2.5px] text-[#3B82F6]">{T.eyebrow}</span>
      <h1 class="mb-1 font-display text-[clamp(2.4rem,5vw,4rem)] font-bold leading-[1.05] tracking-tight text-white">{T.h1}</h1>
      <h2 class="mb-[18px] font-display text-[clamp(1.1rem,2vw,1.5rem)] font-semibold tracking-tight text-slate-600">{T.h1b}</h2>
      <p class="mx-auto mb-9 max-w-[540px] font-body text-slate-400">{T.sub}</p>

      <div class="mx-auto flex max-w-[680px] flex-wrap gap-2.5">
        <select id="dns-type" class="w-auto shrink-0 rounded-[10px] border border-[#3B82F6]/20 bg-[#3B82F6]/[0.08] px-3.5 py-3 font-display text-sm font-bold text-[#3B82F6] outline-none">
          {RECORD_TYPES.map((r) => <option value={r} selected={r === 'A'} class="bg-[#0C1525] text-white">{r}</option>)}
        </select>
        <input id="dns-domain" type="text" placeholder={T.placeholder} class="min-w-[200px] flex-1 rounded-[10px] border border-white/10 bg-white/[0.04] px-4.5 py-3 font-body text-[15px] text-white outline-none focus:border-[#3B82F6]/50" />
        <button id="dns-check-btn" class="flex shrink-0 items-center gap-2 rounded-[10px] border-none bg-[#3B82F6] px-7 py-3 font-display text-[15px] font-bold text-white shadow-[0_0_24px_rgba(59,130,246,.25)] transition-colors hover:bg-[#2563EB] disabled:opacity-70">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35" stroke-linecap="round"/></svg>
          <span id="dns-check-label">{T.check}</span>
        </button>
      </div>
      <p id="dns-type-desc" class="mt-2.5 font-body text-xs text-slate-600"><strong class="text-[#3B82F6]">A</strong> — {T.typeDescriptions.A}</p>
    </div>
  </section>

  <section class="bg-[#060B18] px-6 py-10 md:py-20">
    <div class="mx-auto max-w-[1100px]">
      <div id="dns-consensus" class="mb-5 hidden flex-wrap items-center justify-between gap-3"></div>
      <div id="dns-results" class="hidden grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3"></div>
      <div id="dns-loading" class="hidden grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3"></div>

      <div id="dns-info" class="grid grid-cols-1 gap-4 md:grid-cols-2">
        <div class="rounded-2xl border border-white/[0.07] bg-white/[0.025] p-6">
          <div class="mb-3.5 font-display text-[15px] font-bold text-white">{T.infoTitle}</div>
          <ul class="flex list-none flex-col gap-2.5">
            {T.infoItems.map((item) => (
              <li class="flex gap-2.5 font-body text-[13px] leading-relaxed text-slate-500">
                <span class="shrink-0 text-[#3B82F6]">›</span>{item}
              </li>
            ))}
          </ul>
        </div>
        <div class="rounded-2xl border border-white/[0.07] bg-white/[0.025] p-6">
          <div class="mb-3.5 font-display text-[15px] font-bold text-white">{T.typesTitle}</div>
          <div class="grid grid-cols-2 gap-2">
            {RECORD_TYPES.slice(0, 8).map((r) => (
              <button type="button" class="dns-type-shortcut flex items-center gap-2 rounded-lg border border-white/[0.05] bg-white/[0.02] px-2.5 py-2 text-left transition-colors hover:border-[#3B82F6]/25 hover:bg-[#3B82F6]/5" data-type={r}>
                <span class="shrink-0 rounded border border-[#3B82F6]/20 bg-[#3B82F6]/10 px-1.5 py-0.5 font-body text-[11px] font-bold text-[#3B82F6]">{r}</span>
                <span class="font-body text-[11px] leading-tight text-slate-600">{T.typeDescriptions[r]}</span>
              </button>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>
</main>

<script define:vars={{ RESOLVERS, T, es }}>
  const domainInput = document.getElementById('dns-domain');
  const typeSelect = document.getElementById('dns-type');
  const checkBtn = document.getElementById('dns-check-btn');
  const checkLabel = document.getElementById('dns-check-label');
  const typeDesc = document.getElementById('dns-type-desc');
  const consensusEl = document.getElementById('dns-consensus');
  const resultsEl = document.getElementById('dns-results');
  const loadingEl = document.getElementById('dns-loading');
  const infoEl = document.getElementById('dns-info');

  const DNS_TYPE_NUM = { A: 1, NS: 2, CNAME: 5, SOA: 6, MX: 15, TXT: 16, AAAA: 28, SRV: 33, CAA: 257, PTR: 12 };
  const STATUS_COLOR = { ok: '#22C55E', notfound: '#F59E0B', error: '#EF4444', timeout: '#EF4444' };
  const STATUS_LABEL = { ok: T.propagated, notfound: T.notFound, error: T.error, timeout: T.timeout };

  function cleanRecord(record, type) {
    if (type === 'TXT') return record.replace(/^"|"$/g, '');
    return record;
  }

  async function queryDoH(resolver, domain, type) {
    const t0 = Date.now();
    try {
      const url = `${resolver.doh}?name=${encodeURIComponent(domain)}&type=${type}`;
      const res = await fetch(url, { headers: { Accept: 'application/dns-json' }, signal: AbortSignal.timeout(6000) });
      const data = await res.json();
      const ms = Date.now() - t0;
      if (!data.Answer || data.Answer.length === 0) return { status: 'notfound', records: [], ms };
      const records = data.Answer.filter((r) => r.type === (DNS_TYPE_NUM[type] || 1)).map((r) => ({ data: r.data, ttl: r.TTL }));
      return { status: records.length ? 'ok' : 'notfound', records, ms };
    } catch (e) {
      return { status: e.name === 'TimeoutError' ? 'timeout' : 'error', records: [], ms: Date.now() - t0 };
    }
  }

  function renderLoading() {
    loadingEl.innerHTML = RESOLVERS.map(
      (r) => `
      <div style="background:rgba(255,255,255,.025);border:1px solid rgba(255,255,255,.06);border-radius:14px;padding:14px 18px">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px">
          <span style="font-size:18px">${r.flag}</span>
          <div>
            <div style="font-family:'Instrument Sans',sans-serif;font-size:14px;font-weight:700;color:#fff">${r.name}</div>
            <div style="font-family:'Metrophobic',sans-serif;font-size:11px;color:#3A5A7A">${r.ip}</div>
          </div>
        </div>
        <div style="height:14px;background:rgba(255,255,255,.04);border-radius:4px"></div>
      </div>`
    ).join('');
  }

  function renderResults(results, domain, type) {
    resultsEl.innerHTML = results
      .map(({ resolver, status, records, ms }) => {
        const borderColor = status === 'ok' ? 'rgba(34,197,94,.15)' : status === 'notfound' ? 'rgba(245,158,11,.12)' : 'rgba(239,68,68,.12)';
        const color = STATUS_COLOR[status] || '#4A6A88';
        const recordsHtml = records.length
          ? records.map((rec) => `<div style="display:flex;justify-content:space-between;gap:10px;margin-bottom:6px"><code style="font-family:'Metrophobic',sans-serif;font-size:12px;color:#CBD5E1;word-break:break-all;flex:1">${cleanRecord(rec.data, type)}</code><span style="font-family:'Metrophobic',sans-serif;font-size:10px;color:#2A4060;flex-shrink:0">TTL ${rec.ttl}s</span></div>`).join('')
          : `<span style="font-family:'Metrophobic',sans-serif;font-size:12px;color:#2A4060;font-style:italic">${T.noRecord}</span>`;
        return `
        <div style="background:rgba(255,255,255,.025);border:1px solid ${borderColor};border-radius:14px;overflow:hidden">
          <div style="padding:14px 18px;border-bottom:1px solid rgba(255,255,255,.05);display:flex;align-items:center;justify-content:space-between;background:rgba(255,255,255,.015)">
            <div style="display:flex;align-items:center;gap:10px">
              <span style="font-size:18px">${resolver.flag}</span>
              <div>
                <div style="font-family:'Instrument Sans',sans-serif;font-size:14px;font-weight:700;color:#fff">${resolver.name}</div>
                <div style="font-family:'Metrophobic',sans-serif;font-size:11px;color:#3A5A7A">${resolver.ip} · ${resolver.loc}</div>
              </div>
            </div>
            <div style="display:flex;align-items:center;gap:8px">
              <span style="font-family:'Metrophobic',sans-serif;font-size:11px;color:#3A5A7A">${ms}ms</span>
              <span style="display:inline-flex;align-items:center;gap:4px;background:${color}15;border:1px solid ${color}30;border-radius:6px;padding:2px 10px;font-family:'Metrophobic',sans-serif;font-size:11px;font-weight:700;color:${color}">
                <span style="width:6px;height:6px;border-radius:50%;background:${color};display:inline-block"></span>
                ${STATUS_LABEL[status] || status}
              </span>
            </div>
          </div>
          <div style="padding:12px 18px;min-height:48px">${recordsHtml}</div>
        </div>`;
      })
      .join('');

    const ok = results.filter((r) => r.status === 'ok');
    if (ok.length > 0) {
      const firstSet = ok[0].records.map((r) => cleanRecord(r.data, type)).sort().join('|');
      const allSame = ok.every((r) => r.records.map((x) => cleanRecord(x.data, type)).sort().join('|') === firstSet);
      const badgeColor = allSame ? '#22C55E' : '#F59E0B';
      const badgeBg = allSame ? 'rgba(34,197,94,.08)' : 'rgba(245,158,11,.08)';
      const badgeBorder = allSame ? 'rgba(34,197,94,.25)' : 'rgba(245,158,11,.25)';
      consensusEl.innerHTML = `
        <div style="font-family:'Instrument Sans',sans-serif;font-size:14px;color:#6B8CAE">
          ${T.resultsFor} <strong style="color:#fff">${domain}</strong>
          <span style="margin-left:8px;background:rgba(59,130,246,.1);border:1px solid rgba(59,130,246,.2);border-radius:4px;padding:1px 8px;font-family:'Metrophobic',sans-serif;font-size:11px;color:#3B82F6;font-weight:700">${type}</span>
        </div>
        <div style="background:${badgeBg};border:1px solid ${badgeBorder};border-radius:8px;padding:6px 16px;font-family:'Instrument Sans',sans-serif;font-size:13px;font-weight:700;color:${badgeColor}">
          ${allSame ? T.allMatch : T.mismatch} · ${ok.length}/${results.length} ${T.propagated.toLowerCase()}
        </div>`;
      consensusEl.classList.remove('hidden');
      consensusEl.classList.add('flex');
    } else {
      consensusEl.classList.add('hidden');
    }
  }

  async function runCheck() {
    const raw = domainInput.value.trim().replace(/^https?:\/\//, '').replace(/\/.*$/, '').toLowerCase();
    if (!raw) return;
    const type = typeSelect.value;

    checkBtn.disabled = true;
    checkLabel.textContent = T.checking;
    resultsEl.classList.add('hidden');
    resultsEl.classList.remove('grid');
    infoEl.classList.add('hidden');
    loadingEl.classList.remove('hidden');
    loadingEl.classList.add('grid');
    renderLoading();

    const settled = await Promise.all(RESOLVERS.map(async (resolver) => ({ resolver, ...(await queryDoH(resolver, raw, type)) })));

    loadingEl.classList.add('hidden');
    loadingEl.classList.remove('grid');
    resultsEl.classList.remove('hidden');
    resultsEl.classList.add('grid');
    renderResults(settled, raw, type);

    checkBtn.disabled = false;
    checkLabel.textContent = T.check;
  }

  typeSelect.addEventListener('change', () => {
    const type = typeSelect.value;
    typeDesc.innerHTML = `<strong style="color:#3B82F6">${type}</strong> — ${T.typeDescriptions[type]}`;
  });
  domainInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') runCheck(); });
  checkBtn.addEventListener('click', runCheck);
  document.querySelectorAll('.dns-type-shortcut').forEach((btn) => {
    btn.addEventListener('click', () => {
      typeSelect.value = btn.dataset.type;
      typeSelect.dispatchEvent(new Event('change'));
      domainInput.focus();
    });
  });
</script>
