---
interface Props {
  name: string;
  tagline: string;
  price: string;
  period: string;
  featured?: boolean;
  ctaLabel: string;
  ctaHref: string;
  specs: string[];
}
const { name, tagline, price, period, featured = false, ctaLabel, ctaHref, specs } = Astro.props;
---
<div class={`relative flex flex-col rounded-xl2 p-7 transition-all duration-300 ${
  featured
    ? 'bg-ink text-white shadow-glow scale-[1.03] border border-white/10'
    : 'bg-white border border-slate-200 shadow-card hover:shadow-card-hover hover:-translate-y-1'
}`}>
  {featured && (
    <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-signal px-3 py-1 text-[11px] font-bold uppercase tracking-wide text-ink">
      Popular
    </span>
  )}
  <h3 class={`font-display text-xl font-semibold ${featured ? 'text-white' : 'text-ink'}`}>{name}</h3>
  <p class={`mt-1 text-sm ${featured ? 'text-slate-300' : 'text-slate-500'}`}>{tagline}</p>

  <div class="mt-6 flex items-baseline gap-1">
    <span class={`font-display text-4xl font-semibold ${featured ? 'text-white' : 'text-ink'}`}>{price}</span>
    <span class={`text-sm ${featured ? 'text-slate-400' : 'text-slate-500'}`}>{period}</span>
  </div>

  <ul class="mt-6 flex-1 space-y-3">
    {specs.map((spec) => (
      <li class={`flex items-start gap-2.5 text-sm ${featured ? 'text-slate-200' : 'text-slate-600'}`}>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class={`mt-0.5 shrink-0 ${featured ? 'text-signal' : 'text-accent'}`}><path d="M5 12.5 9.5 17 19 7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        {spec}
      </li>
    ))}
  </ul>

  <a href={ctaHref} class={featured ? 'btn-primary mt-7 w-full !bg-signal !text-ink hover:!bg-white' : 'btn-secondary mt-7 w-full'}>
    {ctaLabel}
  </a>
</div>
