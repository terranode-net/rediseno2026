---
interface Props {
  items: { q: string; a: string }[];
}
const { items } = Astro.props;
---
<div class="mx-auto max-w-3xl divide-y divide-slate-200 rounded-xl2 border border-slate-200 bg-white">
  {items.map((item, i) => (
    <details class="group px-6 py-5" open={i === 0}>
      <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-left font-medium text-ink">
        <span itemprop="name">{item.q}</span>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" class="shrink-0 text-slate-400 transition-transform duration-200 group-open:rotate-45"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </summary>
      <p class="mt-3 text-sm leading-relaxed text-slate-500">{item.a}</p>
    </details>
  ))}
</div>
