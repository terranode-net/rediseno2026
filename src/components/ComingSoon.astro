---
import { pathFor, type PageKey } from '@/lib/site';

interface Props {
  locale: 'es' | 'en';
  pageKey: PageKey;
  eyebrow: string;
  title: string;
  description: string;
}
const { locale, description } = Astro.props;
let { eyebrow, title } = Astro.props;

const t = {
  es: {
    badge: 'Próximamente',
    cta: 'Escríbenos mientras tanto',
    back: 'Volver al inicio',
  },
  en: {
    badge: 'Coming soon',
    cta: 'Reach out in the meantime',
    back: 'Back to home',
  },
}[locale];
---
<section class="relative flex min-h-[70vh] items-center overflow-hidden bg-[#080E1C] px-6 py-24">
  <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse 55% 60% at 50% 40%,rgba(59,130,246,.13),transparent 70%)"></div>
  <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(59,130,246,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(59,130,246,.04) 1px,transparent 1px);background-size:50px 50px"></div>
  <div class="relative z-10 mx-auto max-w-xl text-center">
    <span class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#3B82F6]/25 bg-[#3B82F6]/10 px-4 py-1.5 font-body text-[11px] font-bold uppercase tracking-[2.5px] text-[#60A5FA]">
      <span class="h-1.5 w-1.5 rounded-full bg-[#22C55E] shadow-[0_0_5px_#22C55E]"></span>
      {t.badge}
    </span>
    <h1 class="mb-4 font-display text-[clamp(1.8rem,4vw,2.8rem)] font-bold leading-tight tracking-tight text-white">{title}</h1>
    <p class="mx-auto max-w-md font-body text-slate-400">{description}</p>
    <div class="mt-9 flex flex-wrap justify-center gap-3">
      <a href={pathFor(locale, 'contacto')} class="rounded-lg border-none bg-[#3B82F6] px-6 py-3 font-display text-[15px] font-semibold text-white no-underline shadow-[0_0_24px_rgba(59,130,246,.28)] transition-colors hover:bg-[#2563EB]">{t.cta}</a>
      <a href={pathFor(locale, 'home')} class="rounded-lg border border-white/[0.14] px-6 py-3 font-body text-[15px] text-slate-300 no-underline transition-colors hover:text-white">{t.back}</a>
    </div>
  </div>
</section>
