---
interface Testimonial {
  quote: string;
  author: string;
  role?: string;
}
interface Props {
  items: Testimonial[];
  intervalMs?: number;
}
const { items, intervalMs = 6000 } = Astro.props;
const uid = Math.random().toString(36).slice(2, 8);
---
<div class="mx-auto max-w-2xl" data-carousel={uid} data-interval={intervalMs}>
  <div class="relative min-h-[240px] sm:min-h-[210px]">
    {items.map((t, i) => (
      <div
        class="carousel-slide absolute inset-0 rounded-xl2 border border-slate-200 bg-white p-8 shadow-card transition-opacity duration-500 ease-in-out"
        data-index={i}
        style={i === 0 ? 'opacity:1; pointer-events:auto;' : 'opacity:0; pointer-events:none;'}
      >
        <div class="flex justify-center gap-0.5 text-signal">
          {Array.from({ length: 5 }).map(() => (
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="m12 2 3.1 6.7 7.4.8-5.5 5 1.6 7.3L12 18l-6.6 3.8 1.6-7.3-5.5-5 7.4-.8L12 2Z"/></svg>
          ))}
        </div>
        <p class="mt-5 text-balance text-center text-[15px] leading-relaxed text-slate-600">&ldquo;{t.quote}&rdquo;</p>
        <div class="mt-6 flex items-center justify-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-full bg-accent-soft font-display text-sm font-semibold text-accent">
            {t.author.charAt(0)}
          </div>
          <div class="text-left">
            <p class="text-sm font-semibold text-ink">{t.author}</p>
            {t.role && <p class="text-xs text-slate-400">{t.role}</p>}
          </div>
        </div>
      </div>
    ))}
  </div>

  <div class="mt-6 flex items-center justify-center gap-2">
    {items.map((_, i) => (
      <button
        type="button"
        class="carousel-dot h-2 rounded-full bg-slate-200 transition-all duration-300"
        style={i === 0 ? 'width:22px; background-color:#2D12ED;' : 'width:8px;'}
        data-index={i}
        aria-label={`Testimonial ${i + 1}`}
      ></button>
    ))}
  </div>
</div>

<script>
  document.querySelectorAll<HTMLElement>('[data-carousel]').forEach((root) => {
    const slides = Array.from(root.querySelectorAll<HTMLElement>('.carousel-slide'));
    const dots = Array.from(root.querySelectorAll<HTMLElement>('.carousel-dot'));
    const interval = Number(root.dataset.interval ?? 6000);
    let current = 0;
    let timer: ReturnType<typeof setInterval>;

    function show(index: number) {
      slides.forEach((s, i) => {
        s.style.opacity = i === index ? '1' : '0';
        s.style.pointerEvents = i === index ? 'auto' : 'none';
      });
      dots.forEach((d, i) => {
        d.style.width = i === index ? '22px' : '8px';
        d.style.backgroundColor = i === index ? '#2D12ED' : '';
      });
      current = index;
    }

    function next() {
      show((current + 1) % slides.length);
    }

    function start() {
      timer = setInterval(next, interval);
    }
    function stop() {
      clearInterval(timer);
    }

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        stop();
        show(Number(dot.dataset.index));
        start();
      });
    });

    root.addEventListener('mouseenter', stop);
    root.addEventListener('mouseleave', start);

    if (slides.length > 1) start();
  });
</script>
