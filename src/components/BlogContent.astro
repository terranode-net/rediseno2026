---
import { POSTS, CATEGORIES, CAT_COLORS, GRADIENTS } from '@/lib/blogData';

interface Props { locale: 'es' | 'en' }
const { locale } = Astro.props;
const es = locale === 'es';
const blogPrefix = `/${locale}/blog`;

const featured = POSTS.find((p) => p.featured) || POSTS[0];
const rest = POSTS.filter((p) => !p.featured);

function truncate(str: string, max: number) {
  return str.length > max ? str.slice(0, max).trimEnd() + '…' : str;
}

const T = es ? {
  eyebrow: 'Blog', h1: 'Tutoriales, guías y novedades', sub: 'Aprende sobre hosting, servidores, seguridad web y desarrollo.',
  searchPlaceholder: 'Buscar artículos...', featuredLabel: 'Artículo destacado', readLabel: 'lectura', readArticle: 'Leer artículo', read: 'Leer →',
  noResults: 'No se encontraron artículos.', articles: 'artículos', newsletterLabel: 'Newsletter', newsletterH: 'Recibe artículos en tu correo',
  newsletterSub: 'Tutoriales, guías y noticias sobre hosting y tecnología cloud.', emailPlaceholder: 'tu@correo.com', subscribe: 'Suscribirse',
} : {
  eyebrow: 'Blog', h1: 'Tutorials, guides & news', sub: 'Learn about hosting, servers, web security and development.',
  searchPlaceholder: 'Search articles...', featuredLabel: 'Featured article', readLabel: 'read', readArticle: 'Read article', read: 'Read →',
  noResults: 'No articles found.', articles: 'articles', newsletterLabel: 'Newsletter', newsletterH: 'Get articles in your inbox',
  newsletterSub: 'Tutorials, guides and news about hosting and cloud technology.', emailPlaceholder: 'you@email.com', subscribe: 'Subscribe',
};
---
<main style="padding-top:66px;background:#080E1C;min-height:100vh">
  <section class="relative overflow-hidden border-b border-white/[0.05] px-6 py-16">
    <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse 50% 60% at 50% 0%,rgba(37,99,235,.1),transparent 70%)"></div>
    <div class="relative z-[2] mx-auto max-w-[1160px]">
      <div class="mb-7 flex flex-wrap items-end justify-between gap-5">
        <div>
          <p class="mb-2.5 font-body text-[11px] font-bold uppercase tracking-[2.5px] text-[#3B82F6]">{T.eyebrow}</p>
          <h1 class="font-display text-[clamp(1.8rem,3.5vw,2.8rem)] font-bold leading-[1.1] tracking-tight text-white">{T.h1}</h1>
          <p class="mt-2 max-w-[480px] font-body text-[15px] text-slate-400">{T.sub}</p>
        </div>
        <div class="relative shrink-0">
          <svg viewBox="0 0 24 24" fill="none" stroke="#3A5A7A" stroke-width="1.8" class="absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          <input id="blog-search" type="text" placeholder={T.searchPlaceholder} class="w-[240px] rounded-lg border border-white/10 bg-white/[0.06] py-2.5 pl-9 pr-3.5 font-body text-[13px] text-white outline-none" />
        </div>
      </div>
      <div id="blog-cats" class="flex flex-wrap gap-2">
        {CATEGORIES.map((cat, i) => (
          <button
            type="button"
            class="blog-cat-btn rounded-full px-3.5 py-[5px] font-body text-xs transition-colors"
            data-cat={cat}
            style={i === 0 ? 'background:#3B82F6;border:1px solid #3B82F6;color:#fff;font-weight:700' : 'background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.09);color:#6B8CAE'}
          >{cat}</button>
        ))}
      </div>
    </div>
  </section>

  <div class="mx-auto max-w-[1160px] px-6 py-12 md:py-24">
    <!-- Featured -->
    <section id="blog-featured" class="mb-12">
      <div class="mb-4 flex items-center gap-2">
        <svg viewBox="0 0 24 24" fill="#F59E0B" class="h-3.5 w-3.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        <span class="font-body text-[11px] font-bold uppercase tracking-[2px] text-[#F59E0B]">{T.featuredLabel}</span>
      </div>
      <a href={`${blogPrefix}/${featured.slug}`} class="grid grid-cols-1 overflow-hidden rounded-2xl border border-white/[0.08] bg-white/[0.025] no-underline transition-colors hover:border-[#3B82F6]/25 md:grid-cols-[1fr_1.2fr]">
        <div class="relative min-h-[200px] overflow-hidden md:min-h-[260px]" style={`background:linear-gradient(135deg,#1e3a5f 0%,#0a1f3d 60%,#060d1a 100%)`}>
          <div class="pointer-events-none absolute inset-0" style="background-image:radial-gradient(circle at 20% 60%,rgba(59,130,246,.18) 0%,transparent 60%)"></div>
          <div class="relative z-[2] flex h-full flex-col justify-end p-7">
            <div class="font-display text-[28px] font-bold leading-[1.1] tracking-tight text-white/[0.07]">{featured.title.split(' ').slice(0, 4).join(' ')}</div>
          </div>
          <div class="absolute left-3.5 top-3.5 z-[3]">
            <span class="rounded-full px-2.5 py-0.5 font-body text-xs font-bold" style={`color:${CAT_COLORS[featured.category] || '#3B82F6'};background:${CAT_COLORS[featured.category] || '#3B82F6'}18;border:1px solid ${CAT_COLORS[featured.category] || '#3B82F6'}35`}>{featured.category}</span>
          </div>
        </div>
        <div class="flex flex-col justify-center p-7 md:p-9">
          <div class="mb-3.5 flex items-center gap-3">
            <span class="font-body text-xs text-slate-600">{featured.date}</span>
            <span class="h-[3px] w-[3px] rounded-full bg-slate-700"></span>
            <span class="font-body text-xs text-slate-600">{featured.readTime} {T.readLabel}</span>
          </div>
          <h2 class="mb-3.5 font-display text-[22px] font-bold leading-[1.3] tracking-tight text-white">{featured.title}</h2>
          <p class="mb-5 font-body text-sm leading-relaxed text-slate-400">{featured.excerpt}</p>
          <div class="mb-5 flex flex-wrap gap-1.5">
            {featured.tags.map((tag) => <span class="rounded-full border border-white/[0.07] bg-white/[0.04] px-2.5 py-0.5 font-body text-[11px] text-slate-600">#{tag}</span>)}
          </div>
          <span class="inline-flex w-fit items-center gap-2 rounded-lg border-none bg-[#3B82F6] px-5 py-2.5 font-display text-[13px] font-semibold text-white">
            {T.readArticle}
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" class="h-3 w-3"><path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round"/></svg>
          </span>
        </div>
      </a>
    </section>

    <!-- Grid -->
    <section>
      <p id="blog-count" class="mb-5 font-body text-[13px] text-slate-600"></p>
      <div id="blog-grid" class="grid grid-cols-1 items-stretch gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {rest.map((post) => {
          const grad = GRADIENTS[post.category] || GRADIENTS.default;
          const excerpt = truncate(post.excerpt, 110);
          return (
            <a href={`${blogPrefix}/${post.slug}`} class="blog-card flex h-full flex-col overflow-hidden rounded-2xl border border-white/[0.07] bg-white/[0.025] no-underline transition-colors hover:border-[#3B82F6]/25" data-cat={post.category} data-search={`${post.title} ${post.tags.join(' ')}`.toLowerCase()}>
              <div class="relative h-[170px] shrink-0 overflow-hidden" style={`background:${grad}`}>
                <div class="pointer-events-none absolute inset-0" style="background-image:radial-gradient(circle at 30% 50%,rgba(255,255,255,.04) 0%,transparent 60%)"></div>
                <div class="flex h-full items-center justify-center px-6 text-center">
                  <div class="max-w-[220px] font-display text-xl font-bold leading-[1.2] tracking-tight text-white/[0.07]">{post.title.split(' ').slice(0, 3).join(' ')}…</div>
                </div>
                <div class="absolute left-3 top-3 z-[2]">
                  <span class="rounded-full px-2.5 py-0.5 font-body text-[11px] font-bold" style={`color:${CAT_COLORS[post.category] || '#3B82F6'};background:${CAT_COLORS[post.category] || '#3B82F6'}18;border:1px solid ${CAT_COLORS[post.category] || '#3B82F6'}35`}>{post.category}</span>
                </div>
              </div>
              <div class="flex flex-1 flex-col p-4.5 pb-4">
                <div class="mb-2 flex items-center gap-2.5">
                  <span class="font-body text-[11px] text-slate-600">{post.date}</span>
                  <span class="h-[3px] w-[3px] shrink-0 rounded-full bg-slate-700"></span>
                  <span class="font-body text-[11px] text-slate-600">{post.readTime} {T.readLabel}</span>
                </div>
                <h3 class="mb-2 line-clamp-2 font-display text-[15px] font-bold leading-snug tracking-tight text-white">{post.title}</h3>
                <p class="mb-4 line-clamp-3 font-body text-[13px] leading-relaxed text-slate-500">{excerpt}</p>
                <div class="mt-auto flex items-center justify-between">
                  <div class="flex flex-wrap gap-1">
                    {post.tags.slice(0, 2).map((tag) => <span class="rounded-full border border-white/[0.07] bg-white/[0.04] px-2 py-0.5 font-body text-[10.5px] text-slate-600">#{tag}</span>)}
                  </div>
                  <span class="whitespace-nowrap font-body text-xs font-bold text-[#3B82F6]">{T.read}</span>
                </div>
              </div>
            </a>
          );
        })}
      </div>
      <div id="blog-empty" class="hidden py-16 text-center font-body text-[15px] text-slate-600">{T.noResults}</div>
    </section>

    <!-- Newsletter -->
    <section class="relative mt-16 grid grid-cols-1 items-center gap-8 overflow-hidden rounded-2xl border border-[#3B82F6]/[0.16] bg-[#0C1525] p-8 md:grid-cols-[1fr_auto] md:p-11">
      <div class="relative">
        <p class="mb-2 font-body text-[11px] font-bold uppercase tracking-[2.5px] text-[#3B82F6]">{T.newsletterLabel}</p>
        <h3 class="mb-1.5 font-display text-[clamp(1.2rem,2vw,1.6rem)] font-bold tracking-tight text-white">{T.newsletterH}</h3>
        <p class="font-body text-sm text-slate-400">{T.newsletterSub}</p>
      </div>
      <div class="flex shrink-0 flex-wrap gap-2.5">
        <input type="email" placeholder={T.emailPlaceholder} class="w-[220px] rounded-lg border border-white/[0.12] bg-white/[0.06] px-3.5 py-2.5 font-body text-[13px] text-white outline-none" />
        <button type="button" class="whitespace-nowrap rounded-lg border-none bg-[#3B82F6] px-5 py-2.5 font-display text-[13px] font-semibold text-white">{T.subscribe}</button>
      </div>
    </section>
  </div>
</main>

<script define:vars={{ T }}>
  const catButtons = Array.from(document.querySelectorAll('.blog-cat-btn'));
  const cards = Array.from(document.querySelectorAll('.blog-card'));
  const searchInput = document.getElementById('blog-search');
  const gridEl = document.getElementById('blog-grid');
  const emptyEl = document.getElementById('blog-empty');
  const countEl = document.getElementById('blog-count');
  const featuredSection = document.getElementById('blog-featured');
  let activeCat = 'Todos';

  function applyFilters() {
    const term = searchInput.value.trim().toLowerCase();
    let visible = 0;
    cards.forEach((card) => {
      const matchCat = activeCat === 'Todos' || card.dataset.cat === activeCat;
      const matchSearch = !term || card.dataset.search.includes(term);
      const show = matchCat && matchSearch;
      card.style.display = show ? 'flex' : 'none';
      if (show) visible++;
    });
    countEl.textContent = `${visible} ${T.articles}`;
    emptyEl.classList.toggle('hidden', visible !== 0);
    gridEl.classList.toggle('hidden', visible === 0);
    featuredSection.style.display = activeCat === 'Todos' && !term ? 'block' : 'none';
  }

  catButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      activeCat = btn.dataset.cat;
      catButtons.forEach((b) => {
        const active = b === btn;
        b.style.background = active ? '#3B82F6' : 'rgba(255,255,255,.04)';
        b.style.borderColor = active ? '#3B82F6' : 'rgba(255,255,255,.09)';
        b.style.color = active ? '#fff' : '#6B8CAE';
        b.style.fontWeight = active ? '700' : '400';
      });
      applyFilters();
    });
  });
  searchInput.addEventListener('input', applyFilters);
  applyFilters();
</script>
