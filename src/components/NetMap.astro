---
interface Props {
  locale: 'es' | 'en';
}
const { locale } = Astro.props;

const t = {
  es: {
    topo: 'Topología de Red',
    ok: 'Todos los sistemas operativos',
    transit: 'Tránsito en vivo',
    node: 'Datacenter',
    hint: 'Toca un punto para ver detalles',
    online: 'En línea',
    lat: 'Latencia',
    sla: 'SLA',
    cap: 'Capacidad',
    feat: 'Características',
    view: 'Ver planes en esta región',
  },
  en: {
    topo: 'Network Topology',
    ok: 'All systems operational',
    transit: 'Live transit',
    node: 'Datacenter',
    hint: 'Tap a point for details',
    online: 'Online',
    lat: 'Latency',
    sla: 'SLA',
    cap: 'Capacity',
    feat: 'Features',
    view: 'See plans in this region',
  },
}[locale];

// Coordenadas dentro de un viewBox estilizado (no es un mapa cartográfico exacto:
// es una representación abstracta de la topología, en el mismo espíritu visual
// que el mapa real de terranode.net). Ajusta ping/uptime/capacidad con tus datos
// reales de monitoreo cuando los tengas — estos son valores de referencia.
const DCS = [
  { x: 15, y: 33, label: 'Los Angeles', flag: '🇺🇸',
    addr: locale === 'es' ? 'Los Ángeles, California, EE. UU.' : 'Los Angeles, California, USA',
    desc: locale === 'es' ? 'Nodo de entrada para tráfico de la costa oeste de EE. UU. y LATAM.' : 'Entry node for US West Coast and LATAM traffic.',
    ping: '~35ms', uptime: '99.9%', cap: '10 Gbps',
    feats: ['KVM VPS', 'Ryzen KVM', 'DDoS 160G'] },
  { x: 19, y: 29, label: 'Utah', flag: '🇺🇸',
    addr: locale === 'es' ? 'Utah, EE. UU.' : 'Utah, USA',
    desc: locale === 'es' ? 'Capacidad adicional para cargas de trabajo distribuidas.' : 'Additional capacity for distributed workloads.',
    ping: '~45ms', uptime: '99.9%', cap: '10 Gbps',
    feats: ['Dedicados', 'Backups', 'DDoS 160G'] },
  { x: 33, y: 27, label: 'Chicago', flag: '🇺🇸',
    addr: locale === 'es' ? 'Chicago, Illinois, EE. UU.' : 'Chicago, Illinois, USA',
    desc: locale === 'es' ? 'Punto central de baja latencia para el Medio Oeste de EE. UU.' : 'Low-latency central point for the US Midwest.',
    ping: '~50ms', uptime: '99.9%', cap: '10 Gbps',
    feats: ['VPS NVMe', 'Hosting', 'IPv4 + IPv6'] },
  { x: 29, y: 37, label: 'Houston', flag: '🇺🇸',
    addr: locale === 'es' ? 'Houston, Texas, EE. UU.' : 'Houston, Texas, USA',
    desc: locale === 'es' ? 'Puerta de enlace hacia Latinoamérica con baja latencia.' : 'Low-latency gateway toward Latin America.',
    ping: '~40ms', uptime: '99.9%', cap: '10 Gbps',
    feats: ['Dedicados', 'VPS NVMe', 'DDoS 160G'] },
  { x: 40, y: 30, label: 'Ashburn', flag: '🇺🇸',
    addr: locale === 'es' ? 'Ashburn, Virginia, EE. UU.' : 'Ashburn, Virginia, USA',
    desc: locale === 'es' ? 'Uno de los hubs de interconexión más grandes del mundo.' : 'One of the world\u2019s largest interconnection hubs.',
    ping: '~55ms', uptime: '99.9%', cap: '10 Gbps',
    feats: ['Hosting', 'Terramail', 'DDoS 160G'] },
  { x: 32, y: 61, label: 'Guayaquil', flag: '🇪🇨',
    addr: locale === 'es' ? 'Guayaquil, Ecuador' : 'Guayaquil, Ecuador',
    desc: locale === 'es' ? 'Nuestra sede: la menor latencia posible dentro de Ecuador.' : 'Our home base: the lowest possible latency inside Ecuador.',
    ping: '~5ms', uptime: '99.9%', cap: '1 Gbps',
    feats: ['VPS NVMe', 'Dedicados', 'Terramail'] },
];

const CONNS: [number, number][] = [
  [0, 1], [1, 2], [2, 4], [4, 3], [3, 0], [0, 5], [3, 5], [4, 5],
];
const DURS = [6, 7, 8, 6.5, 7.5, 9, 8.5, 9.5];
---
<section aria-label="Network topology" class="border-y border-white/[0.04] bg-[#070D1A] py-16 md:py-20">
  <div class="container-page">
    <div class="mb-4 flex items-center justify-between">
      <div class="flex items-center gap-2.5">
        <svg viewBox="0 0 24 24" fill="none" stroke="#2D12ED" stroke-width="1.8" class="h-3.5 w-3.5"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12" stroke-linecap="round"/></svg>
        <span class="font-body text-[11px] font-bold uppercase tracking-[3px] text-slate-400">{t.topo}</span>
      </div>
      <div class="flex items-center gap-2 rounded-full border border-signal/20 bg-signal/[0.08] px-3.5 py-1">
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-signal shadow-[0_0_5px_#3EC821]"></span>
        <span class="font-body text-[11px] font-semibold text-signal">{t.ok}</span>
      </div>
    </div>

    <div class="flex flex-col overflow-hidden rounded-xl border border-accent/[0.12] bg-[#060C18] lg:flex-row" id="netmap-root" data-locale={locale}>
      <!-- SVG MAP -->
      <div class="min-w-0 flex-1">
        <svg viewBox="0 0 55 70" class="block w-full bg-[#060C18]">
          <defs>
            <filter id="gs"><feGaussianBlur stdDeviation="0.25" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
            <filter id="gm"><feGaussianBlur stdDeviation="0.5" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
          </defs>

          <!-- decorative dot field -->
          {Array.from({ length: 140 }).map((_, i) => {
            const x = (i * 37) % 55;
            const y = Math.floor(i / 8) * 4.6 % 70;
            return <circle cx={x} cy={y} r="0.28" fill="#132248" />;
          })}

          <!-- Arcs -->
          {CONNS.map(([a, b], ci) => {
            const A = DCS[a], B = DCS[b];
            const mx = (A.x + B.x) / 2;
            const my = (A.y + B.y) / 2 - Math.hypot(B.x - A.x, B.y - A.y) * 0.18;
            const path = `M${A.x.toFixed(2)},${A.y.toFixed(2)} Q${mx.toFixed(2)},${my.toFixed(2)} ${B.x.toFixed(2)},${B.y.toFixed(2)}`;
            return (
              <g>
                <path d={path} fill="none" stroke="rgba(45,18,237,.35)" stroke-width="0.16" />
                <circle r="0.42" fill="#7C6CFB" filter="url(#gs)" opacity=".9">
                  <animateMotion dur={`${DURS[ci]}s`} repeatCount="indefinite" path={path} />
                </circle>
                <circle r="0.26" fill="#B4ABFC" opacity=".6">
                  <animateMotion dur={`${DURS[ci]}s`} begin={`${(DURS[ci] * 0.52).toFixed(1)}s`} repeatCount="indefinite" path={path} />
                </circle>
              </g>
            );
          })}

          <!-- DC pins -->
          {DCS.map((pt, i) => (
            <g class="netmap-pin cursor-pointer" data-index={i}>
              <circle cx={pt.x} cy={pt.y} r="0.8" fill="none" stroke="#2D12ED" stroke-width="0.14">
                <animate attributeName="r" values="0.8;2.6;0.8" dur="3s" begin={`${i * 0.4}s`} repeatCount="indefinite" />
                <animate attributeName="opacity" values=".7;0;.7" dur="3s" begin={`${i * 0.4}s`} repeatCount="indefinite" />
              </circle>
              <circle cx={pt.x} cy={pt.y} r={0.85} fill="#1D4ED8" class="netmap-core" stroke="#7C6CFB" stroke-width="0.2" filter="url(#gm)" />
              <circle cx={pt.x} cy={pt.y} r="0.36" fill="#DDD8FE" />
              <text x={pt.x + 1.1} y={pt.y - 1} font-size="1.6" fill="#9C90FA" font-family="'Instrument Sans',sans-serif" font-weight="600" class="pointer-events-none select-none netmap-label" data-index={i}>{pt.label}</text>
            </g>
          ))}
        </svg>

        <!-- Legend -->
        <div class="flex items-center gap-4 border-t border-accent/[0.08] bg-black/30 px-4 py-2">
          <div class="flex items-center gap-1.5">
            <div class="h-[1.5px] w-[18px]" style="background:linear-gradient(90deg,transparent,#7C6CFB,transparent)"></div>
            <span class="font-body text-[11px] text-slate-500">{t.transit}</span>
          </div>
          <div class="flex items-center gap-1.5">
            <div class="h-2 w-2 rounded-full bg-accent shadow-[0_0_4px_#2D12ED]"></div>
            <span class="font-body text-[11px] text-slate-500">{t.node}</span>
          </div>
          <span class="ml-auto hidden font-body text-[11px] text-slate-600 sm:inline" id="netmap-hint">← {t.hint}</span>
        </div>
      </div>

      <!-- Detail panel -->
      <div id="netmap-panel" class="hidden w-full flex-shrink-0 flex-col overflow-y-auto border-t border-accent/[0.14] bg-[#0A1525] lg:flex lg:w-[280px] lg:border-l lg:border-t-0">
        <div class="flex items-center justify-between border-b border-white/[0.06] px-4 py-3">
          <div class="flex items-center gap-1.5">
            <span class="inline-block h-1.5 w-1.5 rounded-full bg-signal shadow-[0_0_5px_#3EC821]"></span>
            <span class="font-body text-[9px] font-bold uppercase tracking-[2px] text-signal">{t.online}</span>
          </div>
          <button id="netmap-close" class="flex h-5 w-5 items-center justify-center rounded-md border-none bg-white/[0.06] text-xs text-slate-400" aria-label="Close">✕</button>
        </div>
        <div class="p-4" id="netmap-body"></div>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ DCS, t }}>
  const root = document.getElementById('netmap-root');
  const panel = document.getElementById('netmap-panel');
  const body = document.getElementById('netmap-body');
  const closeBtn = document.getElementById('netmap-close');
  const hint = document.getElementById('netmap-hint');
  let selected = null;

  function render(i) {
    const dc = DCS[i];
    body.innerHTML = `
      <h3 class="mb-1 font-display text-[17px] font-bold text-white">${dc.flag} ${dc.label}</h3>
      <div class="mb-2.5 flex items-start gap-1.5">
        <span class="mt-0.5 text-[11px] text-slate-500">📍</span>
        <span class="font-body text-[10px] leading-relaxed text-slate-500">${dc.addr}</span>
      </div>
      <p class="mb-3 border-b border-white/[0.06] pb-3 font-body text-[11px] leading-relaxed text-slate-500">${dc.desc}</p>
      <div class="mb-3 grid grid-cols-3 gap-1.5">
        ${[[dc.ping, t.lat], [dc.uptime, t.sla], [dc.cap, t.cap]].map(([val, lbl]) => `
          <div class="rounded-lg border border-accent/[0.14] bg-accent/[0.07] px-1 py-2 text-center">
            <div class="mb-0.5 font-display text-xs font-bold text-white">${val}</div>
            <div class="text-[7.5px] uppercase tracking-wide text-slate-500">${lbl}</div>
          </div>
        `).join('')}
      </div>
      <div class="mb-3.5">
        <div class="mb-1.5 font-body text-[9px] font-bold uppercase tracking-[2px] text-slate-500">${t.feat}</div>
        <div class="flex flex-wrap gap-1">
          ${dc.feats.map((f) => `<span class="rounded-full border border-accent/20 bg-accent/[0.08] px-2 py-0.5 font-body text-[9.5px] text-accent">${f}</span>`).join('')}
        </div>
      </div>
      <button class="w-full rounded-lg border-none bg-accent px-2.5 py-2.5 font-display text-xs font-semibold text-white transition-colors hover:bg-accent-hover">${t.view}</button>
    `;
  }

  function select(i) {
    selected = selected === i ? null : i;
    root.querySelectorAll('.netmap-core').forEach((el, idx) => {
      el.setAttribute('fill', idx === selected ? '#3B2FE8' : '#1D4ED8');
      el.setAttribute('r', idx === selected ? '1.15' : '0.85');
    });
    root.querySelectorAll('.netmap-label').forEach((el, idx) => {
      el.setAttribute('fill', idx === selected ? '#DDD8FE' : '#9C90FA');
    });
    if (selected === null) {
      panel.classList.add('hidden');
      panel.classList.remove('lg:flex');
      if (hint) hint.style.display = '';
    } else {
      render(selected);
      panel.classList.remove('hidden');
      panel.classList.add('lg:flex');
      if (hint) hint.style.display = 'none';
    }
  }

  root.querySelectorAll('.netmap-pin').forEach((pin) => {
    pin.addEventListener('click', () => select(Number(pin.dataset.index)));
  });
  closeBtn?.addEventListener('click', () => select(selected));
</script>
