---
interface Props {
  locale: 'es' | 'en';
}
const { locale } = Astro.props;

const t = {
  es: {
    topo: 'TOPOLOGÍA DE RED',
    ok: 'Todos los sistemas operativos',
    hint: 'Haz clic en un nodo para ver detalles',
    online: 'EN LÍNEA',
    view: 'Ver Centro de Datos →',
    lat: 'LATENCIA',
    sla: 'UPTIME SLA',
    cap: 'CAPACIDAD',
    feat: 'CARACTERÍSTICAS',
    transit: 'Tránsito de datos',
    node: 'Datacenter',
  },
  en: {
    topo: 'NETWORK TOPOLOGY',
    ok: 'All Systems Operational',
    hint: 'Click on a datacenter pin to view details',
    online: 'ONLINE',
    view: 'View Datacenter →',
    lat: 'LOCAL LATENCY',
    sla: 'UPTIME SLA',
    cap: 'CAPACITY',
    feat: 'FEATURES',
    transit: 'Data Transit',
    node: 'Datacenter',
  },
}[locale];

// Coordenadas y datos reales de la infraestructura de Terranode.
const DCS = [
  { x: 25.32, y: 27.0, flag: '🇺🇸', label: 'Los Ángeles', city: 'Los Angeles, CA',
    addr: 'Coresite LA1 · 900 N Alameda St',
    desc: locale === 'es' ? 'Hub principal en la costa oeste con conectividad premium al Pacífico y acceso directo a redes de tránsito de California.' : 'Main West Coast hub with premium Pacific connectivity and direct access to California transit networks.',
    ping: '8ms', uptime: '99.99%', cap: '40 Gbps', feats: ['Tier 3+', 'DDoS 160 Gbps', 'BGP Transit', 'NVMe', 'IPv6'] },
  { x: 27.81, y: 24.0, flag: '🇺🇸', label: 'Utah', city: 'Salt Lake City, UT',
    addr: 'Evoque SLC1 · 455 S 300 E',
    desc: locale === 'es' ? 'Datacenter en las Montañas Rocosas con climatización natural y energía 100% renovable.' : 'Rocky Mountains datacenter with natural cooling and 100% renewable energy.',
    ping: '22ms', uptime: '99.95%', cap: '20 Gbps', feats: ['Tier 3', 'DDoS 160 Gbps', locale === 'es' ? 'Energía renovable' : 'Renewable energy', 'NVMe'] },
  { x: 37.73, y: 24.0, flag: '🇺🇸', label: 'Chicago', city: 'Chicago, IL',
    addr: 'QTS CHI1 · 350 E Cermak Rd',
    desc: locale === 'es' ? 'Punto de intercambio neutro en el Midwest con acceso a los principales IXPs del centro de Norteamérica.' : 'Neutral interchange point in the Midwest with access to the main IXPs in central North America.',
    ping: '18ms', uptime: '99.99%', cap: '40 Gbps', feats: ['Tier 3+', 'DDoS 160 Gbps', 'BGP Transit', 'SOC 2 II', 'IX'] },
  { x: 34.54, y: 28.5, flag: '🇺🇸', label: 'Houston', city: 'Houston, TX',
    addr: 'CyrusOne · 1649 W Sam Houston Pkwy N',
    desc: locale === 'es' ? 'Instalación premium en el sur de EE.UU. con baja latencia hacia México y toda Latinoamérica.' : 'Premium facility in the southern US with low latency to Mexico and all of Latin America.',
    ping: '15ms', uptime: '99.97%', cap: '20 Gbps', feats: ['Tier 3', 'DDoS 160 Gbps', locale === 'es' ? 'Enlace LATAM' : 'LATAM link', 'NVMe'] },
  { x: 41.85, y: 25.0, flag: '🇺🇸', label: 'Ashburn, VA', city: 'Ashburn, Virginia',
    addr: 'Equinix DC6 · 21715 Filigree Ct',
    desc: locale === 'es' ? 'Capital del Internet. Mayor concentración de fibra y puntos de intercambio del mundo.' : "The Internet's capital. The world's highest concentration of fiber and interchange points.",
    ping: '12ms', uptime: '99.99%', cap: '100 Gbps', feats: ['Tier 3+', 'DDoS 160 Gbps', 'BGP Transit', 'SOC 2 II', 'ISO 27001'] },
  { x: 40.87, y: 41.14, flag: '🇪🇨', label: 'Guayaquil', city: 'Guayaquil, Ecuador',
    addr: 'CNT Datacenter · Av. C. Julio Arosemena Km 1.5',
    desc: locale === 'es' ? 'Nodo local en Ecuador con la latencia más baja del país. Conectado a NAP Ecuador.' : 'Local node in Ecuador with the lowest latency in the country. Connected to NAP Ecuador.',
    ping: '3ms', uptime: '99.95%', cap: '10 Gbps', feats: ['Tier 2+', 'DDoS 160 Gbps', 'NAP Ecuador', locale === 'es' ? 'Latencia local' : 'Local latency'] },
];

const CONNS: [number, number][] = [[0,1],[0,2],[0,3],[0,4],[1,2],[2,4],[3,4],[1,3],[0,5],[3,5]];
const DURS = [3.2, 2.8, 4.1, 3.6, 2.5, 3.9, 2.2, 3.4, 2.9, 4.3];

const OFFSETS = [
  { dx: -3.2, dy: -1.4, anchor: 'end' },
  { dx: -3, dy: -1.4, anchor: 'end' },
  { dx: 1, dy: -1.4, anchor: 'start' },
  { dx: 1, dy: 1.8, anchor: 'start' },
  { dx: 1, dy: -1.4, anchor: 'start' },
  { dx: 1, dy: 1.8, anchor: 'start' },
];

const arcs = CONNS.map(([a, b], ci) => {
  const A = DCS[a], B = DCS[b];
  const mx = (A.x + B.x) / 2;
  const my = (A.y + B.y) / 2 - Math.hypot(B.x - A.x, B.y - A.y) * 0.22;
  return { path: `M${A.x.toFixed(2)},${A.y.toFixed(2)} Q${mx.toFixed(2)},${my.toFixed(2)} ${B.x.toFixed(2)},${B.y.toFixed(2)}`, dur: DURS[ci] };
});
---
<section aria-label="Network topology" class="border-y border-white/[0.04] bg-[#070D1A] py-20">
  <div class="mx-auto max-w-[1160px] px-6 lg:px-8">
    <div class="mb-4 flex items-center justify-between">
      <div class="flex items-center gap-2.5">
        <svg viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="1.8" class="h-3.5 w-3.5"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12" stroke-linecap="round"/></svg>
        <span class="font-body text-[11px] font-bold uppercase tracking-[3px] text-slate-400">{t.topo}</span>
      </div>
      <div class="flex items-center gap-2 rounded-full border border-signal/20 bg-signal/[0.08] px-3.5 py-1">
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-[#22C55E] shadow-[0_0_5px_#22C55E]"></span>
        <span class="font-body text-[11px] font-semibold text-[#22C55E]">{t.ok}</span>
      </div>
    </div>

    <div class="flex flex-col overflow-hidden rounded-xl border border-[#3B82F6]/[0.12] bg-[#060C18] lg:flex-row" id="netmap-root">
      <div class="min-w-0 flex-1">
        <svg viewBox="0 0 147 70" class="block w-full bg-[#060C18]">
          <defs>
            <filter id="gs"><feGaussianBlur stdDeviation="0.4" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
            <filter id="gm"><feGaussianBlur stdDeviation="0.9" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
          </defs>

          {Array.from({ length: 420 }).map((_, i) => {
            const x = (i * 13) % 147;
            const y = (Math.floor(i / 11) * 3.1) % 70;
            return <circle cx={x} cy={y} r="0.22" fill="#152848" />;
          })}

          {arcs.map((arc, ci) => (
            <g>
              <path d={arc.path} fill="none" stroke="rgba(59,130,246,.35)" stroke-width="0.18" />
              <circle r="0.45" fill="#60A5FA" filter="url(#gs)" opacity=".9">
                <animateMotion dur={`${arc.dur}s`} repeatCount="indefinite" path={arc.path} />
              </circle>
              <circle r="0.28" fill="#93C5FD" opacity=".6">
                <animateMotion dur={`${arc.dur}s`} begin={`${(arc.dur * 0.52).toFixed(1)}s`} repeatCount="indefinite" path={arc.path} />
              </circle>
            </g>
          ))}

          {DCS.map((pt, i) => (
            <g class="netmap-pin cursor-pointer" data-index={i}>
              <circle cx={pt.x} cy={pt.y} r="0.8" fill="none" stroke="#3B82F6" stroke-width="0.15">
                <animate attributeName="r" values="0.8;3;0.8" dur="3s" begin={`${i * 0.4}s`} repeatCount="indefinite" />
                <animate attributeName="opacity" values=".7;0;.7" dur="3s" begin={`${i * 0.4}s`} repeatCount="indefinite" />
              </circle>
              <circle cx={pt.x} cy={pt.y} r="0.5" fill="none" stroke="#60A5FA" stroke-width="0.12">
                <animate attributeName="r" values="0.4;1.6;0.4" dur="3s" begin={`${i * 0.4 + 0.4}s`} repeatCount="indefinite" />
                <animate attributeName="opacity" values=".8;0;.8" dur="3s" begin={`${i * 0.4 + 0.4}s`} repeatCount="indefinite" />
              </circle>
              <circle cx={pt.x} cy={pt.y} r="0.85" fill="#1D4ED8" stroke="#60A5FA" stroke-width="0.22" filter="url(#gm)" class="netmap-core" />
              <circle cx={pt.x} cy={pt.y} r="0.38" fill="#DBEAFE" class="netmap-inner" />
              <text
                x={pt.x + OFFSETS[i].dx}
                y={pt.y + OFFSETS[i].dy}
                text-anchor={OFFSETS[i].anchor}
                font-size="1.5"
                fill="#60A5FA"
                font-family="'Instrument Sans',sans-serif"
                font-weight="600"
                class="pointer-events-none select-none netmap-label"
              >{pt.label}</text>
            </g>
          ))}
        </svg>

        <div class="flex items-center gap-4 border-t border-[#3B82F6]/[0.08] bg-black/30 px-4 py-2">
          <div class="flex items-center gap-1.5">
            <div class="h-[1.5px] w-[18px]" style="background:linear-gradient(90deg,transparent,#60A5FA,transparent)"></div>
            <span class="font-body text-[11px] text-slate-500">{t.transit}</span>
          </div>
          <div class="flex items-center gap-1.5">
            <div class="h-2 w-2 rounded-full bg-[#3B82F6] shadow-[0_0_4px_#3B82F6]"></div>
            <span class="font-body text-[11px] text-slate-500">{t.node}</span>
          </div>
          <span class="ml-auto hidden font-body text-[11px] text-slate-600 sm:inline" id="netmap-hint">← {t.hint}</span>
        </div>
      </div>

      <div id="netmap-panel" class="hidden w-full flex-shrink-0 flex-col overflow-y-auto border-t border-[#3B82F6]/[0.14] bg-[#0A1525] lg:flex lg:w-[280px] lg:border-l lg:border-t-0">
        <div class="flex items-center justify-between border-b border-white/[0.06] px-4 py-3">
          <div class="flex items-center gap-1.5">
            <span class="inline-block h-1.5 w-1.5 rounded-full bg-[#22C55E] shadow-[0_0_5px_#22C55E]"></span>
            <span class="font-body text-[9px] font-bold uppercase tracking-[2px] text-[#22C55E]">{t.online}</span>
          </div>
          <button id="netmap-close" class="flex h-5 w-5 items-center justify-center rounded-md border-none bg-white/[0.06] text-xs text-slate-400" aria-label="Close">✕</button>
        </div>
        <div class="p-4" id="netmap-body"></div>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ DCS, t }}>
  const root = document.getElementById('netmap-root');
  const panel = document.getElementById('netmap-panel');
  const body = document.getElementById('netmap-body');
  const closeBtn = document.getElementById('netmap-close');
  const hint = document.getElementById('netmap-hint');
  let selected = null;

  function render(i) {
    const dc = DCS[i];
    body.innerHTML = `
      <h3 class="mb-1 font-display text-[17px] font-bold text-white">${dc.flag} ${dc.label}</h3>
      <div class="mb-2.5 flex items-start gap-1.5">
        <span class="mt-0.5 text-[11px] text-slate-500">📍</span>
        <span class="font-body text-[10px] leading-relaxed text-slate-500">${dc.addr}</span>
      </div>
      <p class="mb-3 border-b border-white/[0.06] pb-3 font-body text-[11px] leading-relaxed text-slate-500">${dc.desc}</p>
      <div class="mb-3 grid grid-cols-3 gap-1.5">
        ${[[dc.ping, t.lat], [dc.uptime, t.sla], [dc.cap, t.cap]].map(([val, lbl]) => `
          <div class="rounded-lg border border-[#3B82F6]/[0.14] bg-[#3B82F6]/[0.07] px-1 py-2 text-center">
            <div class="mb-0.5 font-display text-xs font-bold text-white">${val}</div>
            <div class="text-[7.5px] uppercase tracking-wide text-slate-500">${lbl}</div>
          </div>
        `).join('')}
      </div>
      <div class="mb-3.5">
        <div class="mb-1.5 font-body text-[9px] font-bold uppercase tracking-[2px] text-slate-500">${t.feat}</div>
        <div class="flex flex-wrap gap-1">
          ${dc.feats.map((f) => `<span class="rounded-full border border-[#3B82F6]/20 bg-[#3B82F6]/[0.08] px-2 py-0.5 font-body text-[9.5px] text-[#60A5FA]">${f}</span>`).join('')}
        </div>
      </div>
      <button class="w-full rounded-lg border-none bg-[#3B82F6] px-2.5 py-2.5 font-display text-xs font-semibold text-white transition-colors hover:bg-[#2563EB]">${t.view}</button>
    `;
  }

  function select(i) {
    selected = selected === i ? null : i;
    root.querySelectorAll('.netmap-core').forEach((el, idx) => {
      el.setAttribute('fill', idx === selected ? '#3B82F6' : '#1D4ED8');
      el.setAttribute('stroke', idx === selected ? '#93C5FD' : '#60A5FA');
      el.setAttribute('r', idx === selected ? '1.2' : '0.85');
    });
    root.querySelectorAll('.netmap-inner').forEach((el, idx) => {
      el.setAttribute('r', idx === selected ? '0.55' : '0.38');
    });
    root.querySelectorAll('.netmap-label').forEach((el, idx) => {
      el.setAttribute('fill', idx === selected ? '#93C5FD' : '#60A5FA');
    });
    if (selected === null) {
      panel.classList.add('hidden');
      panel.classList.remove('lg:flex');
      if (hint) hint.style.display = '';
    } else {
      render(selected);
      panel.classList.remove('hidden');
      panel.classList.add('lg:flex');
      if (hint) hint.style.display = 'none';
    }
  }

  root.querySelectorAll('.netmap-pin').forEach((pin) => {
    pin.addEventListener('click', () => select(Number(pin.dataset.index)));
  });
  closeBtn?.addEventListener('click', () => select(selected));
</script>
