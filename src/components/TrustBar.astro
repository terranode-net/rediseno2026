---
interface Props { items: string[] }
const { items } = Astro.props;
---
<div class="border-y border-slate-100 bg-surface py-6">
  <div class="container-page flex flex-wrap items-center justify-center gap-x-10 gap-y-3">
    {items.map((item) => (
      <span class="flex items-center gap-2 text-[13px] font-medium text-slate-500">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" class="text-signal"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.8"/><path d="m8.5 12.5 2.3 2.3L16 10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        {item}
      </span>
    ))}
  </div>
</div>
