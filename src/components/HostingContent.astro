---
interface Props { locale: 'es' | 'en' }
const { locale } = Astro.props;
const es = locale === 'es';
const contactoHref = `/${locale}/${es ? 'contacto' : 'contact'}`;

const PLANS = es ? [
  { id: '8gb', name: 'Plan 8 GB', price: '$40', period: '/año', tagline: 'Para proyectos personales', popular: false, href: 'https://my.terranode.net/store/business-hosting/hosting-8-gb', feats: ['8 GB Espacio NVMe', '40 GB Banda ancha', '5 Bases de datos', 'Correos ilimitados', "SSL Let's Encrypt gratis", 'cPanel incluido', '1-clic WordPress', 'Soporte 24/7'] },
  { id: '14gb', name: 'Plan 14 GB', price: '$64', period: '/año', tagline: 'Para proyectos en crecimiento', popular: true, href: 'https://my.terranode.net/store/business-hosting/hosting-14-gb', feats: ['14 GB Espacio NVMe', '70 GB Banda ancha', '7 Bases de datos', 'Correos ilimitados', "SSL Let's Encrypt gratis", 'cPanel incluido', '1-clic WordPress', 'Soporte 24/7'] },
  { id: '35gb', name: 'Plan 35 GB', price: '$175', period: '/año', tagline: 'Para empresas medianas', popular: false, href: 'https://my.terranode.net/store/business-hosting/hosting-35-gb', feats: ['35 GB Espacio NVMe', '175 GB Banda ancha', '17 Bases de datos', 'Correos ilimitados', "SSL Let's Encrypt gratis", 'cPanel incluido', '1-clic WordPress', 'Soporte prioritario 24/7'] },
] : [
  { id: '8gb', name: '8 GB Plan', price: '$40', period: '/yr', tagline: 'For personal projects', popular: false, href: 'https://my.terranode.net/store/business-hosting/hosting-8-gb', feats: ['8 GB NVMe Space', '40 GB Bandwidth', '5 Databases', 'Unlimited emails', "Free Let's Encrypt SSL", 'cPanel included', '1-click WordPress', '24/7 Support'] },
  { id: '14gb', name: '14 GB Plan', price: '$64', period: '/yr', tagline: 'For growing projects', popular: true, href: 'https://my.terranode.net/store/business-hosting/hosting-14-gb', feats: ['14 GB NVMe Space', '70 GB Bandwidth', '7 Databases', 'Unlimited emails', "Free Let's Encrypt SSL", 'cPanel included', '1-click WordPress', '24/7 Support'] },
  { id: '35gb', name: '35 GB Plan', price: '$175', period: '/yr', tagline: 'For mid-size businesses', popular: false, href: 'https://my.terranode.net/store/business-hosting/hosting-35-gb', feats: ['35 GB NVMe Space', '175 GB Bandwidth', '17 Databases', 'Unlimited emails', "Free Let's Encrypt SSL", 'cPanel included', '1-click WordPress', '24/7 Priority Support'] },
];

const FEATURES = es ? [
  { icon: 'speed', t: 'Máximo Rendimiento', d: 'Tecnología LiteSpeed + CloudLinux con PHP 8.x para la máxima velocidad en tu sitio.' },
  { icon: 'wp', t: '1-clic WordPress', d: 'Instala WordPress (o +300 apps) en segundos con el autoinstalador incluido.' },
  { icon: 'ssl', t: "SSL Let's Encrypt Gratis", d: 'Certificado SSL automático para cada dominio y subdominio de tu cuenta.' },
  { icon: 'spam', t: 'Filtro Anti-spam', d: 'Bandeja de entrada limpia con nuestro sistema avanzado de filtrado en tiempo real.' },
  { icon: 'bkp', t: 'Backups Cada 24h', d: 'Copias de seguridad externas automáticas almacenadas fuera del sitio.' },
  { icon: 'ddos', t: 'Protección DDoS', d: 'Defensa activa ante ataques con mitigación automática hasta 160 Gbps.' },
  { icon: 'mgr', t: 'Migración Gratuita', d: 'Nuestro equipo migra tu hosting, correos y dominios sin tiempo de inactividad.' },
  { icon: 'sup', t: 'Soporte 24/7', d: 'Chat, WhatsApp y ticketing disponibles las 24 horas, todos los días del año.' },
] : [
  { icon: 'speed', t: 'Maximum Performance', d: 'LiteSpeed + CloudLinux technology with PHP 8.x for maximum site speed.' },
  { icon: 'wp', t: '1-Click WordPress', d: 'Install WordPress (or 300+ apps) in seconds with the included auto-installer.' },
  { icon: 'ssl', t: "Free Let's Encrypt SSL", d: 'Automatic SSL certificate for every domain and subdomain on your account.' },
  { icon: 'spam', t: 'Anti-spam Filter', d: 'A clean inbox with our advanced real-time filtering system.' },
  { icon: 'bkp', t: 'Backups Every 24h', d: 'Automatic off-site backups stored away from the server.' },
  { icon: 'ddos', t: 'DDoS Protection', d: 'Active defense against attacks with automatic mitigation up to 160 Gbps.' },
  { icon: 'mgr', t: 'Free Migration', d: 'Our team migrates your hosting, emails and domains with zero downtime.' },
  { icon: 'sup', t: '24/7 Support', d: 'Chat, WhatsApp and ticketing available 24 hours a day, every day.' },
];

const OS_LOGOS = [
  { name: 'cPanel', color: '#FF6C2C' },
  { name: 'LiteSpeed', color: '#0099CC' },
  { name: 'CloudLinux', color: '#3399CC' },
  { name: 'WordPress', color: '#21759B' },
  { name: 'PHP 8.x', color: '#8892BF' },
  { name: 'MySQL', color: '#4479A1' },
  { name: "Let's Encrypt", color: '#003A70' },
  { name: 'Imunify360', color: '#5C6BC0' },
];

const FAQ = es ? [
  { q: '¿Puedo migrar mi sitio actual a Terranode?', a: 'Sí. Ofrecemos migración gratuita desde cualquier proveedor. Nuestro equipo gestiona todo el proceso, incluyendo archivos, base de datos y correos, sin tiempo de inactividad.' },
  { q: '¿El SSL está incluido en todos los planes?', a: 'Sí. Todos los planes incluyen certificados SSL Let\u2019s Encrypt gratuitos e ilimitados para tus dominios y subdominios. Se renuevan automáticamente.' },
  { q: '¿Cuántas cuentas de correo puedo crear?', a: 'Todos los planes incluyen correos ilimitados. Puedes crear tantas cuentas de correo como necesites para tu dominio.' },
  { q: '¿Qué pasa si supero el límite de almacenamiento?', a: 'Recibirás una notificación antes de alcanzar el límite. Puedes actualizar tu plan en cualquier momento desde el panel de cliente.' },
  { q: '¿Tienen soporte para e-commerce?', a: 'Sí. Puedes instalar WooCommerce, Prestashop, Magento o cualquier otro CMS con 1 clic. Los planes de mayor capacidad están recomendados para tiendas con alto tráfico.' },
] : [
  { q: 'Can I migrate my current site to Terranode?', a: 'Yes. We offer free migration from any provider. Our team handles the whole process, including files, database and email, with zero downtime.' },
  { q: 'Is SSL included in every plan?', a: "Yes. Every plan includes free, unlimited Let's Encrypt SSL certificates for your domains and subdomains. They renew automatically." },
  { q: 'How many email accounts can I create?', a: 'Every plan includes unlimited email accounts. Create as many as your domain needs.' },
  { q: 'What happens if I exceed my storage limit?', a: "You'll get a notification before reaching the limit. You can upgrade your plan anytime from the client panel." },
  { q: 'Do you support e-commerce?', a: 'Yes. You can install WooCommerce, Prestashop, Magento or any other CMS with 1 click. Higher-tier plans are recommended for high-traffic stores.' },
];

const ICONS: Record<string, string> = {
  speed: '<path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke-linecap="round"/>',
  wp: '<circle cx="12" cy="12" r="10"/><path d="M2 12h4M18 12h4M12 2v4M12 18v4"/>',
  ssl: '<rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>',
  spam: '<path d="m3 3 18 18M8.67 8.67A4 4 0 0 0 8 10c0 2.21 1.79 4 4 4 .48 0 .94-.09 1.37-.26"/><path d="M19.44 19.44A10 10 0 0 1 12 22C6.48 22 2 17.52 2 12c0-2.72 1.09-5.19 2.86-7.01"/>',
  bkp: '<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/>',
  ddos: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  mgr: '<path d="M5 12H19M12 5l7 7-7 7"/>',
  sup: '<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>',
};

const T = {
  eyebrow: 'Web Hosting',
  h1: es ? 'Potencia tu presencia' : 'Power your online',
  h1b: es ? 'en línea con nosotros' : 'presence with us',
  sub: es ? 'Hosting optimizado con LiteSpeed, CloudLinux y herramientas de alto rendimiento. La base más sólida para tu sitio web.' : 'Optimized hosting with LiteSpeed, CloudLinux and high-performance tools. The strongest foundation for your website.',
  ctaPrimary: es ? 'Ver todos los planes' : 'View all plans',
  ctaSecondary: es ? 'Hablar con ventas' : 'Talk to sales',
  plansH: es ? 'Planes Web Hosting' : 'Web Hosting Plans',
  plansTag: 'PRICING',
  plansSub: es ? 'Todos incluyen cPanel, SSL gratis y soporte 24/7' : 'All include cPanel, free SSL and 24/7 support',
  cta2H: es ? '¿Necesitas un plan personalizado?' : 'Need a custom plan?',
  cta2Sub: es ? 'Contacta con nuestro equipo y diseñamos un plan a la medida de tu empresa.' : "Contact our team and we'll design a plan tailored to your business needs.",
  cta2Btn: es ? 'Cotizar ahora' : 'Get a quote',
  featsH: es ? 'Todo lo que necesita tu sitio web' : 'Everything your website needs',
  faqH: es ? 'Preguntas frecuentes' : 'Frequently asked questions',
  buy: es ? 'Contratar' : 'Get started',
  popular: es ? 'Popular' : 'Popular',
  migrateH: es ? 'Migraciones Gratuitas' : 'Free Migrations',
  migrateD: es ? 'Traslada tu hosting, correos y dominios con nuestro servicio de migración gratuita. Equipo disponible 24/7.' : 'Move your hosting, emails and domains with our free migration service. Team available 24/7.',
  ddosH: es ? 'Protección DDoS' : 'DDoS Protection',
  ddosD: es ? 'Mitigación automática en tiempo real hasta 160 Gbps. Tu sitio siempre disponible.' : 'Automatic real-time mitigation up to 160 Gbps. Your site always available.',
};
---
<main style="padding-top:66px;background:#080E1C;min-height:100vh">
  <!-- HERO -->
  <section class="relative overflow-hidden border-b border-white/[0.04] px-6 py-16 md:py-[72px]">
    <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse 60% 70% at 50% 30%,rgba(37,99,235,.12),transparent 70%)"></div>
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(59,130,246,.035) 1px,transparent 1px),linear-gradient(90deg,rgba(59,130,246,.035) 1px,transparent 1px);background-size:50px 50px"></div>
    <div class="relative z-[2] mx-auto grid max-w-[1160px] grid-cols-1 items-center gap-10 md:grid-cols-2 md:gap-[60px]">
      <div>
        <span class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#3B82F6]/20 bg-[#3B82F6]/[0.08] px-3.5 py-[5px] font-body text-[11px] font-bold uppercase tracking-[2.5px] text-[#3B82F6]">
          <svg viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="2" class="h-3 w-3"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
          {T.eyebrow}
        </span>
        <h1 class="mb-1 font-display text-[clamp(2.2rem,4vw,3.6rem)] font-bold leading-[1.05] tracking-tight text-white">{T.h1}</h1>
        <h2 class="mb-[22px] font-display text-[clamp(2.2rem,4vw,3.6rem)] font-bold leading-[1.05] tracking-tight text-slate-600">{T.h1b}</h2>
        <p class="mb-8 max-w-[460px] font-body text-base leading-[1.7] text-slate-400">{T.sub}</p>
        <div class="flex flex-wrap gap-3">
          <a href="https://my.terranode.net/store/business-hosting" target="_blank" rel="noopener" class="rounded-lg border-none bg-[#3B82F6] px-6 py-3 font-display text-[15px] font-semibold text-white no-underline shadow-[0_0_24px_rgba(59,130,246,.3)] transition-colors hover:bg-[#2563EB]">{T.ctaPrimary}</a>
          <a href={contactoHref} class="rounded-lg border border-white/[0.15] bg-transparent px-6 py-3 font-display text-[15px] font-semibold text-slate-300 no-underline transition-colors hover:text-white">{T.ctaSecondary}</a>
        </div>
      </div>
      <div class="grid grid-cols-4 gap-2.5">
        {OS_LOGOS.map((os) => (
          <div class="rounded-[10px] border border-white/[0.07] bg-white/[0.03] px-2 py-3.5 text-center">
            <div class="mx-auto mb-2 flex h-9 w-9 items-center justify-center rounded-[10px]" style={`background:${os.color}18`}>
              <span class="font-display text-[11px] font-bold" style={`color:${os.color}`}>{os.name[0]}</span>
            </div>
            <div class="font-body text-[10px] leading-tight text-slate-500">{os.name}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PLANS -->
  <section class="bg-[#060B18] px-6 py-[72px]">
    <div class="mx-auto max-w-[1160px]">
      <header class="an mb-10">
        <p class="mb-3.5 font-body text-[11px] font-bold uppercase tracking-[2.5px] text-[#3B82F6]">{T.plansTag}</p>
        <h2 class="mb-1.5 font-display text-[clamp(1.8rem,3vw,2.5rem)] font-bold tracking-tight text-white">{T.plansH}</h2>
        <p class="font-body text-sm text-slate-500">{T.plansSub}</p>
      </header>
      <div class="mb-8 grid grid-cols-1 gap-3.5 md:grid-cols-3">
        {PLANS.map((plan, i) => (
          <article class={`an d${i + 1} relative flex flex-col rounded-2xl p-6`} style={plan.popular ? 'background:rgba(59,130,246,.07);border:1px solid rgba(59,130,246,.35)' : 'background:rgba(255,255,255,.025);border:1px solid rgba(255,255,255,.07)'}>
            {plan.popular && <div class="absolute right-4 top-4 rounded-full bg-[#3B82F6] px-2.5 py-0.5 font-display text-[11px] font-bold text-white">{T.popular}</div>}
            <div class="mb-1.5 font-display text-base font-bold text-white">{plan.name}</div>
            <div class="mb-4 font-body text-xs text-slate-500">{plan.tagline}</div>
            <div class="mb-5 flex items-baseline gap-1">
              <span class="font-display text-[38px] font-bold tracking-tight text-white">{plan.price}</span>
              <span class="font-body text-[13px] text-slate-600">{plan.period}</span>
            </div>
            <a href={plan.href} target="_blank" rel="noopener noreferrer" class="mb-[22px] block rounded-lg py-2.5 text-center font-display text-sm font-semibold text-white no-underline" style={plan.popular ? 'background:#3B82F6;border:1px solid transparent' : 'background:transparent;border:1px solid rgba(255,255,255,.14)'}>{T.buy}</a>
            <ul class="mt-auto flex list-none flex-col gap-2">
              {plan.feats.map((f) => (
                <li class="flex items-start gap-2 font-body text-xs text-slate-400">
                  <svg viewBox="0 0 16 16" fill="none" stroke="#3B82F6" stroke-width="2" class="mt-0.5 h-[13px] w-[13px] shrink-0"><polyline points="2,8 6,12 14,4"/></svg>
                  {f}
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
      <div class="an flex flex-col items-start gap-6 rounded-2xl border border-[#3B82F6]/[0.18] bg-[#3B82F6]/[0.07] p-7 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <div class="mb-1 font-display text-[17px] font-bold text-white">{T.cta2H}</div>
          <p class="font-body text-[13px] text-slate-500">{T.cta2Sub}</p>
        </div>
        <a href={contactoHref} class="shrink-0 whitespace-nowrap rounded-lg bg-[#3B82F6] px-[22px] py-[11px] font-display text-sm font-semibold text-white no-underline">{T.cta2Btn}</a>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="border-t border-white/[0.04] bg-[#080E1C] px-6 py-[72px]">
    <div class="mx-auto max-w-[1160px]">
      <h2 class="an mb-10 text-center font-display text-[clamp(1.8rem,3vw,2.5rem)] font-bold tracking-tight text-white">{T.featsH}</h2>
      <div class="grid grid-cols-1 gap-3.5 sm:grid-cols-2 lg:grid-cols-4">
        {FEATURES.map((f, i) => (
          <div class={`an d${(i % 4) + 1} rounded-2xl border border-white/[0.07] bg-white/[0.025] p-5`}>
            <div class="mb-3.5 flex h-11 w-11 items-center justify-center rounded-xl bg-[#3B82F6]/10">
              <svg viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="1.8" class="h-[22px] w-[22px]" set:html={ICONS[f.icon]}></svg>
            </div>
            <div class="mb-2 font-display text-sm font-semibold text-white">{f.t}</div>
            <p class="font-body text-xs leading-relaxed text-slate-500">{f.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- MIGRATION + DDOS -->
  <section class="bg-[#080E1C] px-6 pb-[72px]">
    <div class="mx-auto grid max-w-[1160px] grid-cols-1 gap-3.5 md:grid-cols-2">
      {[{ icon: 'mgr', h: T.migrateH, d: T.migrateD }, { icon: 'ddos', h: T.ddosH, d: T.ddosD }].map((item, i) => (
        <div class={`an d${i + 1} flex items-start gap-5 rounded-2xl border border-white/[0.07] bg-white/[0.025] p-8`}>
          <div class="flex h-[52px] w-[52px] shrink-0 items-center justify-center rounded-2xl bg-[#3B82F6]/10">
            <svg viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="1.8" class="h-[22px] w-[22px]" set:html={ICONS[item.icon]}></svg>
          </div>
          <div>
            <div class="mb-2.5 font-display text-lg font-bold text-white">{item.h}</div>
            <p class="font-body text-[13px] leading-[1.65] text-slate-500">{item.d}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-white/[0.04] bg-[#060B18] px-6 pb-24">
    <div class="mx-auto max-w-[760px] pt-[72px]">
      <h2 class="an mb-10 text-center font-display text-[clamp(1.8rem,3vw,2.5rem)] font-bold tracking-tight text-white">{T.faqH}</h2>
      <div class="flex flex-col gap-2">
        {FAQ.map((item) => (
          <div class="host-faq-item overflow-hidden rounded-xl border border-white/[0.07] bg-white/[0.025]">
            <button type="button" class="host-faq-btn flex w-full items-center justify-between gap-4 border-none bg-transparent px-5 py-[18px] text-left">
              <span class="font-display text-sm font-semibold text-white">{item.q}</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="#4A6A88" stroke-width="2" class="host-faq-chevron h-4 w-4 shrink-0 transition-transform"><path d="m6 9 6 6 6-6"/></svg>
            </button>
            <div class="host-faq-answer hidden border-t border-white/[0.05] px-5 pb-[18px] pt-3 font-body text-[13px] leading-[1.7] text-slate-500">{item.a}</div>
          </div>
        ))}
      </div>
    </div>
  </section>
</main>

<script>
  document.querySelectorAll('.host-faq-item').forEach((item) => {
    const btn = item.querySelector('.host-faq-btn');
    const answer = item.querySelector('.host-faq-answer');
    const chevron = item.querySelector('.host-faq-chevron') as HTMLElement | null;
    btn?.addEventListener('click', () => {
      const isOpen = !answer?.classList.contains('hidden');
      answer?.classList.toggle('hidden', isOpen);
      if (chevron) chevron.style.transform = isOpen ? 'none' : 'rotate(180deg)';
    });
  });
</script>
