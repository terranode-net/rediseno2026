---
interface Props { locale: 'es' | 'en'; plans?: any[] }
const { locale, plans } = Astro.props;
const es = locale === 'es';
const contactoHref = `/${locale}/${es ? 'contacto' : 'contact'}`;
const BL = '#3B82F6';

const PLANS = (plans && plans.length) ? plans : es ? [
  { id: 'essentials', popular: false, name: 'TerraMail Essentials', price: '$24.99', period: '/año', monthly: '≈ $2.08/mes', tagline: 'Ideal para freelancers y proyectos personales', href: 'https://my.terranode.net/store/business-hosting', feats: ['Buzón de 10 GB', 'Webmail moderno (Terramail Suite)', 'Sincronización móvil (ActiveSync)', 'Acceso POP3 / IMAP / SMTP', 'Antivirus en tiempo real', 'Antispam avanzado', 'SSL/TLS cifrado', 'Soporte 24/7'] },
  { id: 'pro', popular: true, name: 'TerraMail Pro', price: '$69.99', period: '/año', monthly: '≈ $5.83/mes', tagline: 'Para profesionales y equipos en crecimiento', href: 'https://my.terranode.net/store/business-hosting', feats: ['Buzón de 30 GB', 'Webmail moderno (Terramail Suite)', 'Sincronización móvil (ActiveSync)', 'Acceso POP3 / IMAP / SMTP', 'Antivirus en tiempo real', 'Antispam avanzado', 'SSL/TLS cifrado', 'Calendario y contactos compartidos', 'Soporte prioritario 24/7'] },
  { id: 'enterprise', popular: false, name: 'TerraMail Enterprise', price: 'Custom', period: '', monthly: 'Contacta al equipo de ventas', tagline: 'Para empresas con volumen alto de buzones', href: contactoHref, feats: ['Buzones ilimitados', 'Almacenamiento a medida', 'Dominios múltiples', 'ActiveSync para todos los dispositivos', 'Antivirus y antispam enterprise', 'SLA garantizado', 'Migración gratuita', 'Gestor de cuenta dedicado'] },
] : [
  { id: 'essentials', popular: false, name: 'TerraMail Essentials', price: '$24.99', period: '/yr', monthly: '≈ $2.08/mo', tagline: 'Ideal for freelancers and personal projects', href: 'https://my.terranode.net/store/business-hosting', feats: ['10 GB mailbox', 'Modern webmail (Terramail Suite)', 'Mobile sync (ActiveSync)', 'POP3 / IMAP / SMTP access', 'Real-time antivirus', 'Advanced antispam', 'SSL/TLS encryption', '24/7 Support'] },
  { id: 'pro', popular: true, name: 'TerraMail Pro', price: '$69.99', period: '/yr', monthly: '≈ $5.83/mo', tagline: 'For professionals and growing teams', href: 'https://my.terranode.net/store/business-hosting', feats: ['30 GB mailbox', 'Modern webmail (Terramail Suite)', 'Mobile sync (ActiveSync)', 'POP3 / IMAP / SMTP access', 'Real-time antivirus', 'Advanced antispam', 'SSL/TLS encryption', 'Shared calendar and contacts', '24/7 priority support'] },
  { id: 'enterprise', popular: false, name: 'TerraMail Enterprise', price: 'Custom', period: '', monthly: 'Contact sales team', tagline: 'For businesses with high mailbox volume', href: contactoHref, feats: ['Unlimited mailboxes', 'Custom storage', 'Multiple domains', 'ActiveSync for all devices', 'Enterprise antivirus & antispam', 'Guaranteed SLA', 'Free migration', 'Dedicated account manager'] },
];

const FEATS = es ? [
  { icon: 'mail', t: 'Correo con tu dominio', d: 'Usa tu propio dominio (@tuempresa.com) y proyecta una imagen 100% profesional ante tus clientes.' },
  { icon: 'shield', t: 'Antispam + Antivirus', d: 'Filtrado multicapa en tiempo real. Bloquea spam, phishing y adjuntos maliciosos antes de que lleguen a tu bandeja.' },
  { icon: 'mobile', t: 'Sincronización móvil', d: 'ActiveSync para iOS y Android. Tus correos, calendario y contactos siempre actualizados en todos tus dispositivos.' },
  { icon: 'webmail', t: 'Webmail Terramail Suite', d: 'Accede a tu correo desde cualquier navegador con una interfaz moderna, rápida y fácil de usar.' },
  { icon: 'ssl', t: 'Cifrado SSL/TLS', d: 'Todas las comunicaciones viajan cifradas. Tus datos y los de tus clientes siempre protegidos.' },
  { icon: 'cloud', t: 'Infraestructura en la nube', d: 'Alojado en nuestra infraestructura redundante con backups automáticos cada 24 horas.' },
  { icon: 'mgr', t: 'Migración gratuita', d: 'Migración de correos, contactos y calendarios desde cualquier proveedor sin tiempo de inactividad.' },
  { icon: 'sup', t: 'Soporte 24/7', d: 'Equipo técnico disponible por WhatsApp, ticket y chat. Respuesta en menos de 1 hora.' },
] : [
  { icon: 'mail', t: 'Email on your domain', d: 'Use your own domain (@yourcompany.com) and project a 100% professional image to your clients.' },
  { icon: 'shield', t: 'Antispam + Antivirus', d: 'Real-time multi-layer filtering. Blocks spam, phishing and malicious attachments before they reach your inbox.' },
  { icon: 'mobile', t: 'Mobile sync', d: 'ActiveSync for iOS and Android. Your email, calendar and contacts always up to date on every device.' },
  { icon: 'webmail', t: 'Terramail Suite Webmail', d: 'Access your email from any browser with a modern, fast, easy-to-use interface.' },
  { icon: 'ssl', t: 'SSL/TLS encryption', d: 'All communications travel encrypted. Your data and your clients\u2019 data always protected.' },
  { icon: 'cloud', t: 'Cloud infrastructure', d: 'Hosted on our redundant infrastructure with automatic backups every 24 hours.' },
  { icon: 'mgr', t: 'Free migration', d: 'Email, contacts and calendar migration from any provider with zero downtime.' },
  { icon: 'sup', t: '24/7 Support', d: 'Technical team available via WhatsApp, ticket and chat. Response in under 1 hour.' },
];

const FAQ = es ? [
  { q: '¿Puedo usar mi dominio existente con TerraMail?', a: 'Sí. Solo necesitas apuntar los registros MX de tu dominio a nuestros servidores. Nuestro equipo te guía en el proceso sin costo adicional.' },
  { q: '¿Cuántos buzones puedo crear en cada plan?', a: 'Los planes Essentials y Pro incluyen un buzón cada uno. El plan Enterprise incluye buzones ilimitados.' },
  { q: '¿Qué es el Webmail Terramail Suite?', a: 'Una plataforma moderna de correo web con interfaz similar a Outlook: gestiona correos, calendario, contactos y tareas desde cualquier navegador.' },
  { q: '¿Pueden migrar mis correos desde Gmail o Outlook?', a: 'Sí. Realizamos migraciones completas desde Gmail, Outlook.com, cPanel mail, Zoho y otros proveedores sin interrumpir tu operación.' },
  { q: '¿El correo incluye protección contra ataques de phishing?', a: 'Sí. Nuestro sistema antispam avanzado filtra intentos de phishing y adjuntos maliciosos antes de que lleguen a tu bandeja.' },
  { q: '¿Puedo acceder desde mi teléfono?', a: 'Sí. TerraMail es compatible con ActiveSync, configurable en iOS, Android, Outlook y cualquier cliente de correo estándar.' },
] : [
  { q: 'Can I use my existing domain with TerraMail?', a: 'Yes. You just need to point your domain\u2019s MX records to our servers. Our team guides you through it at no extra cost.' },
  { q: 'How many mailboxes can I create per plan?', a: 'Essentials and Pro plans include one mailbox each. The Enterprise plan includes unlimited mailboxes.' },
  { q: 'What is Terramail Suite Webmail?', a: 'A modern webmail platform with an Outlook-like interface: manage email, calendar, contacts and tasks from any browser.' },
  { q: 'Can you migrate my email from Gmail or Outlook?', a: 'Yes. We perform full migrations from Gmail, Outlook.com, cPanel mail, Zoho and other providers without interrupting your operation.' },
  { q: 'Does email include phishing protection?', a: 'Yes. Our advanced antispam system filters phishing attempts and malicious attachments before they reach your inbox.' },
  { q: 'Can I access it from my phone?', a: 'Yes. TerraMail supports ActiveSync, configurable on iOS, Android, Outlook and any standard mail client.' },
];

const APPS = [
  { name: 'Webmail OX', color: '#F97316' },
  { name: 'iOS Mail', color: '#3B82F6' },
  { name: 'Android Mail', color: '#22C55E' },
  { name: 'Outlook', color: '#0078D4' },
  { name: 'Thunderbird', color: '#FF6611' },
  { name: 'Apple Mail', color: '#6366F1' },
];

const ICONS: Record<string, string> = {
  mail: '<rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 7 10-7"/>',
  shield: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4" stroke-linecap="round" stroke-linejoin="round"/>',
  mobile: '<rect x="5" y="2" width="14" height="20" rx="2"/><path d="M12 18h.01" stroke-linecap="round" stroke-width="2.5"/>',
  webmail: '<rect x="3" y="3" width="18" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>',
  ssl: '<rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>',
  cloud: '<path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9z"/>',
  mgr: '<path d="M5 12H19M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>',
  sup: '<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>',
};

const T = {
  badge: 'TerraMail',
  h1: es ? 'Correo Corporativo y' : 'Corporate & Business',
  h1b: es ? 'Empresarial Profesional' : 'Email, Done Right',
  sub: es ? 'Correo electrónico corporativo y empresarial con tu propio dominio (@tuempresa.com): antispam avanzado, webmail moderno, sincronización móvil y soporte técnico 24/7. Desde $24.99/año.' : 'Corporate and business email on your own domain (@yourcompany.com): advanced antispam, modern webmail, mobile sync and 24/7 technical support. From $24.99/year.',
  introH: es ? '¿Por qué contratar correo corporativo con Terranode?' : 'Why get corporate email with Terranode?',
  introBody: es
    ? 'Un correo corporativo (o correo empresarial) es la cuenta de email que usa el nombre de dominio de tu empresa — por ejemplo, ventas@tuempresa.com — en vez de un dominio genérico como Gmail o Hotmail. Además de proyectar una imagen profesional frente a tus clientes y proveedores, TerraMail te da control total sobre tus buzones, mayor seguridad con antispam y antivirus multicapa, y soporte técnico en español disponible 24/7. Es la opción ideal para pymes, agencias, profesionales independientes y empresas que ya usan un dominio propio para su sitio web y quieren que su correo tenga la misma identidad. Configura TerraMail en minutos apuntando los registros MX de tu dominio, con migración gratuita desde Gmail, Outlook o cualquier otro proveedor sin perder tus correos, contactos ni calendario.'
    : 'Corporate email (or business email) is an email account that uses your company\u2019s own domain name — for example, sales@yourcompany.com — instead of a generic domain like Gmail or Hotmail. Beyond projecting a professional image to your clients and vendors, TerraMail gives you full control over your mailboxes, stronger security with multi-layer antispam and antivirus, and 24/7 technical support. It\u2019s the ideal choice for small businesses, agencies, independent professionals and companies that already use their own domain for their website and want their email to match. Set up TerraMail in minutes by pointing your domain\u2019s MX records, with free migration from Gmail, Outlook or any other provider without losing your emails, contacts or calendar.',
  cta1: es ? 'Ver planes' : 'View plans',
  cta2: es ? 'Hablar con ventas' : 'Talk to sales',
  plansTag: es ? 'PRECIOS' : 'PRICING',
  plansH: es ? 'Elige tu plan TerraMail' : 'Choose your TerraMail plan',
  plansSub: es ? 'Todos los planes incluyen antispam, SSL y webmail moderno' : 'All plans include antispam, SSL and modern webmail',
  buy: es ? 'Contratar' : 'Get started',
  quote: es ? 'Solicitar cotización' : 'Request quote',
  popular: es ? 'Popular' : 'Popular',
  featsH: es ? 'Todo lo que necesita tu correo empresarial' : 'Everything your business email needs',
  appsH: es ? 'Compatible con todos tus dispositivos y clientes' : 'Compatible with all your devices and mail clients',
  compH: es ? '¿Por qué TerraMail en lugar de Gmail gratuito?' : 'Why TerraMail instead of free Gmail?',
  faqH: es ? 'Preguntas frecuentes' : 'Frequently asked questions',
  ctaH: es ? '¿Listo para comunicarte como un profesional?' : 'Ready to communicate like a professional?',
  ctaSub: es ? 'Tu correo con dominio propio, antispam y soporte local. Configúralo hoy.' : 'Your email with custom domain, antispam and local support. Set it up today.',
  ctaBtn: es ? 'Ver planes TerraMail' : 'View TerraMail plans',
};

const COMPARE = es ? [
  { feat: 'Dominio propio (@tuempresa.com)', tm: true, gm: false },
  { feat: 'Antispam empresarial avanzado', tm: true, gm: 'Básico' },
  { feat: 'Soporte técnico en español 24/7', tm: true, gm: false },
  { feat: 'Migración gratuita incluida', tm: true, gm: false },
  { feat: 'Sin publicidad', tm: true, gm: false },
  { feat: 'Alojamiento en datacenters propios', tm: true, gm: false },
  { feat: 'SLA de disponibilidad', tm: true, gm: false },
] : [
  { feat: 'Custom domain (@yourcompany.com)', tm: true, gm: false },
  { feat: 'Enterprise advanced antispam', tm: true, gm: 'Basic' },
  { feat: '24/7 Spanish tech support', tm: true, gm: false },
  { feat: 'Free migration included', tm: true, gm: false },
  { feat: 'Ad-free', tm: true, gm: false },
  { feat: 'Hosted on own datacenters', tm: true, gm: false },
  { feat: 'Uptime SLA', tm: true, gm: false },
];
---
<main style="padding-top:66px;background:#080E1C;min-height:100vh">
  <!-- HERO -->
  <section class="relative overflow-hidden border-b border-white/[0.04] px-6 py-16 md:py-[72px]">
    <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse 55% 65% at 50% 30%,rgba(37,99,235,.12),transparent 70%)"></div>
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(59,130,246,.035) 1px,transparent 1px),linear-gradient(90deg,rgba(59,130,246,.035) 1px,transparent 1px);background-size:50px 50px"></div>
    <div class="relative z-[2] mx-auto grid max-w-[1160px] grid-cols-1 items-center gap-10 md:grid-cols-[1.1fr_1fr] md:gap-[60px]">
      <div>
        <div class="mb-5 flex items-center gap-2.5">
          <span class="inline-flex items-center gap-2 rounded-full border border-[#3B82F6]/20 bg-[#3B82F6]/[0.08] px-3.5 py-[5px] font-body text-[11px] font-bold uppercase tracking-[2.5px] text-[#3B82F6]">
            <svg viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="1.8" class="h-[15px] w-[15px]"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 7 10-7"/></svg>
            {T.badge}
          </span>
        </div>
        <h1 class="mb-[22px] font-display text-[clamp(2.2rem,4vw,3.6rem)] font-bold leading-[1.05] tracking-tight text-white">
          {T.h1}<br /><span class="text-slate-600">{T.h1b}</span>
        </h1>
        <p class="mb-8 max-w-[460px] font-body text-base leading-[1.7] text-slate-400">{T.sub}</p>
        <div class="flex flex-wrap gap-3">
          <a href="#planes" class="rounded-lg border-none bg-[#3B82F6] px-6 py-3 font-display text-[15px] font-semibold text-white no-underline shadow-[0_0_24px_rgba(59,130,246,.3)] transition-colors hover:bg-[#2563EB]">{T.cta1}</a>
          <a href={contactoHref} class="rounded-lg border border-white/[0.15] bg-transparent px-6 py-3 font-display text-[15px] font-semibold text-slate-300 no-underline transition-colors hover:text-white">{T.cta2}</a>
        </div>
      </div>

      <!-- Email preview card -->
      <div class="overflow-hidden rounded-2xl border border-white/[0.08] bg-white/[0.03]">
        <div class="flex items-center gap-2.5 border-b border-white/[0.06] bg-[#3B82F6]/[0.08] px-4 py-3">
          <div class="flex gap-1.5">
            {['#FF5F56', '#FFBD2E', '#27C93F'].map((c) => <div class="h-2.5 w-2.5 rounded-full" style={`background:${c}`}></div>)}
          </div>
          <div class="flex-1 rounded-md bg-white/[0.06] px-3 py-1 text-center font-body text-[11px] text-slate-600">webmail.tuempresa.com</div>
        </div>
        <div class="grid grid-cols-[110px_1fr]">
          <div class="border-r border-white/[0.05] bg-black/20 py-3">
            {[{ label: es ? 'Bandeja' : 'Inbox', count: 3, active: true }, { label: es ? 'Enviados' : 'Sent', count: 0, active: false }, { label: 'Spam', count: 0, active: false }, { label: es ? 'Borradores' : 'Drafts', count: 1, active: false }].map((item) => (
              <div class="flex items-center justify-between px-3 py-1.5" style={item.active ? `background:rgba(59,130,246,.15);border-left:2px solid ${BL}` : 'border-left:2px solid transparent'}>
                <span class="font-body text-[11px]" style={item.active ? 'color:#60A5FA' : 'color:#3A5A7A'}>{item.label}</span>
                {item.count > 0 && <span class="rounded-full px-[5px] font-display text-[10px] font-bold leading-4 text-white" style={`background:${BL}`}>{item.count}</span>}
              </div>
            ))}
          </div>
          <div>
            {[{ from: 'cliente@empresa.com', subj: es ? 'Propuesta de colaboración' : 'Collaboration proposal', time: '09:14', unread: true }, { from: 'info@proveedor.net', subj: es ? 'Factura #2025-089' : 'Invoice #2025-089', time: '08:30', unread: true }, { from: 'noreply@banco.com', subj: es ? 'Confirmación de pago' : 'Payment confirmation', time: es ? 'Ayer' : 'Yesterday', unread: false }].map((email, i) => (
              <div class="flex items-start gap-2.5 border-b border-white/[0.04] px-3.5 py-2.5" style={email.unread ? 'background:rgba(59,130,246,.04)' : ''}>
                <div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full font-display text-[11px] font-bold text-white" style={`background:hsl(${i * 60 + 200},50%,30%)`}>{email.from[0].toUpperCase()}</div>
                <div class="min-w-0 flex-1">
                  <div class="flex justify-between gap-2">
                    <span class="truncate font-body text-[11px]" style={email.unread ? 'color:#CBD5E1;font-weight:700' : 'color:#4A6A88'}>{email.from}</span>
                    <span class="shrink-0 font-body text-[10px] text-slate-600">{email.time}</span>
                  </div>
                  <div class="mt-0.5 truncate font-body text-[11px] text-slate-500">{email.subj}</div>
                </div>
                {email.unread && <div class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full" style={`background:${BL}`}></div>}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PLANS -->
  <section id="planes" class="bg-[#060B18] px-6 py-[72px]">
    <div class="mx-auto max-w-[1160px]">
      <header class="an mb-10">
        <p class="mb-3.5 font-body text-[11px] font-bold uppercase tracking-[2.5px] text-[#3B82F6]">{T.plansTag}</p>
        <h2 class="mb-1.5 font-display text-[clamp(1.8rem,3vw,2.5rem)] font-bold tracking-tight text-white">{T.plansH}</h2>
        <p class="font-body text-sm text-slate-500">{T.plansSub}</p>
      </header>
      <div class="grid grid-cols-1 gap-3.5 md:grid-cols-3">
        {PLANS.map((plan, i) => (
          <article class={`an d${i + 1} relative flex flex-col rounded-2xl p-6`} style={plan.popular ? 'background:rgba(59,130,246,.07);border:1px solid rgba(59,130,246,.35)' : 'background:rgba(255,255,255,.025);border:1px solid rgba(255,255,255,.07)'}>
            {plan.popular && <div class="absolute right-4 top-4 rounded-full bg-[#3B82F6] px-2.5 py-0.5 font-display text-[11px] font-bold text-white">{T.popular}</div>}
            <div class="mb-1 font-display text-base font-bold text-white">{plan.name}</div>
            <div class="mb-[18px] font-body text-xs text-slate-500">{plan.tagline}</div>
            <div class="mb-1 flex items-baseline gap-1">
              <span class="font-display font-bold tracking-tight text-white" style={`font-size:${plan.price === 'Custom' ? '26px' : '36px'}`}>{plan.price}</span>
              {plan.period && <span class="font-body text-[13px] text-slate-600">{plan.period}</span>}
            </div>
            <div class="mb-5 font-body text-[11px] text-slate-600">{plan.monthly}</div>
            <a href={plan.href} target={plan.price === 'Custom' ? undefined : '_blank'} rel="noopener noreferrer" class="mb-[22px] block rounded-lg py-2.5 text-center font-display text-sm font-semibold text-white no-underline" style={plan.popular ? 'background:#3B82F6;border:1px solid transparent' : 'background:transparent;border:1px solid rgba(255,255,255,.14)'}>
              {plan.price === 'Custom' ? T.quote : T.buy}
            </a>
            <ul class="mt-auto flex list-none flex-col gap-2">
              {plan.feats.map((f) => (
                <li class="flex items-start gap-2 font-body text-xs text-slate-400">
                  <svg viewBox="0 0 16 16" fill="none" stroke="#3B82F6" stroke-width="2" class="mt-0.5 h-[13px] w-[13px] shrink-0"><polyline points="2,8 6,12 14,4"/></svg>
                  {f}
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="border-t border-white/[0.04] bg-[#080E1C] px-6 py-[72px]">
    <div class="mx-auto max-w-[1160px]">
      <h2 class="an mb-10 text-center font-display text-[clamp(1.8rem,3vw,2.5rem)] font-bold tracking-tight text-white">{T.featsH}</h2>
      <div class="grid grid-cols-1 gap-3.5 sm:grid-cols-2 lg:grid-cols-4">
        {FEATS.map((f, i) => (
          <div class={`an d${(i % 4) + 1} rounded-2xl border border-white/[0.07] bg-white/[0.025] p-5`}>
            <div class="mb-3.5 flex h-11 w-11 items-center justify-center rounded-xl bg-[#3B82F6]/10">
              <svg viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="1.8" class="h-[22px] w-[22px]" set:html={ICONS[f.icon]}></svg>
            </div>
            <div class="mb-2 font-display text-sm font-semibold text-white">{f.t}</div>
            <p class="font-body text-xs leading-relaxed text-slate-500">{f.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- COMPARISON -->
  <section class="bg-[#080E1C] px-6 pb-[72px]">
    <div class="mx-auto max-w-[860px]">
      <h2 class="an mb-10 text-center font-display text-[clamp(1.8rem,3vw,2.5rem)] font-bold tracking-tight text-white">{T.compH}</h2>
      <div class="an overflow-hidden rounded-2xl border border-white/[0.07] bg-white/[0.025]">
        <table class="w-full border-collapse">
          <thead>
            <tr class="border-b border-white/[0.08]">
              <th class="px-5 py-4 text-left font-body text-xs font-bold text-slate-600">{es ? 'Característica' : 'Feature'}</th>
              <th class="px-5 py-4 text-center font-display text-sm font-bold text-[#3B82F6]">TerraMail</th>
              <th class="px-5 py-4 text-center font-display text-sm font-bold text-slate-500">{es ? 'Gmail gratuito' : 'Free Gmail'}</th>
            </tr>
          </thead>
          <tbody>
            {COMPARE.map((row, i) => (
              <tr class="border-b border-white/[0.04]" style={i % 2 === 0 ? 'background:rgba(255,255,255,.01)' : ''}>
                <td class="px-5 py-3.5 font-body text-[13px] text-slate-300">{row.feat}</td>
                <td class="px-5 py-3.5 text-center">
                  {row.tm === true ? <span class="text-base text-[#22C55E]">✓</span> : <span class="font-body text-xs text-[#22C55E]">{row.tm}</span>}
                </td>
                <td class="px-5 py-3.5 text-center">
                  {row.gm === false ? <span class="text-base text-[#EF4444]">✗</span> : <span class="font-body text-xs text-slate-500">{row.gm}</span>}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- COMPATIBLE APPS -->
  <section class="border-t border-white/[0.04] bg-[#060B18] px-6 pb-[72px]">
    <div class="mx-auto max-w-[1160px] pt-[72px]">
      <h2 class="an mb-3 text-center font-display text-[clamp(1.8rem,3vw,2.5rem)] font-bold tracking-tight text-white">{T.appsH}</h2>
      <p class="an mx-auto mb-10 max-w-[540px] text-center font-body text-slate-500">IMAP · POP3 · SMTP · ActiveSync</p>
      <div class="grid grid-cols-3 gap-2.5 sm:grid-cols-6">
        {APPS.map((app, i) => (
          <div class={`an d${(i % 6) + 1} rounded-xl border border-white/[0.07] bg-white/[0.025] px-3 py-5 text-center`}>
            <div class="mx-auto mb-2.5 flex h-11 w-11 items-center justify-center rounded-xl" style={`background:${app.color}18`}>
              <span class="font-display text-base font-bold" style={`color:${app.color}`}>{app.name[0]}</span>
            </div>
            <div class="font-body text-[11px] leading-tight text-slate-500">{app.name}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Intro / contenido SEO -->
  <section class="border-t border-white/[0.04] bg-[#080E1C] px-6 py-16">
    <div class="mx-auto max-w-[820px]">
      <h2 class="mb-4 font-display text-[clamp(1.5rem,2.6vw,2rem)] font-bold tracking-tight text-white">{T.introH}</h2>
      <p class="font-body text-[15px] leading-[1.8] text-slate-400">{T.introBody}</p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-[#060B18] px-6 pb-[72px]">
    <div class="mx-auto max-w-[760px]">
      <h2 class="an mb-10 text-center font-display text-[clamp(1.8rem,3vw,2.5rem)] font-bold tracking-tight text-white">{T.faqH}</h2>
      <div class="flex flex-col gap-2">
        {FAQ.map((item) => (
          <div class="mail-faq-item overflow-hidden rounded-xl border border-white/[0.07] bg-white/[0.025]">
            <button type="button" class="mail-faq-btn flex w-full items-center justify-between gap-4 border-none bg-transparent px-5 py-[18px] text-left">
              <span class="font-display text-sm font-semibold text-white">{item.q}</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="#4A6A88" stroke-width="2" class="mail-faq-chevron h-4 w-4 shrink-0 transition-transform"><path d="m6 9 6 6 6-6"/></svg>
            </button>
            <div class="mail-faq-answer hidden border-t border-white/[0.05] px-5 pb-[18px] pt-3 font-body text-[13px] leading-[1.7] text-slate-500">{item.a}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="bg-[#060B18] px-6 pb-24">
    <div class="mx-auto max-w-[1160px]">
      <div class="an relative overflow-hidden rounded-2xl border border-[#3B82F6]/20 p-8 text-center md:p-[52px]" style="background:linear-gradient(135deg,rgba(59,130,246,.1),rgba(37,99,235,.05))">
        <div class="pointer-events-none absolute inset-0" style="background-image:radial-gradient(circle at 50% 50%,rgba(59,130,246,.08),transparent 70%)"></div>
        <div class="relative z-[2]">
          <h2 class="mb-3 font-display text-[clamp(1.6rem,3vw,2.4rem)] font-bold tracking-tight text-white">{T.ctaH}</h2>
          <p class="mx-auto mb-8 max-w-[480px] font-body text-[15px] text-slate-400">{T.ctaSub}</p>
          <div class="flex flex-wrap justify-center gap-3">
            <a href="#planes" class="rounded-lg bg-[#3B82F6] px-7 py-[13px] font-display text-[15px] font-semibold text-white no-underline shadow-[0_0_28px_rgba(59,130,246,.35)]">{T.ctaBtn}</a>
            <a href={contactoHref} class="rounded-lg border border-white/20 bg-transparent px-7 py-[13px] font-display text-[15px] font-semibold text-slate-300 no-underline">{T.cta2}</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</main>

<script>
  document.querySelectorAll('.mail-faq-item').forEach((item) => {
    const btn = item.querySelector('.mail-faq-btn');
    const answer = item.querySelector('.mail-faq-answer');
    const chevron = item.querySelector('.mail-faq-chevron') as HTMLElement | null;
    btn?.addEventListener('click', () => {
      const isOpen = !answer?.classList.contains('hidden');
      answer?.classList.toggle('hidden', isOpen);
      if (chevron) chevron.style.transform = isOpen ? 'none' : 'rotate(180deg)';
    });
  });
</script>
