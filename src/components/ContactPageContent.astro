---
import { ORG } from '@/lib/site';

interface Props {
  locale: 'es' | 'en';
}
const { locale } = Astro.props;

const T = {
  es: {
    eyebrow: 'Contáctanos',
    h1: 'Escríbenos hoy mismo',
    h1b: 'y comencemos a construir algo increíble juntos',
    sub: 'Descubre una experiencia única donde la innovación y la calidad se unen para brindarte soluciones excepcionales.',
    channels: [
      { icon: 'wa', title: 'Soporte técnico', desc: 'Soporte 24/7 directo por WhatsApp. Respuesta en menos de 1 hora.', cta: 'Abrir WhatsApp', href: ORG.whatsappSupport, color: '#22C55E' },
      { icon: 'wa', title: 'Equipo de ventas', desc: '¿Tienes dudas sobre nuestros planes? Habla con un asesor comercial.', cta: 'Contactar ventas', href: ORG.whatsappSales, color: '#3B82F6' },
      { icon: 'mail', title: 'Correo electrónico', desc: 'Para consultas formales, cotizaciones y solicitudes corporativas.', cta: 'Enviar correo', href: `mailto:${ORG.email}`, color: '#8B5CF6' },
      { icon: 'ticket', title: 'Abrir ticket', desc: 'Crea un ticket en el panel de clientes para soporte técnico detallado.', cta: 'Crear ticket', href: ORG.ticketUrl, color: '#F59E0B' },
      { icon: 'disc', title: 'Discord', desc: 'Únete a nuestra comunidad. Chat en vivo con el equipo y la comunidad.', cta: 'Entrar al servidor', href: ORG.discord, color: '#7C3AED' },
      { icon: 'panel', title: 'Panel de cliente', desc: 'Administra tus servicios, facturas y soporte desde el área de cliente.', cta: 'Ir al panel', href: ORG.clientPortal, color: '#06B6D4' },
    ],
    formH: '¿Cómo podemos ayudarte?',
    formSub: 'Explícanos tu visión y hagámosla realidad juntos.',
    fields: { name: 'Nombre completo', email: 'Correo electrónico', phone: 'Teléfono (opcional)', subject: 'Asunto', message: 'Mensaje', send: 'Enviar mensaje', sending: 'Enviando...', ok: '¡Mensaje enviado! Te responderemos en menos de 24 horas.', placeholder_msg: 'Cuéntanos en qué podemos ayudarte...', err: 'Hubo un problema al enviar tu mensaje. Escríbenos directamente a' },
    subjects: ['Consulta general', 'Presupuesto / Cotización', 'Soporte técnico', 'Migración de servicios', 'Microsoft 365', 'Desarrollo web', 'Otro'],
    infoH: 'Información de contacto',
    info: [
      { icon: 'phone', label: 'Teléfono / WhatsApp', val: ORG.phone, href: ORG.phoneHref },
      { icon: 'mail', label: 'Email', val: ORG.email, href: `mailto:${ORG.email}` },
      { icon: 'clock', label: 'Horario de soporte', val: '24 horas · 7 días a la semana', href: null },
      { icon: 'pin', label: 'Ubicación', val: 'Guayaquil, Ecuador', href: null },
    ],
    slaH: 'Tiempos de respuesta',
    sla: [
      { tier: 'Crítico', time: '< 15 min', desc: 'Caídas de servicio o pérdida total de acceso' },
      { tier: 'Alto', time: '< 1 hora', desc: 'Problemas que afectan el funcionamiento del servicio' },
      { tier: 'Normal', time: '< 4 horas', desc: 'Preguntas técnicas y consultas de configuración' },
      { tier: 'General', time: '< 24 horas', desc: 'Cotizaciones, migraciones e información comercial' },
    ],
  },
  en: {
    eyebrow: 'Contact us',
    h1: 'Write to us today',
    h1b: "and let's start building something incredible together",
    sub: 'Discover a unique experience where innovation and quality come together to provide you with exceptional solutions.',
    channels: [
      { icon: 'wa', title: 'Technical support', desc: '24/7 direct support via WhatsApp. Response in less than 1 hour.', cta: 'Open WhatsApp', href: ORG.whatsappSupport, color: '#22C55E' },
      { icon: 'wa', title: 'Sales team', desc: 'Have questions about our plans? Talk to a sales advisor.', cta: 'Contact sales', href: ORG.whatsappSales, color: '#3B82F6' },
      { icon: 'mail', title: 'Email', desc: 'For formal inquiries, quotes and corporate requests.', cta: 'Send email', href: `mailto:${ORG.email}`, color: '#8B5CF6' },
      { icon: 'ticket', title: 'Open ticket', desc: 'Create a ticket in the client panel for detailed technical support.', cta: 'Create ticket', href: ORG.ticketUrl, color: '#F59E0B' },
      { icon: 'disc', title: 'Discord', desc: 'Join our community. Live chat with the team and community.', cta: 'Join server', href: ORG.discord, color: '#7C3AED' },
      { icon: 'panel', title: 'Client panel', desc: 'Manage your services, invoices and support from the client area.', cta: 'Go to panel', href: ORG.clientPortal, color: '#06B6D4' },
    ],
    formH: 'How can we help you?',
    formSub: "Tell us your vision and let's make it a reality together.",
    fields: { name: 'Full name', email: 'Email address', phone: 'Phone (optional)', subject: 'Subject', message: 'Message', send: 'Send message', sending: 'Sending...', ok: 'Message sent! We will respond within 24 hours.', placeholder_msg: 'Tell us how we can help you...', err: 'There was a problem sending your message. Email us directly at' },
    subjects: ['General inquiry', 'Quote / Estimate', 'Technical support', 'Service migration', 'Microsoft 365', 'Web development', 'Other'],
    infoH: 'Contact information',
    info: [
      { icon: 'phone', label: 'Phone / WhatsApp', val: ORG.phone, href: ORG.phoneHref },
      { icon: 'mail', label: 'Email', val: ORG.email, href: `mailto:${ORG.email}` },
      { icon: 'clock', label: 'Support hours', val: '24 hours · 7 days a week', href: null },
      { icon: 'pin', label: 'Location', val: 'Guayaquil, Ecuador', href: null },
    ],
    slaH: 'Response times',
    sla: [
      { tier: 'Critical', time: '< 15 min', desc: 'Service outages or total loss of access' },
      { tier: 'High', time: '< 1 hour', desc: 'Issues affecting service functionality' },
      { tier: 'Normal', time: '< 4 hours', desc: 'Technical questions and configuration inquiries' },
      { tier: 'General', time: '< 24 hours', desc: 'Quotes, migrations and commercial information' },
    ],
  },
}[locale];

const CHANNEL_ICONS: Record<string, string> = {
  wa: '<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>',
  mail: '<rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 7 10-7"/>',
  ticket: '<path d="M2 9a3 3 0 0 1 0 6v2a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-2a3 3 0 0 1 0-6V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2z"/><path d="M13 5v2M13 17v2M13 11v2" stroke-linecap="round"/>',
  disc: '<path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>',
  panel: '<rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/>',
};

const INFO_ICONS: Record<string, string> = {
  phone: '<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.62 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l.83-.83a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 17z"/>',
  mail: '<rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 7 10-7"/>',
  clock: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14" stroke-linecap="round"/>',
  pin: '<path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/>',
};

const slaColors = ['#EF4444', '#F59E0B', '#3B82F6', '#22C55E'];
---
<main class="bg-[#080E1C]">
  <!-- HERO -->
  <section class="relative overflow-hidden px-6 pb-16 pt-20 md:pt-28">
    <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse 55% 55% at 50% 40%,rgba(45,18,237,.16),transparent 70%)"></div>
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(45,18,237,.05) 1px,transparent 1px),linear-gradient(90deg,rgba(45,18,237,.05) 1px,transparent 1px);background-size:50px 50px"></div>
    <div class="relative z-10 mx-auto max-w-2xl text-center">
      <span class="mb-5 inline-block rounded-full border border-accent/25 bg-accent/10 px-4 py-1.5 font-body text-[11px] font-bold uppercase tracking-[2.5px] text-[#7C6CFB]">
        {T.eyebrow}
      </span>
      <h1 class="font-display text-[clamp(2rem,4.5vw,3.5rem)] font-bold leading-[1.08] tracking-tight text-white">{T.h1}</h1>
      <h2 class="mt-1 font-display text-[clamp(2rem,4.5vw,3.5rem)] font-bold leading-[1.08] tracking-tight text-slate-600">{T.h1b}</h2>
      <p class="mx-auto mt-5 max-w-md font-body text-[15px] leading-relaxed text-slate-400">{T.sub}</p>
    </div>
  </section>

  <!-- CHANNEL CARDS -->
  <section class="px-6 pb-16">
    <div class="mx-auto max-w-[1160px] grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {T.channels.map((ch) => (
        <a href={ch.href} target="_blank" rel="noopener noreferrer" class="flex items-start gap-4 rounded-[14px] border border-white/[0.07] bg-white/[0.025] p-[22px] no-underline transition-colors hover:border-white/[0.15]">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl" style={`background:${ch.color}18`}>
            <svg viewBox="0 0 24 24" fill={ch.icon === 'wa' || ch.icon === 'disc' ? ch.color : 'none'} stroke={ch.icon === 'wa' || ch.icon === 'disc' ? 'none' : ch.color} stroke-width="1.8" class="h-[22px] w-[22px]" set:html={CHANNEL_ICONS[ch.icon]}></svg>
          </div>
          <div class="min-w-0 flex-1">
            <div class="mb-1 font-display text-[15px] font-semibold text-white">{ch.title}</div>
            <p class="mb-3 font-body text-xs leading-[1.55] text-slate-500">{ch.desc}</p>
            <span class="flex items-center gap-1.5 font-body text-xs font-bold" style={`color:${ch.color}`}>
              {ch.cta}
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" class="h-[11px] w-[11px]"><path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round"/></svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- FORM + INFO -->
  <section class="border-t border-white/[0.04] bg-[#060B18] px-6 pb-24 pt-16">
    <div class="mx-auto grid max-w-[1160px] gap-12 lg:grid-cols-[1.4fr_1fr]">
      <!-- Form -->
      <div>
        <p class="mb-3 font-body text-[11px] font-bold uppercase tracking-[2.5px] text-[#7C6CFB]">{T.formH}</p>
        <h2 class="mb-1.5 font-display text-[clamp(1.6rem,2.5vw,2.1rem)] font-bold tracking-tight text-white">{T.formH}</h2>
        <p class="mb-7 font-body text-sm text-slate-400">{T.formSub}</p>

        <form id="tn-contact-form" class="flex flex-col gap-3.5" data-locale={locale}>
          <div class="grid gap-3.5 sm:grid-cols-2">
            <div>
              <label class="mb-1.5 block font-body text-xs text-slate-500">{T.fields.name} *</label>
              <input required name="name" type="text" class="tn-input" />
            </div>
            <div>
              <label class="mb-1.5 block font-body text-xs text-slate-500">{T.fields.email} *</label>
              <input required name="email" type="email" class="tn-input" />
            </div>
          </div>
          <div class="grid gap-3.5 sm:grid-cols-2">
            <div>
              <label class="mb-1.5 block font-body text-xs text-slate-500">{T.fields.phone}</label>
              <input name="phone" type="tel" class="tn-input" />
            </div>
            <div>
              <label class="mb-1.5 block font-body text-xs text-slate-500">{T.fields.subject} *</label>
              <select required name="subject" class="tn-input cursor-pointer appearance-none">
                <option value="" class="bg-[#0C1525]">—</option>
                {T.subjects.map((s) => <option value={s} class="bg-[#0C1525]">{s}</option>)}
              </select>
            </div>
          </div>
          <div>
            <label class="mb-1.5 block font-body text-xs text-slate-500">{T.fields.message} *</label>
            <textarea required name="message" rows="5" placeholder={T.fields.placeholder_msg} class="tn-input resize-y leading-relaxed"></textarea>
          </div>

          <input type="text" name="website" class="hidden" tabindex="-1" autocomplete="off" />

          <button
            type="submit"
            id="tn-submit-btn"
            data-sending={T.fields.sending}
            data-send={T.fields.send}
            class="flex items-center justify-center gap-2 rounded-lg border-none bg-accent px-6 py-[13px] font-display text-[15px] font-semibold text-white shadow-[0_0_24px_rgba(45,18,237,.28)] transition-colors hover:bg-accent-hover disabled:opacity-70"
          >
            <span data-label>{T.fields.send}</span>
          </button>

          <p id="tn-form-error" class="hidden font-body text-sm text-red-400" data-err={T.fields.err} data-email={ORG.email}></p>
        </form>

        <div id="tn-form-success" class="hidden rounded-2xl border border-signal/25 bg-signal/[0.08] p-8 text-center">
          <div class="mx-auto mb-4 flex h-[52px] w-[52px] items-center justify-center rounded-full bg-signal/[0.15]">
            <svg viewBox="0 0 24 24" fill="none" stroke="#3EC821" stroke-width="2.2" class="h-6 w-6"><polyline points="20,6 9,17 4,12" stroke-linecap="round"/></svg>
          </div>
          <p class="font-display text-base font-semibold text-signal">{T.fields.ok}</p>
        </div>
      </div>

      <!-- Info + SLA -->
      <div class="flex flex-col gap-7">
        <div class="rounded-2xl border border-white/[0.07] bg-white/[0.025] p-7">
          <h3 class="mb-5 font-display text-base font-semibold text-white">{T.infoH}</h3>
          <div class="flex flex-col gap-4">
            {T.info.map((item) => (
              <div class="flex items-center gap-3.5">
                <div class="flex h-[38px] w-[38px] shrink-0 items-center justify-center rounded-[10px] bg-accent/10">
                  <svg viewBox="0 0 24 24" fill="none" stroke="#2D12ED" stroke-width="1.8" class="h-[18px] w-[18px]" set:html={INFO_ICONS[item.icon]}></svg>
                </div>
                <div>
                  <div class="mb-0.5 font-body text-[11px] text-slate-500">{item.label}</div>
                  {item.href
                    ? <a href={item.href} class="font-display text-sm font-semibold text-white no-underline hover:text-[#7C6CFB]">{item.val}</a>
                    : <div class="font-display text-sm font-semibold text-white">{item.val}</div>}
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="rounded-2xl border border-white/[0.07] bg-white/[0.025] p-7">
          <h3 class="mb-5 font-display text-base font-semibold text-white">{T.slaH}</h3>
          <div class="flex flex-col gap-2.5">
            {T.sla.map((row, i) => (
              <div class="flex items-start gap-3 rounded-[10px] border border-white/[0.05] bg-white/[0.02] px-3 py-2.5">
                <div class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full" style={`background:${slaColors[i]};box-shadow:0 0 5px ${slaColors[i]}`}></div>
                <div class="flex-1">
                  <div class="mb-0.5 flex items-center justify-between">
                    <span class="font-display text-[13px] font-semibold text-white">{row.tier}</span>
                    <span class="font-body text-xs font-bold" style={`color:${slaColors[i]}`}>{row.time}</span>
                  </div>
                  <p class="font-body text-[11.5px] leading-snug text-slate-500">{row.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>
</main>

<style>
  .tn-input {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    padding: 11px 14px;
    color: #fff;
    font-size: 14px;
    font-family: 'Metrophobic', sans-serif;
    width: 100%;
    outline: none;
    transition: border-color 0.2s;
  }
  .tn-input:focus {
    border-color: rgba(45, 18, 237, 0.5);
  }
</style>

<script>
  import { supabase } from '@/lib/supabase';

  const form = document.getElementById('tn-contact-form') as HTMLFormElement | null;
  const btn = document.getElementById('tn-submit-btn') as HTMLButtonElement | null;
  const label = btn?.querySelector('[data-label]') as HTMLElement | null;
  const successBox = document.getElementById('tn-form-success');
  const errorBox = document.getElementById('tn-form-error') as HTMLElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !btn) return;
    const data = new FormData(form);
    if (data.get('website')) return; // honeypot

    errorBox?.classList.add('hidden');
    btn.disabled = true;
    if (label) label.textContent = btn.dataset.sending ?? '...';

    try {
      const { error } = await supabase.from('contacts').insert({
        name: data.get('name'),
        email: data.get('email'),
        phone: data.get('phone') || null,
        company: null,
        service_interest: data.get('subject'),
        message: data.get('message'),
        locale: form.dataset.locale,
        source_page: window.location.pathname,
      });
      if (error) throw error;

      form.classList.add('hidden');
      successBox?.classList.remove('hidden');
    } catch (err) {
      if (errorBox) {
        errorBox.textContent = `${errorBox.dataset.err ?? 'Error'} ${errorBox.dataset.email ?? ''}`;
        errorBox.classList.remove('hidden');
      }
      console.error('Contact form error:', err);
    } finally {
      btn.disabled = false;
      if (label) label.textContent = btn.dataset.send ?? 'Send';
    }
  });
</script>
