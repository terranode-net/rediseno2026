---
interface Props { locale: 'es' | 'en' }
const { locale } = Astro.props;
const es = locale === 'es';
const contactoHref = `/${locale}/${es ? 'contacto' : 'contact'}`;
const devwebHref = `/${locale}/${es ? 'desarrollo-web' : 'web-development'}`;
const waHref = 'https://wa.me/593998197150';

const SERVICES = es ? [
  { icon: 'erp', t: 'ERP / CRM a Medida', d: 'Sistemas de gestión empresarial adaptados a tus flujos de trabajo. Cotizaciones, inventarios, facturación, CRM, reportes.' },
  { icon: 'portal', t: 'Portales y Plataformas', d: 'Plataformas multi-usuario con roles, dashboards, reportes en tiempo real e integraciones con APIs externas.' },
  { icon: 'auto', t: 'Automatización de Procesos', d: 'Eliminamos tareas manuales y repetitivas. Integramos tus herramientas (email, WhatsApp, facturación electrónica, etc.).' },
  { icon: 'api', t: 'Integraciones y APIs', d: 'Conectamos tu negocio con sistemas externos: SRI Ecuador, pasarelas de pago, marketplaces, ERPs, contabilidad.' },
  { icon: 'mobile', t: 'Aplicaciones Web Progresivas', d: 'PWAs que funcionan como app móvil sin necesidad de App Store. Notificaciones, offline mode, instalable en teléfonos.' },
  { icon: 'report', t: 'Reportes y Analytics', d: 'Dashboards personalizados con KPIs de tu negocio. Exportación a Excel/PDF. Visualización de datos en tiempo real.' },
] : [
  { icon: 'erp', t: 'Custom ERP / CRM', d: 'Business management systems tailored to your workflows. Quotes, inventory, invoicing, CRM, reports.' },
  { icon: 'portal', t: 'Portals & Platforms', d: 'Multi-user platforms with roles, dashboards, real-time reports and external API integrations.' },
  { icon: 'auto', t: 'Process Automation', d: 'We eliminate manual, repetitive tasks. We integrate your tools (email, WhatsApp, e-invoicing, etc.).' },
  { icon: 'api', t: 'Integrations & APIs', d: 'We connect your business with external systems: Ecuador SRI, payment gateways, marketplaces, ERPs, accounting.' },
  { icon: 'mobile', t: 'Progressive Web Apps', d: 'PWAs that work like a mobile app with no App Store needed. Notifications, offline mode, installable on phones.' },
  { icon: 'report', t: 'Reports & Analytics', d: 'Custom dashboards with your business KPIs. Excel/PDF export. Real-time data visualization.' },
];

const STACK = [
  { name: 'React', color: '#61DAFB' },
  { name: 'Node.js', color: '#68A063' },
  { name: 'Next.js', color: '#FFFFFF' },
  { name: 'PostgreSQL', color: '#336791' },
  { name: 'MySQL', color: '#4479A1' },
  { name: 'PHP Laravel', color: '#FF2D20' },
  { name: 'TypeScript', color: '#3178C6' },
  { name: 'REST APIs', color: '#3B82F6' },
  { name: 'Docker', color: '#2496ED' },
  { name: 'Linux VPS', color: '#22C55E' },
];

const PROCESS = es ? [
  { n: '01', t: 'Descubrimiento', d: 'Analizamos tus procesos actuales: qué haces a mano, dónde se pierde tiempo, qué quieres automatizar. Definimos el alcance exacto del sistema.' },
  { n: '02', t: 'Arquitectura', d: 'Diseñamos la base técnica: base de datos, módulos, roles de usuario, integraciones. Antes de codificar, tenemos el plano claro.' },
  { n: '03', t: 'Desarrollo en fases', d: 'Construimos en sprints iterativos. Cada 2-3 semanas ves avances reales y puedes dar feedback. Sin sorpresas al final.' },
  { n: '04', t: 'Pruebas QA', d: 'Pruebas funcionales, de carga y de seguridad en entorno de staging antes del lanzamiento. Cero errores en producción.' },
  { n: '05', t: 'Despliegue', d: 'Instalación en tus servidores (Terranode VPS/Dedicado) con configuración de dominio, SSL, respaldos automáticos y monitoreo.' },
  { n: '06', t: 'Mantenimiento', d: 'Soporte continuo, actualizaciones de seguridad y evolución del sistema conforme crece tu negocio. SLA garantizado.' },
] : [
  { n: '01', t: 'Discovery', d: 'We analyze your current processes: what\u2019s manual, where time is lost, what you want to automate. We define the exact scope.' },
  { n: '02', t: 'Architecture', d: 'We design the technical foundation: database, modules, user roles, integrations. A clear blueprint before we write code.' },
  { n: '03', t: 'Phased development', d: 'We build in iterative sprints. Every 2-3 weeks you see real progress and can give feedback. No surprises at the end.' },
  { n: '04', t: 'QA Testing', d: 'Functional, load and security testing in staging before launch. Zero errors in production.' },
  { n: '05', t: 'Deployment', d: 'Installation on your servers (Terranode VPS/Dedicated) with domain setup, SSL, automatic backups and monitoring.' },
  { n: '06', t: 'Maintenance', d: 'Ongoing support, security updates and system evolution as your business grows. Guaranteed SLA.' },
];

const FEATS = es ? [
  { icon: 'own', t: 'Código propio, sin dependencias', d: 'Eres dueño del código fuente. Sin suscripciones a plataformas de terceros. Tu sistema vive mientras tú decidas.' },
  { icon: 'scale', t: 'Escalable desde el día 1', d: 'Arquitectura diseñada para crecer. Lo que hoy gestiona 10 usuarios, mañana puede manejar 10,000.' },
  { icon: 'secure', t: 'Seguridad de producción', d: 'Autenticación JWT, cifrado de datos, control de accesos por rol, logs de auditoría y protección DDoS.' },
  { icon: 'int', t: 'Integración con lo que ya tienes', d: 'Conectamos con tu sistema de facturación, contabilidad, tienda online, WhatsApp Business API o lo que uses.' },
] : [
  { icon: 'own', t: 'Your own code, no lock-in', d: 'You own the source code. No third-party platform subscriptions. Your system lives as long as you decide.' },
  { icon: 'scale', t: 'Scalable from day 1', d: 'Architecture designed to grow. What manages 10 users today can handle 10,000 tomorrow.' },
  { icon: 'secure', t: 'Production-grade security', d: 'JWT authentication, data encryption, role-based access control, audit logs and DDoS protection.' },
  { icon: 'int', t: 'Integrates with what you already use', d: 'We connect with your invoicing, accounting, online store, WhatsApp Business API or whatever you use.' },
];

const FAQ = es ? [
  { q: '¿Cuánto cuesta un sistema a medida?', a: 'Depende del alcance. Un módulo básico parte desde $1,500. Un ERP completo puede ir de $4,000 a $15,000+. Siempre cotizamos antes de comenzar sin costo.' },
  { q: '¿Cuánto tiempo tarda el desarrollo?', a: 'Proyectos simples: 4-6 semanas. Medianos: 2-4 meses. Complejos: 4-8 meses. Trabajamos en fases, así que usas partes del sistema antes de que esté completo.' },
  { q: '¿Qué pasa si el sistema necesita cambios después?', a: 'Ofrecemos planes de mantenimiento por horas o mensualidad fija. El código es tuyo, así que también puedes llevarlo a otro proveedor.' },
  { q: '¿El sistema puede integrarse con el SRI de Ecuador?', a: 'Sí. Tenemos experiencia con la API del SRI para facturación electrónica, autorización de comprobantes y consultas RUC.' },
  { q: '¿En qué servidor se instala el sistema?', a: 'Lo instalamos en los VPS o servidores dedicados de Terranode. Si ya tienes servidor propio, también podemos instalarlo ahí.' },
  { q: '¿Puedo ver avances antes de que esté terminado?', a: 'Sí. Trabajamos con metodología ágil en sprints de 2 semanas con entregables en staging que puedes ver y probar.' },
] : [
  { q: 'How much does a custom system cost?', a: 'Depends on scope. A basic module starts at $1,500. A full ERP can range from $4,000 to $15,000+. We always quote before starting, at no cost.' },
  { q: 'How long does development take?', a: 'Simple projects: 4-6 weeks. Medium: 2-4 months. Complex: 4-8 months. We work in phases, so you use parts of the system before it\u2019s complete.' },
  { q: 'What if the system needs changes later?', a: 'We offer hourly or fixed monthly maintenance plans. The code is yours, so you can also take it to another provider.' },
  { q: 'Can the system integrate with Ecuador\u2019s SRI?', a: 'Yes. We have experience with the SRI API for e-invoicing, receipt authorization and RUC lookups.' },
  { q: 'Which server is the system installed on?', a: 'We install it on Terranode VPS or dedicated servers. If you already have your own server, we can install it there too.' },
  { q: 'Can I see progress before it\u2019s finished?', a: 'Yes. We work in agile 2-week sprints with staging deliverables you can see and test.' },
];

const ICONS: Record<string, string> = {
  erp: '<rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/>',
  portal: '<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>',
  auto: '<path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke-linecap="round" stroke-linejoin="round"/>',
  api: '<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>',
  mobile: '<rect x="5" y="2" width="14" height="20" rx="2"/><path d="M12 18h.01" stroke-linecap="round" stroke-width="2.5"/>',
  report: '<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>',
  own: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
  scale: '<path d="M18 20V10M12 20V4M6 20v-6"/>',
  secure: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4" stroke-linecap="round" stroke-linejoin="round"/>',
  int: '<circle cx="12" cy="5" r="3"/><circle cx="5" cy="19" r="3"/><circle cx="19" cy="19" r="3"/><path d="M12 8v3M12 11l-5.5 5M12 11l5.5 5"/>',
};

const T = {
  eyebrow: es ? 'Desarrollo de Sistemas · Ecuador' : 'Systems Development · Ecuador',
  h1: es ? 'Desarrollo de Software' : 'Custom Software',
  h1b: es ? 'a Medida en Ecuador' : 'Development in Ecuador',
  sub: es ? 'Desarrollamos sistemas web, ERPs, CRMs, portales y aplicaciones a medida en Ecuador que eliminan procesos manuales y conectan todas las áreas de tu empresa. Con React, Node.js y arquitectura escalable.' : 'We develop custom web systems, ERPs, CRMs, portals and applications in Ecuador that eliminate manual processes and connect every area of your business. With React, Node.js and scalable architecture.',
  introH: es ? 'Empresa de desarrollo de software en Ecuador' : 'Software development company in Ecuador',
  introBody: es
    ? 'Elegir una empresa de desarrollo de software local en Ecuador tiene ventajas concretas frente a contratar un freelancer remoto o una agencia extranjera: comunicación en el mismo horario y zona horaria, entendimiento directo de procesos locales como la facturación electrónica del SRI, y un equipo al que puedes visitar o llamar cuando lo necesites. En Terranode desarrollamos software a medida para pymes y empresas en Guayaquil, Quito, Cuenca y el resto de Ecuador: desde sistemas de inventario y facturación integrados con el SRI, hasta ERPs completos, CRMs de gestión de clientes y portales web complejos. Cada sistema se despliega sobre nuestra propia infraestructura de VPS y servidores dedicados en Ecuador y Estados Unidos, lo que nos permite ofrecerte no solo el desarrollo, sino también el hosting, la seguridad y el soporte técnico continuo desde un mismo proveedor — sin depender de terceros para mantener tu sistema funcionando.'
    : 'Choosing a local software development company in Ecuador has concrete advantages over hiring a remote freelancer or a foreign agency: communication in the same time zone, direct understanding of local processes like Ecuador\u2019s SRI e-invoicing system, and a team you can visit or call whenever you need to. At Terranode we build custom software for small and medium businesses in Guayaquil, Quito, Cuenca and the rest of Ecuador: from inventory and invoicing systems integrated with the SRI, to full ERPs, customer-management CRMs and complex web portals. Every system is deployed on our own VPS and dedicated server infrastructure in Ecuador and the United States, letting us offer not just development but also hosting, security and ongoing technical support from a single provider — with no dependency on third parties to keep your system running.',
  cta1: es ? 'Solicitar cotización gratuita' : 'Request free quote',
  cta2: es ? '¿Solo necesitas un sitio web? → Ver Desarrollo Web' : 'Just need a website? → See Web Development',
  svcTag: es ? 'SERVICIOS' : 'SERVICES',
  svcH: es ? '¿Qué sistemas desarrollamos?' : 'What systems do we develop?',
  svcSub: es ? 'Si puedes describirlo, podemos construirlo' : 'If you can describe it, we can build it',
  stackH: es ? 'Tecnologías que usamos' : 'Technologies we use',
  featsH: es ? 'Ventajas del desarrollo de software a medida en Ecuador' : 'Advantages of custom software development in Ecuador',
  processH: es ? 'Cómo trabajamos' : 'How we work',
  processSub: es ? 'Metodología ágil con entregas parciales cada 2 semanas' : 'Agile methodology with partial deliveries every 2 weeks',
  faqH: es ? 'Preguntas frecuentes' : 'Frequently asked questions',
  ctaH: es ? 'Cuéntanos tu proyecto' : 'Tell us about your project',
  ctaSub: es ? 'Analizamos tu caso sin costo y te enviamos una propuesta técnica y económica en 48 horas.' : 'We analyze your case at no cost and send you a technical and commercial proposal within 48 hours.',
  ctaBtn: es ? 'Iniciar cotización' : 'Start quote',
  ctaWA: es ? 'WhatsApp directo' : 'Direct WhatsApp',
  crossH: es ? '¿SOLO NECESITAS UN SITIO WEB?' : 'JUST NEED A WEBSITE?',
  crossT: es ? 'Diseño Web y E-Commerce' : 'Web Design & E-Commerce',
  crossD: es ? 'Sitios web profesionales y tiendas online con WordPress y WooCommerce. Planes desde $350.' : 'Professional websites and online stores with WordPress and WooCommerce. Plans from $350.',
  crossBtn: es ? 'Ver Diseño Web →' : 'See Web Design →',
};

const CODE_LINES = [
  { color: '#4A6A88', v: es ? '// Sistema de Gestión Empresarial' : '// Business Management System' },
  { color: '#A78BFA', v: 'const', l: ' sistema = {' },
  { color: '#60A5FA', v: `  ${es ? 'módulos' : 'modules'}:`, l: ' [' },
  { color: '#34D399', v: es ? "    'Inventario'" : "    'Inventory'" },
  { color: '#34D399', v: es ? "    'Facturación SRI'" : "    'E-Invoicing'" },
  { color: '#34D399', v: es ? "    'CRM Clientes'" : "    'Customer CRM'" },
  { color: '#34D399', v: es ? "    'Reportes KPI'" : "    'KPI Reports'" },
  { color: '#CBD5E1', v: '  ],' },
  { color: '#60A5FA', v: '  stack:', l: " 'React + Node.js'" },
  { color: '#60A5FA', v: '  deploy:', l: " 'Terranode VPS'" },
  { color: '#60A5FA', v: '  status:', l: '' },
  { color: '#22C55E', v: es ? "'✓ En Producción'" : "'✓ In Production'" },
  { color: '#CBD5E1', v: '};' },
];
---
<main style="padding-top:66px;background:#080E1C;min-height:100vh">
  <!-- HERO -->
  <section class="relative overflow-hidden border-b border-white/[0.04] px-6 py-16 md:py-[72px]">
    <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse 55% 65% at 50% 30%,rgba(37,99,235,.12),transparent 70%)"></div>
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(59,130,246,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(59,130,246,.03) 1px,transparent 1px);background-size:50px 50px"></div>
    <div class="relative z-[2] mx-auto grid max-w-[1160px] grid-cols-1 items-center gap-10 md:grid-cols-[1.1fr_1fr] md:gap-[60px]">
      <div>
        <span class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#3B82F6]/20 bg-[#3B82F6]/[0.08] px-3.5 py-[5px] font-body text-[11px] font-bold uppercase tracking-[2.5px] text-[#3B82F6]">
          <svg viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="2" class="h-3 w-3"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          {T.eyebrow}
        </span>
        <h1 class="mb-[22px] font-display text-[clamp(2.2rem,4vw,3.6rem)] font-bold leading-[1.05] tracking-tight text-white">
          {T.h1}<br /><span class="text-slate-600">{T.h1b}</span>
        </h1>
        <p class="mb-3.5 max-w-[460px] font-body text-base leading-[1.75] text-slate-400">{T.sub}</p>
        <a href={devwebHref} class="mb-8 inline-block border-b border-dashed border-slate-600 pb-px font-body text-xs text-slate-500 no-underline">{T.cta2}</a>
        <div class="flex flex-wrap gap-3">
          <a href={contactoHref} class="rounded-lg border-none bg-[#3B82F6] px-6 py-3 font-display text-[15px] font-semibold text-white no-underline shadow-[0_0_24px_rgba(59,130,246,.3)] transition-colors hover:bg-[#2563EB]">{T.cta1}</a>
          <a href={waHref} target="_blank" rel="noopener noreferrer" class="rounded-lg border border-[#25D366]/30 bg-[#25D366]/10 px-6 py-3 font-display text-[15px] font-semibold text-[#25D366] no-underline">{T.ctaWA}</a>
        </div>
      </div>

      <!-- Animated code terminal -->
      <div class="overflow-hidden rounded-2xl border border-[#3B82F6]/[0.15] bg-[#060B18]/95 font-body">
        <div class="flex items-center gap-2 border-b border-white/[0.06] bg-white/[0.03] px-3.5 py-2.5">
          <div class="flex gap-1.5">
            {['#FF5F56', '#FFBD2E', '#27C93F'].map((c) => <div class="h-2.5 w-2.5 rounded-full" style={`background:${c}`}></div>)}
          </div>
          <span class="ml-1 text-[11px] text-slate-600">sistema-terranode.js</span>
        </div>
        <div class="p-[18px] text-xs leading-[2]">
          {CODE_LINES.map((line, i) => (
            <div class="flex" style={`color:${line.color}`}>
              <span class="mr-3 min-w-[20px] text-right text-[10px] text-[#2A3A50]">{i + 1}</span>
              <span>{line.v}</span>
              {line.l && <span class="text-slate-300">{line.l}</span>}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="bg-[#060B18] px-6 py-[72px]">
    <div class="mx-auto max-w-[1160px]">
      <header class="an mb-10">
        <p class="mb-3.5 font-body text-[11px] font-bold uppercase tracking-[2.5px] text-[#3B82F6]">{T.svcTag}</p>
        <h2 class="mb-1.5 font-display text-[clamp(1.8rem,3vw,2.5rem)] font-bold tracking-tight text-white">{T.svcH}</h2>
        <p class="font-body text-sm text-slate-500">{T.svcSub}</p>
      </header>
      <div class="grid grid-cols-1 gap-3.5 md:grid-cols-3">
        {SERVICES.map((svc, i) => (
          <div class={`an d${(i % 3) + 1} flex items-start gap-4 rounded-2xl border border-white/[0.07] bg-white/[0.025] p-6`}>
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-[#3B82F6]/10">
              <svg viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="1.8" class="h-[22px] w-[22px]" set:html={ICONS[svc.icon]}></svg>
            </div>
            <div>
              <div class="mb-2 font-display text-[15px] font-bold text-white">{svc.t}</div>
              <p class="font-body text-xs leading-[1.65] text-slate-500">{svc.d}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TECH STACK -->
  <section class="bg-[#060B18] px-6 pb-[72px]">
    <div class="mx-auto max-w-[1160px]">
      <h3 class="an mb-5 text-center font-body text-[11px] font-bold uppercase tracking-[2.5px] text-slate-600">{T.stackH}</h3>
      <div class="flex flex-wrap justify-center gap-2.5">
        {STACK.map((tech, i) => (
          <div class={`an d${(i % 5) + 1} rounded-[10px] px-[18px] py-2.5 font-display text-[13px] font-semibold text-slate-300`} style={`background:${tech.color}12;border:1px solid ${tech.color}30`}>{tech.name}</div>
        ))}
      </div>
    </div>
  </section>

  <!-- FEATS -->
  <section class="border-t border-white/[0.04] bg-[#080E1C] px-6 py-[72px]">
    <div class="mx-auto max-w-[1160px]">
      <h2 class="an mb-10 text-center font-display text-[clamp(1.8rem,3vw,2.5rem)] font-bold tracking-tight text-white">{T.featsH}</h2>
      <div class="grid grid-cols-1 gap-3.5 md:grid-cols-2">
        {FEATS.map((f, i) => (
          <div class={`an d${(i % 2) + 1} flex items-start gap-5 rounded-2xl border border-white/[0.07] bg-white/[0.025] p-7`}>
            <div class="flex h-[52px] w-[52px] shrink-0 items-center justify-center rounded-2xl bg-[#3B82F6]/10">
              <svg viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="1.8" class="h-[22px] w-[22px]" set:html={ICONS[f.icon]}></svg>
            </div>
            <div>
              <div class="mb-2.5 font-display text-base font-bold text-white">{f.t}</div>
              <p class="font-body text-[13px] leading-[1.7] text-slate-500">{f.d}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="border-t border-white/[0.04] bg-[#060B18] px-6 py-[72px]">
    <div class="mx-auto max-w-[1160px]">
      <div class="an mb-12 text-center">
        <h2 class="mb-2 font-display text-[clamp(1.8rem,3vw,2.5rem)] font-bold tracking-tight text-white">{T.processH}</h2>
        <p class="font-body text-sm text-slate-500">{T.processSub}</p>
      </div>
      <div class="grid grid-cols-1 gap-3.5 md:grid-cols-3">
        {PROCESS.map((step, i) => (
          <div class={`an d${(i % 3) + 1} rounded-2xl border border-white/[0.07] bg-white/[0.025] p-6`}>
            <div class="mb-2 font-display text-[36px] font-extrabold tracking-tight text-[#3B82F6]/[0.12]">{step.n}</div>
            <div class="mb-2 font-display text-[15px] font-bold text-white">{step.t}</div>
            <p class="font-body text-xs leading-[1.65] text-slate-500">{step.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Intro / contenido SEO -->
  <section class="border-t border-white/[0.04] bg-[#060B18] px-6 py-16">
    <div class="mx-auto max-w-[820px]">
      <h2 class="mb-4 font-display text-[clamp(1.5rem,2.6vw,2rem)] font-bold tracking-tight text-white">{T.introH}</h2>
      <p class="font-body text-[15px] leading-[1.8] text-slate-400">{T.introBody}</p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-white/[0.04] bg-[#080E1C] px-6 py-[72px]">
    <div class="mx-auto max-w-[760px]">
      <h2 class="an mb-10 text-center font-display text-[clamp(1.8rem,3vw,2.5rem)] font-bold tracking-tight text-white">{T.faqH}</h2>
      <div class="flex flex-col gap-2">
        {FAQ.map((item) => (
          <div class="ds-faq-item overflow-hidden rounded-xl border border-white/[0.07] bg-white/[0.025]">
            <button type="button" class="ds-faq-btn flex w-full items-center justify-between gap-4 border-none bg-transparent px-5 py-[18px] text-left">
              <span class="font-display text-sm font-semibold text-white">{item.q}</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="#4A6A88" stroke-width="2" class="ds-faq-chevron h-4 w-4 shrink-0 transition-transform"><path d="m6 9 6 6 6-6"/></svg>
            </button>
            <div class="ds-faq-answer hidden border-t border-white/[0.05] px-5 pb-[18px] pt-3 font-body text-[13px] leading-[1.7] text-slate-500">{item.a}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CROSS-SELL -->
  <section class="bg-[#080E1C] px-6 pb-12">
    <div class="mx-auto max-w-[1160px]">
      <div class="an grid grid-cols-1 items-center gap-6 rounded-2xl border border-white/[0.07] bg-white/[0.025] p-7 md:grid-cols-[1fr_auto]">
        <div>
          <div class="mb-2 font-body text-[11px] font-bold uppercase tracking-[2px] text-[#3B82F6]">{T.crossH}</div>
          <div class="mb-1.5 font-display text-[17px] font-bold text-white">{T.crossT}</div>
          <p class="font-body text-[13px] text-slate-500">{T.crossD}</p>
        </div>
        <a href={devwebHref} class="shrink-0 whitespace-nowrap rounded-lg border border-[#3B82F6] bg-transparent px-[22px] py-[11px] font-display text-sm font-semibold text-[#3B82F6] no-underline">{T.crossBtn}</a>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="bg-[#080E1C] px-6 pb-24">
    <div class="mx-auto max-w-[1160px]">
      <div class="an relative overflow-hidden rounded-2xl border border-[#3B82F6]/20 p-8 text-center md:p-[52px]" style="background:linear-gradient(135deg,rgba(59,130,246,.1),rgba(37,99,235,.05))">
        <div class="pointer-events-none absolute inset-0" style="background-image:radial-gradient(circle at 50% 50%,rgba(59,130,246,.08),transparent 70%)"></div>
        <div class="relative z-[2]">
          <h2 class="mb-3 font-display text-[clamp(1.6rem,3vw,2.4rem)] font-bold tracking-tight text-white">{T.ctaH}</h2>
          <p class="mx-auto mb-8 max-w-[520px] font-body text-[15px] text-slate-400">{T.ctaSub}</p>
          <div class="flex flex-wrap justify-center gap-3">
            <a href={contactoHref} class="rounded-lg bg-[#3B82F6] px-7 py-[13px] font-display text-[15px] font-semibold text-white no-underline shadow-[0_0_28px_rgba(59,130,246,.35)]">{T.ctaBtn}</a>
            <a href={waHref} target="_blank" rel="noopener noreferrer" class="rounded-lg border border-[#25D366]/30 bg-[#25D366]/[0.08] px-7 py-[13px] font-display text-[15px] font-semibold text-[#25D366] no-underline">{T.ctaWA}</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</main>

<script>
  document.querySelectorAll('.ds-faq-item').forEach((item) => {
    const btn = item.querySelector('.ds-faq-btn');
    const answer = item.querySelector('.ds-faq-answer');
    const chevron = item.querySelector('.ds-faq-chevron') as HTMLElement | null;
    btn?.addEventListener('click', () => {
      const isOpen = !answer?.classList.contains('hidden');
      answer?.classList.toggle('hidden', isOpen);
      if (chevron) chevron.style.transform = isOpen ? 'none' : 'rotate(180deg)';
    });
  });
</script>
