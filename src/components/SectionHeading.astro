---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: 'center' | 'left';
}
const { eyebrow, title, description, align = 'center' } = Astro.props;
---
<div class={`mx-auto max-w-2xl ${align === 'center' ? 'text-center' : 'text-left mx-0'}`}>
  {eyebrow && <span class="eyebrow">{eyebrow}</span>}
  <h2 class="mt-4 text-balance text-3xl font-semibold leading-tight text-ink md:text-4xl">{title}</h2>
  {description && <p class="mt-4 text-balance leading-relaxed text-slate-500">{description}</p>}
</div>
