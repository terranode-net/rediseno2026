---
interface Props { locale: 'es' | 'en' }
const { locale } = Astro.props;
const es = locale === 'es';
const contactoHref = `/${locale}/${es ? 'contacto' : 'contact'}`;
const devsysHref = `/${locale}/${es ? 'desarrollo-sistemas' : 'systems'}`;

const PLANS = es ? [
  { id: 'landing', popular: false, name: 'Landing Page', price: '$350', period: 'pago único', tagline: 'Para presentar tu negocio online', feats: ['Hasta 5 secciones', 'Diseño personalizado', 'Responsive mobile-first', 'Formulario de contacto', 'Botón WhatsApp', 'SSL + Hosting 1 año', 'SEO básico', 'Entrega en 7 días'] },
  { id: 'web', popular: false, name: 'Sitio Web Corporativo', price: '$650', period: 'pago único', tagline: 'Para empresas y profesionales', feats: ['Hasta 10 páginas', 'Blog integrado', 'Panel de administración', 'Formularios avanzados', 'Redes sociales', 'SSL + Hosting 1 año', 'SEO on-page completo', 'Entrega en 15 días'] },
  { id: 'ecomm', popular: true, name: 'Tienda Online', price: '$1,200', period: 'pago único', tagline: 'Para vender productos online', feats: ['WooCommerce completo', 'Catálogo ilimitado', 'Pasarela de pagos (PayPal, tarjeta)', 'Gestión de inventario', 'Cupones y descuentos', 'SSL + Hosting 1 año', 'SEO para productos', 'Entrega en 20 días'] },
  { id: 'custom', popular: false, name: 'Proyecto a Medida', price: 'Cotizar', period: '', tagline: 'Cuando ningún plan estándar aplica', feats: ['Diseño 100% personalizado', 'Funcionalidades específicas', 'Integraciones externas', 'Multilingual / multimoneda', 'Migración desde otra plataforma', 'SLA y mantenimiento', 'Soporte prioritario', 'Timeline a convenir'] },
] : [
  { id: 'landing', popular: false, name: 'Landing Page', price: '$350', period: 'one-time', tagline: 'To showcase your business online', feats: ['Up to 5 sections', 'Custom design', 'Mobile-first responsive', 'Contact form', 'WhatsApp button', 'SSL + 1yr Hosting', 'Basic SEO', '7-day delivery'] },
  { id: 'web', popular: false, name: 'Corporate Website', price: '$650', period: 'one-time', tagline: 'For companies and professionals', feats: ['Up to 10 pages', 'Integrated blog', 'Admin panel', 'Advanced forms', 'Social media', 'SSL + 1yr Hosting', 'Full on-page SEO', '15-day delivery'] },
  { id: 'ecomm', popular: true, name: 'Online Store', price: '$1,200', period: 'one-time', tagline: 'To sell products online', feats: ['Full WooCommerce', 'Unlimited catalog', 'Payment gateway (PayPal, card)', 'Inventory management', 'Coupons and discounts', 'SSL + 1yr Hosting', 'Product SEO', '20-day delivery'] },
  { id: 'custom', popular: false, name: 'Custom Project', price: 'Get quote', period: '', tagline: 'When no standard plan fits', feats: ['100% custom design', 'Specific functionality', 'External integrations', 'Multilingual / multicurrency', 'Migration from another platform', 'SLA and maintenance', 'Priority support', 'Timeline by agreement'] },
];

const STACK = [
  { name: 'WordPress', color: '#21759B' },
  { name: 'WooCommerce', color: '#96588A' },
  { name: 'Elementor', color: '#E2498A' },
  { name: 'PHP', color: '#777BB4' },
  { name: 'MySQL', color: '#4479A1' },
  { name: 'LiteSpeed', color: '#E5880E' },
  { name: 'cPanel', color: '#FF6C2C' },
  { name: 'Cloudflare', color: '#F48120' },
];

const FEATS = es ? [
  { icon: 'mobile', t: '100% Responsive', d: 'Tu sitio se ve perfecto en móvil, tablet y escritorio. Diseño mobile-first desde el primer píxel.' },
  { icon: 'speed', t: 'Carga rápida', d: 'Optimizamos imágenes, caché y código. Google Page Speed por encima de 90 puntos en todos los proyectos.' },
  { icon: 'seo', t: 'SEO integrado', d: 'Estructura de URLs, meta tags, schema markup y sitemap XML incluidos desde el inicio del proyecto.' },
  { icon: 'secure', t: 'Seguridad SSL', d: "HTTPS con Let's Encrypt, firewall a nivel de servidor y copias de seguridad diarias automáticas." },
  { icon: 'cms', t: 'Fácil de administrar', d: 'Panel WordPress intuitivo. Tú mismo podrás agregar productos, noticias y páginas sin tocar código.' },
  { icon: 'cart', t: 'E-commerce completo', d: 'WooCommerce: gestión de inventario, pasarelas de pago, cupones, variaciones y reportes de ventas.' },
  { icon: 'support', t: 'Soporte post-entrega', d: '30 días de soporte gratuito tras la entrega. Planes de mantenimiento mensual disponibles.' },
  { icon: 'host', t: 'Hospedado en Terranode', d: 'Tu sitio alojado en nuestros servidores LiteSpeed con DDoS 160 Gbps y uptime 99.9%.' },
] : [
  { icon: 'mobile', t: '100% Responsive', d: 'Your site looks perfect on mobile, tablet and desktop. Mobile-first design from pixel one.' },
  { icon: 'speed', t: 'Fast loading', d: 'We optimize images, cache and code. Google PageSpeed above 90 on every project.' },
  { icon: 'seo', t: 'Built-in SEO', d: 'URL structure, meta tags, schema markup and XML sitemap included from day one.' },
  { icon: 'secure', t: 'SSL Security', d: "HTTPS with Let's Encrypt, server-level firewall and automatic daily backups." },
  { icon: 'cms', t: 'Easy to manage', d: 'Intuitive WordPress panel. Add products, news and pages yourself without touching code.' },
  { icon: 'cart', t: 'Full e-commerce', d: 'WooCommerce: inventory management, payment gateways, coupons, variations and sales reports.' },
  { icon: 'support', t: 'Post-delivery support', d: '30 days of free support after delivery. Monthly maintenance plans available.' },
  { icon: 'host', t: 'Hosted on Terranode', d: 'Your site hosted on our LiteSpeed servers with 160 Gbps DDoS protection and 99.9% uptime.' },
];

const PROCESS = es ? [
  { n: '01', t: 'Briefing', d: 'Reunión inicial para entender tu negocio, objetivos, estilo y competencia. Definimos alcance y cronograma.' },
  { n: '02', t: 'Diseño UI', d: 'Diseñamos wireframes y mockups visuales. Sin escribir código hasta que apruebes cómo se ve.' },
  { n: '03', t: 'Desarrollo', d: 'Construimos el sitio con WordPress/WooCommerce según el diseño aprobado. Pruebas en entorno de staging.' },
  { n: '04', t: 'Revisión', d: 'Te mostramos el sitio completo. Aplicamos tus correcciones hasta que estés 100% satisfecho.' },
  { n: '05', t: 'Lanzamiento', d: 'Migración al dominio definitivo, configuración DNS, SSL e indexación en Google. Tu sitio en vivo.' },
  { n: '06', t: 'Entrenamiento', d: 'Sesión de capacitación para que sepas administrar tu sitio de forma independiente.' },
] : [
  { n: '01', t: 'Briefing', d: 'Initial meeting to understand your business, goals, style and competitors. We define scope and timeline.' },
  { n: '02', t: 'UI Design', d: 'We design wireframes and visual mockups. No code until you approve how it looks.' },
  { n: '03', t: 'Development', d: 'We build the site with WordPress/WooCommerce per the approved design. Testing in staging.' },
  { n: '04', t: 'Review', d: 'We show you the finished site and apply your revisions until you\u2019re 100% satisfied.' },
  { n: '05', t: 'Launch', d: 'Migration to your final domain, DNS setup, SSL and Google indexing. Your site goes live.' },
  { n: '06', t: 'Training', d: 'A training session so you can manage your site independently.' },
];

const FAQ = es ? [
  { q: '¿El dominio y hosting están incluidos?', a: 'El hosting en Terranode está incluido el primer año en todos los planes. El dominio tiene un costo adicional de ~$12/año.' },
  { q: '¿Cuánto tiempo tarda en estar listo mi sitio?', a: 'Depende del plan: Landing 7 días, Corporativo 15 días, Tienda Online 20 días.' },
  { q: '¿Puedo administrar el contenido yo mismo?', a: 'Sí. WordPress tiene un panel muy intuitivo. Incluimos una sesión de capacitación.' },
  { q: '¿Qué pasa si quiero cambios después de la entrega?', a: 'Tienes 30 días de soporte gratuito para correcciones menores. Ofrecemos planes de mantenimiento mensual.' },
  { q: '¿Puedo migrar mi sitio actual a WordPress?', a: 'Sí. Migramos contenido, imágenes y SEO desde cualquier plataforma sin pérdida de posicionamiento.' },
  { q: '¿Incluye la creación de contenido o fotos?', a: 'El desarrollo no incluye redacción de textos ni fotografía, pero sí maquetación y optimización de las imágenes que nos proporciones.' },
] : [
  { q: 'Are domain and hosting included?', a: 'Terranode hosting is included the first year on every plan. The domain costs ~$12/yr extra.' },
  { q: 'How long until my site is ready?', a: 'Depends on the plan: Landing 7 days, Corporate 15 days, Online Store 20 days.' },
  { q: 'Can I manage the content myself?', a: 'Yes. WordPress has a very intuitive panel. We include a training session.' },
  { q: 'What if I want changes after delivery?', a: 'You get 30 days of free support for minor fixes. Monthly maintenance plans are available.' },
  { q: 'Can I migrate my current site to WordPress?', a: 'Yes. We migrate content, images and SEO from any platform without losing rankings.' },
  { q: 'Does it include content writing or photos?', a: 'Development doesn\u2019t include copywriting or photography, but we do handle layout and optimization of images you provide.' },
];

const ICONS: Record<string, string> = {
  mobile: '<rect x="5" y="2" width="14" height="20" rx="2"/><path d="M12 18h.01" stroke-linecap="round" stroke-width="2.5"/>',
  speed: '<path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke-linecap="round" stroke-linejoin="round"/>',
  seo: '<circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/><path d="M11 8v6M8 11h6" stroke-linecap="round"/>',
  secure: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4" stroke-linecap="round" stroke-linejoin="round"/>',
  cms: '<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>',
  cart: '<circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>',
  support: '<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>',
  host: '<rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><path d="M6 6h.01M6 18h.01" stroke-linecap="round" stroke-width="2.5"/>',
};

const T = {
  eyebrow: es ? 'Diseño & E-Commerce · Ecuador' : 'Design & E-Commerce · Ecuador',
  h1: es ? 'Diseño y Desarrollo Web' : 'Professional Web Design',
  h1b: es ? 'Profesional en Ecuador' : '& Development in Ecuador',
  sub: es ? 'Diseñamos y desarrollamos páginas web y tiendas online en Ecuador con WordPress y WooCommerce. Sitios rápidos, seguros, optimizados para SEO y fáciles de administrar tú mismo.' : 'We design and develop websites and online stores in Ecuador with WordPress and WooCommerce. Fast, secure, SEO-optimized sites that are easy to manage yourself.',
  introH: es ? 'Agencia de diseño web en Ecuador con hosting propio' : 'Web design agency in Ecuador with in-house hosting',
  introBody: es
    ? 'A diferencia de una agencia de diseño web independiente, Terranode también es el proveedor de la infraestructura donde vive tu sitio: alojamos tu página web en nuestros propios servidores en Ecuador y Estados Unidos, lo que significa tiempos de carga más rápidos para visitantes ecuatorianos, soporte técnico end-to-end (diseño, desarrollo y hosting con un solo proveedor) y sin depender de terceros cuando algo falla. Trabajamos con negocios, profesionales y emprendimientos en Guayaquil, Quito, Cuenca y el resto de Ecuador que necesitan una página web corporativa, una tienda online o una landing page que realmente convierta visitas en clientes. Todos nuestros sitios se construyen sobre WordPress — el gestor de contenido más usado del mundo — con SEO técnico desde el primer día: velocidad de carga optimizada, estructura de encabezados correcta, sitemap XML y certificado SSL incluido.'
    : 'Unlike an independent web design agency, Terranode is also the provider of the infrastructure your site lives on: we host your website on our own servers in Ecuador and the United States, meaning faster load times for Ecuadorian visitors, end-to-end technical support (design, development and hosting from a single provider), and no dependency on third parties when something breaks. We work with businesses, professionals and startups in Guayaquil, Quito, Cuenca and the rest of Ecuador that need a corporate website, an online store, or a landing page that actually converts visits into customers. Every site we build runs on WordPress — the world\u2019s most widely used content management system — with technical SEO from day one: optimized load speed, correct heading structure, XML sitemap and SSL certificate included.',
  cta1: es ? 'Ver planes y precios' : 'View plans & pricing',
  cta2: es ? 'Solicitar cotización' : 'Request a quote',
  sistLink: es ? '¿Necesitas un sistema a medida? → Ver Desarrollo de Sistemas' : 'Need a custom system? → See Systems Development',
  plansTag: es ? 'PLANES' : 'PLANS',
  plansH: es ? 'Planes de Desarrollo Web' : 'Web Development Plans',
  plansSub: es ? 'Precios fijos, sin sorpresas. Entrega en tiempo acordado o te devolvemos el 50%.' : 'Fixed prices, no surprises. On-time delivery or we refund 50%.',
  popular: es ? 'Más solicitado' : 'Most requested',
  quote: es ? 'Cotizar' : 'Get quote',
  stackH: es ? 'Tecnología que usamos' : 'Technologies we use',
  featsH: es ? 'Por qué elegirnos para tu sitio web en Ecuador' : 'Why choose us for your website in Ecuador',
  processH: es ? 'Nuestro proceso de trabajo' : 'Our work process',
  processSub: es ? 'Transparente, estructurado y sin sorpresas' : 'Transparent, structured and no surprises',
  faqH: es ? 'Preguntas frecuentes' : 'Frequently asked questions',
  ctaH: es ? '¿Listo para tener tu sitio web?' : 'Ready to get your website?',
  ctaSub: es ? 'Cuéntanos tu proyecto y te respondemos en menos de 24 horas con una propuesta.' : "Tell us about your project and we'll respond in under 24 hours with a proposal.",
  ctaBtn: es ? 'Iniciar proyecto' : 'Start project',
  crossH: es ? '¿NECESITAS MÁS QUE UN SITIO WEB?' : 'NEED MORE THAN A WEBSITE?',
  crossT: es ? 'Desarrollo de Sistemas a Medida' : 'Custom Systems Development',
  crossD: es ? 'Automatización de procesos, ERPs, CRMs, portales y aplicaciones web complejas. Con React, Node.js y arquitectura escalable.' : 'Process automation, ERPs, CRMs, portals and complex web apps. With React, Node.js and scalable architecture.',
  crossBtn: es ? 'Ver Desarrollo de Sistemas →' : 'See Systems Dev →',
};
---
<main style="padding-top:66px;background:#080E1C;min-height:100vh">
  <!-- HERO -->
  <section class="relative overflow-hidden border-b border-white/[0.04] px-6 py-16 md:py-[72px]">
    <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse 55% 65% at 50% 30%,rgba(37,99,235,.12),transparent 70%)"></div>
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(59,130,246,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(59,130,246,.03) 1px,transparent 1px);background-size:50px 50px"></div>
    <div class="relative z-[2] mx-auto grid max-w-[1160px] grid-cols-1 items-center gap-10 md:grid-cols-[1.05fr_1fr] md:gap-14">
      <div>
        <span class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#3B82F6]/20 bg-[#3B82F6]/[0.08] px-3.5 py-[5px] font-body text-[11px] font-bold uppercase tracking-[2.5px] text-[#3B82F6]">
          <svg viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="2" class="h-3 w-3"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
          {T.eyebrow}
        </span>
        <h1 class="mb-[22px] font-display text-[clamp(2.4rem,4.5vw,3.8rem)] font-bold leading-[1.05] tracking-tight text-white">
          {T.h1}<br /><span class="text-slate-600">{T.h1b}</span>
        </h1>
        <p class="mb-3.5 max-w-[480px] font-body text-base leading-[1.75] text-slate-400">{T.sub}</p>
        <a href={devsysHref} class="mb-8 inline-block border-b border-dashed border-slate-600 pb-px font-body text-xs text-slate-500 no-underline">{T.sistLink}</a>
        <div class="flex flex-wrap gap-3">
          <a href="#planes" class="rounded-lg border-none bg-[#3B82F6] px-6 py-3 font-display text-[15px] font-semibold text-white no-underline shadow-[0_0_24px_rgba(59,130,246,.3)] transition-colors hover:bg-[#2563EB]">{T.cta1}</a>
          <a href={contactoHref} class="rounded-lg border border-white/[0.15] bg-transparent px-6 py-3 font-display text-[15px] font-semibold text-slate-300 no-underline transition-colors hover:text-white">{T.cta2}</a>
        </div>
      </div>

      <!-- Browser mockup -->
      <div class="relative">
        <div class="pointer-events-none absolute -inset-5 rounded-full" style="background:radial-gradient(ellipse at 50% 50%,rgba(59,130,246,.12),transparent 70%)"></div>
        <div class="relative overflow-hidden rounded-2xl border border-[#3B82F6]/20 bg-[#0C1525]/95 shadow-[0_32px_64px_rgba(0,0,0,.5)]">
          <div class="flex items-center gap-2.5 border-b border-white/[0.06] bg-[#060B18]/90 px-4 py-3">
            <div class="flex gap-1.5">
              {['#FF5F56', '#FFBD2E', '#27C93F'].map((c) => <div class="h-2.5 w-2.5 rounded-full" style={`background:${c}`}></div>)}
            </div>
            <div class="flex flex-1 items-center gap-1.5 rounded-md bg-white/[0.06] px-3 py-1 font-body text-[11px] text-slate-600">
              <div class="h-2 w-2 shrink-0 rounded-full bg-[#22C55E]"></div>
              tutienda.com
            </div>
            <div class="font-body text-[10px] text-slate-700">WooCommerce</div>
          </div>
          <div style="background:linear-gradient(135deg,#1e3a5f,#0f2340)" class="border-b border-white/[0.05] px-5 pb-4 pt-5">
            <div class="mb-1 font-display text-[11px] font-bold text-white">🛍️ {es ? 'Tu Tienda Online' : 'Your Online Store'}</div>
            <div class="mb-2.5 font-body text-[10px] text-white/40">{es ? 'Diseñada y desarrollada por Terranode' : 'Designed and developed by Terranode'}</div>
            <div class="flex gap-1.5">
              <div class="rounded bg-[#3B82F6] px-3 py-1 font-display text-[10px] font-bold text-white">{es ? 'Ver Catálogo' : 'View Catalog'}</div>
              <div class="rounded border border-white/20 px-3 py-1 font-display text-[10px] text-white/60">{es ? 'Contactar' : 'Contact'}</div>
            </div>
          </div>
          <div class="px-4 py-3.5">
            <div class="mb-2.5 font-body text-[9px] font-bold uppercase tracking-[2px] text-slate-600">{es ? 'PRODUCTOS DESTACADOS' : 'FEATURED PRODUCTS'}</div>
            <div class="grid grid-cols-3 gap-2">
              {[{ name: es ? 'Producto A' : 'Product A', price: '$29.99', badge: es ? 'Nuevo' : 'New' }, { name: es ? 'Producto B' : 'Product B', price: '$49.99', badge: es ? 'Popular' : 'Popular' }, { name: es ? 'Producto C' : 'Product C', price: '$19.99', badge: es ? 'Oferta' : 'Sale' }].map((prod) => (
                <div class="overflow-hidden rounded-lg border border-white/[0.06] bg-white/[0.03]">
                  <div class="flex h-[50px] items-center justify-center text-lg" style="background:linear-gradient(135deg,rgba(59,130,246,.15),rgba(139,92,246,.1))">🏷</div>
                  <div class="p-2">
                    <div class="mb-0.5 font-body text-[9px] text-slate-500">{prod.name}</div>
                    <div class="flex items-center justify-between">
                      <span class="font-display text-[11px] font-bold text-[#60A5FA]">{prod.price}</span>
                      <span class="rounded bg-[#22C55E]/10 px-1 font-body text-[8px] text-[#22C55E]">{prod.badge}</span>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
          <div class="flex justify-between border-t border-white/[0.05] px-4 py-2.5">
            {[['📦', es ? '142 pedidos' : '142 orders'], ['💰', '$8,450'], ['⭐', '4.9 / 5']].map(([ic, v]) => (
              <div class="text-center">
                <div class="text-xs">{ic}</div>
                <div class="mt-0.5 font-body text-[9px] text-slate-500">{v}</div>
              </div>
            ))}
          </div>
        </div>
        <div class="absolute -right-3 -top-3 rounded-lg border border-[#3B82F6]/30 bg-[#0C1525]/95 px-3 py-2 shadow-[0_8px_24px_rgba(0,0,0,.4)]">
          <div class="font-display text-[11px] font-bold text-white">✅ {es ? 'SEO incluido' : 'SEO included'}</div>
        </div>
        <div class="absolute -bottom-2.5 -left-3.5 rounded-lg border border-[#22C55E]/25 bg-[#0C1525]/95 px-3 py-2 shadow-[0_8px_24px_rgba(0,0,0,.4)]">
          <div class="font-display text-[11px] font-bold text-[#22C55E]">🚀 {es ? 'Entrega en 15 días' : '15-day delivery'}</div>
        </div>
      </div>
    </div>
  </section>

  <!-- PLANS -->
  <section id="planes" class="bg-[#060B18] px-6 py-[72px]">
    <div class="mx-auto max-w-[1160px]">
      <header class="an mb-10">
        <p class="mb-3.5 font-body text-[11px] font-bold uppercase tracking-[2.5px] text-[#3B82F6]">{T.plansTag}</p>
        <h2 class="mb-1.5 font-display text-[clamp(1.8rem,3vw,2.5rem)] font-bold tracking-tight text-white">{T.plansH}</h2>
        <p class="font-body text-sm text-slate-500">{T.plansSub}</p>
      </header>
      <div class="grid grid-cols-1 gap-3.5 sm:grid-cols-2 lg:grid-cols-4">
        {PLANS.map((plan, i) => (
          <article class={`an d${i + 1} relative flex flex-col rounded-2xl p-[22px]`} style={plan.popular ? 'background:rgba(59,130,246,.07);border:1px solid rgba(59,130,246,.35)' : 'background:rgba(255,255,255,.025);border:1px solid rgba(255,255,255,.07)'}>
            {plan.popular && <div class="absolute right-3.5 top-3.5 rounded-full bg-[#3B82F6] px-2.5 py-0.5 font-display text-[11px] font-bold text-white">{T.popular}</div>}
            <div class="mb-1 font-display text-[15px] font-bold text-white">{plan.name}</div>
            <div class="mb-[18px] font-body text-xs leading-snug text-slate-500">{plan.tagline}</div>
            <div class="mb-1 flex items-baseline gap-1.5">
              <span class="font-display font-bold tracking-tight text-white" style={`font-size:${plan.price.includes('$') ? '30px' : '24px'}`}>{plan.price}</span>
            </div>
            {plan.period && <div class="mb-5 font-body text-[11px] text-slate-600">{plan.period}</div>}
            <a href={contactoHref} class={`mb-5 block rounded-lg py-2.5 text-center font-display text-[13px] font-semibold text-white no-underline ${plan.period ? '' : 'mt-4'}`} style={plan.popular ? 'background:#3B82F6;border:1px solid transparent' : 'background:transparent;border:1px solid rgba(255,255,255,.14)'}>{T.quote}</a>
            <ul class="mt-auto flex list-none flex-col gap-[7px]">
              {plan.feats.map((f) => (
                <li class="flex items-start gap-2 font-body text-[11.5px] text-slate-400">
                  <svg viewBox="0 0 16 16" fill="none" stroke="#3B82F6" stroke-width="2" class="mt-0.5 h-[13px] w-[13px] shrink-0"><polyline points="2,8 6,12 14,4"/></svg>
                  {f}
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- TECH STACK -->
  <section class="bg-[#060B18] px-6 pb-[72px]">
    <div class="mx-auto max-w-[1160px]">
      <h3 class="an mb-5 text-center font-body text-[11px] font-bold uppercase tracking-[2.5px] text-slate-600">{T.stackH}</h3>
      <div class="flex flex-wrap justify-center gap-2.5">
        {STACK.map((tech, i) => (
          <div class={`an d${(i % 4) + 1} rounded-[10px] px-5 py-2.5 font-display text-[13px] font-semibold text-slate-300`} style={`background:${tech.color}12;border:1px solid ${tech.color}30`}>{tech.name}</div>
        ))}
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="border-t border-white/[0.04] bg-[#080E1C] px-6 py-[72px]">
    <div class="mx-auto max-w-[1160px]">
      <h2 class="an mb-10 text-center font-display text-[clamp(1.8rem,3vw,2.5rem)] font-bold tracking-tight text-white">{T.featsH}</h2>
      <div class="grid grid-cols-1 gap-3.5 sm:grid-cols-2 lg:grid-cols-4">
        {FEATS.map((f, i) => (
          <div class={`an d${(i % 4) + 1} rounded-2xl border border-white/[0.07] bg-white/[0.025] p-5`}>
            <div class="mb-3.5 flex h-11 w-11 items-center justify-center rounded-xl bg-[#3B82F6]/10">
              <svg viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="1.8" class="h-[22px] w-[22px]" set:html={ICONS[f.icon]}></svg>
            </div>
            <div class="mb-2 font-display text-sm font-semibold text-white">{f.t}</div>
            <p class="font-body text-xs leading-relaxed text-slate-500">{f.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="border-t border-white/[0.04] bg-[#060B18] px-6 py-[72px]">
    <div class="mx-auto max-w-[1160px]">
      <div class="an mb-12 text-center">
        <h2 class="mb-2 font-display text-[clamp(1.8rem,3vw,2.5rem)] font-bold tracking-tight text-white">{T.processH}</h2>
        <p class="font-body text-sm text-slate-500">{T.processSub}</p>
      </div>
      <div class="grid grid-cols-1 gap-3.5 md:grid-cols-3">
        {PROCESS.map((step, i) => (
          <div class={`an d${(i % 3) + 1} rounded-2xl border border-white/[0.07] bg-white/[0.025] p-6`}>
            <div class="mb-2.5 font-display text-[28px] font-extrabold tracking-tight text-[#3B82F6]/20">{step.n}</div>
            <div class="mb-2 font-display text-[15px] font-bold text-white">{step.t}</div>
            <p class="font-body text-xs leading-[1.65] text-slate-500">{step.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Intro / contenido SEO -->
  <section class="border-t border-white/[0.04] bg-[#060B18] px-6 py-16">
    <div class="mx-auto max-w-[820px]">
      <h2 class="mb-4 font-display text-[clamp(1.5rem,2.6vw,2rem)] font-bold tracking-tight text-white">{T.introH}</h2>
      <p class="font-body text-[15px] leading-[1.8] text-slate-400">{T.introBody}</p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-white/[0.04] bg-[#080E1C] px-6 pt-[72px]">
    <div class="mx-auto max-w-[760px]">
      <h2 class="an mb-10 text-center font-display text-[clamp(1.8rem,3vw,2.5rem)] font-bold tracking-tight text-white">{T.faqH}</h2>
      <div class="flex flex-col gap-2">
        {FAQ.map((item) => (
          <div class="dw-faq-item overflow-hidden rounded-xl border border-white/[0.07] bg-white/[0.025]">
            <button type="button" class="dw-faq-btn flex w-full items-center justify-between gap-4 border-none bg-transparent px-5 py-[18px] text-left">
              <span class="font-display text-sm font-semibold text-white">{item.q}</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="#4A6A88" stroke-width="2" class="dw-faq-chevron h-4 w-4 shrink-0 transition-transform"><path d="m6 9 6 6 6-6"/></svg>
            </button>
            <div class="dw-faq-answer hidden border-t border-white/[0.05] px-5 pb-[18px] pt-3 font-body text-[13px] leading-[1.7] text-slate-500">{item.a}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CROSS-SELL -->
  <section class="bg-[#080E1C] px-6 py-12">
    <div class="mx-auto max-w-[1160px]">
      <div class="an grid grid-cols-1 items-center gap-6 rounded-2xl border border-white/[0.07] bg-white/[0.025] p-7 md:grid-cols-[1fr_auto]">
        <div>
          <div class="mb-2 font-body text-[11px] font-bold uppercase tracking-[2px] text-[#3B82F6]">{T.crossH}</div>
          <div class="mb-1.5 font-display text-[17px] font-bold text-white">{T.crossT}</div>
          <p class="font-body text-[13px] text-slate-500">{T.crossD}</p>
        </div>
        <a href={devsysHref} class="shrink-0 whitespace-nowrap rounded-lg border border-[#3B82F6] bg-transparent px-[22px] py-[11px] font-display text-sm font-semibold text-[#3B82F6] no-underline">{T.crossBtn}</a>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="bg-[#080E1C] px-6 pb-24">
    <div class="mx-auto max-w-[1160px]">
      <div class="an relative overflow-hidden rounded-2xl border border-[#3B82F6]/20 p-8 text-center md:p-[52px]" style="background:linear-gradient(135deg,rgba(59,130,246,.1),rgba(37,99,235,.05))">
        <div class="pointer-events-none absolute inset-0" style="background-image:radial-gradient(circle at 50% 50%,rgba(59,130,246,.08),transparent 70%)"></div>
        <div class="relative z-[2]">
          <h2 class="mb-3 font-display text-[clamp(1.6rem,3vw,2.4rem)] font-bold tracking-tight text-white">{T.ctaH}</h2>
          <p class="mx-auto mb-8 max-w-[480px] font-body text-[15px] text-slate-400">{T.ctaSub}</p>
          <div class="flex flex-wrap justify-center gap-3">
            <a href={contactoHref} class="rounded-lg bg-[#3B82F6] px-7 py-[13px] font-display text-[15px] font-semibold text-white no-underline shadow-[0_0_28px_rgba(59,130,246,.35)]">{T.ctaBtn}</a>
            <a href="#planes" class="rounded-lg border border-white/20 bg-transparent px-7 py-[13px] font-display text-[15px] font-semibold text-slate-300 no-underline">{T.cta1}</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</main>

<script>
  document.querySelectorAll('.dw-faq-item').forEach((item) => {
    const btn = item.querySelector('.dw-faq-btn');
    const answer = item.querySelector('.dw-faq-answer');
    const chevron = item.querySelector('.dw-faq-chevron') as HTMLElement | null;
    btn?.addEventListener('click', () => {
      const isOpen = !answer?.classList.contains('hidden');
      answer?.classList.toggle('hidden', isOpen);
      if (chevron) chevron.style.transform = isOpen ? 'none' : 'rotate(180deg)';
    });
  });
</script>
