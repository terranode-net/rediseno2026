---
interface Props {
  locale: 'es' | 'en';
}
const { locale } = Astro.props;
const es = locale === 'es';
const BL = '#3B82F6';

const FLAG: Record<string, string> = { us: '🇺🇸', ec: '🇪🇨' };

const REGIONS = Astro.props.regions ?? [];
const DEFAULT_REGION = REGIONS[0]?.id ?? '';

const PLANS = Astro.props.plans ?? [];

const OS_LIST = ['Ubuntu 22.04', 'Ubuntu 20.04', 'Debian 12', 'CentOS 7', 'Rocky Linux 9', 'AlmaLinux 9', 'Arch Linux', 'Fedora 39', 'Windows Server 2022'];

const FEATS = es ? [
  { icon: 'nvme', t: 'NVMe DDR4', d: 'Hasta 10x más rápido que SATA SSD.' },
  { icon: 'bolt', t: 'Deploy en 60s', d: 'Servidor listo en menos de 60 segundos.' },
  { icon: 'root', t: 'Full Root Access', d: 'Instala cualquier software sin restricciones.' },
  { icon: 'net', t: 'Puerto 10 Gbps', d: 'Puerto dedicado de 10 Gbps incluido.' },
  { icon: 'snap', t: 'Snapshots', d: 'Respaldos o rollbacks con un clic.' },
  { icon: 'panel', t: 'Panel VirtFusion', d: 'Gestión de SO, reinicios y estadísticas.' },
  { icon: 'ip', t: 'IPv4 + IPv6', d: 'IP dedicada incluida en todos los planes.' },
  { icon: 'ddos', t: 'DDoS 160 Gbps', d: 'Protección automática ante ataques.' },
] : [
  { icon: 'nvme', t: 'NVMe DDR4', d: 'Up to 10x faster than SATA SSD.' },
  { icon: 'bolt', t: 'Deploy in 60s', d: 'Server ready in under 60 seconds.' },
  { icon: 'root', t: 'Full Root Access', d: 'Install any software with no restrictions.' },
  { icon: 'net', t: '10 Gbps Port', d: 'Dedicated 10 Gbps port included.' },
  { icon: 'snap', t: 'Snapshots', d: 'One-click backups or rollbacks.' },
  { icon: 'panel', t: 'VirtFusion Panel', d: 'Manage OS, reboots and stats.' },
  { icon: 'ip', t: 'IPv4 + IPv6', d: 'Dedicated IP included on every plan.' },
  { icon: 'ddos', t: 'DDoS 160 Gbps', d: 'Automatic protection against attacks.' },
];

const FAQ = es ? [
  { q: '¿Puedo reinstalar el SO desde el panel?', a: 'Sí. Desde VirtFusion puedes reinstalar el SO en cualquier momento en menos de 5 minutos.' },
  { q: '¿Los backups están incluidos?', a: 'Los backups automáticos son opcionales. Puedes crear snapshots manuales desde el panel.' },
  { q: '¿Todos los planes están en todas las regiones?', a: 'No. Los planes de mayor capacidad (TNS-07, TNS-08) solo están en Ashburn. Selecciona tu región para ver los planes disponibles.' },
  { q: '¿Puedo escalar mi plan más adelante?', a: 'Sí. Actualiza a un plan mayor desde el panel de cliente sin migración ni tiempo de inactividad.' },
  { q: '¿Qué es Full Root Access?', a: 'Acceso SSH root completo: instala cualquier software, modifica configuraciones del kernel y controla todo.' },
] : [
  { q: 'Can I reinstall the OS from the panel?', a: 'Yes. From VirtFusion you can reinstall the OS at any time in under 5 minutes.' },
  { q: 'Are backups included?', a: 'Automatic backups are optional. You can create manual snapshots from the panel.' },
  { q: 'Are all plans available in every region?', a: 'No. Higher-capacity plans (TNS-07, TNS-08) are only available in Ashburn. Select your region to see available plans.' },
  { q: 'Can I scale my plan later?', a: 'Yes. Upgrade to a bigger plan from the client panel with no migration or downtime.' },
  { q: 'What is Full Root Access?', a: 'Full root SSH access: install any software, modify kernel configuration and control everything.' },
];

const T = {
  h1: es ? 'Servidores VPS de' : 'High-performance',
  h1b: es ? 'alto rendimiento' : 'VPS Servers',
  sub: es ? 'Virtualización KVM con NVMe DDR4 y deploy en 60 segundos. Elige tu región.' : 'KVM virtualization with NVMe DDR4 and deploy in 60 seconds. Choose your region.',
  regionH: es ? 'Región de despliegue' : 'Compute Region',
  regionSub: es ? 'Elige dónde se aloja tu servidor' : 'Choose where your server is hosted',
  plansTag: es ? 'PLANES' : 'PLANS',
  plansH: es ? 'Elige tu VPS' : 'Choose your VPS',
  plansSub: es ? 'Root access completo, 10 Gbps y DDoS 160 Gbps en todos los planes' : 'Full root access, 10 Gbps and DDoS 160 Gbps on all plans',
  deploy: es ? 'Desplegar' : 'Deploy',
  popular: es ? 'Popular' : 'Popular',
  cards: es ? 'Tarjetas' : 'Cards',
  table: es ? 'Tabla' : 'Table',
  noplans: es ? 'Sin planes en esta región' : 'No plans in this region',
  featsH: es ? '¿Por qué Terranode VPS?' : 'Why Terranode VPS?',
  panelH: es ? 'Panel VirtFusion' : 'VirtFusion Panel',
  panelD: es ? 'Gestiona reinicios, SO, estadísticas y snapshots con un clic.' : 'Manage reboots, OS, stats and snapshots with one click.',
  faqH: es ? 'Preguntas frecuentes' : 'FAQ',
  tbH: es ? ['Plan', 'CPU', 'RAM', 'Almacenamiento', 'Ancho de Banda', 'Puerto', 'Precio', ''] : ['Plan', 'CPU', 'RAM', 'Storage', 'Bandwidth', 'Port', 'Price', ''],
  online: es ? 'En línea' : 'Online',
  plansAvail: es ? 'planes disponibles' : 'plans available',
  latency: es ? 'latencia' : 'latency',
  contactSales: es ? 'Contactar ventas →' : 'Contact sales →',
  viewPlans: es ? 'Ver planes' : 'View plans',
  talkSales: es ? 'Hablar con ventas' : 'Talk to sales',
  osTag: es ? 'SISTEMAS OPERATIVOS' : 'OPERATING SYSTEMS',
  osH: es ? 'Elige el SO que necesitas' : 'Choose the OS you need',
  customIso: es ? '+ ISO personalizada' : '+ Custom ISO',
  panelFeats: es ? ['Reinstalar SO', 'Snapshots', 'Consola VNC', 'Estadísticas', 'Reboot', 'Firewall'] : ['Reinstall OS', 'Snapshots', 'VNC Console', 'Statistics', 'Reboot', 'Firewall'],
};

const ICONS: Record<string, string> = {
  nvme: '<rect x="2" y="6" width="20" height="12" rx="2"/><path d="M6 12h4M14 12h4" stroke-linecap="round"/><circle cx="12" cy="12" r="1" fill="currentColor"/>',
  bolt: '<path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke-linecap="round" stroke-linejoin="round"/>',
  root: '<rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>',
  net: '<path d="M5 12H19M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>',
  snap: '<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/>',
  panel: '<rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/>',
  ip: '<circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10A15.3 15.3 0 0 1 8 12a15.3 15.3 0 0 1 4-10z"/>',
  ddos: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
};

const contactoHref = `/${locale}/${es ? 'contacto' : 'contact'}`;
---
<main style="padding-top:66px;background:#080E1C;min-height:100vh">
  <!-- HERO -->
  <section class="relative overflow-hidden border-b border-white/[0.04] px-6 py-16 md:py-[72px]">
    <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse 55% 65% at 50% 30%,rgba(37,99,235,.12),transparent 70%)"></div>
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(59,130,246,.035) 1px,transparent 1px),linear-gradient(90deg,rgba(59,130,246,.035) 1px,transparent 1px);background-size:50px 50px"></div>
    <div class="relative z-[2] mx-auto grid max-w-[1160px] grid-cols-1 items-center gap-10 md:grid-cols-[1.1fr_1fr] md:gap-[60px]">
      <div>
        <span class="mb-6 inline-flex items-center gap-2 rounded-full border border-[#3B82F6]/20 bg-[#3B82F6]/[0.08] px-3.5 py-[5px] font-body text-[11px] font-bold uppercase tracking-[2.5px] text-[#3B82F6]">
          <svg viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="2" class="h-3 w-3"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/></svg>
          VPS Server
        </span>
        <h1 class="mb-1 font-display text-[clamp(2.2rem,4vw,3.6rem)] font-bold leading-[1.05] tracking-tight text-white">{T.h1}</h1>
        <h2 class="mb-[22px] font-display text-[clamp(2.2rem,4vw,3.6rem)] font-bold leading-[1.05] tracking-tight text-slate-600">{T.h1b}</h2>
        <p class="mb-8 max-w-[460px] font-body text-base leading-[1.7] text-slate-400">{T.sub}</p>
        <div class="flex flex-wrap gap-3">
          <a href="#planes" class="rounded-lg border-none bg-[#3B82F6] px-6 py-3 font-display text-[15px] font-semibold text-white no-underline shadow-[0_0_24px_rgba(59,130,246,.3)] transition-colors hover:bg-[#2563EB]">{T.viewPlans}</a>
          <a href={contactoHref} class="rounded-lg border border-white/[0.15] bg-transparent px-6 py-3 font-display text-[15px] font-semibold text-slate-300 no-underline transition-colors hover:text-white">{T.talkSales}</a>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-3.5 rounded-2xl border border-white/[0.08] bg-white/[0.03] p-7">
        {[['KVM', es ? 'Virtualización' : 'Virtualization'], ['NVMe', es ? 'Almacenamiento' : 'Storage'], ['60s', 'Deploy'], ['10 Gbps', es ? 'Puerto' : 'Port'], ['160 Gbps', 'DDoS'], ['24/7', es ? 'Soporte' : 'Support']].map(([v, l]) => (
          <div class="rounded-[10px] border border-[#3B82F6]/10 bg-[#3B82F6]/5 px-4 py-3.5">
            <div class="font-display text-xl font-bold tracking-tight text-white">{v}</div>
            <div class="mt-0.5 font-body text-[11px] text-slate-600">{l}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- REGION SELECTOR + PLANS -->
  <section id="planes" class="bg-[#060B18] px-6 py-14 md:py-[72px]">
    <div class="mx-auto max-w-[1160px]">
      <div class="mb-5">
        <div class="mb-4 flex items-baseline gap-3">
          <h3 class="m-0 font-display text-[17px] font-bold text-white">{T.regionH}</h3>
          <span class="font-body text-xs text-slate-600">{T.regionSub}</span>
        </div>
        <div id="region-grid" class="grid grid-cols-2 gap-2.5 sm:grid-cols-3 lg:grid-cols-5">
          {REGIONS.map((r) => (
            <button
              type="button"
              class="region-btn rounded-xl border p-3.5 text-left transition-all"
              data-region={r.id}
              style={r.id === DEFAULT_REGION ? 'background:rgba(59,130,246,.1);border-color:rgba(59,130,246,.45)' : 'background:rgba(255,255,255,.025);border-color:rgba(255,255,255,.07)'}
            >
              <div class="mb-1.5 flex items-center gap-2">
                <span class="text-lg">{FLAG[r.country] || '🌐'}</span>
                <div class="h-1.5 w-1.5 rounded-full" style={r.status === 'online' ? 'background:#22C55E' : 'background:#EF4444'}></div>
              </div>
              <div class="region-name font-display text-[13px] font-bold leading-tight" style={r.id === DEFAULT_REGION ? 'color:#60A5FA' : 'color:#fff'}>{r.name}</div>
              <div class="mt-[3px] font-body text-[11px] text-slate-600">{r.ping} {T.latency}</div>
            </button>
          ))}
        </div>
        <div id="region-status" class="mt-3 flex items-center gap-2 font-body text-xs">
          <div class="h-1.5 w-1.5 rounded-full bg-[#22C55E] shadow-[0_0_5px_#22C55E]"></div>
          <span class="font-bold text-[#22C55E]">{T.online}</span>
          <span class="text-slate-600">·</span>
          <span id="region-status-name" class="text-slate-500">Ashburn, VA</span>
          <span class="text-slate-600">·</span>
          <span id="region-status-count" class="text-slate-500">8 {T.plansAvail}</span>
        </div>
      </div>

      <div class="mb-5 flex flex-wrap items-end justify-between gap-4 border-t border-white/[0.05] pt-6">
        <div>
          <p class="mb-3.5 font-body text-[11px] font-bold uppercase tracking-[2.5px] text-[#3B82F6]">{T.plansTag}</p>
          <h2 class="mb-1 font-display text-[clamp(1.8rem,3vw,2.5rem)] font-bold tracking-tight text-white">{T.plansH}</h2>
          <p class="font-body text-[13px] text-slate-500">{T.plansSub}</p>
        </div>
        <div class="flex shrink-0 gap-1 rounded-lg bg-white/[0.04] p-1">
          <button type="button" id="view-cards-btn" class="view-btn rounded-md border px-4 py-1.5 font-body text-xs" style="background:rgba(59,130,246,.2);border-color:rgba(59,130,246,.4);color:#60A5FA">{T.cards}</button>
          <button type="button" id="view-table-btn" class="view-btn rounded-md border border-transparent px-4 py-1.5 font-body text-xs text-slate-600">{T.table}</button>
        </div>
      </div>

      <div id="plans-empty" class="hidden rounded-2xl border border-white/[0.06] bg-white/[0.02] p-12 text-center">
        <div class="mb-3 text-3xl">🔧</div>
        <div class="mb-2 font-display text-base font-semibold text-white">{T.noplans}</div>
        <a href={contactoHref} class="font-body text-[13px] text-[#3B82F6]">{T.contactSales}</a>
      </div>

      <div id="plans-cards" class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-4">
        {PLANS.map((p) => (
          <article class="plan-card relative flex flex-col rounded-2xl p-[22px_18px]" data-regions={p.regions.join(',')} style={p.popular ? 'background:rgba(59,130,246,.08);border:1px solid rgba(59,130,246,.35)' : 'background:rgba(255,255,255,.025);border:1px solid rgba(255,255,255,.07)'}>
            {p.popular && <div class="absolute right-3 top-3 rounded-full bg-[#3B82F6] px-2 py-0.5 font-display text-[10px] font-bold text-white">{T.popular}</div>}
            <div class="mb-3.5 font-display text-[15px] font-bold text-white">{p.name}</div>
            <div class="mb-4 grid grid-cols-2 gap-1.5">
              {[['CPU', p.cpu], ['RAM', p.ram], [es ? 'Disco' : 'Disk', p.disk], ['BW', p.bw]].map(([k, v]) => (
                <div class="rounded-md bg-white/[0.04] px-2 py-1.5">
                  <div class="font-body text-[10px] text-slate-600">{k}</div>
                  <div class="font-display text-[11px] font-semibold text-slate-300">{v}</div>
                </div>
              ))}
            </div>
            <div class="mb-3.5 font-display text-[28px] font-bold tracking-tight text-white">
              {p.price}<span class="text-xs font-normal text-slate-600">/{es ? 'mes' : 'mo'}</span>
            </div>
            <a href={p.href} target="_blank" rel="noopener noreferrer" class="mt-auto block rounded-lg py-2.5 text-center font-display text-[13px] font-semibold text-white no-underline" style={p.popular ? 'background:#3B82F6;border:1px solid transparent' : 'background:transparent;border:1px solid rgba(255,255,255,.14)'}>{T.deploy}</a>
          </article>
        ))}
      </div>

      <div id="plans-table" class="hidden overflow-x-auto">
        <table class="w-full border-collapse font-body text-[13px]">
          <thead>
            <tr class="border-b border-white/[0.08]">
              {T.tbH.map((h) => <th class="whitespace-nowrap px-4 py-3 text-left text-[11px] font-bold uppercase tracking-wide text-slate-600">{h}</th>)}
            </tr>
          </thead>
          <tbody>
            {PLANS.map((p, i) => (
              <tr class="plan-row border-b border-white/[0.04]" data-regions={p.regions.join(',')} style={p.popular ? 'background:rgba(59,130,246,.05)' : i % 2 === 0 ? 'background:rgba(255,255,255,.01)' : ''}>
                <td class="px-4 py-3.5 font-display font-bold">
                  <span class="text-white">{p.name}</span>
                  {p.popular && <span class="ml-1.5 rounded-full bg-[#3B82F6] px-1.5 py-px text-[10px] font-bold text-white">{T.popular}</span>}
                </td>
                <td class="px-4 py-3.5 text-slate-300">{p.cpu}</td>
                <td class="px-4 py-3.5 text-slate-300">{p.ram}</td>
                <td class="px-4 py-3.5 text-slate-300">{p.disk}</td>
                <td class="px-4 py-3.5 text-slate-300">{p.bw}</td>
                <td class="px-4 py-3.5 text-slate-300">10 Gbps</td>
                <td class="px-4 py-3.5 font-display font-bold text-[#60A5FA]">{p.price}<span class="font-normal text-slate-600">/{es ? 'mes' : 'mo'}</span></td>
                <td class="px-4 py-3.5">
                  <a href={p.href} target="_blank" rel="noopener noreferrer" class="rounded-md bg-[#3B82F6] px-3.5 py-1.5 font-display text-xs font-semibold text-white no-underline">{T.deploy}</a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- OS -->
  <section class="bg-[#060B18] px-6 pb-14">
    <div class="mx-auto max-w-[1160px]">
      <div class="rounded-2xl border border-white/[0.07] bg-white/[0.025] p-7 md:p-8">
        <p class="mb-1.5 font-body text-[11px] font-bold uppercase tracking-[2.5px] text-[#3B82F6]">{T.osTag}</p>
        <h3 class="mb-[18px] font-display text-[17px] font-bold text-white">{T.osH}</h3>
        <div class="flex flex-wrap gap-2">
          {OS_LIST.map((os) => (
            <span class="rounded-lg border border-white/[0.07] bg-white/[0.04] px-3.5 py-1.5 font-body text-xs text-slate-500">{os}</span>
          ))}
          <span class="rounded-lg border border-[#3B82F6]/20 bg-[#3B82F6]/[0.07] px-3.5 py-1.5 font-body text-xs text-[#3B82F6]">{T.customIso}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="border-t border-white/[0.04] bg-[#080E1C] px-6 py-[72px]">
    <div class="mx-auto max-w-[1160px]">
      <h2 class="an mb-10 text-center font-display text-[clamp(1.8rem,3vw,2.5rem)] font-bold tracking-tight text-white">{T.featsH}</h2>
      <div class="grid grid-cols-1 gap-3.5 sm:grid-cols-2 lg:grid-cols-4">
        {FEATS.map((f, i) => (
          <div class={`an d${(i % 4) + 1} rounded-2xl border border-white/[0.07] bg-white/[0.025] p-5`}>
            <div class="mb-3.5 flex h-11 w-11 items-center justify-center rounded-xl bg-[#3B82F6]/10">
              <svg viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="1.8" class="h-[22px] w-[22px]" set:html={ICONS[f.icon]}></svg>
            </div>
            <div class="mb-2 font-display text-sm font-semibold text-white">{f.t}</div>
            <p class="font-body text-xs leading-relaxed text-slate-500">{f.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Panel -->
  <section class="bg-[#080E1C] px-6 pb-[72px]">
    <div class="mx-auto max-w-[1160px]">
      <div class="grid grid-cols-1 items-center gap-8 rounded-[16px] border border-white/[0.07] bg-white/[0.025] p-8 md:grid-cols-2 md:gap-10 md:p-10">
        <div>
          <p class="mb-3.5 font-body text-[11px] font-bold uppercase tracking-[2.5px] text-[#3B82F6]">VIRTFUSION</p>
          <h3 class="mb-3.5 font-display text-[clamp(1.4rem,2.2vw,2rem)] font-bold tracking-tight text-white">{T.panelH}</h3>
          <p class="mb-5 font-body text-sm leading-[1.75] text-slate-500">{T.panelD}</p>
          <div class="flex flex-wrap gap-2">
            {T.panelFeats.map((f) => (
              <span class="rounded-md border border-white/[0.07] bg-white/[0.04] px-2.5 py-1 font-body text-[11px] text-slate-500">{f}</span>
            ))}
          </div>
        </div>
        <div class="rounded-xl border border-[#3B82F6]/[0.15] bg-[#060B18]/80 p-5 font-body text-xs">
          <div class="mb-4 flex gap-1.5">
            {['#FF5F56', '#FFBD2E', '#27C93F'].map((c) => <div class="h-[11px] w-[11px] rounded-full" style={`background:${c}`}></div>)}
          </div>
          {[['status', 'running', '#22C55E'], ['region', 'Ashburn, VA', '#CBD5E1'], ['CPU', '12%', '#60A5FA'], ['RAM', '1.2 / 4 GB', '#60A5FA'], ['Disk', '18 / 40 GB NVMe', '#60A5FA'], ['Network', '↑ 2.1MB ↓ 5.8MB/s', '#A78BFA']].map(([l, v, c]) => (
            <div class="flex justify-between border-b border-white/[0.05] py-[5px]">
              <span class="text-slate-600">{l}</span>
              <span class="font-bold" style={`color:${c}`}>{v}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-white/[0.04] bg-[#060B18] px-6 pb-24">
    <div class="mx-auto max-w-[760px] pt-[72px]">
      <h2 class="an mb-10 text-center font-display text-[clamp(1.8rem,3vw,2.5rem)] font-bold tracking-tight text-white">{T.faqH}</h2>
      <div class="flex flex-col gap-2">
        {FAQ.map((item, i) => (
          <div class="vps-faq-item overflow-hidden rounded-xl border border-white/[0.07] bg-white/[0.025]">
            <button type="button" class="vps-faq-btn flex w-full items-center justify-between gap-4 border-none bg-transparent px-5 py-[18px] text-left">
              <span class="font-display text-sm font-semibold text-white">{item.q}</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="#4A6A88" stroke-width="2" class="vps-faq-chevron h-4 w-4 shrink-0 transition-transform"><path d="m6 9 6 6 6-6"/></svg>
            </button>
            <div class="vps-faq-answer hidden border-t border-white/[0.05] px-5 pb-[18px] pt-3 font-body text-[13px] leading-[1.7] text-slate-500">{item.a}</div>
          </div>
        ))}
      </div>
    </div>
  </section>
</main>

<script define:vars={{ DEFAULT_REGION }}>
  // Region filter
  const regionButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('.region-btn'));
  const planCards = Array.from(document.querySelectorAll<HTMLElement>('.plan-card'));
  const planRows = Array.from(document.querySelectorAll<HTMLElement>('.plan-row'));
  const cardsWrap = document.getElementById('plans-cards');
  const tableWrap = document.getElementById('plans-table');
  const emptyState = document.getElementById('plans-empty');
  const statusName = document.getElementById('region-status-name');
  const statusCount = document.getElementById('region-status-count');
  const regionData: Record<string, string> = {};
  regionButtons.forEach((btn) => {
    regionData[btn.dataset.region ?? ''] = btn.querySelector('.region-name')?.textContent ?? '';
  });

  let currentRegion = DEFAULT_REGION;
  let currentView: 'cards' | 'table' = 'cards';

  function applyRegion(region: string) {
    currentRegion = region;
    regionButtons.forEach((btn) => {
      const active = btn.dataset.region === region;
      const nameEl = btn.querySelector('.region-name') as HTMLElement | null;
      btn.style.background = active ? 'rgba(59,130,246,.1)' : 'rgba(255,255,255,.025)';
      btn.style.borderColor = active ? 'rgba(59,130,246,.45)' : 'rgba(255,255,255,.07)';
      if (nameEl) nameEl.style.color = active ? '#60A5FA' : '#fff';
    });
    if (statusName) statusName.textContent = regionData[region] ?? '';

    let visibleCount = 0;
    planCards.forEach((card) => {
      const regions = (card.dataset.regions ?? '').split(',');
      const show = regions.includes(region);
      card.style.display = show ? 'flex' : 'none';
      if (show) visibleCount++;
    });
    planRows.forEach((row) => {
      const regions = (row.dataset.regions ?? '').split(',');
      row.style.display = regions.includes(region) ? '' : 'none';
    });
    if (statusCount) statusCount.textContent = `${visibleCount} ${document.documentElement.lang === 'es' ? 'planes disponibles' : 'plans available'}`;

    if (emptyState && cardsWrap && tableWrap) {
      if (visibleCount === 0) {
        emptyState.classList.remove('hidden');
        cardsWrap.classList.add('hidden');
        tableWrap.classList.add('hidden');
      } else {
        emptyState.classList.add('hidden');
        applyView(currentView);
      }
    }
  }

  function applyView(view: 'cards' | 'table') {
    currentView = view;
    const cardsBtn = document.getElementById('view-cards-btn');
    const tableBtn = document.getElementById('view-table-btn');
    if (cardsWrap && tableWrap) {
      cardsWrap.classList.toggle('hidden', view !== 'cards');
      tableWrap.classList.toggle('hidden', view !== 'table');
    }
    [cardsBtn, tableBtn].forEach((btn) => {
      if (!btn) return;
      const active = btn.id === `view-${view}-btn`;
      btn.style.background = active ? 'rgba(59,130,246,.2)' : 'transparent';
      btn.style.borderColor = active ? 'rgba(59,130,246,.4)' : 'transparent';
      btn.style.color = active ? '#60A5FA' : '#4A6A88';
    });
  }

  regionButtons.forEach((btn) => {
    btn.addEventListener('click', () => applyRegion(btn.dataset.region ?? DEFAULT_REGION));
  });
  document.getElementById('view-cards-btn')?.addEventListener('click', () => applyView('cards'));
  document.getElementById('view-table-btn')?.addEventListener('click', () => applyView('table'));

  applyRegion(DEFAULT_REGION);
  applyView('cards');

  // FAQ accordion
  document.querySelectorAll('.vps-faq-item').forEach((item) => {
    const btn = item.querySelector('.vps-faq-btn');
    const answer = item.querySelector('.vps-faq-answer');
    const chevron = item.querySelector('.vps-faq-chevron') as HTMLElement | null;
    btn?.addEventListener('click', () => {
      const isOpen = !answer?.classList.contains('hidden');
      answer?.classList.toggle('hidden', isOpen);
      if (chevron) chevron.style.transform = isOpen ? 'none' : 'rotate(180deg)';
    });
  });
</script>
