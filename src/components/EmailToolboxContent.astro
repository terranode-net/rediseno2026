---
interface Props { locale: 'es' | 'en' }
const { locale } = Astro.props;
const es = locale === 'es';

const TOOLS = es ? [
  { id: 'mx', icon: '📨', label: 'MX Lookup', placeholder: 'ejemplo: terranode.net', hint: 'Registros de correo del dominio' },
  { id: 'spf', icon: '✉️', label: 'SPF Check', placeholder: 'ejemplo: terranode.net', hint: 'Política de remitentes autorizados' },
  { id: 'dkim', icon: '🔑', label: 'DKIM Check', placeholder: 'selector:dominio.com', hint: 'ej: google:terranode.net' },
  { id: 'dmarc', icon: '🛡️', label: 'DMARC Check', placeholder: 'ejemplo: terranode.net', hint: 'Política de autenticación de correo' },
  { id: 'blacklist', icon: '🚫', label: 'Blacklist Check', placeholder: 'IP o dominio', hint: 'Verifica listas negras de spam' },
  { id: 'dns', icon: '🔍', label: 'DNS Lookup', placeholder: 'dominio o IP', hint: 'Cualquier tipo de registro DNS' },
  { id: 'ptr', icon: '↩️', label: 'PTR / rDNS', placeholder: 'ejemplo: 1.2.3.4', hint: 'Reverse DNS lookup de una IP' },
  { id: 'headers', icon: '📋', label: 'Analizar Cabeceras', placeholder: '', hint: 'Pega las cabeceras de un email' },
  { id: 'smtp', icon: '🔌', label: 'SMTP Diagnostics', placeholder: 'ejemplo: mail.terranode.net', hint: 'Registros SMTP y TLS del dominio' },
] : [
  { id: 'mx', icon: '📨', label: 'MX Lookup', placeholder: 'e.g: terranode.net', hint: "Domain's mail records" },
  { id: 'spf', icon: '✉️', label: 'SPF Check', placeholder: 'e.g: terranode.net', hint: 'Authorized sender policy' },
  { id: 'dkim', icon: '🔑', label: 'DKIM Check', placeholder: 'selector:domain.com', hint: 'e.g: google:terranode.net' },
  { id: 'dmarc', icon: '🛡️', label: 'DMARC Check', placeholder: 'e.g: terranode.net', hint: 'Email authentication policy' },
  { id: 'blacklist', icon: '🚫', label: 'Blacklist Check', placeholder: 'IP or domain', hint: 'Check spam blacklists' },
  { id: 'dns', icon: '🔍', label: 'DNS Lookup', placeholder: 'domain or IP', hint: 'Any DNS record type' },
  { id: 'ptr', icon: '↩️', label: 'PTR / rDNS', placeholder: 'e.g: 1.2.3.4', hint: 'Reverse DNS lookup of an IP' },
  { id: 'headers', icon: '📋', label: 'Analyze Headers', placeholder: '', hint: 'Paste an email\u2019s headers' },
  { id: 'smtp', icon: '🔌', label: 'SMTP Diagnostics', placeholder: 'e.g: mail.terranode.net', hint: 'SMTP and TLS records for the domain' },
];

const T = es ? {
  eyebrow: '📧 Herramienta gratuita',
  h1a: 'Email & DNS', h1b: 'Toolbox',
  sub: 'MX, SPF, DKIM, DMARC, Blacklist, DNS, PTR, análisis de cabeceras y diagnóstico SMTP — todo en un solo lugar.',
  headerPlaceholder: 'Pega aquí las cabeceras completas del email',
  verify: 'Verificar →', checking: 'Consultando...', analyze: 'Analizar cabeceras →', analyzing: 'Analizando...',
  errDomain: 'Ingresa un dominio o IP', errHeaders: 'Pega las cabeceras del email', errDkimFmt: 'Formato: selector:dominio.com', errNoIp: 'No se pudo resolver el dominio a IP',
} : {
  eyebrow: '📧 Free tool',
  h1a: 'Email & DNS', h1b: 'Toolbox',
  sub: 'MX, SPF, DKIM, DMARC, Blacklist, DNS, PTR, header analysis and SMTP diagnostics — all in one place.',
  headerPlaceholder: "Paste the email's full headers here",
  verify: 'Check →', checking: 'Querying...', analyze: 'Analyze headers →', analyzing: 'Analyzing...',
  errDomain: 'Enter a domain or IP', errHeaders: 'Paste the email headers', errDkimFmt: 'Format: selector:domain.com', errNoIp: 'Could not resolve domain to IP',
};
---
<main style="padding-top:66px;background:#080E1C;min-height:100vh">
  <section class="relative overflow-hidden border-b border-white/[0.05] px-6 py-14">
    <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse 50% 70% at 50% 0%,rgba(37,99,235,.12),transparent 70%)"></div>
    <div class="relative z-[1] mx-auto max-w-[900px] text-center">
      <div class="mb-4.5 inline-flex items-center gap-2 rounded-full border border-[#3B82F6]/[0.22] bg-[#3B82F6]/[0.08] px-4 py-[5px] font-body text-[11px] font-bold uppercase tracking-[2px] text-[#3B82F6]">{T.eyebrow}</div>
      <h1 class="mb-3.5 font-display text-[clamp(1.8rem,4vw,2.8rem)] font-bold leading-[1.08] tracking-tight text-white">{T.h1a} <span class="text-[#3B82F6]">{T.h1b}</span></h1>
      <p class="mx-auto max-w-[580px] font-body text-[15px] leading-[1.7] text-slate-400">{T.sub}</p>
    </div>
  </section>

  <div class="mx-auto max-w-[1100px] px-6 py-8 md:py-24">
    <div id="et-tabs" class="mb-6 flex flex-wrap gap-1.5">
      {TOOLS.map((tool, i) => (
        <button
          type="button"
          class="et-tab flex items-center gap-1.5 rounded-lg border px-3.5 py-[7px] font-body text-xs font-semibold transition-colors"
          data-tool={tool.id}
          style={i === 0 ? 'background:rgba(59,130,246,.12);border-color:rgba(59,130,246,.4);color:#3B82F6' : 'background:rgba(255,255,255,.04);border-color:rgba(255,255,255,.08);color:#4A6A88'}
        >
          <span>{tool.icon}</span><span>{tool.label}</span>
        </button>
      ))}
    </div>

    <div class="mb-2 rounded-2xl border border-white/[0.07] bg-white/[0.025] p-6">
      <div id="et-current-title" class="mb-1 font-display text-[15px] font-bold text-white"></div>
      <p id="et-current-hint" class="mb-4 font-body text-xs text-slate-600"></p>

      <textarea id="et-header-input" placeholder={T.headerPlaceholder} class="hidden min-h-[160px] w-full resize-y rounded-[10px] border border-white/10 bg-white/[0.05] p-3.5 font-mono text-[11px] leading-relaxed text-slate-400 outline-none"></textarea>

      <div id="et-input-row" class="flex gap-2.5">
        <select id="et-dns-type" class="hidden shrink-0 rounded-lg border border-white/[0.12] bg-white/[0.06] px-3.5 py-2.5 font-body text-[13px] text-white outline-none">
          {['A', 'AAAA', 'MX', 'TXT', 'CNAME', 'NS', 'SOA', 'CAA', 'SRV', 'PTR'].map((t) => <option value={t} class="bg-[#0C1525]">{t}</option>)}
        </select>
        <input id="et-input" type="text" class="flex-1 rounded-[10px] border border-white/10 bg-white/[0.05] px-4 py-2.5 font-body text-sm text-white outline-none" />
        <button id="et-run-btn" class="shrink-0 rounded-[10px] border-none bg-[#3B82F6] px-7 py-2.5 font-display text-sm font-bold text-white disabled:opacity-70">{T.verify}</button>
      </div>
      <button id="et-run-headers-btn" class="mt-2.5 hidden rounded-lg border-none bg-[#3B82F6] px-6 py-2.5 font-display text-[13px] font-bold text-white disabled:opacity-70">{T.analyze}</button>
    </div>

    <div id="et-error" class="mb-2 hidden rounded-[10px] border border-red-500/20 bg-red-500/[0.07] px-4 py-3 font-body text-sm text-red-400"></div>
    <div id="et-result" class="mt-4"></div>
  </div>
</main>

<script define:vars={{ TOOLS, T, es }}>
  const DOH = 'https://dns.google/resolve';
  const RBLS = ['zen.spamhaus.org', 'bl.spamcop.net', 'b.barracudacentral.org', 'dnsbl.sorbs.net', 'psbl.surriel.com', 'ix.dnsbl.manitu.net', 'dnsbl-1.uceprotect.net', 'spam.dnsbl.sorbs.net', 'bl.0spam.org', 'truncate.gbudb.net', 'dnsbl.dronebl.org', 'all.s5h.net', 'rbl.metunet.com', 'bogons.cymru.com', 'db.wpbl.info'];

  const GR = '#22C55E', RD = '#EF4444', YW = '#F59E0B', BL = '#3B82F6', DIM = '#6B8CAE', MUT = '#4A6A88', W = '#fff';

  let currentTool = 'mx';
  const tabs = document.getElementById('et-tabs');
  const titleEl = document.getElementById('et-current-title');
  const hintEl = document.getElementById('et-current-hint');
  const headerInput = document.getElementById('et-header-input');
  const inputRow = document.getElementById('et-input-row');
  const dnsTypeSel = document.getElementById('et-dns-type');
  const mainInput = document.getElementById('et-input');
  const runBtn = document.getElementById('et-run-btn');
  const runHeadersBtn = document.getElementById('et-run-headers-btn');
  const errorEl = document.getElementById('et-error');
  const resultEl = document.getElementById('et-result');

  function selectTool(id) {
    currentTool = id;
    const tool = TOOLS.find((t) => t.id === id);
    titleEl.textContent = `${tool.icon} ${tool.label}`;
    hintEl.textContent = tool.hint;
    mainInput.placeholder = tool.placeholder;
    mainInput.value = '';
    errorEl.classList.add('hidden');
    resultEl.innerHTML = '';

    tabs.querySelectorAll('.et-tab').forEach((btn) => {
      const active = btn.dataset.tool === id;
      btn.style.background = active ? 'rgba(59,130,246,.12)' : 'rgba(255,255,255,.04)';
      btn.style.borderColor = active ? 'rgba(59,130,246,.4)' : 'rgba(255,255,255,.08)';
      btn.style.color = active ? '#3B82F6' : '#4A6A88';
    });

    if (id === 'headers') {
      headerInput.classList.remove('hidden');
      inputRow.classList.add('hidden');
      runHeadersBtn.classList.remove('hidden');
    } else {
      headerInput.classList.add('hidden');
      inputRow.classList.remove('hidden');
      runHeadersBtn.classList.add('hidden');
      dnsTypeSel.classList.toggle('hidden', id !== 'dns');
    }
  }
  tabs.querySelectorAll('.et-tab').forEach((btn) => btn.addEventListener('click', () => selectTool(btn.dataset.tool)));

  async function dnsQuery(name, type) {
    const url = `${DOH}?name=${encodeURIComponent(name)}&type=${type}`;
    const res = await fetch(url, { headers: { Accept: 'application/dns-json' } });
    if (!res.ok) throw new Error('DNS query failed');
    return res.json();
  }
  function extractTxt(data) {
    return (data.Answer || []).filter((r) => r.type === 16).map((r) => r.data.replace(/^"|"$/g, '').replace(/"\s*"/g, ''));
  }
  function badge(ok, label) {
    const c = ok === true ? GR : ok === false ? RD : YW;
    const icon = ok === true ? '✓' : ok === false ? '✗' : '⚠';
    return `<span style="display:inline-flex;align-items:center;gap:5px;font-family:'Metrophobic',sans-serif;font-size:11px;font-weight:700;color:${c};background:${c}12;border:1px solid ${c}30;border-radius:100px;padding:3px 10px;flex-shrink:0">${icon} ${label}</span>`;
  }
  function recordRow(type, value, ttl, extra) {
    return `<div style="display:grid;grid-template-columns:60px 1fr auto;gap:10px;padding:10px 14px;border-bottom:1px solid rgba(255,255,255,.04);font-size:12px;font-family:'Metrophobic',sans-serif;align-items:start">
      <span style="color:${BL};font-weight:700;font-family:'Instrument Sans',sans-serif">${type}</span>
      <span style="color:${DIM};word-break:break-all;line-height:1.5">${value}${extra ? `<span style="color:${MUT}"> ${extra}</span>` : ''}</span>
      ${ttl ? `<span style="color:${MUT};flex-shrink:0">${ttl}s</span>` : '<span></span>'}
    </div>`;
  }
  function resultHeader(icon, title, badgeHtml) {
    return `<div style="display:flex;align-items:center;justify-content:space-between;padding:12px 16px;background:rgba(255,255,255,.02);border-bottom:1px solid rgba(255,255,255,.05)">
      <div style="display:flex;align-items:center;gap:8px"><span>${icon}</span><span style="font-family:'Instrument Sans',sans-serif;font-size:13px;font-weight:700;color:${W}">${title}</span></div>
      ${badgeHtml}
    </div>`;
  }
  function box(inner) {
    return `<div style="background:rgba(255,255,255,.025);border:1px solid rgba(255,255,255,.07);border-radius:12px;overflow:hidden;margin-top:16px">${inner}</div>`;
  }

  function parseHeaders(raw) {
    const lines = raw.replace(/\r\n/g, '\n').replace(/\r/g, '\n').split('\n');
    const headers = {};
    let current = '';
    lines.forEach((line) => {
      if (/^[A-Za-z0-9-]+:/.test(line)) {
        const idx = line.indexOf(':');
        current = line.slice(0, idx).toLowerCase();
        headers[current] = (headers[current] || '') + line.slice(idx + 1).trim();
      } else if (/^\s+/.test(line) && current) {
        headers[current] += ' ' + line.trim();
      }
    });
    return headers;
  }
  function extractHops(raw) {
    const received = [];
    const regex = /Received:\s*([\s\S]*?)(?=Received:|$)/gi;
    let m;
    while ((m = regex.exec(raw)) !== null) received.push(m[1].trim());
    return received.slice(0, 8);
  }

  function renderResult(R) {
    if (R.type === 'mx') {
      resultEl.innerHTML = box(
        resultHeader('📨', `MX — ${R.domain}`, badge(R.records.length > 0, `${R.records.length} ${es ? 'registros' : 'records'}`)) +
        (R.records.length === 0
          ? `<div style="padding:16px;font-family:'Metrophobic',sans-serif;font-size:13px;color:${RD}">${es ? 'No se encontraron registros MX.' : 'No MX records found.'}</div>`
          : R.records.map((r) => recordRow('MX', r.host, r.ttl, `p${r.prio}`)).join(''))
      );
    } else if (R.type === 'spf') {
      let inner = resultHeader('✉️', `SPF — ${R.domain}`, badge(R.found, R.found ? (es ? 'SPF encontrado' : 'SPF found') : (es ? 'Sin SPF' : 'No SPF')));
      if (!R.found) {
        inner += `<div style="padding:16px 18px"><p style="font-family:'Metrophobic',sans-serif;font-size:13px;color:${RD};margin:0">${es ? 'No se encontró registro SPF.' : 'No SPF record found.'}</p></div>`;
      } else {
        inner += recordRow('SPF', R.raw);
        const mechs = R.mechanisms.map((m) => `<span style="font-family:monospace;font-size:12px;color:${BL};background:rgba(59,130,246,.08);padding:2px 8px;border-radius:4px;margin-right:6px">${m}</span>`).join('');
        const policyColor = R.policy.includes('-all') ? GR : R.policy.includes('~all') ? YW : RD;
        inner += `<div style="padding:14px 18px">${mechs}<div style="margin-top:8px;font-family:'Metrophobic',sans-serif;font-size:12px;color:${W}">${es ? 'Política' : 'Policy'}: <span style="color:${policyColor}">${R.policy}</span></div></div>`;
      }
      resultEl.innerHTML = box(inner);
    } else if (R.type === 'dkim') {
      let inner = resultHeader('🔑', `DKIM — ${R.selector}._domainkey.${R.domain}`, badge(R.found, R.found ? (es ? 'DKIM encontrado' : 'DKIM found') : (es ? 'Sin DKIM' : 'No DKIM')));
      if (!R.found) {
        inner += `<div style="padding:16px 18px"><p style="font-family:'Metrophobic',sans-serif;font-size:13px;color:${RD};margin:0">${es ? `No se encontró DKIM para el selector "${R.selector}".` : `No DKIM found for selector "${R.selector}".`}</p></div>`;
      } else {
        inner += Object.entries(R.tags).map(([k, v]) => recordRow(k.toUpperCase(), k === 'p' ? v.substring(0, 60) + '...' : v)).join('');
      }
      resultEl.innerHTML = box(inner);
    } else if (R.type === 'dmarc') {
      const p = R.parsed;
      let inner = resultHeader('🛡️', `DMARC — _dmarc.${R.domain}`, badge(R.found, R.found ? (es ? 'DMARC encontrado' : 'DMARC found') : (es ? 'Sin DMARC' : 'No DMARC')));
      if (!R.found) {
        inner += `<div style="padding:16px 18px"><p style="font-family:'Metrophobic',sans-serif;font-size:13px;color:${RD};margin:0">${es ? 'No se encontró registro DMARC.' : 'No DMARC record found.'}</p></div>`;
      } else {
        inner += recordRow('DMARC', R.raw);
        const items = [
          { k: es ? 'Política (p)' : 'Policy (p)', v: p.p, ok: p.p === 'reject' ? true : p.p === 'quarantine' ? null : false },
          { k: es ? 'Reporte rua' : 'Report (rua)', v: p.rua ? '✓ ' + p.rua : (es ? 'No configurado' : 'Not set'), ok: !!p.rua },
          { k: es ? '% aplicación' : '% enforcement', v: (p.pct || '100') + '%', ok: null },
        ];
        inner += `<div style="padding:14px 18px;display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:10px">${items.map((item) => `<div style="background:rgba(255,255,255,.03);border-radius:8px;padding:10px 12px"><div style="font-family:'Metrophobic',sans-serif;font-size:10px;color:${MUT};margin-bottom:3px">${item.k}</div><div style="font-family:'Instrument Sans',sans-serif;font-size:13px;font-weight:700;color:${item.ok === true ? GR : item.ok === false ? RD : DIM}">${item.v || '—'}</div></div>`).join('')}</div>`;
      }
      resultEl.innerHTML = box(inner);
    } else if (R.type === 'blacklist') {
      const listed = R.results.filter((r) => r.listed);
      const clean = R.results.filter((r) => !r.listed);
      let inner = resultHeader('🚫', `Blacklist — ${R.ip}`, badge(listed.length === 0, listed.length === 0 ? (es ? 'Limpio' : 'Clean') : `${es ? 'En' : 'On'} ${listed.length} ${es ? 'listas' : 'lists'}`));
      if (listed.length > 0) {
        inner += `<div style="padding:12px 16px;background:rgba(239,68,68,.06)"><div style="font-family:'Instrument Sans',sans-serif;font-size:12px;font-weight:700;color:${RD};margin-bottom:8px">🚨 ${es ? 'En listas negras' : 'On blacklists'} (${listed.length})</div>${listed.map((r) => `<div style="font-family:monospace;font-size:12px;color:${RD};margin-bottom:3px">✗ ${r.rbl}</div>`).join('')}</div>`;
      }
      inner += `<div style="padding:12px 16px"><div style="font-family:'Instrument Sans',sans-serif;font-size:12px;font-weight:700;color:${GR};margin-bottom:8px">✓ ${es ? 'Listas limpias' : 'Clean lists'} (${clean.length}/${R.results.length})</div><div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:4px">${clean.map((r) => `<div style="font-family:'Metrophobic',sans-serif;font-size:11px;color:${MUT}">✓ ${r.rbl}</div>`).join('')}</div></div>`;
      resultEl.innerHTML = box(inner);
    } else if (R.type === 'dns') {
      resultEl.innerHTML = box(
        resultHeader('🔍', `${R.recordType} — ${R.domain}`, badge(R.records.length > 0, `${R.records.length} ${es ? 'resultado(s)' : 'result(s)'}`)) +
        (R.records.length === 0
          ? `<div style="padding:16px;font-family:'Metrophobic',sans-serif;font-size:13px;color:${MUT}">${es ? `No se encontraron registros ${R.recordType}.` : `No ${R.recordType} records found.`}</div>`
          : R.records.map((r) => recordRow(R.recordType, r.data, r.ttl)).join(''))
      );
    } else if (R.type === 'ptr') {
      resultEl.innerHTML = box(
        resultHeader('↩️', `rDNS — ${R.ip}`, badge(R.records.length > 0, R.records.length > 0 ? (es ? 'PTR encontrado' : 'PTR found') : (es ? 'Sin PTR' : 'No PTR'))) +
        (R.records.length === 0
          ? `<div style="padding:16px 18px"><p style="font-family:'Metrophobic',sans-serif;font-size:12px;color:${YW};margin:0">${es ? 'No hay registro PTR para esta IP.' : 'No PTR record for this IP.'}</p></div>`
          : R.records.map((r) => recordRow('PTR', r.ptr, r.ttl)).join(''))
      );
    } else if (R.type === 'headers') {
      const items = [
        { label: es ? 'De' : 'From', val: R.from },
        { label: es ? 'Fecha' : 'Date', val: R.date },
        { label: 'Message-ID', val: R.messageId },
        { label: 'Return-Path', val: R.returnPath },
      ].filter((i) => i.val);
      let inner = resultHeader('📋', es ? 'Análisis de Cabeceras' : 'Header Analysis', `<div style="display:flex;gap:6px">${badge(R.spfOk, 'SPF')}${badge(R.dkimOk, 'DKIM')}${badge(R.dmarcOk, 'DMARC')}</div>`);
      inner += `<div style="padding:16px 18px;display:grid;grid-template-columns:1fr 1fr;gap:10px">${items.map((item) => `<div style="background:rgba(255,255,255,.03);border-radius:8px;padding:10px 12px"><div style="font-family:'Metrophobic',sans-serif;font-size:10px;color:${MUT};margin-bottom:2px">${item.label}</div><div style="font-family:'Metrophobic',sans-serif;font-size:12px;color:${DIM};word-break:break-all">${item.val}</div></div>`).join('')}</div>`;
      if (R.hops.length > 0) {
        inner += `<div style="border-top:1px solid rgba(255,255,255,.05);padding:14px 18px"><div style="font-family:'Instrument Sans',sans-serif;font-size:12px;font-weight:700;color:${W};margin-bottom:10px">${es ? 'Ruta del mensaje' : 'Message route'} (${R.hops.length} ${es ? 'saltos' : 'hops'})</div>${R.hops.map((h, i) => `<div style="display:flex;gap:10px;margin-bottom:8px"><span style="font-family:'Instrument Sans',sans-serif;font-size:10px;font-weight:700;color:${BL};background:rgba(59,130,246,.1);border-radius:50%;width:20px;height:20px;display:flex;align-items:center;justify-content:center;flex-shrink:0">${i + 1}</span><span style="font-family:'Metrophobic',sans-serif;font-size:11px;color:${MUT};line-height:1.5;word-break:break-all">${h.substring(0, 200)}</span></div>`).join('')}</div>`;
      }
      resultEl.innerHTML = box(inner);
    } else if (R.type === 'smtp') {
      let inner = resultHeader('🔌', `SMTP — ${R.domain}`, `<div style="display:flex;gap:6px;flex-wrap:wrap">${badge(R.spfOk, 'SPF')}${badge(R.dmarcOk, 'DMARC')}${badge(R.dkimFound.length > 0, 'DKIM')}${badge(R.mtaOk, 'MTA-STS')}</div>`);
      inner += `<div style="padding:14px 18px"><div style="font-family:'Instrument Sans',sans-serif;font-size:12px;font-weight:700;color:${W};margin-bottom:8px">📨 ${es ? 'Servidores MX' : 'MX Servers'}</div>${R.mxRecs.map((r) => `<div style="font-family:monospace;font-size:12px;color:${DIM};margin-bottom:4px">p${r.prio} ${r.host}</div>`).join('')}`;
      const rows = [
        { ok: R.spfOk, label: 'SPF', detail: R.spfTxt ? R.spfTxt.substring(0, 60) + '...' : (es ? 'Falta registro SPF' : 'Missing SPF record') },
        { ok: R.dmarcOk, label: 'DMARC', detail: R.dmarcTxt ? R.dmarcTxt.substring(0, 60) + '...' : `${es ? 'Falta' : 'Missing'} _dmarc.${R.domain}` },
        { ok: R.dkimFound.length > 0, label: 'DKIM', detail: R.dkimFound.length > 0 ? `${es ? 'Selectores' : 'Selectors'}: ${R.dkimFound.join(', ')}` : (es ? 'No se encontraron selectores DKIM comunes' : 'No common DKIM selectors found') },
        { ok: R.mtaOk, label: 'MTA-STS', detail: R.mtaTxt || (es ? 'No configurado' : 'Not configured') },
      ];
      inner += `<div style="margin-top:14px;display:flex;flex-direction:column;gap:8px">${rows.map((item) => `<div style="display:flex;gap:10px;padding:10px 12px;background:rgba(255,255,255,.03);border-radius:8px"><span style="font-size:14px;flex-shrink:0">${item.ok ? '✅' : '❌'}</span><div><div style="font-family:'Instrument Sans',sans-serif;font-size:13px;font-weight:600;color:${item.ok ? GR : RD};margin-bottom:2px">${item.label}</div><div style="font-family:'Metrophobic',sans-serif;font-size:11px;color:${MUT}">${item.detail}</div></div></div>`).join('')}</div></div>`;
      resultEl.innerHTML = box(inner);
    }
  }

  async function run() {
    errorEl.classList.add('hidden');
    resultEl.innerHTML = '';
    const val = mainInput.value.trim();
    const header = headerInput.value;

    if (currentTool !== 'headers' && !val) { errorEl.textContent = T.errDomain; errorEl.classList.remove('hidden'); return; }
    if (currentTool === 'headers' && !header.trim()) { errorEl.textContent = T.errHeaders; errorEl.classList.remove('hidden'); return; }

    runBtn.disabled = true;
    runHeadersBtn.disabled = true;
    const label = currentTool === 'headers' ? T.analyzing : T.checking;
    if (currentTool === 'headers') runHeadersBtn.textContent = label; else runBtn.textContent = label;

    try {
      if (currentTool === 'mx') {
        const data = await dnsQuery(val, 'MX');
        const records = (data.Answer || []).filter((r) => r.type === 15).sort((a, b) => parseInt(a.data) - parseInt(b.data)).map((r) => { const [prio, ...rest] = r.data.split(' '); return { prio, host: rest.join(' ').replace(/\.$/, ''), ttl: r.TTL }; });
        renderResult({ type: 'mx', domain: val, records });
      } else if (currentTool === 'spf') {
        const data = await dnsQuery(val, 'TXT');
        const txts = extractTxt(data);
        const spfRaw = txts.find((t) => t.toLowerCase().startsWith('v=spf1'));
        if (!spfRaw) renderResult({ type: 'spf', domain: val, found: false });
        else {
          const parts = spfRaw.split(/\s+/);
          const mechanisms = [];
          let policy = '?unknown';
          parts.forEach((p) => {
            if (p === 'v=spf1') return;
            if (p === '+all' || p === 'all') policy = es ? '⚠ +all (permite todo — peligroso)' : '⚠ +all (allows everything — dangerous)';
            else if (p === '~all') policy = '~all (softfail)';
            else if (p === '-all') policy = es ? '-all (fail ✓ recomendado)' : '-all (fail ✓ recommended)';
            else if (p === '?all') policy = es ? '?all (neutro)' : '?all (neutral)';
            else mechanisms.push(p);
          });
          renderResult({ type: 'spf', domain: val, found: true, mechanisms, policy, raw: spfRaw });
        }
      } else if (currentTool === 'dkim') {
        let selector = '', domain = val;
        if (val.includes(':')) [selector, domain] = val.split(':');
        if (!selector) { errorEl.textContent = T.errDkimFmt; errorEl.classList.remove('hidden'); throw 'stop'; }
        const lookup = `${selector}._domainkey.${domain}`;
        const data = await dnsQuery(lookup, 'TXT');
        const txts = extractTxt(data);
        const dkim = txts.find((t) => t.includes('p='));
        if (!dkim) renderResult({ type: 'dkim', domain, selector, found: false });
        else {
          const tags = {};
          dkim.split(';').forEach((t) => { const [k, v] = t.trim().split('='); if (k && v !== undefined) tags[k.trim()] = v.trim(); });
          renderResult({ type: 'dkim', domain, selector, found: true, tags });
        }
      } else if (currentTool === 'dmarc') {
        const data = await dnsQuery(`_dmarc.${val}`, 'TXT');
        const txts = extractTxt(data);
        const dmarc = txts.find((t) => t.toLowerCase().startsWith('v=dmarc1'));
        if (!dmarc) renderResult({ type: 'dmarc', domain: val, found: false });
        else {
          const tags = {};
          dmarc.split(';').forEach((t) => { const [k, v] = t.trim().split('='); if (k && v !== undefined) tags[k.trim().toLowerCase()] = v.trim(); });
          renderResult({ type: 'dmarc', domain: val, found: true, parsed: tags, raw: dmarc });
        }
      } else if (currentTool === 'blacklist') {
        let ip = val;
        if (!/^\d+\.\d+\.\d+\.\d+$/.test(val)) {
          const d = await dnsQuery(val, 'A');
          const a = (d.Answer || []).find((r) => r.type === 1);
          if (!a) { errorEl.textContent = T.errNoIp; errorEl.classList.remove('hidden'); throw 'stop'; }
          ip = a.data;
        }
        const rev = ip.split('.').reverse().join('.');
        const checks = await Promise.allSettled(RBLS.map(async (rbl) => {
          try { const d = await dnsQuery(`${rev}.${rbl}`, 'A'); return { rbl, listed: (d.Answer || []).some((r) => r.type === 1) }; }
          catch { return { rbl, listed: false }; }
        }));
        renderResult({ type: 'blacklist', ip, results: checks.map((r) => (r.status === 'fulfilled' ? r.value : { rbl: '?', listed: false })) });
      } else if (currentTool === 'dns') {
        const dnsType = dnsTypeSel.value;
        const data = await dnsQuery(val, dnsType);
        renderResult({ type: 'dns', domain: val, recordType: dnsType, records: (data.Answer || []).map((r) => ({ type: r.type, data: r.data, ttl: r.TTL })) });
      } else if (currentTool === 'ptr') {
        let lookup = val;
        if (/^\d+\.\d+\.\d+\.\d+$/.test(val)) lookup = val.split('.').reverse().join('.') + '.in-addr.arpa';
        const data = await dnsQuery(lookup, 'PTR');
        renderResult({ type: 'ptr', ip: val, records: (data.Answer || []).filter((r) => r.type === 12).map((r) => ({ ptr: r.data.replace(/\.$/, ''), ttl: r.TTL })) });
      } else if (currentTool === 'headers') {
        const h = parseHeaders(header);
        const auth = h['authentication-results'] || '';
        renderResult({
          type: 'headers', from: h['from'] || '', date: h['date'] || '', messageId: h['message-id'] || '', returnPath: h['return-path'] || '',
          spfOk: auth.includes('spf=pass'), dkimOk: auth.includes('dkim=pass'), dmarcOk: auth.includes('dmarc=pass'), hops: extractHops(header),
        });
      } else if (currentTool === 'smtp') {
        const mx = await dnsQuery(val, 'MX');
        const mxRecs = (mx.Answer || []).filter((r) => r.type === 15).sort((a, b) => parseInt(a.data) - parseInt(b.data)).map((r) => { const [p, ...h] = r.data.split(' '); return { prio: p, host: h.join(' ').replace(/\.$/, '') }; });
        const spfData = await dnsQuery(val, 'TXT');
        const spfTxt = extractTxt(spfData).find((t) => t.toLowerCase().startsWith('v=spf1'));
        const dmarcData = await dnsQuery(`_dmarc.${val}`, 'TXT');
        const dmarcTxt = extractTxt(dmarcData).find((t) => t.toLowerCase().startsWith('v=dmarc1'));
        const selectors = ['google', 'mail', 'default', 'selector1', 'selector2', 'dkim', 'k1', 's1', 's2', 'smtp'];
        const dkimChecks = await Promise.allSettled(selectors.map(async (sel) => {
          try { const d = await dnsQuery(`${sel}._domainkey.${val}`, 'TXT'); const t = extractTxt(d).find((x) => x.includes('p=')); return t ? { selector: sel, found: true } : { selector: sel, found: false }; }
          catch { return { selector: sel, found: false }; }
        }));
        const dkimFound = dkimChecks.filter((r) => r.status === 'fulfilled' && r.value.found).map((r) => r.value.selector);
        const mtaData = await dnsQuery(`_mta-sts.${val}`, 'TXT').catch(() => ({ Answer: [] }));
        const mtaTxt = extractTxt(mtaData).find((t) => t.includes('v=STSv1'));
        renderResult({ type: 'smtp', domain: val, mxRecs, spfTxt, spfOk: !!spfTxt, dmarcTxt, dmarcOk: !!dmarcTxt, dkimFound, mtaTxt, mtaOk: !!mtaTxt });
      }
    } catch (e) {
      if (e !== 'stop') {
        errorEl.textContent = `Error: ${e?.message || e}`;
        errorEl.classList.remove('hidden');
      }
    }

    runBtn.disabled = false;
    runHeadersBtn.disabled = false;
    runBtn.textContent = T.verify;
    runHeadersBtn.textContent = T.analyze;
  }

  runBtn.addEventListener('click', run);
  runHeadersBtn.addEventListener('click', run);
  mainInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') run(); });

  selectTool('mx');
</script>
