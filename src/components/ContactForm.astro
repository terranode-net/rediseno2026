---
import type { Locale } from '@/lib/site';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

const t = {
  es: {
    name: 'Nombre completo', email: 'Correo electrónico', phone: 'Teléfono (opcional)',
    company: 'Empresa (opcional)', service: 'Servicio de interés', message: 'Cuéntanos sobre tu proyecto',
    submit: 'Enviar mensaje', sending: 'Enviando...',
    success: '¡Gracias! Recibimos tu mensaje y te contactaremos muy pronto.',
    error: 'Hubo un problema al enviar tu mensaje. Intenta de nuevo o escríbenos directamente a',
    services: ['VPS', 'Hosting', 'Servidores Dedicados', 'Terramail', 'Microsoft 365', 'Otro'],
    placeholderMsg: 'Ej: Necesito migrar mi tienda WordPress con unas 5,000 visitas diarias...',
  },
  en: {
    name: 'Full name', email: 'Email address', phone: 'Phone (optional)',
    company: 'Company (optional)', service: 'Service of interest', message: 'Tell us about your project',
    submit: 'Send message', sending: 'Sending...',
    success: 'Thanks! We received your message and will get back to you shortly.',
    error: 'There was a problem sending your message. Please try again or email us directly at',
    services: ['VPS', 'Hosting', 'Dedicated Servers', 'Terramail', 'Microsoft 365', 'Other'],
    placeholderMsg: 'E.g: I need to migrate my WordPress store with about 5,000 daily visits...',
  },
}[locale];
---
<form id="contact-form" class="space-y-5" data-locale={locale}>
  <div class="grid gap-5 sm:grid-cols-2">
    <div>
      <label for="name" class="mb-1.5 block text-sm font-medium text-ink">{t.name}</label>
      <input id="name" name="name" type="text" required class="w-full rounded-xl border border-slate-200 px-4 py-3 text-sm outline-none transition-colors focus:border-accent" />
    </div>
    <div>
      <label for="email" class="mb-1.5 block text-sm font-medium text-ink">{t.email}</label>
      <input id="email" name="email" type="email" required class="w-full rounded-xl border border-slate-200 px-4 py-3 text-sm outline-none transition-colors focus:border-accent" />
    </div>
  </div>

  <div class="grid gap-5 sm:grid-cols-2">
    <div>
      <label for="phone" class="mb-1.5 block text-sm font-medium text-ink">{t.phone}</label>
      <input id="phone" name="phone" type="tel" class="w-full rounded-xl border border-slate-200 px-4 py-3 text-sm outline-none transition-colors focus:border-accent" />
    </div>
    <div>
      <label for="company" class="mb-1.5 block text-sm font-medium text-ink">{t.company}</label>
      <input id="company" name="company" type="text" class="w-full rounded-xl border border-slate-200 px-4 py-3 text-sm outline-none transition-colors focus:border-accent" />
    </div>
  </div>

  <div>
    <label for="service_interest" class="mb-1.5 block text-sm font-medium text-ink">{t.service}</label>
    <select id="service_interest" name="service_interest" required class="w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm outline-none transition-colors focus:border-accent">
      {t.services.map((s) => <option value={s}>{s}</option>)}
    </select>
  </div>

  <div>
    <label for="message" class="mb-1.5 block text-sm font-medium text-ink">{t.message}</label>
    <textarea id="message" name="message" required rows="4" placeholder={t.placeholderMsg} class="w-full rounded-xl border border-slate-200 px-4 py-3 text-sm outline-none transition-colors focus:border-accent"></textarea>
  </div>

  <!-- Honeypot anti-spam -->
  <input type="text" name="website" class="hidden" tabindex="-1" autocomplete="off" />

  <button
    type="submit"
    id="submit-btn"
    class="btn-primary w-full sm:w-auto"
    data-sending={t.sending}
    data-submit={t.submit}
  >
    <span data-label>{t.submit}</span>
  </button>

  <p
    id="form-feedback"
    class="hidden text-sm"
    role="status"
    data-success={t.success}
    data-error={t.error}
  ></p>
</form>

<script>
  import { supabase } from '@/lib/supabase';

  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const label = btn?.querySelector('[data-label]') as HTMLElement | null;
  const feedback = document.getElementById('form-feedback') as HTMLParagraphElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !btn) return;
    const data = new FormData(form);

    // Honeypot check — if filled, silently drop (likely a bot)
    if (data.get('website')) return;

    btn.disabled = true;
    if (label) label.textContent = btn.dataset.sending ?? '...';

    try {
      const { error } = await supabase.from('contacts').insert({
        name: data.get('name'),
        email: data.get('email'),
        phone: data.get('phone') || null,
        company: data.get('company') || null,
        service_interest: data.get('service_interest'),
        message: data.get('message'),
        locale: form.dataset.locale,
        source_page: window.location.pathname,
      });

      if (error) throw error;

      if (feedback) {
        feedback.textContent = feedback.dataset.success ?? 'OK';
        feedback.className = 'text-sm text-signal font-medium';
        feedback.classList.remove('hidden');
      }
      form.reset();
    } catch (err) {
      if (feedback) {
        feedback.textContent = `${feedback.dataset.error ?? 'Error'} hola@terranode.net`;
        feedback.className = 'text-sm text-red-600 font-medium';
        feedback.classList.remove('hidden');
      }
      console.error('Contact form error:', err);
    } finally {
      btn.disabled = false;
      if (label) label.textContent = btn.dataset.submit ?? 'Submit';
    }
  });
</script>
