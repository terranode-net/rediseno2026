---
interface Props { locale: 'es' | 'en' }
const { locale } = Astro.props;
const es = locale === 'es';
const contactoHref = `/${locale}/${es ? 'contacto' : 'contact'}`;

const PLANS = es ? [
  { id: 'exchange', popular: false, name: 'Exchange Online Plan 1', badge: null, price: '$5.50', period: '/mes/usuario', tagline: 'Correo empresarial con Outlook sin apps de escritorio', href: 'https://my.terranode.net', feats: ['Buzón de 50 GB por usuario', 'Mensajes hasta 150 MB', 'Outlook Web App', 'Bandeja de entrada prioritarios', 'Archivo automático de correos', 'Contactos y calendario compartido', 'Antispam y antimalware', 'Soporte Terranode 24/7'] },
  { id: 'basic', popular: false, name: 'Microsoft 365 Business Basic', badge: 'M365', price: '$7.20', period: '/mes/usuario', tagline: 'Productividad en la nube para todo tu equipo', href: 'https://my.terranode.net', feats: ['Buzón de 50 GB por usuario', '1 TB de almacenamiento en OneDrive', 'Teams: chat, llamadas y video', 'SharePoint colaborativo', '+10 aplicaciones (Planner, Forms, Bookings…)', 'Aplicaciones web de Office (Word, Excel, PP)', 'Antispam y antimalware', 'Soporte Terranode 24/7'] },
  { id: 'standard', popular: true, name: 'Microsoft 365 Business Standard', badge: 'M365', price: '$12.50', period: '/mes/usuario', tagline: 'Todo lo de Basic más las apps de escritorio descargables', href: 'https://my.terranode.net', feats: ['Todo lo del plan Business Basic', 'Word, Excel, PowerPoint y Outlook instalables', 'Hasta 5 PCs o Macs por usuario', 'Webinars con registro de asistentes', 'Microsoft Loop: espacios colaborativos', 'Microsoft Clipchamp: edición de video', 'Copilot (AI) disponible como add-on', 'Soporte Terranode 24/7 + migración gratis'] },
] : [
  { id: 'exchange', popular: false, name: 'Exchange Online Plan 1', badge: null, price: '$5.50', period: '/mo/user', tagline: 'Business email with Outlook, no desktop apps', href: 'https://my.terranode.net', feats: ['50 GB mailbox per user', 'Messages up to 150 MB', 'Outlook Web App', 'Focused Inbox', 'Automatic email archiving', 'Shared contacts and calendar', 'Antispam and antimalware', '24/7 Terranode support'] },
  { id: 'basic', popular: false, name: 'Microsoft 365 Business Basic', badge: 'M365', price: '$7.20', period: '/mo/user', tagline: 'Cloud productivity for your whole team', href: 'https://my.terranode.net', feats: ['50 GB mailbox per user', '1 TB OneDrive storage', 'Teams: chat, calls and video', 'Collaborative SharePoint', '10+ apps (Planner, Forms, Bookings…)', 'Web versions of Office (Word, Excel, PP)', 'Antispam and antimalware', '24/7 Terranode support'] },
  { id: 'standard', popular: true, name: 'Microsoft 365 Business Standard', badge: 'M365', price: '$12.50', period: '/mo/user', tagline: 'Everything in Basic plus downloadable desktop apps', href: 'https://my.terranode.net', feats: ['Everything in Business Basic', 'Installable Word, Excel, PowerPoint, Outlook', 'Up to 5 PCs or Macs per user', 'Webinars with attendee registration', 'Microsoft Loop: collaborative spaces', 'Microsoft Clipchamp: video editing', 'Copilot (AI) available as add-on', '24/7 Terranode support + free migration'] },
];

const APPS_SHOWCASE = es ? [
  { name: 'Teams', color: '#6264A7', desc: 'Chat, videollamadas, reuniones' },
  { name: 'Outlook', color: '#0078D4', desc: 'Correo, calendario, contactos' },
  { name: 'Word', color: '#2B5797', desc: 'Documentos y redacción' },
  { name: 'Excel', color: '#217346', desc: 'Hojas de cálculo y análisis' },
  { name: 'PowerPoint', color: '#B7472A', desc: 'Presentaciones profesionales' },
  { name: 'OneDrive', color: '#0078D4', desc: '1 TB almacenamiento en la nube' },
  { name: 'SharePoint', color: '#036C70', desc: 'Intranet y colaboración' },
  { name: 'Loop', color: '#7719AA', desc: 'Espacios colaborativos en tiempo real' },
] : [
  { name: 'Teams', color: '#6264A7', desc: 'Chat, video calls, meetings' },
  { name: 'Outlook', color: '#0078D4', desc: 'Email, calendar, contacts' },
  { name: 'Word', color: '#2B5797', desc: 'Documents and writing' },
  { name: 'Excel', color: '#217346', desc: 'Spreadsheets and analysis' },
  { name: 'PowerPoint', color: '#B7472A', desc: 'Professional presentations' },
  { name: 'OneDrive', color: '#0078D4', desc: '1 TB cloud storage' },
  { name: 'SharePoint', color: '#036C70', desc: 'Intranet and collaboration' },
  { name: 'Loop', color: '#7719AA', desc: 'Real-time collaborative spaces' },
];

const FEATS = es ? [
  { icon: 'partner', t: 'Partner Microsoft Certificado', d: 'Terranode es Partner oficial de Microsoft en Ecuador. Venta y soporte con respaldo directo.' },
  { icon: 'migrate', t: 'Migración Gratuita', d: 'Migramos tus correos desde Gmail, cPanel, Zoho u otro proveedor sin pérdida de datos ni tiempo de inactividad.' },
  { icon: 'support', t: 'Soporte en Español 24/7', d: 'Configuración, onboarding y soporte post-venta en español con equipo local en Ecuador.' },
  { icon: 'billing', t: 'Facturación en Ecuador', d: 'Factura electrónica válida para Ecuador. Sin complicaciones con pagos en dólares locales.' },
  { icon: 'secure', t: 'Seguridad Microsoft', d: 'Protección avanzada contra amenazas, antivirus y cumplimiento de normativas internacionales de datos.' },
  { icon: 'scale', t: 'Escala con tu empresa', d: 'Agrega o quita licencias en cualquier momento. Pago mensual o anual según lo que más te convenga.' },
] : [
  { icon: 'partner', t: 'Certified Microsoft Partner', d: 'Terranode is an official Microsoft Partner in Ecuador. Sales and support with direct backing.' },
  { icon: 'migrate', t: 'Free Migration', d: 'We migrate your emails from Gmail, cPanel, Zoho or any other provider with zero data loss or downtime.' },
  { icon: 'support', t: '24/7 Local Support', d: 'Setup, onboarding and post-sale support in Spanish and English with a local Ecuador-based team.' },
  { icon: 'billing', t: 'Ecuador Invoicing', d: 'Valid electronic invoice for Ecuador. No hassle with local dollar payments.' },
  { icon: 'secure', t: 'Microsoft Security', d: 'Advanced threat protection, antivirus and compliance with international data regulations.' },
  { icon: 'scale', t: 'Scales with your company', d: 'Add or remove licenses anytime. Pay monthly or annually, whichever works best for you.' },
];

const FAQ = es ? [
  { q: '¿Mi empresa ya tiene M365. ¿Puedo migrar con Terranode?', a: '¡Sí! Transferimos tu suscripción existente a Terranode sin interrupciones. Obtienes el mismo servicio de Microsoft más nuestro soporte local en español.' },
  { q: '¿Incluye las apps de Office instaladas en la PC?', a: 'Las apps descargables (Word, Excel, PowerPoint, Outlook) están incluidas solo en el plan Business Standard. Los planes Exchange y Basic incluyen las versiones web.' },
  { q: '¿Cuántos usuarios puedo agregar?', a: 'No hay límite de usuarios en los planes Business. Cada licencia corresponde a un usuario. Puedes agregar o quitar licencias en cualquier momento desde tu panel de administración.' },
  { q: '¿Qué es Microsoft Copilot y está incluido?', a: 'Microsoft Copilot es el asistente de IA integrado en M365 que ayuda con redacción, resúmenes y análisis de datos. Actualmente está disponible como add-on. Consúltanos para cotización.' },
  { q: '¿Pueden ayudarme a configurar Microsoft 365 desde cero?', a: 'Sí. Nuestro equipo gestiona la activación, configuración del dominio, creación de cuentas y migración de datos.' },
  { q: '¿Puedo pagar mensual o anualmente?', a: 'Ofrecemos ambas opciones. El pago anual tiene un descuento adicional.' },
] : [
  { q: 'My company already has M365. Can I migrate with Terranode?', a: 'Yes! We transfer your existing subscription to Terranode with no interruptions. You get the same Microsoft service plus our local support.' },
  { q: 'Does it include desktop-installed Office apps?', a: 'Downloadable apps (Word, Excel, PowerPoint, Outlook) are included only in the Business Standard plan. Exchange and Basic plans include web versions.' },
  { q: 'How many users can I add?', a: 'There\u2019s no user limit on Business plans. Each license corresponds to one user. You can add or remove licenses anytime.' },
  { q: 'What is Microsoft Copilot and is it included?', a: 'Microsoft Copilot is the AI assistant built into M365 that helps with writing, summarizing and data analysis. It\u2019s currently available as an add-on.' },
  { q: 'Can you help me set up Microsoft 365 from scratch?', a: 'Yes. Our team handles activation, domain setup, account creation and data migration.' },
  { q: 'Can I pay monthly or annually?', a: 'We offer both options. Annual billing gets an additional discount.' },
];

const ICONS: Record<string, string> = {
  partner: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4" stroke-linecap="round" stroke-linejoin="round"/>',
  migrate: '<path d="M5 12H19M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>',
  support: '<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>',
  billing: '<rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/>',
  secure: '<rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>',
  scale: '<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>',
};

const T = {
  badge: es ? 'Partner Microsoft · Ecuador' : 'Microsoft Partner · Ecuador',
  h1: es ? 'La suite de productividad' : 'The productivity suite',
  h1b: es ? 'que impulsa tu negocio' : 'that powers your business',
  sub: es ? 'Teams, Outlook, Word, Excel, PowerPoint y 1 TB en la nube. Vendido y soportado por Terranode, Partner certificado de Microsoft en Ecuador.' : 'Teams, Outlook, Word, Excel, PowerPoint and 1 TB in the cloud. Sold and supported by Terranode, Microsoft certified partner in Ecuador.',
  cta1: es ? 'Ver planes' : 'View plans',
  cta2: es ? 'Hablar con ventas' : 'Talk to sales',
  plansTag: es ? 'PLANES' : 'PLANS',
  plansH: es ? 'Elige tu plan Microsoft 365' : 'Choose your Microsoft 365 plan',
  plansSub: es ? 'Todos los planes incluyen soporte de Terranode, migración y factura local' : 'All plans include Terranode support, migration and local invoice',
  popular: es ? 'Más popular' : 'Most popular',
  buy: es ? 'Contratar' : 'Get started',
  appsH: es ? 'Todas las apps que tu equipo ya conoce' : 'All the apps your team already knows',
  featsH: es ? '¿Por qué comprar M365 con Terranode?' : 'Why buy M365 with Terranode?',
  faqH: es ? 'Preguntas frecuentes' : 'Frequently asked questions',
  ctaH: es ? '¿Listo para modernizar tu empresa?' : 'Ready to modernize your business?',
  ctaSub: es ? 'Partner oficial de Microsoft en Ecuador. Migración gratis, soporte 24/7 y factura local.' : 'Official Microsoft partner in Ecuador. Free migration, 24/7 support and local invoice.',
  ctaBtn: es ? 'Cotizar ahora' : 'Get a quote',
};
---
<main style="padding-top:66px;background:#080E1C;min-height:100vh">
  <!-- HERO -->
  <section class="relative overflow-hidden border-b border-white/[0.04] px-6 py-16 md:py-[72px]">
    <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse 55% 65% at 50% 30%,rgba(0,120,212,.1),transparent 70%)"></div>
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(0,120,212,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(0,120,212,.03) 1px,transparent 1px);background-size:50px 50px"></div>
    <div class="relative z-[2] mx-auto grid max-w-[1160px] grid-cols-1 items-center gap-10 md:grid-cols-[1.1fr_1fr] md:gap-[60px]">
      <div>
        <div class="mb-5 flex flex-wrap items-center gap-2.5">
          <span class="inline-flex items-center gap-2 rounded-full border border-[#0078D4]/25 bg-[#0078D4]/[0.08] px-3.5 py-[5px] font-body text-[11px] font-bold uppercase tracking-[2px] text-[#0078D4]">Microsoft 365</span>
          <span class="rounded-full border border-[#3B82F6]/20 bg-[#3B82F6]/[0.07] px-3 py-1 font-body text-[11px] font-bold text-[#60A5FA]">{T.badge}</span>
        </div>
        <h1 class="mb-1 font-display text-[clamp(2.2rem,4vw,3.6rem)] font-bold leading-[1.05] tracking-tight text-white">{T.h1}</h1>
        <h2 class="mb-[22px] font-display text-[clamp(2.2rem,4vw,3.6rem)] font-bold leading-[1.05] tracking-tight text-slate-600">{T.h1b}</h2>
        <p class="mb-8 max-w-[460px] font-body text-base leading-[1.7] text-slate-400">{T.sub}</p>
        <div class="flex flex-wrap gap-3">
          <a href="#planes" class="rounded-lg border-none bg-[#0078D4] px-6 py-3 font-display text-[15px] font-semibold text-white no-underline shadow-[0_0_24px_rgba(0,120,212,.3)]">{T.cta1}</a>
          <a href={contactoHref} class="rounded-lg border border-white/[0.15] bg-transparent px-6 py-3 font-display text-[15px] font-semibold text-slate-300 no-underline transition-colors hover:text-white">{T.cta2}</a>
        </div>
      </div>
      <div class="grid grid-cols-4 gap-2">
        {APPS_SHOWCASE.map((app) => (
          <div class="rounded-xl px-2.5 py-4 text-center" style={`background:${app.color}14;border:1px solid ${app.color}30`}>
            <div class="mx-auto mb-2 flex h-9 w-9 items-center justify-center rounded-lg" style={`background:${app.color}`}>
              <span class="font-display text-sm font-bold text-white">{app.name[0]}</span>
            </div>
            <div class="mb-0.5 font-display text-[11px] font-semibold text-slate-300">{app.name}</div>
            <div class="font-body text-[9.5px] leading-tight text-slate-600">{app.desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PLANS -->
  <section id="planes" class="bg-[#060B18] px-6 py-[72px]">
    <div class="mx-auto max-w-[1160px]">
      <header class="an mb-10">
        <p class="mb-3.5 font-body text-[11px] font-bold uppercase tracking-[2.5px] text-[#3B82F6]">{T.plansTag}</p>
        <h2 class="mb-1.5 font-display text-[clamp(1.8rem,3vw,2.5rem)] font-bold tracking-tight text-white">{T.plansH}</h2>
        <p class="font-body text-sm text-slate-500">{T.plansSub}</p>
      </header>
      <div class="grid grid-cols-1 gap-3.5 md:grid-cols-3">
        {PLANS.map((plan, i) => (
          <article class={`an d${i + 1} relative flex flex-col rounded-2xl p-6`} style={plan.popular ? 'background:rgba(0,120,212,.07);border:1px solid rgba(0,120,212,.4)' : 'background:rgba(255,255,255,.025);border:1px solid rgba(255,255,255,.07)'}>
            {plan.popular && <div class="absolute right-4 top-4 rounded-full bg-[#0078D4] px-2.5 py-0.5 font-display text-[11px] font-bold text-white">{T.popular}</div>}
            {plan.badge && (
              <span class="mb-2.5 inline-block w-fit rounded-full border border-[#0078D4]/25 bg-[#0078D4]/10 px-2 py-0.5 font-body text-[9px] font-bold uppercase tracking-[2px] text-[#0078D4]">{plan.badge}</span>
            )}
            <div class="mb-1 font-display text-[15px] font-bold text-white">{plan.name}</div>
            <div class="mb-[18px] font-body text-xs leading-relaxed text-slate-500">{plan.tagline}</div>
            <div class="mb-5 flex items-baseline gap-1">
              <span class="font-display text-[36px] font-bold tracking-tight text-white">{plan.price}</span>
              <span class="font-body text-xs text-slate-600">{plan.period}</span>
            </div>
            <a href={plan.href} target="_blank" rel="noopener noreferrer" class="mb-[22px] block rounded-lg py-2.5 text-center font-display text-sm font-semibold text-white no-underline" style={plan.popular ? 'background:#0078D4;border:1px solid transparent' : 'background:transparent;border:1px solid rgba(255,255,255,.14)'}>{T.buy}</a>
            <ul class="mt-auto flex list-none flex-col gap-2">
              {plan.feats.map((f) => (
                <li class="flex items-start gap-2 font-body text-xs text-slate-400">
                  <svg viewBox="0 0 12 12" fill="none" stroke="#0078D4" stroke-width="2.2" class="mt-0.5 h-3 w-3 shrink-0"><polyline points="2,6 5,9 10,3" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  {f}
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY TERRANODE -->
  <section class="border-t border-white/[0.04] bg-[#080E1C] px-6 py-[72px]">
    <div class="mx-auto max-w-[1160px]">
      <h2 class="an mb-10 text-center font-display text-[clamp(1.8rem,3vw,2.5rem)] font-bold tracking-tight text-white">{T.featsH}</h2>
      <div class="grid grid-cols-1 gap-3.5 md:grid-cols-3">
        {FEATS.map((f, i) => (
          <div class={`an d${(i % 3) + 1} flex items-start gap-4 rounded-2xl border border-white/[0.07] bg-white/[0.025] p-6`}>
            <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-[#3B82F6]/10">
              <svg viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="1.8" class="h-[22px] w-[22px]" set:html={ICONS[f.icon]}></svg>
            </div>
            <div>
              <div class="mb-2 font-display text-sm font-semibold text-white">{f.t}</div>
              <p class="font-body text-xs leading-relaxed text-slate-500">{f.d}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-white/[0.04] bg-[#060B18] px-6 pb-[72px]">
    <div class="mx-auto max-w-[760px] pt-[72px]">
      <h2 class="an mb-10 text-center font-display text-[clamp(1.8rem,3vw,2.5rem)] font-bold tracking-tight text-white">{T.faqH}</h2>
      <div class="flex flex-col gap-2">
        {FAQ.map((item) => (
          <div class="m365-faq-item overflow-hidden rounded-xl border border-white/[0.07] bg-white/[0.025]">
            <button type="button" class="m365-faq-btn flex w-full items-center justify-between gap-4 border-none bg-transparent px-5 py-[18px] text-left">
              <span class="font-display text-sm font-semibold text-white">{item.q}</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="#4A6A88" stroke-width="2" class="m365-faq-chevron h-4 w-4 shrink-0 transition-transform"><path d="m6 9 6 6 6-6"/></svg>
            </button>
            <div class="m365-faq-answer hidden border-t border-white/[0.05] px-5 pb-[18px] pt-3 font-body text-[13px] leading-[1.7] text-slate-500">{item.a}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="bg-[#060B18] px-6 pb-24">
    <div class="mx-auto max-w-[1160px]">
      <div class="an relative overflow-hidden rounded-2xl border border-[#0078D4]/20 p-8 text-center md:p-[52px]" style="background:linear-gradient(135deg,rgba(0,120,212,.1),rgba(0,78,140,.05))">
        <div class="pointer-events-none absolute inset-0" style="background-image:radial-gradient(circle at 50% 50%,rgba(0,120,212,.08),transparent 70%)"></div>
        <div class="relative z-[2]">
          <div class="mb-5 inline-flex items-center gap-1.5 rounded-full border border-[#0078D4]/25 bg-[#0078D4]/[0.08] px-3.5 py-[5px] font-body text-[11px] font-bold uppercase tracking-[2px] text-[#0078D4]">Partner Microsoft · Ecuador</div>
          <h2 class="mb-3 font-display text-[clamp(1.6rem,3vw,2.4rem)] font-bold tracking-tight text-white">{T.ctaH}</h2>
          <p class="mx-auto mb-8 max-w-[480px] font-body text-[15px] text-slate-400">{T.ctaSub}</p>
          <div class="flex flex-wrap justify-center gap-3">
            <a href={contactoHref} class="rounded-lg bg-[#0078D4] px-7 py-[13px] font-display text-[15px] font-semibold text-white no-underline shadow-[0_0_28px_rgba(0,120,212,.3)]">{T.ctaBtn}</a>
            <a href="#planes" class="rounded-lg border border-white/20 bg-transparent px-7 py-[13px] font-display text-[15px] font-semibold text-slate-300 no-underline">{T.cta1}</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</main>

<script>
  document.querySelectorAll('.m365-faq-item').forEach((item) => {
    const btn = item.querySelector('.m365-faq-btn');
    const answer = item.querySelector('.m365-faq-answer');
    const chevron = item.querySelector('.m365-faq-chevron') as HTMLElement | null;
    btn?.addEventListener('click', () => {
      const isOpen = !answer?.classList.contains('hidden');
      answer?.classList.toggle('hidden', isOpen);
      if (chevron) chevron.style.transform = isOpen ? 'none' : 'rotate(180deg)';
    });
  });
</script>
