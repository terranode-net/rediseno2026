---
import { NAV, PAGE_MAP, pathFor, type Locale, type PageKey } from '@/lib/site';

interface Props {
  locale: Locale;
  currentKey: PageKey;
}
const { locale, currentKey } = Astro.props;
const other: Locale = locale === 'es' ? 'en' : 'es';
const switchHref = pathFor(other, currentKey);
const homeHref = pathFor(locale, 'home');

const t = {
  es: { cta: 'Portal de Cliente', quote: 'Cotiza ahora' },
  en: { cta: 'Client Portal', quote: 'Get a quote' },
}[locale];
---
<header class="sticky top-0 z-50 border-b border-slate-100/80 bg-white/85 backdrop-blur-md">
  <div class="container-page flex h-16 items-center justify-between md:h-20">
    <a href={homeHref} class="flex items-center gap-2 shrink-0">
      <img src="/logo-mark.png" alt="Terranode" class="h-7 w-auto" width="63" height="77" />
      <span class="font-display text-xl font-semibold tracking-tight text-ink">terra<span class="text-accent">node</span></span>
    </a>

    <nav class="hidden lg:flex items-center gap-1">
      {NAV.map((item) => {
        const href = pathFor(locale, item.key);
        const active = item.key === currentKey;
        return (
          <a
            href={href}
            class={`rounded-full px-3.5 py-2 text-[14px] font-medium transition-colors ${
              active ? 'bg-accent-soft text-accent' : 'text-slate-600 hover:text-ink'
            }`}
          >
            {item.label[locale]}
          </a>
        );
      })}
    </nav>

    <div class="flex items-center gap-2">
      <a
        href={switchHref}
        class="hidden sm:inline-flex items-center gap-1.5 rounded-full border border-slate-200 px-3 py-1.5 text-[13px] font-semibold text-slate-600 hover:border-accent hover:text-accent transition-colors"
        aria-label={locale === 'es' ? 'Switch to English' : 'Cambiar a Español'}
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" class="opacity-70"><path d="M12 21c4.97 0 9-4.03 9-9s-4.03-9-9-9-9 4.03-9 9 4.03 9 9 9Z" stroke="currentColor" stroke-width="1.6"/><path d="M3.6 9h16.8M3.6 15h16.8M12 3a14.5 14.5 0 0 1 0 18M12 3a14.5 14.5 0 0 0 0 18" stroke="currentColor" stroke-width="1.6"/></svg>
        {other === 'en' ? 'EN' : 'ES'}
      </a>
      <a href={pathFor(locale, 'contacto')} class="btn-primary !px-5 !py-2.5 text-[13px]">
        {t.quote}
      </a>
      <button id="menu-btn" class="lg:hidden inline-flex h-10 w-10 items-center justify-center rounded-full border border-slate-200" aria-label="Menu">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
    </div>
  </div>

  <div id="mobile-nav" class="hidden lg:hidden border-t border-slate-100 bg-white">
    <div class="container-page flex flex-col gap-1 py-3">
      {NAV.map((item) => (
        <a href={pathFor(locale, item.key)} class="rounded-lg px-3 py-2.5 text-[15px] font-medium text-slate-700 hover:bg-surface">
          {item.label[locale]}
        </a>
      ))}
      <a href={switchHref} class="rounded-lg px-3 py-2.5 text-[15px] font-medium text-accent">
        {other === 'en' ? 'English' : 'Español'}
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('menu-btn');
  const nav = document.getElementById('mobile-nav');
  btn?.addEventListener('click', () => nav?.classList.toggle('hidden'));
</script>
