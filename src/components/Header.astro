---
import { SERVICES_NAV, TOP_NAV, COMING_SOON, pathFor, type Locale, type PageKey } from '@/lib/site';

interface Props {
  locale: Locale;
  currentKey: PageKey;
}
const { locale, currentKey } = Astro.props;
const other: Locale = locale === 'es' ? 'en' : 'es';
const switchHref = pathFor(other, currentKey);
const homeHref = pathFor(locale, 'home');
const isServiceActive = SERVICES_NAV.some((i) => i.key === currentKey);

const t = {
  es: { cta: 'Cotiza ahora', services: 'Servicios', soon: 'Pronto' },
  en: { cta: 'Get a quote', services: 'Services', soon: 'Soon' },
}[locale];
---
<header class="sticky top-0 z-50 border-b border-white/[0.06] bg-[#080E1C]/85 backdrop-blur-md">
  <div class="container-page flex h-16 items-center justify-between md:h-[68px]">
    <a href={homeHref} class="flex items-center gap-2 shrink-0">
      <img src="/logo-mark.png" alt="Terranode" class="h-7 w-auto" width="63" height="77" />
      <span class="font-display text-xl font-semibold tracking-tight text-white">terra<span class="text-[#3B82F6]">node</span></span>
    </a>

    <nav class="hidden lg:flex items-center gap-1">
      <!-- Services dropdown -->
      <div class="relative" id="services-dd">
        <button
          type="button"
          id="services-btn"
          class={`flex items-center gap-1 rounded-full px-3.5 py-2 font-body text-[14px] font-medium transition-colors ${
            isServiceActive ? 'bg-[#3B82F6]/10 text-[#60A5FA]' : 'text-slate-400 hover:text-white'
          }`}
        >
          {t.services}
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="transition-transform" id="services-chevron"><polyline points="6 9 12 15 18 9" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div id="services-menu" class="invisible absolute left-0 top-full z-50 mt-2 w-64 origin-top-left rounded-xl border border-white/10 bg-[#0C1525] p-2 opacity-0 shadow-2xl transition-all duration-150">
          {SERVICES_NAV.map((item) => {
            const soon = COMING_SOON.includes(item.key);
            return (
              <a
                href={pathFor(locale, item.key)}
                class={`flex items-center justify-between rounded-lg px-3 py-2.5 font-body text-[13.5px] transition-colors ${
                  item.key === currentKey ? 'bg-[#3B82F6]/10 text-[#60A5FA]' : 'text-slate-300 hover:bg-white/5 hover:text-white'
                }`}
              >
                {item.label[locale]}
                {soon && <span class="rounded-full bg-white/[0.08] px-2 py-0.5 text-[10px] text-slate-400">{t.soon}</span>}
              </a>
            );
          })}
        </div>
      </div>

      {TOP_NAV.filter((i) => i.key !== 'contacto').map((item) => {
        const active = item.key === currentKey;
        const soon = COMING_SOON.includes(item.key);
        return (
          <a
            href={pathFor(locale, item.key)}
            class={`flex items-center gap-1.5 rounded-full px-3.5 py-2 font-body text-[14px] font-medium transition-colors ${
              active ? 'bg-[#3B82F6]/10 text-[#60A5FA]' : 'text-slate-400 hover:text-white'
            }`}
          >
            {item.label[locale]}
            {soon && <span class="rounded-full bg-white/[0.08] px-1.5 py-0.5 text-[9px] text-slate-500">{t.soon}</span>}
          </a>
        );
      })}
    </nav>

    <div class="flex items-center gap-2">
      <a
        href={switchHref}
        class="hidden sm:inline-flex items-center gap-1.5 rounded-full border border-white/10 px-3 py-1.5 font-body text-[13px] font-semibold text-slate-300 transition-colors hover:border-[#3B82F6]/50 hover:text-[#60A5FA]"
        aria-label={locale === 'es' ? 'Switch to English' : 'Cambiar a Español'}
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" class="opacity-70"><path d="M12 21c4.97 0 9-4.03 9-9s-4.03-9-9-9-9 4.03-9 9 4.03 9 9 9Z" stroke="currentColor" stroke-width="1.6"/><path d="M3.6 9h16.8M3.6 15h16.8M12 3a14.5 14.5 0 0 1 0 18M12 3a14.5 14.5 0 0 0 0 18" stroke="currentColor" stroke-width="1.6"/></svg>
        {other === 'en' ? 'EN' : 'ES'}
      </a>
      <a
        href={pathFor(locale, 'contacto')}
        class="inline-flex items-center justify-center rounded-lg bg-[#3B82F6] px-5 py-2.5 font-display text-[13px] font-semibold text-white shadow-[0_0_20px_rgba(59,130,246,.25)] transition-colors hover:bg-[#2563EB]"
      >
        {t.cta}
      </a>
      <button id="menu-btn" class="lg:hidden inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/10 text-white" aria-label="Menu">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
    </div>
  </div>

  <div id="mobile-nav" class="hidden border-t border-white/[0.06] bg-[#080E1C] lg:hidden">
    <div class="container-page flex flex-col gap-1 py-3">
      <div class="px-3 pb-1 pt-2 font-body text-[11px] font-bold uppercase tracking-wider text-slate-600">{t.services}</div>
      {SERVICES_NAV.map((item) => (
        <a href={pathFor(locale, item.key)} class="flex items-center justify-between rounded-lg px-3 py-2.5 font-body text-[15px] font-medium text-slate-300 hover:bg-white/[0.04]">
          {item.label[locale]}
          {COMING_SOON.includes(item.key) && <span class="rounded-full bg-white/[0.08] px-2 py-0.5 text-[10px] text-slate-500">{t.soon}</span>}
        </a>
      ))}
      <div class="mt-2 border-t border-white/[0.06] pt-2"></div>
      {TOP_NAV.map((item) => (
        <a href={pathFor(locale, item.key)} class="flex items-center justify-between rounded-lg px-3 py-2.5 font-body text-[15px] font-medium text-slate-300 hover:bg-white/[0.04]">
          {item.label[locale]}
          {COMING_SOON.includes(item.key) && <span class="rounded-full bg-white/[0.08] px-2 py-0.5 text-[10px] text-slate-500">{t.soon}</span>}
        </a>
      ))}
      <a href={switchHref} class="rounded-lg px-3 py-2.5 font-body text-[15px] font-medium text-[#60A5FA]">
        {other === 'en' ? 'English' : 'Español'}
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('menu-btn');
  const nav = document.getElementById('mobile-nav');
  btn?.addEventListener('click', () => nav?.classList.toggle('hidden'));

  const ddRoot = document.getElementById('services-dd');
  const ddBtn = document.getElementById('services-btn');
  const ddMenu = document.getElementById('services-menu');
  const chevron = document.getElementById('services-chevron');

  function openDD() {
    ddMenu?.classList.remove('invisible', 'opacity-0');
    ddMenu?.classList.add('opacity-100');
    chevron?.classList.add('rotate-180');
  }
  function closeDD() {
    ddMenu?.classList.add('invisible', 'opacity-0');
    ddMenu?.classList.remove('opacity-100');
    chevron?.classList.remove('rotate-180');
  }

  ddBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = !ddMenu?.classList.contains('invisible');
    isOpen ? closeDD() : openDD();
  });
  document.addEventListener('click', (e) => {
    if (ddRoot && !ddRoot.contains(e.target as Node)) closeDD();
  });
  ddRoot?.addEventListener('mouseenter', openDD);
  ddRoot?.addEventListener('mouseleave', closeDD);
</script>
