  { id: 'ovh', name: 'OVHcloud', flag: '🇫🇷', color: '#123F6D', competitor: false, asns: [16276], keywords: ['ovh', 'kimsufi'], desc: es ? 'Proveedor europeo líder con servidores dedicados y cloud.' : 'Leading European provider with dedicated servers and cloud.', speed: es ? 'Rápido' : 'Fast', uptime: '99.99%', score: 83 },
  { id: 'fastly', name: 'Fastly CDN', flag: '🇺🇸', color: '#FF282D', competitor: false, asns: [54113], keywords: ['fastly'], desc: es ? 'CDN de alto rendimiento usado por grandes plataformas.' : 'High-performance CDN used by major platforms.', speed: es ? 'Muy rápido' : 'Very fast', uptime: '99.99%', score: 89 },
  { id: 'vercel', name: 'Vercel', flag: '🇺🇸', color: '#ffffff', competitor: false, asns: [394536, 209242], keywords: ['vercel'], desc: es ? 'Plataforma Jamstack optimizada para frontends y serverless.' : 'Jamstack platform optimized for frontends and serverless.', speed: es ? 'Muy rápido' : 'Very fast', uptime: '99.99%', score: 88 },
  { id: 'netlify', name: 'Netlify', flag: '🇺🇸', color: '#00C7B7', competitor: false, asns: [394536], keywords: ['netlify'], desc: es ? 'Plataforma para sitios estáticos y JAMstack.' : 'Platform for static sites and JAMstack.', speed: es ? 'Muy rápido' : 'Very fast', uptime: '99.99%', score: 87 },
  { id: 'terranode', name: 'Terranode', flag: '🇪🇨', color: '#3B82F6', competitor: false, asns: [], keywords: ['terranode'], desc: es ? '¡Excelente elección! Tu web ya está en Terranode.' : 'Excellent choice! Your site is already on Terranode.', speed: es ? 'Muy rápido' : 'Very fast', uptime: '99.99%', score: 99, isSelf: true },
];

const T = es ? {
  eyebrow: 'Herramienta gratuita', h1: '¿Dónde está alojada esta web?', h1b: 'Detecta el proveedor de hosting de cualquier dominio',
  sub: 'Descubre en qué empresa está alojado cualquier sitio web — servidor, datacenter, proveedor y calidad del hosting.',
  placeholder: 'ejemplo: google.com', check: 'Detectar hosting', checking: 'Analizando...', analyzing: 'Resolviendo DNS y consultando ASN...',
  hostedBy: 'Alojado en', ipAddress: 'Dirección IP', asn: 'ASN', org: 'Organización', location: 'Ubicación', speed: 'Velocidad', uptime: 'Uptime',
  unknown: 'Proveedor no identificado', unknownSub: 'No pudimos identificar el proveedor de hosting de este dominio.',
  errorTitle: 'No se pudo resolver el dominio', errorSub: 'Verifica que el dominio esté escrito correctamente y que tenga registros DNS activos.', retry: 'Reintentar',
  promoTitle: '¿Tu web está en', promoMid: '? Cámbiate a Terranode', promoDesc: 'Obtén hasta 3× más velocidad, DDoS 160 Gbps y soporte 24/7 desde Ecuador.',
  promoCta: 'Ver planes →', promoCtaWa: 'Hablar con un asesor →',
  selfTitle: '¡Tu web ya está en Terranode! 🎉', selfSub: 'Excelente elección. Disfruta de la mejor infraestructura desde Ecuador.',
  infoTitle: '¿Cómo funciona esta herramienta?',
  infoItems: ['Resuelve la IP del dominio usando DNS sobre HTTPS', 'Consulta el ASN (Autonomous System Number) de esa IP', 'Identifica la organización propietaria del bloque de IPs', 'Cruza esa información con una base de datos de proveedores conocidos'],
  cfNote: '⚠️ Si el dominio usa Cloudflare como proxy, verás Cloudflare como proveedor — el hosting real está detrás.',
  popularTitle: 'Proveedores populares',
} : {
  eyebrow: 'Free tool', h1: 'Who is hosting this website?', h1b: 'Detect the hosting provider of any domain',
  sub: 'Find out which company hosts any website — server, datacenter, provider and hosting quality.',
  placeholder: 'example: google.com', check: 'Detect hosting', checking: 'Analyzing...', analyzing: 'Resolving DNS and querying ASN...',
  hostedBy: 'Hosted by', ipAddress: 'IP Address', asn: 'ASN', org: 'Organization', location: 'Location', speed: 'Speed', uptime: 'Uptime',
  unknown: 'Provider not identified', unknownSub: 'We could not identify the hosting provider for this domain.',
  errorTitle: 'Could not resolve domain', errorSub: 'Check that the domain is spelled correctly and has active DNS records.', retry: 'Retry',
  promoTitle: 'Your site is on', promoMid: '? Switch to Terranode', promoDesc: 'Get up to 3× more speed, 160 Gbps DDoS protection and 24/7 support.',
  promoCta: 'View plans →', promoCtaWa: 'Talk to an advisor →',
  selfTitle: 'Your site is already on Terranode! 🎉', selfSub: 'Excellent choice. Enjoy the best infrastructure from Ecuador.',
  infoTitle: 'How does this tool work?',
  infoItems: ["Resolves the domain's IP using DNS over HTTPS", 'Queries the ASN (Autonomous System Number) of that IP', 'Identifies the organization that owns the IP block', 'Cross-references with a database of known providers'],
  cfNote: "⚠️ If the domain uses Cloudflare as a proxy, you'll see Cloudflare as the provider — the real host is behind it.",
  popularTitle: 'Popular providers',
};
---
<main style="padding-top:66px;background:#080E1C;min-height:100vh">
  <section class="relative overflow-hidden border-b border-white/[0.04] px-6 py-16 md:py-[72px]">
    <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(ellipse 60% 70% at 50% 30%,rgba(37,99,235,.13),transparent 70%)"></div>
    <div class="pointer-events-none absolute inset-0" style="background-image:linear-gradient(rgba(59,130,246,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(59,130,246,.03) 1px,transparent 1px);background-size:50px 50px"></div>
    <div class="relative z-[2] mx-auto max-w-[760px] text-center">
      <span class="mb-5 inline-block rounded-full border border-[#3B82F6]/[0.22] bg-[#3B82F6]/[0.08] px-4 py-[5px] font-body text-[11px] font-bold uppercase tracking-[2.5px] text-[#3B82F6]">{T.eyebrow}</span>
      <h1 class="mb-1 font-display text-[clamp(2rem,4.5vw,3.6rem)] font-bold leading-[1.05] tracking-tight text-white">{T.h1}</h1>
      <h2 class="mb-[18px] font-display text-[clamp(1rem,2vw,1.35rem)] font-semibold tracking-tight text-slate-600">{T.h1b}</h2>
      <p class="mx-auto mb-9 max-w-[540px] font-body text-slate-400">{T.sub}</p>

      <div class="mx-auto flex max-w-[640px] gap-2.5">
        <input id="hd-domain" type="text" placeholder={T.placeholder} class="flex-1 rounded-[10px] border border-white/10 bg-white/[0.04] px-4.5 py-3 font-body text-[15px] text-white outline-none focus:border-[#3B82F6]/50" />
        <button id="hd-check-btn" class="flex shrink-0 items-center gap-2 whitespace-nowrap rounded-[10px] border-none bg-[#3B82F6] px-7 py-3 font-display text-[15px] font-bold text-white shadow-[0_0_24px_rgba(59,130,246,.25)] transition-colors hover:bg-[#2563EB] disabled:opacity-70">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35" stroke-linecap="round"/></svg>
          <span id="hd-check-label">{T.check}</span>
        </button>
      </div>
      <p id="hd-analyzing" class="mt-3 hidden font-body text-xs text-slate-600">{T.analyzing}</p>
    </div>
  </section>

  <section class="bg-[#060B18] px-6 py-10 md:py-24">
    <div class="mx-auto max-w-[1000px]">
      <div id="hd-error-block" class="hidden py-16 text-center">
        <div class="mb-4 text-5xl">🔍</div>
        <div class="mb-2 font-display text-lg font-bold text-white">{T.errorTitle}</div>
        <p class="mb-6 font-body text-slate-500">{T.errorSub}</p>
        <button id="hd-retry-btn" class="rounded-lg border-none bg-[#3B82F6] px-6 py-2.5 font-display text-sm font-semibold text-white">{T.retry}</button>
      </div>

      <div id="hd-result" class="hidden flex-col gap-5"></div>

      <div id="hd-empty" class="grid grid-cols-1 gap-4 md:grid-cols-2">
        <div class="rounded-2xl border border-white/[0.07] bg-white/[0.025] p-6">
          <div class="mb-3.5 font-display text-[15px] font-bold text-white">{T.infoTitle}</div>
          <ol class="m-0 flex list-none flex-col gap-3 p-0">
            {T.infoItems.map((item, i) => (
              <li class="flex gap-3 font-body text-[13px] leading-relaxed text-slate-500">
                <span class="flex h-[22px] w-[22px] shrink-0 items-center justify-center rounded-full border border-[#3B82F6]/25 bg-[#3B82F6]/[0.15] font-display text-[11px] font-bold text-[#3B82F6]">{i + 1}</span>
                {item}
              </li>
            ))}
          </ol>
        </div>
        <div class="rounded-2xl border border-white/[0.07] bg-white/[0.025] p-6">
          <div class="mb-3.5 font-display text-[15px] font-bold text-white">{T.popularTitle}</div>
          <div class="flex flex-col gap-2">
            {PROVIDERS.filter((p) => !p.isSelf).slice(0, 8).map((p) => (
              <div class="flex items-center gap-2.5 border-b border-white/[0.04] py-1.5">
                <span class="text-base">{p.flag}</span>
                <span class="flex-1 font-display text-[13px] font-semibold text-white">{p.name}</span>
                <div class="flex items-center gap-1.5">
                  <div class="h-1 w-10 overflow-hidden rounded-sm bg-white/[0.06]">
                    <div class="h-full rounded-sm" style={`width:${p.score}%;background:${p.score >= 85 ? '#22C55E' : p.score >= 70 ? '#3B82F6' : p.score >= 60 ? '#F59E0B' : '#EF4444'}`}></div>
                  </div>
                  <span class="w-7 font-body text-[11px] font-bold" style={`color:${p.score >= 85 ? '#22C55E' : p.score >= 70 ? '#3B82F6' : p.score >= 60 ? '#F59E0B' : '#EF4444'}`}>{p.score}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>
</main>

<script define:vars={{ PROVIDERS, T, vpsHref, whatsappHref: 'https://wa.link/nooz4l' }}>
  const domainInput = document.getElementById('hd-domain');
  const checkBtn = document.getElementById('hd-check-btn');
  const checkLabel = document.getElementById('hd-check-label');
  const analyzingEl = document.getElementById('hd-analyzing');
  const errorBlock = document.getElementById('hd-error-block');
  const resultEl = document.getElementById('hd-result');
  const emptyEl = document.getElementById('hd-empty');

  function scoreColor(s) { return s >= 85 ? '#22C55E' : s >= 70 ? '#3B82F6' : s >= 60 ? '#F59E0B' : '#EF4444'; }
  function speedColor(s) { return ['Muy rápido', 'Very fast'].includes(s) ? '#22C55E' : ['Rápido', 'Fast'].includes(s) ? '#3B82F6' : ['Bueno', 'Good'].includes(s) ? '#60A5FA' : ['Medio', 'Medium'].includes(s) ? '#F59E0B' : '#EF4444'; }
  function flagEmoji(code) {
    if (!code || code.length !== 2) return '🌐';
    return String.fromCodePoint(...[...code.toUpperCase()].map((c) => 0x1f1e0 - 65 + c.charCodeAt(0)));
  }

  function matchProvider(org, asn) {
    if (!org && !asn) return null;
    const orgLow = (org || '').toLowerCase();
    for (const p of PROVIDERS) if (asn && p.asns.includes(Number(asn))) return p;
    for (const p of PROVIDERS) if (p.keywords.some((k) => orgLow.includes(k))) return p;
    return null;
  }

  async function detectHosting(domain) {
    const dohRes = await fetch(`https://dns.google/resolve?name=${encodeURIComponent(domain)}&type=A`, { headers: { Accept: 'application/dns-json' }, signal: AbortSignal.timeout(7000) });
    const dohData = await dohRes.json();
    if (!dohData.Answer || !dohData.Answer.length) throw new Error('nxdomain');
    const ip = dohData.Answer.find((r) => r.type === 1)?.data;
    if (!ip) throw new Error('no_a_record');
    const ipRes = await fetch(`https://ipwho.is/${ip}`, { signal: AbortSignal.timeout(7000) });
    const ipData = await ipRes.json();
    const asn = ipData.connection?.asn || null;
    const org = ipData.connection?.isp || ipData.connection?.org || ipData.org || '';
    const isp = ipData.connection?.isp || '';
    return { ip, asn, org, isp, city: ipData.city, country: ipData.country, countryCode: ipData.country_code };
  }

  function renderResult(result) {
    const provider = matchProvider(result.org + ' ' + result.isp, result.asn);
    const locStr = `${flagEmoji(result.countryCode)} ${result.city || ''}${result.city && result.country ? ', ' : ''}${result.country || '—'}`;

    const detailItems = [
      { label: T.ipAddress, value: result.ip, mono: true },
      { label: T.asn, value: result.asn ? `AS${result.asn}` : '—', mono: true },
      { label: T.org, value: result.org || '—' },
      { label: T.location, value: locStr },
    ];
    if (provider) {
      detailItems.push({ label: T.speed, value: provider.speed, color: speedColor(provider.speed) });
      detailItems.push({ label: T.uptime, value: provider.uptime, color: '#22C55E' });
    }

    const detailsHtml = detailItems
      .map(
        (item, i) => `
      <div style="padding:18px 24px;border-top:1px solid rgba(255,255,255,.05);${i % 2 === 0 ? 'border-right:1px solid rgba(255,255,255,.05)' : ''}">
        <div style="font-family:'Metrophobic',sans-serif;font-size:11px;color:#3A5A7A;margin-bottom:5px;text-transform:uppercase;letter-spacing:1px">${item.label}</div>
        <div style="font-family:${item.mono ? "'Metrophobic',sans-serif" : "'Instrument Sans',sans-serif"};font-weight:${item.mono ? 400 : 600};font-size:14px;color:${item.color || '#fff'}">${item.value}</div>
      </div>`
      )
      .join('');

    let html = `
      <div style="background:${provider?.isSelf ? 'rgba(59,130,246,.07)' : 'rgba(255,255,255,.03)'};border:2px solid ${provider ? provider.color + '30' : 'rgba(255,255,255,.08)'};border-radius:20px;overflow:hidden">
        <div style="padding:28px 32px;border-bottom:1px solid rgba(255,255,255,.06);display:flex;align-items:center;justify-content:space-between;gap:20px;flex-wrap:wrap;background:${provider ? `linear-gradient(135deg, ${provider.color}08 0%, transparent 60%)` : 'transparent'}">
          <div style="display:flex;align-items:center;gap:18px">
            <div style="width:64px;height:64px;border-radius:16px;background:${provider ? provider.color + '18' : 'rgba(255,255,255,.04)'};border:1px solid ${provider ? provider.color + '30' : 'rgba(255,255,255,.08)'};display:flex;align-items:center;justify-content:center;font-size:28px;flex-shrink:0">${provider ? provider.flag : '❓'}</div>
            <div>
              <div style="font-family:'Metrophobic',sans-serif;font-size:11px;color:#3A5A7A;letter-spacing:1.5px;text-transform:uppercase;margin-bottom:4px">${T.hostedBy}</div>
              <div style="font-family:'Instrument Sans',sans-serif;font-weight:700;font-size:clamp(1.4rem,2.5vw,2rem);color:${provider ? provider.color : '#fff'}">${provider ? provider.name : T.unknown}</div>
              ${provider && !provider.isSelf ? `<div style="font-family:'Metrophobic',sans-serif;font-size:12px;color:#4A6A88;margin-top:4px">${provider.desc}</div>` : ''}
            </div>
          </div>
          ${provider ? `<div style="text-align:center"><div style="font-family:'Instrument Sans',sans-serif;font-weight:700;font-size:36px;color:${scoreColor(provider.score)};line-height:1">${provider.score}</div><div style="font-family:'Metrophobic',sans-serif;font-size:11px;color:#3A5A7A">/ 100</div></div>` : ''}
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr))">${detailsHtml}</div>
      </div>`;

    if (provider?.isSelf) {
      html += `
      <div style="background:linear-gradient(135deg,rgba(59,130,246,.12),rgba(59,130,246,.04));border:1px solid rgba(59,130,246,.3);border-radius:16px;padding:28px 32px;display:flex;align-items:center;gap:20px">
        <span style="font-size:48px">🚀</span>
        <div><div style="font-family:'Instrument Sans',sans-serif;font-weight:700;font-size:18px;color:#fff;margin-bottom:4px">${T.selfTitle}</div><p style="font-family:'Metrophobic',sans-serif;font-size:13px;color:#4A6A88;margin:0">${T.selfSub}</p></div>
      </div>`;
    } else if (provider?.competitor) {
      const chips = [
        ['DDoS', '160 Gbps', '🛡️'],
        [T.speed, '10 Gbps', '⚡'],
        [T.uptime, '99.99%', '✅'],
        [es ? 'Soporte' : 'Support', '24/7', '💬'],
      ]
        .map(([label, val, icon]) => `<div style="background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);border-radius:8px;padding:6px 12px;font-family:'Metrophobic',sans-serif;font-size:11px;color:#CBD5E1">${icon} <strong style="color:#fff">${val}</strong> ${label}</div>`)
        .join('');
      html += `
      <div style="background:linear-gradient(135deg,rgba(59,130,246,.15) 0%,rgba(37,99,235,.08) 50%,rgba(59,130,246,.12) 100%);border:1px solid rgba(59,130,246,.3);border-radius:20px;padding:32px;position:relative;overflow:hidden">
        <div style="display:flex;align-items:center;justify-content:space-between;gap:24px;flex-wrap:wrap">
          <div style="flex:1;min-width:280px">
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px">
              <span style="font-size:24px">⚡</span>
              <span style="font-family:'Metrophobic',sans-serif;font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:#3B82F6;background:rgba(59,130,246,.12);border:1px solid rgba(59,130,246,.25);border-radius:100px;padding:3px 12px">Terranode vs ${provider.name}</span>
            </div>
            <h3 style="font-family:'Instrument Sans',sans-serif;font-weight:700;font-size:clamp(1.2rem,2.5vw,1.7rem);color:#fff;margin-bottom:8px;line-height:1.2">${T.promoTitle} <span style="color:${provider.color}">${provider.name}</span>${T.promoMid} <span style="color:#3B82F6">🚀</span></h3>
            <p style="font-family:'Metrophobic',sans-serif;font-size:13px;color:#6B8CAE;line-height:1.6;margin-bottom:16px">${T.promoDesc}</p>
            <div style="display:flex;gap:10px;flex-wrap:wrap">${chips}</div>
          </div>
          <div style="display:flex;flex-direction:column;gap:10px;flex-shrink:0">
            <a href="${vpsHref}" style="display:block;background:#3B82F6;color:#fff;text-decoration:none;padding:13px 28px;border-radius:10px;font-family:'Instrument Sans',sans-serif;font-weight:700;font-size:14px;text-align:center;white-space:nowrap">${T.promoCta}</a>
            <a href="${whatsappHref}" target="_blank" rel="noopener noreferrer" style="display:block;background:rgba(34,197,94,.12);color:#22C55E;text-decoration:none;padding:13px 28px;border-radius:10px;font-family:'Instrument Sans',sans-serif;font-weight:700;font-size:14px;text-align:center;border:1px solid rgba(34,197,94,.25);white-space:nowrap">${T.promoCtaWa}</a>
          </div>
        </div>
      </div>`;
    }

    if (provider?.id === 'cloudflare') {
      html += `<div style="background:rgba(243,128,32,.06);border:1px solid rgba(243,128,32,.2);border-radius:12px;padding:14px 20px;font-family:'Metrophobic',sans-serif;font-size:13px;color:#F59E0B">${T.cfNote}</div>`;
    }
    if (!provider) {
      html += `<div style="background:rgba(255,255,255,.02);border:1px solid rgba(255,255,255,.07);border-radius:16px;padding:24px 28px"><p style="font-family:'Metrophobic',sans-serif;font-size:13px;color:#4A6A88;margin:0">${T.unknownSub}</p></div>`;
    }

    resultEl.innerHTML = html;
  }

  async function run() {
    const raw = domainInput.value.trim().replace(/^https?:\/\//, '').replace(/\/.*$/, '').toLowerCase();
    if (!raw) return;

    checkBtn.disabled = true;
    checkLabel.textContent = T.checking;
    analyzingEl.classList.remove('hidden');
    errorBlock.classList.add('hidden');
    resultEl.classList.add('hidden');
    resultEl.classList.remove('flex');
    emptyEl.classList.add('hidden');

    try {
      const info = await detectHosting(raw);
      renderResult(info);
      resultEl.classList.remove('hidden');
      resultEl.classList.add('flex');
    } catch (e) {
      errorBlock.classList.remove('hidden');
    }

    analyzingEl.classList.add('hidden');
    checkBtn.disabled = false;
    checkLabel.textContent = T.check;
  }

  domainInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') run(); });
  checkBtn.addEventListener('click', run);
  document.getElementById('hd-retry-btn')?.addEventListener('click', run);
</script>
