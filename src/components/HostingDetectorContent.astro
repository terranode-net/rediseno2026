  { id: 'vultr', name: 'Vultr', flag: '🇺🇸', color: '#007BFC', competitor: false, asns: [20473], keywords: ['vultr', 'choopa'], desc: es ? 'Cloud con servidores en 32 ubicaciones, buena velocidad y precio.' : 'Cloud with servers in 32 locations, good speed and price.', speed: es ? 'Rápido' : 'Fast', uptime: '99.99%', score: 84 },
