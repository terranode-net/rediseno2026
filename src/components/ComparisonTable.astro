---
interface Props {
  headers: string[];
  rows: (string | number)[][];
}
const { headers, rows } = Astro.props;
---
<div class="overflow-x-auto rounded-xl2 border border-slate-200">
  <table class="w-full min-w-[640px] border-collapse text-left text-sm">
    <thead>
      <tr class="bg-ink text-white">
        {headers.map((h) => <th class="px-5 py-3.5 font-medium">{h}</th>)}
      </tr>
    </thead>
    <tbody>
      {rows.map((row, i) => (
        <tr class={i % 2 === 0 ? 'bg-white' : 'bg-surface'}>
          {row.map((cell, j) => (
            <td class={`px-5 py-3.5 ${j === 0 ? 'font-semibold text-ink' : 'text-slate-600'}`}>{cell}</td>
          ))}
        </tr>
      ))}
    </tbody>
  </table>
</div>
