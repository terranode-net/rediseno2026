---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BlogPostContent from '@/components/BlogPostContent.astro';
import { POSTS, getFullPost } from '@/lib/blogData';
import { organizationSchema } from '@/lib/schema';
import { SITE_URL } from '@/lib/site';

export function getStaticPaths() {
  return POSTS.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const post = getFullPost(slug as string);
const postUrl = `${SITE_URL}/en/blog/${slug}/`;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.title,
  description: post.intro,
  image: `${SITE_URL}/og/og-default.png`,
  datePublished: post.date,
  dateModified: post.date,
  articleSection: post.category,
  author: { '@type': 'Organization', name: post.author, url: SITE_URL },
  publisher: { '@id': `${SITE_URL}/#organization` },
  mainEntityOfPage: { '@type': 'WebPage', '@id': postUrl },
  keywords: post.tags.join(', '),
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE_URL}/en/` },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${SITE_URL}/en/blog/` },
    { '@type': 'ListItem', position: 3, name: post.title, item: postUrl },
  ],
};
---
<BaseLayout
  locale="en"
  pageKey="blog"
  title={`${post.title} | Terranode Blog`}
  description={post.intro}
  jsonLd={[organizationSchema('en'), articleSchema, breadcrumb]}
  canonicalOverride={{ es: `${SITE_URL}/es/blog/${slug}/`, en: postUrl }}
>
  <BlogPostContent locale="en" slug={slug as string} />
</BaseLayout>
