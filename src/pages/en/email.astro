---
export const prerender = false;
import BaseLayout from '@/layouts/BaseLayout.astro';
import TerraMailContent from '@/components/TerraMailContent.astro';
import { getMailPlans, priceNumber } from '@/lib/db';
import { SITE_URL } from '@/lib/site';
import { organizationSchema, breadcrumbSchema, faqSchema, serviceSchema, productPlanSchema } from '@/lib/schema';

const mailPlans = await getMailPlans();

const faqs = [
  { q: 'Can I use my existing domain with TerraMail?', a: 'Yes, just point your domain\u2019s MX records to our servers.' },
  { q: 'How many mailboxes can I create per plan?', a: 'Essentials and Pro include one each; Enterprise includes unlimited mailboxes.' },
  { q: 'What is Terramail Suite Webmail?', a: 'A modern webmail platform with an Outlook-like interface.' },
  { q: 'Can you migrate my email from Gmail or Outlook?', a: 'Yes, full migrations without interrupting your operation.' },
  { q: 'Does email include phishing protection?', a: 'Yes, advanced antispam filtering phishing attempts and malicious attachments.' },
  { q: 'Can I access it from my phone?', a: 'Yes, ActiveSync compatible on iOS, Android and any standard mail client.' },
];
const plans = mailPlans
  .filter((p) => !isNaN(Number(priceNumber(p.price))) && Number(priceNumber(p.price)) > 0)
  .map((p) => ({
    name: p.name,
    price: priceNumber(p.price),
    description: `${p.storage} mailbox, ${p.tagline}.`,
    url: `${SITE_URL}/en/store/terramail-${p.id}`,
  }));
const breadcrumb = breadcrumbSchema('en', [{ name: 'Home', key: 'home' }, { name: 'Business Email', key: 'terramail' }]);
const service = serviceSchema('en', { name: 'TerraMail Business Email', description: 'Professional business email with antispam, antivirus and webmail included.', pageKey: 'terramail', serviceType: 'Business Email Hosting' });
---
<BaseLayout
  locale="en"
  pageKey="terramail"
  title='TerraMail: Corporate & Business Email from $24.99/yr | Terranode'
  description='Professional corporate and business email with your own domain, advanced antispam, modern webmail and mobile sync. Free migration. From $24.99/yr.'
  jsonLd={[organizationSchema('en'), breadcrumb, service, ...productPlanSchema(plans), faqSchema(faqs)]}
>
  <TerraMailContent locale="en" plans={mailPlans} />
</BaseLayout>
