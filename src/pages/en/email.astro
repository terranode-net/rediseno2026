---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import PricingCard from '@/components/PricingCard.astro';
import FeatureCard from '@/components/FeatureCard.astro';
import FAQAccordion from '@/components/FAQAccordion.astro';
import CTASection from '@/components/CTASection.astro';
import { pathFor, ORG } from '@/lib/site';
import { organizationSchema, breadcrumbSchema, faqSchema, serviceSchema, productPlanSchema } from '@/lib/schema';

const faqs = [
  { q: 'What is Terramail?', a: 'Terramail is our professional corporate email service on your own domain (e.g. you@yourcompany.com), with excellent deliverability plus built-in antispam and antivirus.' },
  { q: 'Is Terramail the same as Microsoft 365?', a: 'No, they\u2019re different services. Terramail is our own email solution, ideal if you want simplicity and low cost. Microsoft 365 is Microsoft\u2019s full suite with Outlook, Teams and Office. We\u2019ll help you choose based on your needs.' },
  { q: 'Can I access my email from my phone?', a: 'Yes, Terramail works with any email client (Outlook, Gmail app, Apple Mail) via IMAP/SMTP, plus a modern webmail accessible from any browser.' },
  { q: 'How many email accounts can I create?', a: 'It depends on the plan you choose. We offer everything from individual plans to corporate packages with dozens of accounts and shared mailboxes.' },
];

const plans = [
  { name: 'Mail Basic', tagline: 'For entrepreneurs', price: '$2', period: '/mo', specs: ['5 GB per mailbox', '1 email account', 'Antispam + Antivirus', 'Webmail included'] },
  { name: 'Mail Business', tagline: 'For small teams', price: '$5', period: '/mo', featured: true, specs: ['25 GB per mailbox', 'Up to 10 accounts', 'Antispam + Antivirus', 'IMAP/SMTP support', 'Shared calendars'] },
  { name: 'Mail Enterprise', tagline: 'For growing companies', price: '$9', period: '/mo', specs: ['50 GB per mailbox', 'Unlimited accounts', 'Advanced rules & aliases', '24/7 priority support'] },
];

const breadcrumb = breadcrumbSchema('en', [{ name: 'Home', key: 'home' }, { name: 'Terramail', key: 'terramail' }]);
const service = serviceSchema('en', {
  name: 'Terramail — Business Email',
  description: 'Corporate email on your own domain, with high deliverability and antispam protection.',
  pageKey: 'terramail',
  serviceType: 'Business Email Hosting',
});
const products = productPlanSchema(plans.map(p => ({ name: p.name, price: p.price.replace('$',''), description: p.tagline, url: pathFor('en','terramail') })));
---
<BaseLayout
  locale="en"
  pageKey="terramail"
  title="Terramail: Professional Business Email | Terranode"
  description="Corporate email on your own domain with antispam, antivirus and high deliverability. Plans from $2/mo with 24/7 support."
  jsonLd={[organizationSchema('en'), breadcrumb, service, ...products, faqSchema(faqs)]}
>
  <Hero
    eyebrow="Terramail · Business Email"
    title="Email that makes your brand"
    highlight="look professional"
    description="Leave @gmail.com behind. With Terramail your team writes from you@yourcompany.com, with enterprise-grade security and deliverability."
    primaryCta={{ label: 'Activate my email', href: pathFor('en','contacto') }}
    secondaryCta={{ label: 'See Microsoft 365', href: pathFor('en','m365') }}
  />

  <section class="container-page py-20 md:py-28">
    <SectionHeading eyebrow="Plans" title="Business email for every team size" />
    <div class="mt-14 grid gap-6 lg:grid-cols-3">
      {plans.map((p) => (
        <PricingCard name={p.name} tagline={p.tagline} price={p.price} period={p.period} featured={p.featured} specs={p.specs} ctaLabel="Order now" ctaHref={pathFor('en','contacto')} />
      ))}
    </div>
  </section>

  <section class="bg-surface py-20 md:py-28">
    <div class="container-page">
      <SectionHeading eyebrow="Features" title="Built for your business communication" />
      <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <FeatureCard icon="lock" title="Antispam & antivirus" description="Advanced filters that keep your inbox clean and safe." />
        <FeatureCard icon="globe" title="High deliverability" description="SPF, DKIM and DMARC configuration so your emails land in the inbox, not spam." />
        <FeatureCard icon="server" title="Cross-platform access" description="IMAP, SMTP and modern webmail, compatible with Outlook, Apple Mail and more." />
        <FeatureCard icon="shield" title="Automatic backups" description="Periodic backups of every mailbox." />
        <FeatureCard icon="chart" title="Admin panel" description="Create, delete and manage your team's accounts in seconds." />
        <FeatureCard icon="support" title="24/7 support" description="Real technical assistance when your team needs it most." />
      </div>
    </div>
  </section>

  <section class="container-page pb-20 md:pb-28">
    <SectionHeading eyebrow="FAQ" title="Everything about Terramail" />
    <div class="mt-12"><FAQAccordion items={faqs} /></div>
  </section>

  <CTASection
    title="Give your company the email it deserves"
    description="We activate your business email the same day, with support to migrate your current accounts."
    primaryCta={{ label: 'Activate Terramail', href: pathFor('en','contacto') }}
    secondaryCta={{ label: 'Client portal', href: ORG.clientPortal }}
  />
</BaseLayout>
