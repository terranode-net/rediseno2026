---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import ContactForm from '@/components/ContactForm.astro';
import FeatureCard from '@/components/FeatureCard.astro';
import { ORG } from '@/lib/site';
import { organizationSchema, breadcrumbSchema } from '@/lib/schema';

const breadcrumb = breadcrumbSchema('en', [{ name: 'Home', key: 'home' }, { name: 'Contact', key: 'contacto' }]);
---
<BaseLayout
  locale="en"
  pageKey="contacto"
  title="Contact | Talk to a Terranode Engineer"
  description="Questions about VPS, hosting, dedicated servers or Microsoft 365? Reach out and an engineer will get back to you the same day."
  jsonLd={[organizationSchema('en'), breadcrumb]}
>
  <section class="relative overflow-hidden bg-ink pt-16 pb-14 md:pt-24 md:pb-20">
    <div class="absolute inset-0 bg-dot-grid opacity-[0.15]"></div>
    <div class="container-page relative text-center">
      <span class="eyebrow !border-white/15 !bg-white/5 !text-white/90">Contact</span>
      <h1 class="mx-auto mt-6 max-w-2xl text-balance text-4xl font-semibold leading-[1.1] text-white md:text-5xl">
        Let's talk about your <span class="text-accent">infrastructure</span>
      </h1>
      <p class="mx-auto mt-5 max-w-lg text-slate-300">
        Tell us what you need and an engineer — not a bot — will get back to you with a clear recommendation.
      </p>
    </div>
  </section>

  <section class="container-page -mt-10 pb-24 md:-mt-14">
    <div class="grid gap-8 lg:grid-cols-5">
      <div class="lg:col-span-3 rounded-xl2 border border-slate-200 bg-white p-6 shadow-card md:p-10">
        <ContactForm locale="en" />
      </div>

      <div class="lg:col-span-2 space-y-6">
        <div class="card !cursor-default">
          <h3 class="font-display text-lg font-semibold text-ink">Email</h3>
          <p class="mt-2 text-sm text-slate-500">We reply within 24 business hours.</p>
          <a href={`mailto:${ORG.email}`} class="mt-3 inline-block text-sm font-semibold text-accent">{ORG.email}</a>
        </div>
        <div class="card !cursor-default">
          <h3 class="font-display text-lg font-semibold text-ink">WhatsApp / Phone</h3>
          <p class="mt-2 text-sm text-slate-500">For quick questions or urgent support.</p>
          <a href={ORG.whatsapp} class="mt-3 inline-block text-sm font-semibold text-accent">{ORG.phone}</a>
        </div>
        <div class="card !cursor-default">
          <h3 class="font-display text-lg font-semibold text-ink">Client Portal</h3>
          <p class="mt-2 text-sm text-slate-500">Already a client? Manage your services and tickets here.</p>
          <a href={ORG.clientPortal} target="_blank" rel="noopener" class="mt-3 inline-block text-sm font-semibold text-accent">my.terranode.net →</a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-surface py-20">
    <div class="container-page">
      <SectionHeading eyebrow="Before you write in" title="Here's how we can help, depending on your situation" />
      <div class="mt-14 grid gap-6 sm:grid-cols-3">
        <FeatureCard icon="server" title="New client?" description="Tell us about your project and we'll recommend the exact VPS, hosting or dedicated server plan." />
        <FeatureCard icon="support" title="Already a client?" description="For technical support, use the client portal and open a ticket — it's faster than the form." />
        <FeatureCard icon="shield" title="Sales inquiry?" description="Custom sales and quotes for businesses with specific requirements." />
      </div>
    </div>
  </section>
</BaseLayout>
