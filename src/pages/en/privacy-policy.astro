---
import BaseLayout from '@/layouts/BaseLayout.astro';
import LegalPageContent from '@/components/LegalPageContent.astro';
import { organizationSchema, breadcrumbSchema } from '@/lib/schema';

const sections = [
  { id: 'intro', title: '1. Introduction', content: `This Privacy Policy describes how Terranode S.A.S collects, uses and protects personal data. This policy complies with Ecuador's LOPDP (Organic Law on Personal Data Protection).\n\nContact: info@terranode.net | +593 99 819 7150 | Guayaquil, Ecuador` },
  { id: 'data', title: '2. Data We Collect', content: `Required: Full name, email, phone, address, tax ID (RUC/CI), billing address. Payment card data is processed by PCI-DSS certified gateways; Terranode does not store full card data.\n\nAutomatically collected: IP address, browser type, OS, pages visited, access logs.` },
  { id: 'purposes', title: '3. Purposes', content: `Contractual: Account management, service provisioning, technical notifications, support.\nLegal obligation: Electronic invoice issuance per SRI requirements, accounting, tax compliance.\nLegitimate interest: Fraud prevention, infrastructure protection.\nMarketing (with consent): Newsletters and promotions — unsubscribe anytime.` },
  { id: 'retention', title: '4. Retention', content: `Billing data: 7 years (SRI requirement). Account data: Contract duration + 1 year. Technical logs: 90 days to 1 year. Support tickets: 1 year. Marketing: Until consent is withdrawn.` },
  { id: 'rights', title: '5. Your Rights', content: `Under LOPDP: Access, Rectification, Erasure, Objection, Portability.\n\nTo exercise rights, email info@terranode.net or open a ticket at my.terranode.net with your full name, ID number, account email and the right you wish to exercise. We respond within 15 business days.` },
  { id: 'security', title: '6. Security', content: `We implement SSL/TLS encryption, role-based access controls, access monitoring and periodic security assessments. In the event of a data breach, we will notify affected users and the competent authority as required by the LOPDP.` },
  { id: 'contact', title: '7. Contact', content: `Terranode S.A.S\nEmail: info@terranode.net\nSupport: https://my.terranode.net\nPhone: +593 99 819 7150\nGuayaquil, Ecuador` },
];
const breadcrumb = breadcrumbSchema('en', [{ name: 'Home', key: 'home' }, { name: 'Privacy Policy', key: 'privacy' }]);
---
<BaseLayout
  locale="en"
  pageKey="privacy"
  title="Privacy Policy · Terranode"
  description="Terranode S.A.S Privacy Policy compliant with Ecuador's LOPDP. How we collect, use and protect your personal data for billing and services."
  jsonLd={[organizationSchema('en'), breadcrumb]}
>
  <LegalPageContent
    locale="en"
    title="Privacy & Data Protection Policy"
    badge="Privacy · LOPDP Ecuador"
    icon="🔏"
    subtitle="This policy describes how Terranode collects, uses and protects your personal data, in compliance with Ecuador's Personal Data Protection Law (LOPDP)."
    updated="March 20, 2026"
    complianceBadge="LOPDP Ecuador compliant"
    sections={sections}
  />
</BaseLayout>
