---
import BaseLayout from '@/layouts/BaseLayout.astro';
import IPCheckContent from '@/components/IPCheckContent.astro';
import FAQSection from '@/components/FAQSection.astro';
import { organizationSchema, breadcrumbSchema, faqSchema, howToSchema } from '@/lib/schema';

const breadcrumb = breadcrumbSchema('en', [{ name: 'Home', key: 'home' }, { name: 'What is my IP?', key: 'myip' }]);

const faqs = [
  { q: 'Why doesn\u2019t my IP match my exact city?', a: 'IP geolocation is based on the block assigned to your internet provider, which is usually registered to the region\u2019s main city, not your exact location.' },
  { q: 'What\u2019s the difference between a public and private IP?', a: 'Your public IP identifies you on the internet to other servers. Your private IP is used by your router to identify devices within your own local network.' },
  { q: 'How do I know if my IP changed?', a: 'Reload this page: if you have a dynamic IP (most residential connections), it can change whenever you restart your router or after a few days.' },
  { q: 'Does the tool detect if I\u2019m using a VPN or proxy?', a: 'Yes, it analyzes the ASN and other signals to flag if your connection appears to come from a known VPN or proxy service.' },
];

const howTo = howToSchema({
  name: 'How to look up your public IP address',
  description: 'Steps to see your public IP, internet provider and approximate location.',
  totalTime: 'PT10S',
  steps: [
    { name: 'Open the page', text: 'Your public IP address is detected automatically when the tool loads.' },
    { name: 'Review the details', text: 'You\u2019ll see your internet service provider (ISP), ASN, approximate location, and whether VPN or proxy use is detected.' },
  ],
});
---
<BaseLayout
  locale="en"
  pageKey="myip"
  title="What is my IP? | Free Tool | Terranode"
  description="Look up your public IP address, internet provider, ASN, location and VPN/proxy detection instantly. Free tool by Terranode."
  jsonLd={[organizationSchema('en'), breadcrumb, howTo, faqSchema(faqs)]}
>
  <IPCheckContent locale="en" />
  <FAQSection locale="en" items={faqs} />
</BaseLayout>
