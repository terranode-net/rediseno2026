---
import BaseLayout from '@/layouts/BaseLayout.astro';
import DevWebContent from '@/components/DevWebContent.astro';
import { SITE_URL } from '@/lib/site';
import { organizationSchema, breadcrumbSchema, faqSchema, serviceSchema, productPlanSchema } from '@/lib/schema';

const faqs = [
  { q: 'Are domain and hosting included?', a: 'Hosting is included the first year on every plan. The domain costs ~$12/yr extra.' },
  { q: 'How long until my site is ready?', a: 'Landing 7 days, Corporate 15 days, Online Store 20 days.' },
  { q: 'Can I manage the content myself?', a: 'Yes, WordPress has an intuitive panel and we include training.' },
  { q: 'Can I migrate my current site to WordPress?', a: 'Yes, without losing SEO rankings.' },
  { q: 'Do you build websites for businesses anywhere in Ecuador?', a: 'Yes, we work remotely with clients in Guayaquil, Quito, Cuenca and the rest of the country \u2014 the whole design, review and delivery process happens online.' },
  { q: 'Is the site hosted in Ecuador?', a: 'We have our own infrastructure in Ecuador and the United States; we can host your site wherever gives your audience the best speed.' },
  { q: 'Does the online store integrate with Ecuadorian payment gateways?', a: 'Yes, we integrate PlaceToPay, PagoPlux, PayPhone and other gateways used in Ecuador, plus international cards.' },
];
const plans = [
  { name: 'Landing Page', price: '350', description: 'Up to 5 sections, custom design, responsive, 7-day delivery.', url: `${SITE_URL}/en/store/devweb-landing` },
  { name: 'Corporate Website', price: '650', description: 'Up to 10 pages, blog, admin panel, 15-day delivery.', url: `${SITE_URL}/en/store/devweb-corporate` },
  { name: 'Online Store', price: '1200', description: 'Full WooCommerce, unlimited catalog, payment gateway, 20-day delivery.', url: `${SITE_URL}/en/store/devweb-store` },
];
const breadcrumb = breadcrumbSchema('en', [{ name: 'Home', key: 'home' }, { name: 'Web Development', key: 'devweb' }]);
const service = serviceSchema('en', { name: 'Web Design & Development in Ecuador', description: 'Custom website and online store design with WordPress and WooCommerce, hosted on our own infrastructure in Ecuador.', pageKey: 'devweb', serviceType: 'Web Design', areaServed: ['EC'] });
---
<BaseLayout
  locale="en"
  pageKey="devweb"
  title="Web Design & Development in Ecuador from $350 | Terranode"
  description="Web design agency in Ecuador: corporate websites and online stores with WordPress and WooCommerce. Fast, secure and SEO-optimized. From $350."
  jsonLd={[organizationSchema('en'), breadcrumb, service, ...productPlanSchema(plans), faqSchema(faqs)]}
>
  <DevWebContent locale="en" />
</BaseLayout>
