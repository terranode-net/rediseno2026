---
export const prerender = false;
import AdminLayout from '@/layouts/AdminLayout.astro';
import { requireAdmin } from '@/lib/supabaseServerAuth';

const guard = await requireAdmin(Astro);
if (guard) return guard;
---
<AdminLayout title="Suscriptores" active="subscribers">
  <div class="mb-4 flex items-center justify-between">
    <p id="count" class="text-sm text-slate-500">Cargando…</p>
    <button id="export-btn" class="rounded-md bg-ink px-3 py-1.5 text-xs font-semibold text-white hover:bg-ink-2">Exportar CSV</button>
  </div>
  <div id="table" class="overflow-x-auto rounded-xl border border-slate-200 bg-white"></div>

  <script>
    import { supabaseBrowser as supabase } from '@/lib/supabaseBrowser';

    let rows: Record<string, any>[] = [];

    async function load() {
      const { data, error } = await supabase.from('subscribers').select('*').order('created_at', { ascending: false });
      const countEl = document.getElementById('count')!;
      const tableEl = document.getElementById('table')!;
      if (error) {
        tableEl.innerHTML = `<div class="p-4 text-sm text-red-700">${error.message}</div>`;
        return;
      }
      rows = data ?? [];
      countEl.textContent = `${rows.length} suscriptor(es)`;

      const body = rows
        .map(
          (r) => `<tr class="border-b border-slate-100">
            <td class="px-3 py-2 text-sm">${r.email}</td>
            <td class="px-3 py-2 text-sm text-slate-500">${r.locale ?? ''}</td>
            <td class="px-3 py-2 text-sm text-slate-500">${r.source ?? ''}</td>
            <td class="px-3 py-2 text-sm text-slate-500">${new Date(r.created_at).toLocaleDateString()}</td>
            <td class="px-3 py-2 text-sm">${r.active ? '✅' : '—'}</td>
            <td class="px-3 py-2 text-right"><button data-id="${r.id}" class="del-btn rounded-md border border-red-200 px-2 py-1 text-xs font-semibold text-red-600 hover:bg-red-50">Eliminar</button></td>
          </tr>`
        )
        .join('');

      tableEl.innerHTML = `<table class="w-full border-collapse">
        <thead><tr class="bg-surface text-left text-xs font-semibold uppercase tracking-wide text-slate-400">
          <th class="px-3 py-2">Email</th><th class="px-3 py-2">Idioma</th><th class="px-3 py-2">Origen</th><th class="px-3 py-2">Fecha</th><th class="px-3 py-2">Activo</th><th></th>
        </tr></thead>
        <tbody>${body || '<tr><td class="p-4 text-sm text-slate-400" colspan="6">Todavía no hay suscriptores.</td></tr>'}</tbody>
      </table>`;

      tableEl.querySelectorAll('.del-btn').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const id = (btn as HTMLElement).dataset.id;
          if (!confirm('¿Eliminar este suscriptor?')) return;
          await supabase.from('subscribers').delete().eq('id', id);
          load();
        });
      });
    }

    document.getElementById('export-btn')?.addEventListener('click', () => {
      const csv = ['email,locale,source,created_at,active', ...rows.map((r) => `${r.email},${r.locale ?? ''},${r.source ?? ''},${r.created_at},${r.active}`)].join('\n');
      const blob = new Blob([csv], { type: 'text/csv' });
      const a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = 'suscriptores-terranode.csv';
      a.click();
    });

    load();
  </script>
</AdminLayout>
