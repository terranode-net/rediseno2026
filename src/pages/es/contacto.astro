---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import ContactForm from '@/components/ContactForm.astro';
import FeatureCard from '@/components/FeatureCard.astro';
import { ORG } from '@/lib/site';
import { organizationSchema, breadcrumbSchema } from '@/lib/schema';

const breadcrumb = breadcrumbSchema('es', [{ name: 'Inicio', key: 'home' }, { name: 'Contacto', key: 'contacto' }]);
---
<BaseLayout
  locale="es"
  pageKey="contacto"
  title="Contacto | Habla con un ingeniero de Terranode"
  description="¿Tienes dudas sobre VPS, hosting, servidores dedicados o Microsoft 365? Escríbenos y un ingeniero te responderá el mismo día."
  jsonLd={[organizationSchema('es'), breadcrumb]}
>
  <section class="relative overflow-hidden bg-ink pt-16 pb-14 md:pt-24 md:pb-20">
    <div class="absolute inset-0 bg-dot-grid opacity-[0.15]"></div>
    <div class="container-page relative text-center">
      <span class="eyebrow !border-white/15 !bg-white/5 !text-white/90">Contacto</span>
      <h1 class="mx-auto mt-6 max-w-2xl text-balance text-4xl font-semibold leading-[1.1] text-white md:text-5xl">
        Hablemos de tu <span class="text-accent">infraestructura</span>
      </h1>
      <p class="mx-auto mt-5 max-w-lg text-slate-300">
        Cuéntanos qué necesitas y un ingeniero — no un bot — te responderá con una recomendación clara.
      </p>
    </div>
  </section>

  <section class="container-page -mt-10 pb-24 md:-mt-14">
    <div class="grid gap-8 lg:grid-cols-5">
      <div class="lg:col-span-3 rounded-xl2 border border-slate-200 bg-white p-6 shadow-card md:p-10">
        <ContactForm locale="es" />
      </div>

      <div class="lg:col-span-2 space-y-6">
        <div class="card !cursor-default">
          <h3 class="font-display text-lg font-semibold text-ink">Correo</h3>
          <p class="mt-2 text-sm text-slate-500">Respondemos en menos de 24 horas hábiles.</p>
          <a href={`mailto:${ORG.email}`} class="mt-3 inline-block text-sm font-semibold text-accent">{ORG.email}</a>
        </div>
        <div class="card !cursor-default">
          <h3 class="font-display text-lg font-semibold text-ink">WhatsApp / Teléfono</h3>
          <p class="mt-2 text-sm text-slate-500">Para consultas rápidas o soporte urgente.</p>
          <a href={ORG.whatsapp} class="mt-3 inline-block text-sm font-semibold text-accent">{ORG.phone}</a>
        </div>
        <div class="card !cursor-default">
          <h3 class="font-display text-lg font-semibold text-ink">Portal de Cliente</h3>
          <p class="mt-2 text-sm text-slate-500">Ya eres cliente? Gestiona tus servicios y tickets aquí.</p>
          <a href={ORG.clientPortal} target="_blank" rel="noopener" class="mt-3 inline-block text-sm font-semibold text-accent">my.terranode.net →</a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-surface py-20">
    <div class="container-page">
      <SectionHeading eyebrow="Antes de escribirnos" title="Así te ayudamos según lo que necesites" />
      <div class="mt-14 grid gap-6 sm:grid-cols-3">
        <FeatureCard icon="server" title="¿Nuevo cliente?" description="Cuéntanos tu proyecto y te recomendamos el plan exacto de VPS, hosting o servidor dedicado." />
        <FeatureCard icon="support" title="¿Ya eres cliente?" description="Para soporte técnico usa el portal de cliente y abre un ticket — es más rápido que el formulario." />
        <FeatureCard icon="shield" title="¿Consulta comercial?" description="Ventas y cotizaciones personalizadas para empresas con necesidades específicas." />
      </div>
    </div>
  </section>
</BaseLayout>
