---
import BaseLayout from '@/layouts/BaseLayout.astro';
import VPSContent from '@/components/VPSContent.astro';
import { pathFor, SITE_URL } from '@/lib/site';
import { organizationSchema, breadcrumbSchema, faqSchema, serviceSchema, productPlanSchema } from '@/lib/schema';

const faqs = [
  { q: '¿Puedo reinstalar el SO desde el panel?', a: 'Sí. Desde VirtFusion puedes reinstalar el SO en cualquier momento en menos de 5 minutos.' },
  { q: '¿Los backups están incluidos?', a: 'Los backups automáticos son opcionales. Puedes crear snapshots manuales desde el panel.' },
  { q: '¿Todos los planes están en todas las regiones?', a: 'No. Los planes de mayor capacidad (TNS-07, TNS-08) solo están en Ashburn. Selecciona tu región para ver los planes disponibles.' },
  { q: '¿Puedo escalar mi plan más adelante?', a: 'Sí. Actualiza a un plan mayor desde el panel de cliente sin migración ni tiempo de inactividad.' },
  { q: '¿Qué es Full Root Access?', a: 'Acceso SSH root completo: instala cualquier software, modifica configuraciones del kernel y controla todo.' },
];

const plans = [
  { name: 'TNS-01', price: '2.99', description: '1 vCPU, 1 GB RAM, 25 GB NVMe, 1 TB de transferencia.', url: `${SITE_URL}/es/store/tns-01` },
  { name: 'TNS-02', price: '5.00', description: '1 vCPU, 2 GB RAM, 30 GB NVMe, 2 TB de transferencia.', url: `${SITE_URL}/es/store/tns-02` },
  { name: 'TNS-03', price: '9.00', description: '2 vCPU, 4 GB RAM, 40 GB NVMe, 3 TB de transferencia.', url: `${SITE_URL}/es/store/tns-03` },
  { name: 'TNS-04', price: '18.50', description: '4 vCPU, 8 GB RAM, 80 GB NVMe, 5 TB de transferencia.', url: `${SITE_URL}/es/store/tns-04` },
  { name: 'TNS-05', price: '25.00', description: '6 vCPU, 12 GB RAM, 120 GB NVMe, 6 TB de transferencia.', url: `${SITE_URL}/es/store/tns-05` },
  { name: 'TNS-06', price: '35.00', description: '8 vCPU, 16 GB RAM, 150 GB NVMe, 7 TB de transferencia.', url: `${SITE_URL}/es/store/tns-06` },
  { name: 'TNS-07', price: '75.00', description: '16 vCPU, 32 GB RAM, 320 GB NVMe, 8 TB de transferencia.', url: `${SITE_URL}/es/store/tns-07` },
  { name: 'TNS-08', price: '155.00', description: '22 vCPU, 64 GB RAM, 1024 GB NVMe, 10 TB de transferencia.', url: `${SITE_URL}/es/store/tns-08` },
];

const breadcrumb = breadcrumbSchema('es', [{ name: 'Inicio', key: 'home' }, { name: 'VPS', key: 'vps' }]);
const service = serviceSchema('es', {
  name: 'VPS NVMe',
  description: 'Servidores privados virtuales con virtualización KVM, almacenamiento NVMe y despliegue en 60 segundos, con datacenters en Ashburn, Los Ángeles, Chicago, Houston y Guayaquil.',
  pageKey: 'vps',
  serviceType: 'VPS Hosting',
});
---
<BaseLayout
  locale="es"
  pageKey="vps"
  title="VPS NVMe desde $2.99/mes | 5 Regiones | Terranode"
  description="Servidores VPS con virtualización KVM, NVMe DDR4 y deploy en 60 segundos. 8 planes desde $2.99/mes. Elige tu región: Ashburn, Los Ángeles, Chicago, Houston o Guayaquil."
  jsonLd={[organizationSchema('es'), breadcrumb, service, ...productPlanSchema(plans), faqSchema(faqs)]}
>
  <VPSContent locale="es" />
</BaseLayout>
