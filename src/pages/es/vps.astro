---
// Renderizado en servidor: los precios se leen de Supabase en cada visita,
// así los cambios del panel de administración se ven al instante y Google
// sigue viendo el precio dentro del HTML y del JSON-LD.
export const prerender = false;

import BaseLayout from '@/layouts/BaseLayout.astro';
import VPSContent from '@/components/VPSContent.astro';
import { getVpsRegions, getVpsPlans, priceNumber } from '@/lib/db';
import { SITE_URL } from '@/lib/site';
import { organizationSchema, breadcrumbSchema, faqSchema, serviceSchema, productPlanSchema } from '@/lib/schema';

const [regions, plans] = await Promise.all([getVpsRegions(), getVpsPlans()]);

const faqs = [
  { q: '¿Puedo reinstalar el SO desde el panel?', a: 'Sí. Desde VirtFusion puedes reinstalar el SO en cualquier momento en menos de 5 minutos.' },
  { q: '¿Los backups están incluidos?', a: 'Los backups automáticos son opcionales. Puedes crear snapshots manuales desde el panel.' },
  { q: '¿Todos los planes están en todas las regiones?', a: 'No. La disponibilidad varía por región y por stock. Selecciona tu región para ver los planes disponibles.' },
  { q: '¿Puedo escalar mi plan más adelante?', a: 'Sí. Actualiza a un plan mayor desde el panel de cliente sin migración ni tiempo de inactividad.' },
  { q: '¿Qué es Full Root Access?', a: 'Acceso SSH root completo: instala cualquier software, modifica configuraciones del kernel y controla todo.' },
];

const products = productPlanSchema(
  plans
    .filter((p) => !isNaN(Number(priceNumber(p.price))) && Number(priceNumber(p.price)) > 0)
    .map((p) => ({
      name: `VPS ${p.name}`,
      price: priceNumber(p.price),
      description: `${p.cpu}, ${p.ram} RAM, ${p.disk}, ${p.bw}.`,
      url: `${SITE_URL}/es/vps`,
    }))
);

const breadcrumb = breadcrumbSchema('es', [{ name: 'Inicio', key: 'home' }, { name: 'VPS', key: 'vps' }]);
const service = serviceSchema('es', {
  name: 'VPS NVMe',
  description: 'Servidores privados virtuales con virtualización KVM, almacenamiento NVMe y despliegue en 60 segundos.',
  pageKey: 'vps',
  serviceType: 'VPS Hosting',
});
---
<BaseLayout
  locale="es"
  pageKey="vps"
  title='VPS NVMe desde $2.99/mes | 5 Regiones | Terranode'
  description='Servidores VPS con virtualización KVM, NVMe DDR4 y deploy en 60 segundos. Elige tu región: Ashburn, Los Ángeles, Chicago, Houston o Guayaquil.'
  jsonLd={[organizationSchema('es'), breadcrumb, service, ...products, faqSchema(faqs)]}
>
  <VPSContent locale="es" regions={regions} plans={plans} />
</BaseLayout>
