---
import BaseLayout from '@/layouts/BaseLayout.astro';
import DevWebContent from '@/components/DevWebContent.astro';
import { SITE_URL } from '@/lib/site';
import { organizationSchema, breadcrumbSchema, faqSchema, serviceSchema, productPlanSchema } from '@/lib/schema';

const faqs = [
  { q: '¿El dominio y hosting están incluidos?', a: 'El hosting está incluido el primer año en todos los planes. El dominio tiene un costo adicional de ~$12/año.' },
  { q: '¿Cuánto tiempo tarda en estar listo mi sitio?', a: 'Landing 7 días, Corporativo 15 días, Tienda Online 20 días.' },
  { q: '¿Puedo administrar el contenido yo mismo?', a: 'Sí, WordPress tiene un panel intuitivo e incluimos capacitación.' },
  { q: '¿Puedo migrar mi sitio actual a WordPress?', a: 'Sí, sin pérdida de posicionamiento SEO.' },
  { q: '¿Hacen páginas web para negocios en cualquier ciudad de Ecuador?', a: 'Sí, trabajamos de forma remota con clientes en Guayaquil, Quito, Cuenca y el resto del país — todo el proceso de diseño, revisión y entrega se hace en línea.' },
  { q: '¿El sitio queda alojado en Ecuador?', a: 'Contamos con infraestructura propia en Ecuador y Estados Unidos; podemos alojar tu sitio en la ubicación que ofrezca mejor velocidad para tu audiencia.' },
  { q: '¿La tienda online se integra con pasarelas de pago ecuatorianas?', a: 'Sí, integramos PlaceToPay, PagoPlux, PayPhone y otras pasarelas usadas en Ecuador, además de tarjetas internacionales.' },
];
const plans = [
  { name: 'Landing Page', price: '350', description: 'Hasta 5 secciones, diseño personalizado, responsive, entrega en 7 días.', url: `${SITE_URL}/es/store/devweb-landing` },
  { name: 'Sitio Web Corporativo', price: '650', description: 'Hasta 10 páginas, blog, panel de administración, entrega en 15 días.', url: `${SITE_URL}/es/store/devweb-corporativo` },
  { name: 'Tienda Online', price: '1200', description: 'WooCommerce completo, catálogo ilimitado, pasarela de pagos, entrega en 20 días.', url: `${SITE_URL}/es/store/devweb-tienda` },
];
const breadcrumb = breadcrumbSchema('es', [{ name: 'Inicio', key: 'home' }, { name: 'Desarrollo Web', key: 'devweb' }]);
const service = serviceSchema('es', { name: 'Diseño y Desarrollo Web en Ecuador', description: 'Diseño de páginas web, tiendas online y e-commerce a medida con WordPress y WooCommerce, alojados en infraestructura propia en Ecuador.', pageKey: 'devweb', serviceType: 'Web Design', areaServed: ['EC'] });
---
<BaseLayout
  locale="es"
  pageKey="devweb"
  title="Diseño y Desarrollo Web en Ecuador desde $350 | Terranode"
  description="Agencia de diseño web en Ecuador: páginas corporativas y tiendas online con WordPress y WooCommerce. Rápidas, seguras y optimizadas para SEO. Desde $350."
  jsonLd={[organizationSchema('es'), breadcrumb, service, ...productPlanSchema(plans), faqSchema(faqs)]}
>
  <DevWebContent locale="es" />
</BaseLayout>
