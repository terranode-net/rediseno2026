---
import BaseLayout from '@/layouts/BaseLayout.astro';
import IPCheckContent from '@/components/IPCheckContent.astro';
import { organizationSchema, breadcrumbSchema } from '@/lib/schema';

const breadcrumb = breadcrumbSchema('es', [{ name: 'Inicio', key: 'home' }, { name: '¿Cuál es mi IP?', key: 'myip' }]);
---
<BaseLayout
  locale="es"
  pageKey="myip"
  title="¿Cuál es mi IP? | Herramienta gratuita | Terranode"
  description="Consulta tu dirección IP pública, proveedor de internet, ASN, ubicación y detección de VPN/proxy al instante. Herramienta gratuita de Terranode."
  jsonLd={[organizationSchema('es'), breadcrumb]}
>
  <IPCheckContent locale="es" />
</BaseLayout>
