---
import BaseLayout from '@/layouts/BaseLayout.astro';
import IPCheckContent from '@/components/IPCheckContent.astro';
import FAQSection from '@/components/FAQSection.astro';
import { organizationSchema, breadcrumbSchema, faqSchema, howToSchema } from '@/lib/schema';

const breadcrumb = breadcrumbSchema('es', [{ name: 'Inicio', key: 'home' }, { name: '¿Cuál es mi IP?', key: 'myip' }]);

const faqs = [
  { q: '¿Por qué mi IP no coincide con mi ciudad exacta?', a: 'La geolocalización por IP se basa en el bloque asignado a tu proveedor de internet, que suele registrarse en la ciudad principal de la región, no en tu ubicación exacta.' },
  { q: '¿Qué diferencia hay entre IP pública y privada?', a: 'La IP pública es la que te identifica en internet frente a otros servidores. La IP privada es la que usa tu router para identificar dispositivos dentro de tu propia red local.' },
  { q: '¿Cómo sé si mi IP cambió?', a: 'Vuelve a cargar esta página: si usas una IP dinámica (la mayoría de conexiones residenciales), puede cambiar cada vez que reinicias el router o pasan varios días.' },
  { q: '¿La herramienta detecta si uso VPN o proxy?', a: 'Sí, analiza el ASN y otros indicadores para señalar si tu conexión parece provenir de un servicio de VPN o proxy conocido.' },
];

const howTo = howToSchema({
  name: 'Cómo consultar tu dirección IP pública',
  description: 'Pasos para ver tu IP pública, proveedor de internet y ubicación aproximada.',
  totalTime: 'PT10S',
  steps: [
    { name: 'Abre la página', text: 'Tu dirección IP pública se detecta automáticamente al cargar la herramienta.' },
    { name: 'Revisa los datos', text: 'Verás tu proveedor de internet (ISP), ASN, ubicación aproximada y si se detecta uso de VPN o proxy.' },
  ],
});
---
<BaseLayout
  locale="es"
  pageKey="myip"
  title="¿Cuál es mi IP? | Herramienta gratuita | Terranode"
  description="Consulta tu dirección IP pública, proveedor de internet, ASN, ubicación y detección de VPN/proxy al instante. Herramienta gratuita de Terranode."
  jsonLd={[organizationSchema('es'), breadcrumb, howTo, faqSchema(faqs)]}
>
  <IPCheckContent locale="es" />
  <FAQSection locale="es" items={faqs} />
</BaseLayout>
