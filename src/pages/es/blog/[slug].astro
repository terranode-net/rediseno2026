---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BlogPostContent from '@/components/BlogPostContent.astro';
import { POSTS, getFullPost } from '@/lib/blogData';
import { organizationSchema } from '@/lib/schema';
import { SITE_URL } from '@/lib/site';

export function getStaticPaths() {
  return POSTS.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const post = getFullPost(slug as string);

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.title,
  description: post.intro,
  datePublished: post.date,
  author: { '@type': 'Organization', name: post.author },
  publisher: { '@id': `${SITE_URL}/#organization` },
  mainEntityOfPage: `${SITE_URL}/es/blog/${slug}`,
  keywords: post.tags.join(', '),
};
---
<BaseLayout
  locale="es"
  pageKey="blog"
  title={`${post.title} | Terranode Blog`}
  description={post.intro}
  jsonLd={[organizationSchema('es'), articleSchema]}
>
  <BlogPostContent locale="es" slug={slug as string} />
</BaseLayout>
