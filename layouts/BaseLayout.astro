---
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import Seo from '@/components/Seo.astro';
import '@/styles/global.css';
import { LOCALES, type Locale, type PageKey } from '@/lib/site';

interface Props {
  locale: Locale;
  pageKey: PageKey;
  title: string;
  description: string;
  ogImage?: string;
  jsonLd?: Record<string, any> | Record<string, any>[];
  noindex?: boolean;
}

const { locale, pageKey, title, description, ogImage, jsonLd, noindex } = Astro.props;
---
<!doctype html>
<html lang={LOCALES[locale].htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <Seo locale={locale} pageKey={pageKey} title={title} description={description} ogImage={ogImage} jsonLd={jsonLd} noindex={noindex} />
    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:z-[100] focus:bg-white focus:px-4 focus:py-2">
      {locale === 'es' ? 'Saltar al contenido' : 'Skip to content'}
    </a>
    <Header locale={locale} currentKey={pageKey} />
    <main id="main">
      <slot />
    </main>
    <Footer locale={locale} />
    <script>
      // Scroll-reveal: fades/slides in any element with class "an" the first time it enters the viewport.
      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.12 }
      );
      document.querySelectorAll('.an').forEach((el) => io.observe(el));
    </script>
  </body>
</html>
