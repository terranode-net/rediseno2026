---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HostingDetectorContent from '@/components/HostingDetectorContent.astro';
import { organizationSchema, breadcrumbSchema } from '@/lib/schema';

const breadcrumb = breadcrumbSchema('es', [{ name: 'Inicio', key: 'home' }, { name: 'Detector de Hosting', key: 'hostingDetector' }]);
---
<BaseLayout
  locale="es"
  pageKey="hostingDetector"
  title="¿Dónde Está Alojada Esta Web? Detector de Hosting Gratis | Terranode"
  description="Descubre el proveedor de hosting, IP, ASN y calidad de cualquier sitio web al instante. Herramienta gratuita de Terranode."
  jsonLd={[organizationSchema('es'), breadcrumb]}
>
  <HostingDetectorContent locale="es" />
</BaseLayout>
