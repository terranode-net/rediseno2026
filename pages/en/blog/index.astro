---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BlogContent from '@/components/BlogContent.astro';
import { organizationSchema, breadcrumbSchema } from '@/lib/schema';

const breadcrumb = breadcrumbSchema('en', [{ name: 'Home', key: 'home' }, { name: 'Blog', key: 'blog' }]);
---
<BaseLayout
  locale="en"
  pageKey="blog"
  title="Terranode Blog | Hosting Tutorials, Guides & News"
  description="Learn about hosting, VPS, dedicated servers, web security and development. Technical tutorials and guides from the Terranode team."
  jsonLd={[organizationSchema('en'), breadcrumb]}
>
  <BlogContent locale="en" />
</BaseLayout>
