---
export const prerender = false;
import AdminLayout from '@/layouts/AdminLayout.astro';
---
<AdminLayout title="Ciudades (SEO local)" active="cities">
  <div id="table"></div>
  <script>
    import { mountAdminTable } from '@/lib/adminTable';
    mountAdminTable({
      table: 'cities',
      pk: 'slug',
      orderBy: 'sort_order',
      labelSingular: 'ciudad',
      newRowDefaults: { name: '', province: '', country: 'Ecuador', active: true, sort_order: 99 },
      columns: [
        { key: 'slug', label: 'Slug', type: 'text', width: 'w-32' },
        { key: 'name', label: 'Nombre', type: 'text' },
        { key: 'province', label: 'Provincia', type: 'text' },
        { key: 'country', label: 'País', type: 'text', width: 'w-28' },
        { key: 'sort_order', label: 'Orden', type: 'number', width: 'w-20' },
        { key: 'active', label: 'Activo', type: 'boolean', width: 'w-16' },
      ],
    });
  </script>
</AdminLayout>
